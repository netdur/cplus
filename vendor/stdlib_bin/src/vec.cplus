// stdlib_bin/vec — declarations only. Bodies live in ../lib/<arch>/stdlib_bin.a.
//
// Generics caveat: the .a must ship per-instantiation entry points for
// every concrete `T` that consumers use. Phase 3+ pins the exported-T set
// (likely u8 / i32 / i64 / string / *u8 to start). For exotic T not in the
// shipped set, the source `stdlib` package is the fallback.

// Common-case per-instantiation symbols (Phase 3 to expand).
extern fn stdlib_vec_u8_push(buf: *u8, x: u8);
extern fn stdlib_vec_u8_pop(buf: *u8) -> bool;
extern fn stdlib_vec_u8_len(buf: *u8) -> usize;
extern fn stdlib_vec_u8_capacity(buf: *u8) -> usize;
extern fn stdlib_vec_u8_drop(buf: *u8);

pub struct Vec[T] {
    ptr: *T,
    len: usize,
    cap: usize,
}

impl [T] Vec[T] {
    pub fn new() -> Vec[T] {
        return Vec[T] { ptr: unsafe { 0 as *T }, len: 0 as usize, cap: 0 as usize };
    }

    pub fn with_capacity(n: usize) -> Vec[T] {
        // TODO: stdlib_bin_vec_<T>_with_capacity for the shipped-T set.
        return Vec[T] { ptr: unsafe { 0 as *T }, len: 0 as usize, cap: n };
    }

    pub fn push(mut self, x: T) {
        // TODO: dispatch to stdlib_vec_<T>_push.
        return;
    }

    pub fn pop(mut self) -> bool {
        // TODO: dispatch to stdlib_vec_<T>_pop.
        return false;
    }

    pub fn len(self) -> usize {
        return self.len;
    }

    pub fn capacity(self) -> usize {
        return self.cap;
    }

    pub fn as_slice(self) -> T[] {
        return unsafe { slice_from_raw_parts(self.ptr, self.len) };
    }

    fn drop(mut self) {
        // TODO: dispatch to stdlib_vec_<T>_drop (frees the buffer).
        return;
    }
}
