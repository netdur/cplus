// stdlib_bin/result — full C+ source. Tagged enums are pure C+ semantics;
// there's nothing to put in the .a for them.

pub enum Result[T, E] {
    Ok(T),
    Err(E),
}

pub enum IoError {
    NotFound,
    PermissionDenied,
    AlreadyExists,
    Interrupted,
    UnexpectedEof,
    InvalidInput,
    InvalidData,
    WouldBlock,
    ConnectionRefused,
    ConnectionReset,
    AddrInUse,
    BrokenPipe,
    TimedOut,
    Other,
}
