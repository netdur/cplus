// stdlib_bin/fs — declarations only. Bodies live in ../lib/<arch>/stdlib_bin.a.

import "./result" as result;
import "./vec" as vec;

// C-ABI entry points. Return codes: 0 on success, negative IoError-tag on
// failure (matches the IoError enum's declaration order at the .a's
// build time — release pipeline must keep them in sync).
extern fn stdlib_fs_file_open(path_ptr: *u8, path_len: usize, out_fd: *i32) -> i32;
extern fn stdlib_fs_file_create(path_ptr: *u8, path_len: usize, out_fd: *i32) -> i32;
extern fn stdlib_fs_file_read_to_end(fd: i32, out_buf: *u8, out_cap: usize, out_len: *usize) -> i32;
extern fn stdlib_fs_file_write_all(fd: i32, data_ptr: *u8, data_len: usize) -> i32;
extern fn stdlib_fs_file_close(fd: i32);

// Layout pinned so the .a can reason about the struct's bytes. fd == -1
// is the "already-closed / never-opened" sentinel.
pub struct File {
    fd: i32,
}

impl File {
    pub fn open(path: str) -> result::Result[File, result::IoError] {
        // TODO: call stdlib_fs_file_open, translate rc into Result.
        return result::Result::Err(result::IoError::Other);
    }

    pub fn create(path: str) -> result::Result[File, result::IoError] {
        // TODO: call stdlib_fs_file_create.
        return result::Result::Err(result::IoError::Other);
    }

    pub fn read_to_end(mut self) -> result::Result[vec::Vec[u8], result::IoError] {
        // TODO: call stdlib_fs_file_read_to_end into a growing Vec[u8].
        return result::Result::Err(result::IoError::Other);
    }

    pub fn write_all(mut self, data: vec::Vec[u8]) -> result::Result[(), result::IoError] {
        // TODO: call stdlib_fs_file_write_all on data.as_slice().
        return result::Result::Err(result::IoError::Other);
    }

    pub fn close(move self) {
        // TODO: stdlib_fs_file_close(self.fd); zero self.fd to disarm Drop.
        return;
    }

    fn drop(mut self) {
        // TODO: if self.fd != -1: stdlib_fs_file_close(self.fd).
        return;
    }
}
