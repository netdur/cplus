// vendor/cuda/src/buffer.cplus — owned device-memory handle.
//
// `DeviceBuffer` owns a `cudaMalloc`'d allocation; Drop calls `cudaFree`
// at scope exit. Byte-oriented (like vendor/metal's Buffer); typed copies
// go through the raw pointer + a byte count. The device address is a *device*
// pointer — never dereference it on the host; hand it to kernels / cuBLAS.
//
// The public surface follows naming_guideline.md:
//   - the raw handle and size are hidden behind `_dptr` / `_size`; reach them
//     through role-named accessors `device_ptr()` and `byte_count()`.
//   - `alloc(bytes:)` takes its content (the byte budget) and returns a
//     value-or-reason `Result[DeviceBuffer, CudaError]`.
//   - the host<->device copies read as a phrase — `buf.write(from: hostPtr,
//     bytes: n)` / `buf.read(to: hostPtr, bytes: n)` — and report failure as
//     `Option[CudaError]` (`None` = success, `Some(Runtime(code))` keeps the
//     `cudaError_t`); same deliberate mapping documented in runtime.cplus.

import "./runtime" as runtime;
import "stdlib/result" as result;
import "stdlib/option" as option;

extern fn cudaMalloc(dev_ptr: **u8, size: usize) -> i32;
extern fn cudaFree(dev_ptr: *u8) -> i32;
extern fn cudaMemcpy(dst: *u8, src: *u8, count: usize, kind: i32) -> i32;
extern fn malloc(n: usize) -> *u8;
extern fn free(p: *u8);

struct DeviceBuffer {
    opaque _dptr: *u8,   // device pointer (opaque on host)
    _size: usize,        // bytes
}

// Void wrapper around `cudaFree` so `drop` releases the field as a bare
// statement passing `this._dptr` directly — the form the raw-pointer
// accountability check recognizes as a provable release. `cudaFree(NULL)`
// is a documented no-op, so this is safe on a moved-from buffer.
fn device_free(p: *u8) {
    let _rc: i32 = { cudaFree(p) };
    return;
}

// Allocate `bytes` of device memory.
fn alloc(bytes: usize) -> result::Result[DeviceBuffer, runtime::CudaError] {
    // cudaMalloc writes the device pointer into a `void**`; stage it in a
    // host slot, then read it back (C+ has no address-of-local).
    let slot: *u8 = { malloc(8 as usize) };
    let pp: **u8 = { slot as **u8 };
    let rc: i32 = { cudaMalloc(pp, bytes) };
    let dptr: *u8 = { *pp };
    { free(slot); }
    if rc != (0 as i32) {
        return result::Result[DeviceBuffer, runtime::CudaError]::Err(runtime::CudaError::Runtime(rc));
    }
    return result::Result[DeviceBuffer, runtime::CudaError]::Ok(DeviceBuffer { _dptr: dptr, _size: bytes });
}

impl DeviceBuffer {
    // The device address — pass this to kernels / cuBLAS (`h.sgemm(..,
    // a: buf.device_ptr(), ..)`). Never dereference it on the host.
    fn device_ptr(this) -> *u8 {
        return this._dptr;
    }

    // The buffer's size in bytes.
    fn byte_count(this) -> usize {
        return this._size;
    }

    // Copy up to `min(bytes, byte_count())` bytes from host `from` into this
    // device buffer. `None` on success; `Some(CudaError::Runtime(code))`
    // preserves the failure.
    fn write(this, from: *u8, bytes: usize) -> option::Option[runtime::CudaError] {
        let n: usize = if bytes < this._size { bytes } else { this._size };
        let rc: i32 = { cudaMemcpy(this._dptr, from, n, runtime::memcpy_host_to_device()) };
        if rc != (0 as i32) {
            return option::Option[runtime::CudaError]::Some(runtime::CudaError::Runtime(rc));
        }
        return option::Option[runtime::CudaError]::None;
    }

    // Copy up to `min(bytes, byte_count())` bytes from this device buffer into
    // host `to`. `None` on success; `Some(CudaError::Runtime(code))`
    // preserves the failure.
    fn read(this, to: *u8, bytes: usize) -> option::Option[runtime::CudaError] {
        let n: usize = if bytes < this._size { bytes } else { this._size };
        let rc: i32 = { cudaMemcpy(to, this._dptr, n, runtime::memcpy_device_to_host()) };
        if rc != (0 as i32) {
            return option::Option[runtime::CudaError]::Some(runtime::CudaError::Runtime(rc));
        }
        return option::Option[runtime::CudaError]::None;
    }

    fn drop(ref this) {
        device_free(this._dptr);
        this._dptr = { 0 as *u8 };
        return;
    }
}
