// vendor/cuda/src/cublas.cplus — cuBLAS bindings (the "crush large numbers"
// path on NVIDIA). cuBLAS is COLUMN-MAJOR; callers lay out matrices
// accordingly (or transpose via the `Op` flags). Matrix/vector operands are
// DEVICE pointers — pass `DeviceBuffer.dptr`, which keeps ownership with the
// caller (the buffer isn't consumed).
//
// alpha / beta are HOST scalars in cuBLAS's default pointer mode; we stage
// them in host slots and pass their addresses.

import "./runtime" as runtime;
import "./buffer" as buffer;
import "stdlib/result" as result;

extern fn malloc(n: usize) -> *u8;
extern fn free(p: *u8);

extern fn cublasCreate_v2(handle: **u8) -> i32;
extern fn cublasDestroy_v2(handle: *u8) -> i32;
extern fn cublasSgemm_v2(
    handle: *u8, transa: i32, transb: i32,
    m: i32, n: i32, k: i32,
    alpha: *u8, a: *u8, lda: i32, b: *u8, ldb: i32,
    beta: *u8, c: *u8, ldc: i32,
) -> i32;
extern fn cublasSgemv_v2(
    handle: *u8, trans: i32,
    m: i32, n: i32,
    alpha: *u8, a: *u8, lda: i32, x: *u8, incx: i32,
    beta: *u8, y: *u8, incy: i32,
) -> i32;

// cublasOperation_t.
enum Op {
    N, // no transpose      (CUBLAS_OP_N = 0)
    T, // transpose         (CUBLAS_OP_T = 1)
    C, // conjugate transpose (CUBLAS_OP_C = 2)
}

fn op_raw(o: Op) -> i32 {
    let v: i32 = match o {
        Op::N => 0 as i32,
        Op::T => 1 as i32,
        Op::C => 2 as i32,
    };
    return v;
}

struct Handle {
    raw: *u8,
}

// Void wrapper around `cublasDestroy_v2` so `drop` releases the field as a
// bare statement passing `this.raw` directly (the form the raw-pointer
// accountability check recognizes as a provable release).
fn handle_destroy(h: *u8) {
    let _rc: i32 = unsafe { cublasDestroy_v2(h) };
    return;
}

// Create a cuBLAS context (one per thread/stream; cache it).
fn handle_new() -> result::Result[Handle, runtime::CudaError] {
    let slot: *u8 = unsafe { malloc(8 as usize) };
    let pp: **u8 = unsafe { slot as **u8 };
    let rc: i32 = unsafe { cublasCreate_v2(pp) };
    let raw: *u8 = unsafe { *pp };
    unsafe { free(slot); }
    if rc != (0 as i32) {
        return result::Result[Handle, runtime::CudaError]::Err(runtime::CudaError::Blas(rc));
    }
    return result::Result[Handle, runtime::CudaError]::Ok(Handle { raw: raw });
}

impl Handle {
    // Single-precision GEMM: C = alpha * op(A) * op(B) + beta * C.
    // Column-major; `a`/`b`/`c` are device pointers (`DeviceBuffer.dptr`).
    // Returns the raw cublasStatus_t (0 = success).
    fn sgemm(
        this,
        transa: Op, transb: Op,
        m: i32, n: i32, k: i32,
        alpha: f32, a: *u8, lda: i32, b: *u8, ldb: i32,
        beta: f32, c: *u8, ldc: i32,
    ) -> i32 {
        let abuf: *u8 = unsafe { malloc(4 as usize) };
        let bbuf: *u8 = unsafe { malloc(4 as usize) };
        unsafe { *(abuf as *f32) = alpha; }
        unsafe { *(bbuf as *f32) = beta; }
        let rc: i32 = unsafe {
            cublasSgemm_v2(
                this.raw, op_raw(transa), op_raw(transb),
                m, n, k,
                abuf, a, lda, b, ldb,
                bbuf, c, ldc,
            )
        };
        unsafe { free(abuf); }
        unsafe { free(bbuf); }
        return rc;
    }

    // Single-precision GEMV: y = alpha * op(A) * x + beta * y.
    // Column-major; `a`/`x`/`y` are device pointers. The matrix-vector form
    // behind vector search (`scores = database @ query`). Returns the raw
    // cublasStatus_t (0 = success).
    fn sgemv(
        this,
        trans: Op,
        m: i32, n: i32,
        alpha: f32, a: *u8, lda: i32, x: *u8, incx: i32,
        beta: f32, y: *u8, incy: i32,
    ) -> i32 {
        let abuf: *u8 = unsafe { malloc(4 as usize) };
        let bbuf: *u8 = unsafe { malloc(4 as usize) };
        unsafe { *(abuf as *f32) = alpha; }
        unsafe { *(bbuf as *f32) = beta; }
        let rc: i32 = unsafe {
            cublasSgemv_v2(
                this.raw, op_raw(trans),
                m, n,
                abuf, a, lda, x, incx,
                bbuf, y, incy,
            )
        };
        unsafe { free(abuf); }
        unsafe { free(bbuf); }
        return rc;
    }

    fn drop(ref this) {
        handle_destroy(this.raw);
        this.raw = unsafe { 0 as *u8 };
        return;
    }
}
