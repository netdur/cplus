{
  "_comment": "cpc-bindgen naming overrides for NSXMLParser. Protocol callbacks share the same `methods` map keyed by the protocol name — the long auto-snaked selector becomes a short, readable handler name.",
  "methods": {
    "NSXMLParserDelegate": {
      "parserDidStartDocument:":                                          { "name": "did_start_document" },
      "parserDidEndDocument:":                                            { "name": "did_end_document" },
      "parser:didStartElement:namespaceURI:qualifiedName:attributes:":    { "name": "did_start_element" },
      "parser:didEndElement:namespaceURI:qualifiedName:":                 { "name": "did_end_element" },
      "parser:foundCharacters:":                                          { "name": "found_characters" },
      "parser:foundComment:":                                             { "name": "found_comment" }
    }
  }
}
