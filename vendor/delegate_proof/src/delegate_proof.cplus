// Proves DELEGATE SYNTHESIS in pure C+: build an NSXMLParserDelegate class at
// runtime, install a C+ function as its `parser:didStartElement:...` IMP, set it
// on a real NSXMLParser, and parse. The synchronous parse fires the synthesized
// IMP once per element. No Objective-C source, no build integration — the same
// class-synthesis path vendor/appkit uses, now in vendor/objc so the generator
// can emit it. This is the hand proof; the generator emission comes next.

import "objc/runtime" as rt;
import "objc/bridge" as bridge;
import "objc/synthesis" as synth;
import "./xmlparser" as xml;
import "./decimal_proof" as decimal_proof;
import "./decimal_gen" as decimal_gen;

// Stable per-object key for the associated handler context (identity only —
// never dereferenced by the runtime).
fn assoc_key() -> *u8 {
    return { 100 as *u8 };
}

// IMP for `parser:didStartElement:namespaceURI:qualifiedName:attributes:`
// (void return; self + _cmd + 5 object args). Counts elements through the
// associated `*i64` context — exactly the trampoline shape the generator emits.
fn xml_did_start(self_obj: *u8, cmd: *u8, parser: *u8, name: *u8, ns: *u8, qname: *u8, attrs: *u8) {
    let ctx: *u8 = synth::get_associated(self_obj, assoc_key());
    let counter: *i64 = { ctx as *i64 };
    { *counter = (*counter) +% (1 as i64); };
    return;
}

#[test]
fn synthesized_xml_delegate_counts_elements() {
    // "<root><child/><child/></root>" -> 3 start-element events.
    let xml: *u8 = bridge::nsstring("<root><child/><child/></root>");
    let data: *u8 = rt::msg_id_u64(xml, rt::sel(#str_ptr("dataUsingEncoding:\0")), 4 as u64);

    // Synthesize the delegate class with our C+ IMP.
    let nsobject: *u8 = rt::get_class(#str_ptr("NSObject\0"));
    let cls: *u8 = synth::allocate_class_pair(nsobject, #str_ptr("CplusXMLDelegate\0"), 0 as usize);
    let did_start: *u8 = rt::sel(#str_ptr("parser:didStartElement:namespaceURI:qualifiedName:attributes:\0"));
    let added: i8 = synth::add_method_v_5id(cls, did_start, xml_did_start, #str_ptr("v@:@@@@@\0"));
    synth::register_class_pair(cls);
    assert added != (0 as i8);

    // Instantiate and attach the counter context.
    var count: i64 = 0;
    let cp: *u8 = { #addr_of(count) as *u8 };
    let delegate: *u8 = synth::alloc_init_class(cls);
    synth::set_associated(delegate, assoc_key(), cp);

    // Drive a real NSXMLParser; parse() fires the IMP synchronously per element.
    let parser_cls: *u8 = rt::get_class(#str_ptr("NSXMLParser\0"));
    let alloced: *u8 = rt::msg_id(parser_cls, rt::sel(#str_ptr("alloc\0")));
    let parser: *u8 = rt::msg_id_id(alloced, rt::sel(#str_ptr("initWithData:\0")), data);
    rt::msg_void_id(parser, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    let ok: i8 = rt::msg_i8(parser, rt::sel(#str_ptr("parse\0")));

    assert ok != (0 as i8);
    assert count == (3 as i64);
    return;
}

// Same proof, but through the cpc-bindgen-GENERATED multi-method synthesizer
// (xmlparser.cplus). One create_XMLParserDelegate installs BOTH callbacks; each
// routes to its own handler via the shared, caller-owned handler table. The
// counters live in a `Counts` the handlers reach through the `user` pointer.
struct Counts {
    starts: i64,
    ends: i64,
}

fn gen_count_start(user: *u8, parser: *u8, name: *u8, ns: *u8, qname: *u8, attrs: *u8) {
    let c: *Counts = { user as *Counts };
    { (*c).starts = (*c).starts +% (1 as i64); };
    return;
}

fn gen_count_end(user: *u8, parser: *u8, name: *u8, ns: *u8, qname: *u8) {
    let c: *Counts = { user as *Counts };
    { (*c).ends = (*c).ends +% (1 as i64); };
    return;
}

#[test]
fn generated_xml_delegate_counts_elements() {
    let xml_str: *u8 = bridge::nsstring("<root><child/><child/></root>");
    let data: *u8 = rt::msg_id_u64(xml_str, rt::sel(#str_ptr("dataUsingEncoding:\0")), 4 as u64);

    var counts: Counts = Counts { starts: 0, ends: 0 };
    let up: *u8 = { #addr_of(counts) as *u8 };
    // Install only the two callbacks we implement; the other ~17 stay noops.
    var ctx: xml::XMLParserDelegate = xml::XMLParserDelegate_new(up);
    ctx.set_did_start_element(gen_count_start);   // short names via overrides.json
    ctx.set_did_end_element(gen_count_end);
    let delegate: *u8 = xml::create_XMLParserDelegate(#addr_of(ctx));

    let parser_cls: *u8 = rt::get_class(#str_ptr("NSXMLParser\0"));
    let alloced: *u8 = rt::msg_id(parser_cls, rt::sel(#str_ptr("alloc\0")));
    let parser: *u8 = rt::msg_id_id(alloced, rt::sel(#str_ptr("initWithData:\0")), data);
    rt::msg_void_id(parser, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    let ok: i8 = rt::msg_i8(parser, rt::sel(#str_ptr("parse\0")));

    assert ok != (0 as i8);
    assert counts.starts == (3 as i64);   // <root>, <child>, <child>
    assert counts.ends == (3 as i64);     // matching close tags
    return;
}

// Non-void callbacks through the GENERATED synthesizer (decimal_gen): the
// generated DecimalNumberBehaviors installs C+ scale (-> i16) and roundingMode
// (-> u64) IMPs that NSDecimalNumber consults during division.
#[link_name = "objc_msgSend"]
extern fn send_id2b(recv: *u8, sel: *u8, a: *u8, b: *u8) -> *u8;

fn gen_rounding(user: *u8) -> u64 {
    return 0 as u64; // NSRoundPlain
}

fn gen_scale(user: *u8) -> i16 {
    return 0 as i16; // integer result
}

#[test]
fn generated_decimal_behavior_scale_fires() {
    var beh: decimal_gen::DecimalNumberBehaviors = decimal_gen::DecimalNumberBehaviors_new({ 0 as *u8 });
    beh.set_rounding_mode(gen_rounding);
    beh.set_scale(gen_scale);
    let behavior: *u8 = decimal_gen::create_DecimalNumberBehaviors(#addr_of(beh));

    let dn: *u8 = rt::get_class(#str_ptr("NSDecimalNumber\0"));
    let with_str: *u8 = rt::sel(#str_ptr("decimalNumberWithString:\0"));
    let ten: *u8 = rt::msg_id_id(dn, with_str, bridge::nsstring("10"));
    let three: *u8 = rt::msg_id_id(dn, with_str, bridge::nsstring("3"));
    let result: *u8 = { send_id2b(ten, rt::sel(#str_ptr("decimalNumberByDividingBy:withBehavior:\0")), three, behavior) };
    let dv: f64 = rt::msg_f64(result, rt::sel(#str_ptr("doubleValue\0")));

    assert dv > (2.95 as f64);   // scale 0 -> 3.0, not full-precision 3.333
    assert dv < (3.05 as f64);
    return;
}
