// Feasibility proof for NON-VOID delegate callbacks (data-source style: the
// callback returns a value the framework consumes). NSDecimalNumberBehaviors is
// a pure-computation, headless, synchronous protocol: NSDecimalNumber arithmetic
// calls the behavior's `scale` (returns short) and `roundingMode` (returns
// NSUInteger) to shape the result. We synthesize a behavior in C+ whose `scale`
// returns 0, divide 10/3, and confirm the result rounded to an integer (3.0) —
// only possible if our scalar-returning IMP actually fired. The void-callback
// path is already proven; this checks the value-returning IMP shapes.

import "objc/runtime" as rt;
import "objc/bridge" as bridge;
import "objc/synthesis" as synth;

// class_addMethod for value-returning IMPs (kept local to this proof until the
// shapes are wired into the generator).
#[link_name = "class_addMethod"]
extern fn am_u64(cls: *u8, sel: *u8, imp: fn(*u8, *u8) -> u64, types: *u8) -> i8;
#[link_name = "class_addMethod"]
extern fn am_i16(cls: *u8, sel: *u8, imp: fn(*u8, *u8) -> i16, types: *u8) -> i8;
#[link_name = "class_addMethod"]
extern fn am_id4(cls: *u8, sel: *u8, imp: fn(*u8, *u8, *u8, *u8, *u8, *u8) -> *u8, types: *u8) -> i8;
#[link_name = "objc_msgSend"]
extern fn send_id2(recv: *u8, sel: *u8, a: *u8, b: *u8) -> *u8;

fn beh_rounding(self_obj: *u8, cmd: *u8) -> u64 {
    return 0 as u64; // NSRoundPlain
}

fn beh_scale(self_obj: *u8, cmd: *u8) -> i16 {
    return 0 as i16; // 0 fraction digits -> integer result
}

fn beh_exception(self_obj: *u8, cmd: *u8, op: *u8, err: *u8, l: *u8, r: *u8) -> *u8 {
    return { 0 as *u8 }; // nil -> raise (never hit for a clean divide)
}

#[test]
fn nonvoid_decimal_behavior_scale_fires() {
    let nsobject: *u8 = rt::get_class(#str_ptr("NSObject\0"));
    let cls: *u8 = synth::allocate_class_pair(nsobject, #str_ptr("CplusDecimalBehavior\0"), 0 as usize);
    let a0: i8 = { am_u64(cls, rt::sel(#str_ptr("roundingMode\0")), beh_rounding, #str_ptr("Q@:\0")) };
    let a1: i8 = { am_i16(cls, rt::sel(#str_ptr("scale\0")), beh_scale, #str_ptr("s@:\0")) };
    let a2: i8 = { am_id4(cls, rt::sel(#str_ptr("exceptionDuringOperation:error:leftOperand:rightOperand:\0")), beh_exception, #str_ptr("@@:@@@@\0")) };
    synth::register_class_pair(cls);
    assert a0 != (0 as i8);
    assert a1 != (0 as i8);
    assert a2 != (0 as i8);
    let behavior: *u8 = synth::alloc_init_class(cls);

    let dn: *u8 = rt::get_class(#str_ptr("NSDecimalNumber\0"));
    let with_str: *u8 = rt::sel(#str_ptr("decimalNumberWithString:\0"));
    let ten: *u8 = rt::msg_id_id(dn, with_str, bridge::nsstring("10"));
    let three: *u8 = rt::msg_id_id(dn, with_str, bridge::nsstring("3"));
    let result: *u8 = { send_id2(ten, rt::sel(#str_ptr("decimalNumberByDividingBy:withBehavior:\0")), three, behavior) };
    let dv: f64 = rt::msg_f64(result, rt::sel(#str_ptr("doubleValue\0")));

    // scale()=0 -> 10/3 rounds to 3.0. Full precision (~3.333) would fail this,
    // so passing proves the C+ `scale` IMP was consulted by NSDecimalNumber.
    assert dv > (2.95 as f64);
    assert dv < (3.05 as f64);
    return;
}
