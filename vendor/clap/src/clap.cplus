// vendor/clap/src/clap.cplus
// Zero-copy command line argument parser.

import "stdlib/vec" as vec;
import "stdlib/hash_map" as map;
import "stdlib/option" as option;
import "stdlib/result" as result;

extern fn write(fd: i32, buf: *u8, count: usize) -> isize;
extern fn exit(code: i32);

// Scan `len` bytes from `ptr` for the first occurrence of `b`. Returns
// the offset (relative to `ptr`) as `Some(usize)`, or `None` if not
// found. Used by `--name=value` parsing to find the `=` separator.
fn find_byte(ptr: *u8, len: usize, b: u8) -> option::Option[usize] {
    var i: usize = 0 as usize;
    while i < len {
        let p: *u8 = { ptr + i };
        if { *p } == b {
            return option::Option[usize]::Some(i);
        }
        i = i +% (1 as usize);
    }
    return option::Option[usize]::None;
}

struct Arg {
    name: str,
    short_name: str,
    long_name: str,
    help: str,
    is_flag: bool,
    required: bool,
}

fn new_arg(name: str) -> Arg {
    return Arg {
        name: name,
        short_name: "",
        long_name: "",
        help: "",
        is_flag: false,
        required: false,
    };
}

impl Arg {
    // Convention shim — matches stdlib's `Type::new`. Equivalent to
    // package-level `clap::new_arg(name)`.
    fn new(name: str) -> Arg {
        return new_arg(name);
    }

    fn short(ref this, s: str) -> Arg {
        this.short_name = s;
        return this;
    }
    fn long(ref this, l: str) -> Arg {
        this.long_name = l;
        return this;
    }
    fn flag(ref this) -> Arg {
        this.is_flag = true;
        return this;
    }
    fn required(ref this) -> Arg {
        this.required = true;
        return this;
    }
    fn help(ref this, h: str) -> Arg {
        this.help = h;
        return this;
    }
}

struct App {
    name: str,
    version: str,
    author: str,
    about: str,
    args: vec::Vec[Arg],
}

fn new_app(name: str) -> App {
    return App {
        name: name,
        version: "",
        author: "",
        about: "",
        args: vec::new::[Arg](),
    };
}

fn write_out(fd: i32, s: str) {
    let p: *u8 = #str_ptr(s);
    let n: usize = #str_len(s);
    var written: usize = 0;
    while written < n {
        let q: *u8 = { p + written };
        let w: isize = { write(fd, q, n -% written) };
        if w <= (0 as isize) { return; }
        written = written +% (w as usize);
    }
    return;
}

impl App {
    // Convention shim — matches stdlib's `Type::new`. Equivalent to
    // package-level `clap::new_app(name)`.
    fn new(name: str) -> App {
        return new_app(name);
    }

    fn version(ref this, v: str) -> App {
        this.version = v;
        return this;
    }
    fn author(ref this, a: str) -> App {
        this.author = a;
        return this;
    }
    fn about(ref this, ab: str) -> App {
        this.about = ab;
        return this;
    }
    fn arg(ref this, take argument: Arg) -> App {
        this.args.push(argument);
        return this;
    }

    fn find_arg_by_long(this, name: str) -> option::Option[Arg] {
        var i: usize = 0 as usize;
        let len: usize = this.args.len();
        while i < len {
            let item: Arg = vec::at_copy::[Arg](this.args, i);
            if item.long_name == name {
                return option::some::[Arg](item);
            }
            i = i +% (1 as usize);
        }
        return option::Option[Arg]::None;
    }

    fn find_arg_by_short(this, name: str) -> option::Option[Arg] {
        var i: usize = 0 as usize;
        let len: usize = this.args.len();
        while i < len {
            let item: Arg = vec::at_copy::[Arg](this.args, i);
            if item.short_name == name {
                return option::some::[Arg](item);
            }
            i = i +% (1 as usize);
        }
        return option::Option[Arg]::None;
    }

    fn print_help_and_exit(this) {
        let fd: i32 = 1; // stdout
        write_out(fd, this.name);
        write_out(fd, "\n");
        if #str_len(this.version) > 0 {
            write_out(fd, "Version: ");
            write_out(fd, this.version);
            write_out(fd, "\n");
        }
        if #str_len(this.author) > 0 {
            write_out(fd, "Author: ");
            write_out(fd, this.author);
            write_out(fd, "\n");
        }
        if #str_len(this.about) > 0 {
            write_out(fd, this.about);
            write_out(fd, "\n");
        }
        write_out(fd, "\nUSAGE:\n    ");
        write_out(fd, this.name);
        write_out(fd, " [FLAGS] [OPTIONS] [POSITIONALS]\n\nFLAGS & OPTIONS:\n");

        var i: usize = 0 as usize;
        let len: usize = this.args.len();
        while i < len {
            let item: Arg = vec::at_copy::[Arg](this.args, i);
            write_out(fd, "    ");
            if #str_len(item.short_name) > 0 {
                write_out(fd, "-");
                write_out(fd, item.short_name);
                write_out(fd, ", ");
            } else {
                write_out(fd, "    ");
            }
            if #str_len(item.long_name) > 0 {
                write_out(fd, "--");
                write_out(fd, item.long_name);
            }
            if !item.is_flag {
                write_out(fd, " <value>");
            }
            if #str_len(item.help) > 0 {
                write_out(fd, "        ");
                write_out(fd, item.help);
            }
            if item.required {
                write_out(fd, " (required)");
            }
            write_out(fd, "\n");
            i = i +% (1 as usize);
        }

        { exit(0 as i32); }
        return;
    }

    fn print_unknown_arg_and_exit(this, arg: str) {
        let fd: i32 = 2; // stderr
        write_out(fd, "error: Found argument '");
        write_out(fd, arg);
        write_out(fd, "' which wasn't expected, or isn't valid in this context\n\n");
        write_out(fd, "USAGE:\n    ");
        write_out(fd, this.name);
        write_out(fd, " [FLAGS] [OPTIONS] [POSITIONALS]\n");
        { exit(1 as i32); }
        return;
    }

    fn print_missing_value_and_exit(this, name: str) {
        let fd: i32 = 2; // stderr
        write_out(fd, "error: The argument '--");
        write_out(fd, name);
        write_out(fd, "' requires a value but none was supplied\n");
        { exit(1 as i32); }
        return;
    }

    fn print_missing_required_and_exit(this, name: str) {
        let fd: i32 = 2; // stderr
        write_out(fd, "error: The following required arguments were not provided:\n    ");
        write_out(fd, name);
        write_out(fd, "\n");
        { exit(1 as i32); }
        return;
    }

    // Cross-platform entrypoint. Consumers construct the args vector
    // however suits their platform — on macOS via stdlib::env, on Linux
    // via a custom `main(argc, argv)` once C+ exposes that, etc. The
    // pre-v0.0.9 `get_matches()` shortcut that called `_NSGetArgc/Argv`
    // directly was Darwin-only and has been dropped to keep this
    // package portable.
    fn get_matches_from(this, take args: vec::Vec[str]) -> ArgMatches {
        var matches: map::HashMap[str, str] = map::new::[str, str]();
        var positionals: vec::Vec[str] = vec::new::[str]();

        let n: usize = args.len();
        var i: usize = 1 as usize;

        let args_len: usize = this.args.len();

        while i < n {
            let arg_str: str = vec::at_copy::[str](args, i);

            if #str_len(arg_str) > (1 as usize) && { *#str_ptr(arg_str) } == ('-' as u8) {
                if arg_str == "--help" || arg_str == "-h" {
                    this.print_help_and_exit();
                }

                if #str_len(arg_str) > (2 as usize) && { *(#str_ptr(arg_str) + 1) } == ('-' as u8) {
                    // Long option: --name OR --name=value.
                    let body_ptr: *u8 = { #str_ptr(arg_str) + 2 };
                    let body_len: usize = #str_len(arg_str) -% (2 as usize);
                    let eq_pos: option::Option[usize] = find_byte(body_ptr, body_len, '=' as u8);

                    let opt_name: str = match eq_pos {
                        option::Option[usize]::Some(p) => { #str_from_raw_parts(body_ptr, p) },
                        option::Option[usize]::None => { #str_from_raw_parts(body_ptr, body_len) },
                    };
                    let inline_value: option::Option[str] = match eq_pos {
                        option::Option[usize]::Some(p) => {
                            let val_ptr: *u8 = { body_ptr + (p +% (1 as usize)) };
                            let val_len: usize = body_len -% p -% (1 as usize);
                            option::Option[str]::Some({ #str_from_raw_parts(val_ptr, val_len) })
                        }
                        option::Option[usize]::None => option::Option[str]::None,
                    };

                    let opt_arg: option::Option[Arg] = this.find_arg_by_long(opt_name);
                    guard let option::Option[Arg]::Some(found) = opt_arg else {
                        this.print_unknown_arg_and_exit(arg_str);
                        return ArgMatches {
                            matches: map::new::[str, str](),
                            positionals: vec::new::[str](),
                        };
                    };

                    if found.is_flag {
                        // Flags don't accept `=value`. If the user wrote
                        // `--flag=...` silently treat it as the flag.
                        matches.insert(found.name, "true");
                    } else {
                        match inline_value {
                            option::Option[str]::Some(v) => {
                                matches.insert(found.name, v);
                            }
                            option::Option[str]::None => {
                                if i +% (1 as usize) < n {
                                    i = i +% (1 as usize);
                                    let val: str = vec::at_copy::[str](args, i);
                                    matches.insert(found.name, val);
                                } else {
                                    this.print_missing_value_and_exit(found.name);
                                }
                            }
                        };
                    }
                } else {
                    // Short option: `-n` or combined flags `-abc`.
                    // Try combined-flag form first: every byte must be a
                    // known flag-typed short option. If any byte fails
                    // the lookup OR points at a non-flag, fall back to
                    // the single-option path with the whole `-...` body
                    // as the option name.
                    let body_ptr: *u8 = { #str_ptr(arg_str) + 1 };
                    let body_len: usize = #str_len(arg_str) -% (1 as usize);

                    var all_flags: bool = body_len > (1 as usize);
                    var k: usize = 0 as usize;
                    while all_flags && k < body_len {
                        let bptr: *u8 = { body_ptr + k };
                        let one: str = { #str_from_raw_parts(bptr, 1 as usize) };
                        let oa: option::Option[Arg] = this.find_arg_by_short(one);
                        match oa {
                            option::Option[Arg]::Some(a) => {
                                if !a.is_flag { all_flags = false; }
                            }
                            option::Option[Arg]::None => { all_flags = false; }
                        };
                        k = k +% (1 as usize);
                    }

                    if all_flags {
                        // Combined form `-abc` — insert each flag.
                        var j2: usize = 0 as usize;
                        while j2 < body_len {
                            let bptr: *u8 = { body_ptr + j2 };
                            let one: str = { #str_from_raw_parts(bptr, 1 as usize) };
                            guard let option::Option[Arg]::Some(a) = this.find_arg_by_short(one) else {
                                // can't happen — checked in loop above
                                return ArgMatches {
                                    matches: map::new::[str, str](),
                                    positionals: vec::new::[str](),
                                };
                            };
                            matches.insert(a.name, "true");
                            j2 = j2 +% (1 as usize);
                        }
                    } else {
                        let opt_name: str = { #str_from_raw_parts(body_ptr, body_len) };
                        let opt_arg: option::Option[Arg] = this.find_arg_by_short(opt_name);
                        guard let option::Option[Arg]::Some(found) = opt_arg else {
                            this.print_unknown_arg_and_exit(arg_str);
                            return ArgMatches {
                                matches: map::new::[str, str](),
                                positionals: vec::new::[str](),
                            };
                        };

                        if found.is_flag {
                            matches.insert(found.name, "true");
                        } else {
                            if i +% (1 as usize) < n {
                                i = i +% (1 as usize);
                                let val: str = vec::at_copy::[str](args, i);
                                matches.insert(found.name, val);
                            } else {
                                this.print_missing_value_and_exit(found.name);
                            }
                        }
                    }
                }
            } else {
                positionals.push(arg_str);
            }
            i = i +% (1 as usize);
        }

        var j: usize = 0 as usize;
        while j < args_len {
            let item: Arg = vec::at_copy::[Arg](this.args, j);
            if item.required {
                if !matches.contains_key(item.name) {
                    this.print_missing_required_and_exit(item.name);
                }
            }
            j = j +% (1 as usize);
        }

        return ArgMatches {
            matches: matches,
            positionals: positionals,
        };
    }
}

struct ArgMatches {
    matches: map::HashMap[str, str],
    positionals: vec::Vec[str],
}

impl ArgMatches {
    fn is_present(this, name: str) -> bool {
        return this.matches.contains_key(name);
    }

    fn value_of(this, name: str) -> option::Option[str] {
        let res = this.matches.get(name);
        guard let result::Result[str, result::IoError]::Ok(val) = res else {
            return option::Option[str]::None;
        };
        return option::some::[str](val);
    }

    fn positional_count(this) -> usize {
        return this.positionals.len();
    }

    fn positional_at(this, i: usize) -> str {
        return vec::at_copy::[str](this.positionals, i);
    }
}

// ---------------- Unit tests (run via `cpc test`) ----------------
//
// These tests build argv vectors in code and feed them to
// `get_matches_from(...)` directly — no _NSGetArgc/Argv involved.
// Each test exercises one parsing rule (long, short, =value,
// combined-flag, positional, missing-required).

fn make_argv(items: vec::Vec[str]) -> vec::Vec[str] {
    return items;
}

#[test]
fn test_arg_builder_chains() {
    var a: Arg = Arg::new("v");
    a = a.short("v");
    a = a.long("verbose");
    a = a.flag();
    assert a.name == "v";
    assert a.short_name == "v";
    assert a.long_name == "verbose";
    assert a.is_flag;
}

#[test]
fn test_app_builder_chains() {
    var app: App = App::new("mytool");
    app = app.version("1.0");
    app = app.author("me");
    app = app.about("does things");
    assert app.name == "mytool";
    assert app.version == "1.0";
    assert app.author == "me";
    assert app.about == "does things";
}

#[test]
fn test_long_option_with_separate_value() {
    var a1: Arg = Arg::new("name");
    a1 = a1.long("name");
    var app: App = App::new("t");
    app = app.arg(a1);

    var argv: vec::Vec[str] = vec::new::[str]();
    argv.push("t");
    argv.push("--name");
    argv.push("alice");

    let m: ArgMatches = app.get_matches_from(argv);
    guard let option::Option[str]::Some(v) = m.value_of("name") else {
        assert false;
        return;
    };
    assert v == "alice";
}

#[test]
fn test_long_option_with_equals_value() {
    var a1: Arg = Arg::new("name");
    a1 = a1.long("name");
    var app: App = App::new("t");
    app = app.arg(a1);

    var argv: vec::Vec[str] = vec::new::[str]();
    argv.push("t");
    argv.push("--name=bob");

    let m: ArgMatches = app.get_matches_from(argv);
    guard let option::Option[str]::Some(v) = m.value_of("name") else {
        assert false;
        return;
    };
    assert v == "bob";
}

#[test]
fn test_short_flag() {
    var a: Arg = Arg::new("v");
    a = a.short("v");
    a = a.flag();
    var app: App = App::new("t");
    app = app.arg(a);

    var argv: vec::Vec[str] = vec::new::[str]();
    argv.push("t");
    argv.push("-v");

    let m: ArgMatches = app.get_matches_from(argv);
    assert m.is_present("v");
}

#[test]
fn test_combined_short_flags() {
    var a1: Arg = Arg::new("a");
    a1 = a1.short("a");
    a1 = a1.flag();
    var a2: Arg = Arg::new("b");
    a2 = a2.short("b");
    a2 = a2.flag();
    var a3: Arg = Arg::new("c");
    a3 = a3.short("c");
    a3 = a3.flag();

    var app: App = App::new("t");
    app = app.arg(a1);
    app = app.arg(a2);
    app = app.arg(a3);

    var argv: vec::Vec[str] = vec::new::[str]();
    argv.push("t");
    argv.push("-abc");

    let m: ArgMatches = app.get_matches_from(argv);
    assert m.is_present("a");
    assert m.is_present("b");
    assert m.is_present("c");
}

#[test]
fn test_positionals_collected() {
    var app: App = App::new("t");

    var argv: vec::Vec[str] = vec::new::[str]();
    argv.push("t");
    argv.push("pos1");
    argv.push("pos2");
    argv.push("pos3");

    let m: ArgMatches = app.get_matches_from(argv);
    assert m.positional_count() == (3 as usize);
    assert m.positional_at(0 as usize) == "pos1";
    assert m.positional_at(2 as usize) == "pos3";
}

#[test]
fn test_value_of_missing_returns_none() {
    var app: App = App::new("t");
    var argv: vec::Vec[str] = vec::new::[str]();
    argv.push("t");
    let m: ArgMatches = app.get_matches_from(argv);
    match m.value_of("missing") {
        option::Option[str]::Some(_) => { assert false; }
        option::Option[str]::None => { assert true; }
    };
}

#[test]
fn test_app_args_collects_via_vec() {
    var app: App = App::new("t");
    app = app.arg(Arg::new("x"));
    app = app.arg(Arg::new("y"));
    assert app.args.len() == (2 as usize);
    let a0: Arg = vec::at_copy::[Arg](app.args, 0 as usize);
    let a1: Arg = vec::at_copy::[Arg](app.args, 1 as usize);
    assert a0.name == "x";
    assert a1.name == "y";
}
