// vendor/agent_core/src/auth.cplus
//
// The agent-surface authorization gate (plan.agent-core.md §5, §6 layer 3).
//
// Authorization is all-or-none per agent: the policy makes a single grant
// decision per channel, not a per-operation adjudication. Once admitted, the
// agent operates within what exposure (layer 1, `identity::set_exposed`) and the
// node ceiling (layer 2, `identity::set_observe_only`) already allow — the gate
// adds nothing per node and nothing separate for events.
//
// The policy is supplied as code (a function pointer): enabling the surface is
// supplying the policy, so there is no "armed" flag — a gate either has a policy
// or is default-deny. "Ask the user", persisted consent, and tokens live in a
// consumer-side helper that calls the gate and returns Allow/Reject; the core
// gate stays a pure predicate that never blocks and never prompts.

pub enum Channel {
    // The in-app assistant: the user clicked the help icon and is present.
    InApp,
    // An external agent attached over the MCP bridge (by PID).
    External,
}

pub enum Decision {
    Allow,
    Reject,
}

// What the policy decides over. Deliberately coarse (the grant is per agent /
// channel, not per node or per op); a field can be added without changing the
// gate's shape.
pub struct Request {
    pub channel: Channel,
}

pub fn request(channel: Channel) -> Request {
    return Request { channel: channel };
}

// The gate holds the developer's policy. A function pointer, not a closure
// (C+ has no closures, and the grant needs no captured state — per-channel
// behaviour comes from the `Request`).
pub struct AuthGate {
    policy: fn(Request) -> Decision,
}

// The default-deny policy: reject everything. `deny_all` installs it so an
// un-served surface is closed, with no null/optional in the gate.
fn reject_always(req: Request) -> Decision {
    return Decision::Reject;
}

// A closed gate: nothing is admitted until `serve` supplies a real policy.
pub fn deny_all() -> AuthGate {
    let p: fn(Request) -> Decision = reject_always;
    return AuthGate { policy: p };
}

// Arm the gate with a policy. This is how the surface is enabled (§8): you
// cannot turn it on without supplying the decision function.
pub fn serve(policy: fn(Request) -> Decision) -> AuthGate {
    return AuthGate { policy: policy };
}

impl AuthGate {
    // The single grant check. Pure: no I/O, no prompt, never blocks.
    pub fn check(self, req: Request) -> Decision {
        return (self.policy)(req);
    }
}

pub fn decision_eq(a: Decision, b: Decision) -> bool {
    return match a {
        Decision::Allow => match b {
            Decision::Allow => true,
            Decision::Reject => false,
        },
        Decision::Reject => match b {
            Decision::Allow => false,
            Decision::Reject => true,
        },
    };
}

pub fn channel_eq(a: Channel, b: Channel) -> bool {
    return match a {
        Channel::InApp => match b {
            Channel::InApp => true,
            Channel::External => false,
        },
        Channel::External => match b {
            Channel::InApp => false,
            Channel::External => true,
        },
    };
}

// ====================================================================
// Tests
// ====================================================================

// A representative policy: trust the in-app assistant, reject external agents.
// (A real consumer would route External through the consent helper.)
fn inapp_only(req: Request) -> Decision {
    return match req.channel {
        Channel::InApp => Decision::Allow,
        Channel::External => Decision::Reject,
    };
}

#[test]
fn test_default_deny_rejects_every_channel() {
    let gate: AuthGate = deny_all();
    assert decision_eq(gate.check(request(Channel::InApp)), Decision::Reject);
    assert decision_eq(gate.check(request(Channel::External)), Decision::Reject);
}

#[test]
fn test_served_policy_decides_per_channel() {
    let p: fn(Request) -> Decision = inapp_only;
    let gate: AuthGate = serve(p);
    assert decision_eq(gate.check(request(Channel::InApp)), Decision::Allow);
    assert decision_eq(gate.check(request(Channel::External)), Decision::Reject);
}

#[test]
fn test_decision_and_channel_eq() {
    assert decision_eq(Decision::Allow, Decision::Allow);
    assert (decision_eq(Decision::Allow, Decision::Reject)) == false;
    assert channel_eq(Channel::InApp, Channel::InApp);
    assert (channel_eq(Channel::InApp, Channel::External)) == false;
}
