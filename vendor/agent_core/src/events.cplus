// vendor/agent_core/src/events.cplus
//
// The agent-surface event layer (plan.agent-core.md §7).
//
// Events bubble up the agent-id tree: a subscription on a node receives events
// from that node and all its descendants. There is NO topic-wildcard grammar —
// subscribing higher in the tree is the only "wildcard", and the tree is the
// filter. A subscription is a conjunction of three optional equality filters:
//
//   { node?, verb?, role? }   (all optional, AND-ed, default = any)
//
// `node` filters by subtree (source-or-ancestor), `verb` by event kind, `role`
// by the source node's kind. Verbs are curated (no raw input firehose) and drawn
// from the W3C a11y + AppKit AX semantic channels.
//
// Backpressure (§7.3): each subscriber has a bounded queue. `ui_changed`
// coalesces (at most one pending); on overflow the OLDEST event is dropped and a
// dropped-count is kept; the emitter never blocks.

import "stdlib/vec" as vec;
import "stdlib/option" as option;
import "./identity" as identity;

// The curated verb vocabulary (plan.agent-core.md §7.2). Discrete/committed
// semantic events only; grows deliberately.
enum Verb {
    Clicked,
    Changed,
    Submitted,
    Selected,
    Toggled,
    Opened,
    Closed,
    Enabled,
    Disabled,
    Added,
    Removed,
    Appeared,
    Disappeared,
    WindowOpened,
    WindowClosed,
    UiChanged,
}

fn verb_index(v: Verb) -> i32 {
    return match v {
        Verb::Clicked => 0,
        Verb::Changed => 1,
        Verb::Submitted => 2,
        Verb::Selected => 3,
        Verb::Toggled => 4,
        Verb::Opened => 5,
        Verb::Closed => 6,
        Verb::Enabled => 7,
        Verb::Disabled => 8,
        Verb::Added => 9,
        Verb::Removed => 10,
        Verb::Appeared => 11,
        Verb::Disappeared => 12,
        Verb::WindowOpened => 13,
        Verb::WindowClosed => 14,
        Verb::UiChanged => 15,
    };
}

fn verb_eq(a: Verb, b: Verb) -> bool {
    return verb_index(a) == verb_index(b);
}

fn is_ui_changed(v: Verb) -> bool {
    return verb_index(v) == 15;
}

// An event: which node it came from (NodeId) and what happened. Copy.
struct Event {
    source: usize,
    verb: Verb,
}

fn event(source: usize, verb: Verb) -> Event {
    return Event { source: source, verb: verb };
}

// A subscription: a conjunction of optional filters. Copy (no owned storage).
struct Subscription {
    node: option::Option[usize],
    verb: option::Option[Verb],
    role: option::Option[identity::Role],
}

// Everything: no filters (every event in the whole app). Narrow with the
// builder methods below.
fn everything() -> Subscription {
    return Subscription {
        node: option::Option[usize]::None,
        verb: option::Option[Verb]::None,
        role: option::Option[identity::Role]::None,
    };
}

impl Subscription {
    // Restrict to a subtree: events from this node or any descendant.
    fn on_node(this, n: usize) -> Subscription {
        return Subscription { node: option::Option[usize]::Some(n), verb: this.verb, role: this.role };
    }
    fn on_verb(this, v: Verb) -> Subscription {
        return Subscription { node: this.node, verb: option::Option[Verb]::Some(v), role: this.role };
    }
    fn on_role(this, r: identity::Role) -> Subscription {
        return Subscription { node: this.node, verb: this.verb, role: option::Option[identity::Role]::Some(r) };
    }
}

// Whether `n` is `source` or an ancestor of it (the bubbling test).
fn is_ancestor_or_self(reg: *identity::Registry, n: usize, source: usize) -> bool {
    var cur: option::Option[usize] = option::Option[usize]::Some(source);
    loop {
        match cur {
            option::Option[usize]::Some(c) => {
                if c == n {
                    return true;
                }
                cur = (*reg).parent_of(c);
            }
            option::Option[usize]::None => {
                return false;
            }
        }
    }
    return false;
}

// Does an event from `source` with `verb` match `filter`, given the tree? verb +
// role are equality filters; node is the subtree (bubbling) test. Takes the
// event's fields (both Copy) rather than the Event itself, so the caller can
// keep ownership of the Event for enqueueing.
// Takes the filter's three fields individually (not the `Subscription` struct):
// reading a struct-typed field by value out of `this` is a partial move the
// move-checker rejects, but Option/enum fields copy fine, so the subscriber
// stores them flat and passes them here.
fn matches(reg: *identity::Registry, node_f: option::Option[usize], verb_f: option::Option[Verb], role_f: option::Option[identity::Role], source: usize, verb: Verb) -> bool {
    let verb_ok: bool = match verb_f {
        option::Option[Verb]::Some(v) => verb_eq(v, verb),
        option::Option[Verb]::None => true,
    };
    if !verb_ok {
        return false;
    }
    let role_ok: bool = match role_f {
        option::Option[identity::Role]::Some(r) => identity::role_eq(r, (*reg).role_of(source)),
        option::Option[identity::Role]::None => true,
    };
    if !role_ok {
        return false;
    }
    return match node_f {
        option::Option[usize]::None => true,
        option::Option[usize]::Some(n) => is_ancestor_or_self(reg, n, source),
    };
}

// A subscriber: a filter plus a bounded FIFO of matched events. `head` is the
// dequeue cursor (poll advances it instead of shifting); the backing Vec is
// compacted once the cursor passes `cap` so it stays bounded.
struct Subscriber {
    // The filter, stored flat (see `matches` for why not a `Subscription` field).
    node: option::Option[usize],
    verb: option::Option[Verb],
    role: option::Option[identity::Role],
    cap: usize,
    queue: vec::Vec[Event],
    head: usize,
    dropped: usize,
}

fn subscriber(filter: Subscription, cap: usize) -> Subscriber {
    return Subscriber {
        node: filter.node,
        verb: filter.verb,
        role: filter.role,
        cap: cap,
        queue: vec::new::[Event](),
        head: 0 as usize,
        dropped: 0 as usize,
    };
}

impl Subscriber {
    // Events waiting to be polled.
    fn pending(this) -> usize {
        return this.queue.count() -% this.head;
    }

    // Events dropped to date due to overflow.
    fn dropped_count(this) -> usize {
        return this.dropped;
    }

    fn has_pending_ui_changed(this) -> bool {
        var i: usize = this.head;
        while i < this.queue.count() {
            let uc: bool = match this.queue.at_ptr(i) {
                option::Option[*Event]::Some(p) => is_ui_changed({ (*p).verb }),
                option::Option[*Event]::None => false,
            };
            if uc {
                return true;
            }
            i = i +% (1 as usize);
        }
        return false;
    }

    fn compact(ref this) {
        if this.head < this.cap {
            return;
        }
        var nq: vec::Vec[Event] = vec::new::[Event]();
        var i: usize = this.head;
        while i < this.queue.count() {
            match this.queue.at_ptr(i) {
                option::Option[*Event]::Some(p) => { nq.append({ *p }); }
                option::Option[*Event]::None => {}
            }
            i = i +% (1 as usize);
        }
        this.queue = nq;
        this.head = 0 as usize;
        return;
    }

    // Offer an event. Enqueues iff it matches the filter, applying backpressure:
    // `ui_changed` coalesces to at most one pending; on overflow the oldest event
    // is dropped (dropped-count bumped). Never blocks.
    fn offer(ref this, reg: *identity::Registry, ev: Event) {
        let src: usize = ev.source;
        let vb: Verb = ev.verb;
        if !matches(reg, this.node, this.verb, this.role, src, vb) {
            return;
        }
        if is_ui_changed(vb) && this.has_pending_ui_changed() {
            return;
        }
        if this.pending() >= this.cap {
            this.head = this.head +% (1 as usize);
            this.dropped = this.dropped +% (1 as usize);
        }
        this.queue.append(ev);
        this.compact();
        return;
    }

    // Dequeue the oldest pending event, or None.
    fn poll(ref this) -> option::Option[Event] {
        if this.head >= this.queue.count() {
            return option::Option[Event]::None;
        }
        let out: option::Option[Event] = match this.queue.at_ptr(this.head) {
            option::Option[*Event]::Some(p) => option::Option[Event]::Some({ *p }),
            option::Option[*Event]::None => option::Option[Event]::None,
        };
        this.head = this.head +% (1 as usize);
        return out;
    }
}

// ====================================================================
// Tests
// ====================================================================

// A small tree:  app(0) -> window(1) -> [ btn(2, Button), field(3, Input) ]
fn fixture() -> identity::Registry {
    var r: identity::Registry = identity::new();
    let root: usize = r.root();
    let win: usize = r.add_child(root, option::Option[str]::Some("win"), identity::Role::Window);
    let _btn: usize = r.add_child(win, option::Option[str]::Some("btn"), identity::Role::Button);
    let _field: usize = r.add_child(win, option::Option[str]::Some("field"), identity::Role::Input);
    return r;
}

fn poll_count(ref s: Subscriber) -> usize {
    var n: usize = 0 as usize;
    loop {
        match s.poll() {
            option::Option[Event]::Some(_) => { n = n +% (1 as usize); }
            option::Option[Event]::None => { return n; }
        }
    }
    return n;
}

#[test]
fn test_bubbling_ancestor_receives_descendant_event() {
    var r: identity::Registry = fixture();
    // Subscribe at the window; a click on the button (a descendant) bubbles up.
    var s: Subscriber = subscriber(everything().on_node(1 as usize), 8 as usize);
    s.offer({ #addr_of(r) }, event(2 as usize, Verb::Clicked));
    assert s.pending() == (1 as usize);
}

#[test]
fn test_node_filter_excludes_other_subtree() {
    var r: identity::Registry = fixture();
    // Subscribe at the button; an event on the field (a sibling) must NOT match.
    var s: Subscriber = subscriber(everything().on_node(2 as usize), 8 as usize);
    s.offer({ #addr_of(r) }, event(3 as usize, Verb::Changed));
    assert s.pending() == (0 as usize);
}

#[test]
fn test_root_subscription_matches_anything() {
    var r: identity::Registry = fixture();
    var s: Subscriber = subscriber(everything(), 8 as usize);
    s.offer({ #addr_of(r) }, event(2 as usize, Verb::Clicked));
    s.offer({ #addr_of(r) }, event(3 as usize, Verb::Changed));
    assert s.pending() == (2 as usize);
}

#[test]
fn test_verb_filter() {
    var r: identity::Registry = fixture();
    var s: Subscriber = subscriber(everything().on_verb(Verb::Clicked), 8 as usize);
    s.offer({ #addr_of(r) }, event(2 as usize, Verb::Clicked));
    s.offer({ #addr_of(r) }, event(2 as usize, Verb::Changed));
    assert s.pending() == (1 as usize);
    match s.poll() {
        option::Option[Event]::Some(e) => { assert verb_eq(e.verb, Verb::Clicked); }
        option::Option[Event]::None => { assert false; }
    }
    return;
}

#[test]
fn test_role_filter_cross_cutting() {
    var r: identity::Registry = fixture();
    // "every button click anywhere" — role+verb, no node.
    var s: Subscriber = subscriber(everything().on_role(identity::Role::Button).on_verb(Verb::Clicked), 8 as usize);
    s.offer({ #addr_of(r) }, event(2 as usize, Verb::Clicked)); // btn -> match
    s.offer({ #addr_of(r) }, event(3 as usize, Verb::Clicked)); // field (Input) -> no match
    assert s.pending() == (1 as usize);
}

#[test]
fn test_poll_is_fifo_and_drains() {
    var r: identity::Registry = fixture();
    var s: Subscriber = subscriber(everything(), 8 as usize);
    s.offer({ #addr_of(r) }, event(2 as usize, Verb::Clicked));
    s.offer({ #addr_of(r) }, event(3 as usize, Verb::Changed));
    match s.poll() {
        option::Option[Event]::Some(e) => { assert verb_eq(e.verb, Verb::Clicked); }
        option::Option[Event]::None => { assert false; }
    }
    match s.poll() {
        option::Option[Event]::Some(e) => { assert verb_eq(e.verb, Verb::Changed); }
        option::Option[Event]::None => { assert false; }
    }
    assert s.pending() == (0 as usize);
}

#[test]
fn test_ui_changed_coalesces() {
    var r: identity::Registry = fixture();
    var s: Subscriber = subscriber(everything(), 8 as usize);
    s.offer({ #addr_of(r) }, event(0 as usize, Verb::UiChanged));
    s.offer({ #addr_of(r) }, event(0 as usize, Verb::UiChanged));
    s.offer({ #addr_of(r) }, event(0 as usize, Verb::UiChanged));
    // Three ui_changed collapse to one pending.
    assert s.pending() == (1 as usize);
    // A non-ui_changed event still enqueues alongside.
    s.offer({ #addr_of(r) }, event(2 as usize, Verb::Clicked));
    assert s.pending() == (2 as usize);
}

#[test]
fn test_overflow_drops_oldest_and_counts() {
    var r: identity::Registry = fixture();
    var s: Subscriber = subscriber(everything(), 2 as usize);
    s.offer({ #addr_of(r) }, event(2 as usize, Verb::Clicked));   // [click]
    s.offer({ #addr_of(r) }, event(3 as usize, Verb::Changed));   // [click, changed]
    s.offer({ #addr_of(r) }, event(2 as usize, Verb::Submitted)); // overflow -> drop click -> [changed, submitted]
    assert s.pending() == (2 as usize);
    assert s.dropped_count() == (1 as usize);
    // Oldest (click) was dropped; next polled is `changed`.
    match s.poll() {
        option::Option[Event]::Some(e) => { assert verb_eq(e.verb, Verb::Changed); }
        option::Option[Event]::None => { assert false; }
    }
    return;
}

#[test]
fn test_compaction_keeps_backing_bounded_no_double_free() {
    var r: identity::Registry = fixture();
    var s: Subscriber = subscriber(everything(), 2 as usize);
    var i: usize = 0 as usize;
    // Many offers + polls force overflow drops and compaction repeatedly.
    while i < (64 as usize) {
        s.offer({ #addr_of(r) }, event(2 as usize, Verb::Clicked));
        let _e: option::Option[Event] = s.poll();
        i = i +% (1 as usize);
    }
    // Still consistent; ASan would catch a double free from compaction.
    assert s.pending() <= (2 as usize);
}
