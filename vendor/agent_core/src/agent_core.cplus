// vendor/agent_core/src/agent_core.cplus
//
// Root module of the agent surface core (plan.agent-core.md). The
// framework-agnostic core; AppKit backends and the MCP bridge live in separate
// packages that depend on this one.

import "./identity" as identity;
import "./auth" as auth;
import "./events" as events;
import "./surface" as surface;

// Convenience constructor re-export; also keeps `identity` in the module graph.
fn new_registry() -> identity::Registry {
    return identity::new();
}

// A closed (default-deny) auth gate; also keeps `auth` in the module graph.
fn closed_gate() -> auth::AuthGate {
    return auth::deny_all();
}

// A subscriber to everything; also keeps `events` in the module graph.
fn subscribe_all() -> events::Subscriber {
    return events::subscriber(events::everything(), 64 as usize);
}

// A fresh text-version table; also keeps `surface` in the module graph.
fn new_versions() -> surface::TextVersions {
    return surface::new_text_versions();
}

#[test]
fn test_root_constructs_registry() {
    let r: identity::Registry = new_registry();
    assert r.len() == (1 as usize);
}
