// vendor/agent_core/src/surface.cplus
//
// The agent-surface action + text-op layer (plan.agent-core.md §5.2, §5.3).
//
// This is the framework-agnostic ENFORCEMENT brain, not the widget I/O. The
// core decides whether an operation is permitted — addressing (the node exists),
// exposure (layer 1), the affordance ceiling (layer 2), and, for text edits,
// optimistic-concurrency via a version stamp — and returns an `Outcome`. The
// actual read/write/click on a real widget is GUI-coupled and belongs to the
// backend (the AppKit slice), which performs the operation only when the core
// returns `Allowed`.
//
// Why not a dispatched `UiBackend` interface + a fake here? cpc does not yet
// support interface-bound generics (`fn op[B: UiBackend](...)` / `Surface[B]`),
// and has no closures, so the core cannot dispatch polymorphically through a
// port. Keeping the core to pure authorization + version state sidesteps that
// entirely and is the cleaner framework-agnostic boundary anyway: the backend is
// dumb execution, the core is the policy.
//
// Consumer flow:
//   click(id)            -> authorize_action; if Allowed, backend.activate(node)
//   input(id, text)      -> authorize_action; if Allowed, backend.set_value(...)
//   scroll_to(id)        -> authorize_read;   if Allowed, backend.scroll_to(node)
//   get_text(id)         -> authorize_read;   if Allowed, read widget + version_of(node)
//   replace_range(...)   -> authorize_text_write(base_version); if Allowed,
//                           backend.set_text(...) then versions.bump(node)

import "stdlib/option" as option;
import "stdlib/result" as result;
import "stdlib/hash_map" as hash_map;
import "./identity" as identity;

// The result of an authorization check.
pub enum Outcome {
    Allowed,
    NotFound,       // no node with that id / invalid handle
    NotExposed,     // node exists but is not in the agent-visible tree (layer 1)
    NotActionable,  // observe-only or disabled (layer 2 ceiling)
    VersionConflict, // text edit raced a change; the agent must re-read
}

fn outcome_index(o: Outcome) -> i32 {
    return match o {
        Outcome::Allowed => 0,
        Outcome::NotFound => 1,
        Outcome::NotExposed => 2,
        Outcome::NotActionable => 3,
        Outcome::VersionConflict => 4,
    };
}

pub fn outcome_eq(a: Outcome, b: Outcome) -> bool {
    return outcome_index(a) == outcome_index(b);
}

// Authorize a mutating/activating action (click, input). Requires the node to
// exist, be exposed, and be within the affordance ceiling.
pub fn authorize_action(reg: identity::Registry, node: usize) -> Outcome {
    if !reg.is_valid(node) {
        return Outcome::NotFound;
    }
    if !reg.is_exposed(node) {
        return Outcome::NotExposed;
    }
    if !reg.is_agent_actionable(node) {
        return Outcome::NotActionable;
    }
    return Outcome::Allowed;
}

// Authorize a read / navigation (get_text, scroll_to). Requires the node to
// exist and be exposed; the ceiling does not apply (reading/scrolling-to an
// observe-only node is fine — you just cannot act on it).
pub fn authorize_read(reg: identity::Registry, node: usize) -> Outcome {
    if !reg.is_valid(node) {
        return Outcome::NotFound;
    }
    if !reg.is_exposed(node) {
        return Outcome::NotExposed;
    }
    return Outcome::Allowed;
}

// Core-side per-node text version (plan.agent-core.md §5.2). Maintained here, not
// by the backend: `get_text` returns the current version, and `replace_range`
// supplies the version it read so a racing edit is rejected (optimistic
// concurrency) rather than silently clobbering.
pub struct TextVersions {
    v: hash_map::HashMap[usize, u64],
}

pub fn new_text_versions() -> TextVersions {
    return TextVersions { v: hash_map::new::[usize, u64]() };
}

impl TextVersions {
    // A node's current text version (0 until its first edit).
    pub fn version_of(this, node: usize) -> u64 {
        return match this.v.get(node) {
            result::Result[u64, result::IoError]::Ok(x) => x,
            result::Result[u64, result::IoError]::Err(_) => 0 as u64,
        };
    }

    // Bump after a committed write. The consumer calls this once the backend has
    // actually applied the edit.
    pub fn bump(ref this, node: usize) {
        let cur: u64 = this.version_of(node);
        this.v.insert(node, cur +% (1 as u64));
        return;
    }
}

// Authorize a text edit: the node must pass the action checks AND the caller's
// `base_version` must match the current version (else a concurrent change won
// the race). On `Allowed` the consumer applies the edit, then calls
// `versions.bump(node)`.
pub fn authorize_text_write(reg: identity::Registry, versions: TextVersions, node: usize, base_version: u64) -> Outcome {
    let act: Outcome = authorize_action(reg, node);
    if !outcome_eq(act, Outcome::Allowed) {
        return act;
    }
    if base_version != versions.version_of(node) {
        return Outcome::VersionConflict;
    }
    return Outcome::Allowed;
}

// ====================================================================
// Tests
// ====================================================================

// app(0) -> [ btn(1, Button, tagged), field(2, Input, tagged) ]
fn fixture() -> identity::Registry {
    var r: identity::Registry = identity::new();
    let root: usize = r.root();
    let _btn: usize = r.add_child(root, option::Option[str]::Some("btn"), identity::Role::Button);
    let _field: usize = r.add_child(root, option::Option[str]::Some("field"), identity::Role::Input);
    return r;
}

#[test]
fn test_action_allowed_on_exposed_actionable() {
    let r: identity::Registry = fixture();
    assert outcome_eq(authorize_action(r, 1 as usize), Outcome::Allowed);
}

#[test]
fn test_action_not_found_for_bad_handle() {
    let r: identity::Registry = fixture();
    assert outcome_eq(authorize_action(r, 999 as usize), Outcome::NotFound);
}

#[test]
fn test_action_blocked_when_unexposed() {
    var r: identity::Registry = fixture();
    r.set_exposed(1 as usize, false);
    assert outcome_eq(authorize_action(r, 1 as usize), Outcome::NotExposed);
}

#[test]
fn test_action_blocked_by_observe_only_ceiling() {
    var r: identity::Registry = fixture();
    r.set_observe_only(1 as usize);
    assert outcome_eq(authorize_action(r, 1 as usize), Outcome::NotActionable);
}

#[test]
fn test_action_blocked_when_disabled() {
    var r: identity::Registry = fixture();
    r.set_enabled(1 as usize, false);
    assert outcome_eq(authorize_action(r, 1 as usize), Outcome::NotActionable);
}

#[test]
fn test_read_allows_observe_only_but_not_unexposed() {
    var r: identity::Registry = fixture();
    r.set_observe_only(1 as usize);
    // observe-only is still readable / scroll-to-able.
    assert outcome_eq(authorize_read(r, 1 as usize), Outcome::Allowed);
    r.set_exposed(2 as usize, false);
    assert outcome_eq(authorize_read(r, 2 as usize), Outcome::NotExposed);
}

#[test]
fn test_text_version_starts_zero_and_bumps() {
    var tv: TextVersions = new_text_versions();
    assert tv.version_of(2 as usize) == (0 as u64);
    tv.bump(2 as usize);
    assert tv.version_of(2 as usize) == (1 as u64);
    tv.bump(2 as usize);
    assert tv.version_of(2 as usize) == (2 as u64);
}

#[test]
fn test_text_write_optimistic_concurrency() {
    let r: identity::Registry = fixture();
    var tv: TextVersions = new_text_versions();
    // Agent read version 0, edits with base 0 -> allowed.
    assert outcome_eq(authorize_text_write(r, tv, 2 as usize, 0 as u64), Outcome::Allowed);
    // Commit advances the version.
    tv.bump(2 as usize);
    // A second edit still based on 0 lost the race -> conflict.
    assert outcome_eq(authorize_text_write(r, tv, 2 as usize, 0 as u64), Outcome::VersionConflict);
    // Re-read (version 1) succeeds.
    assert outcome_eq(authorize_text_write(r, tv, 2 as usize, 1 as u64), Outcome::Allowed);
}

#[test]
fn test_text_write_gated_by_exposure_before_version() {
    var r: identity::Registry = fixture();
    let tv: TextVersions = new_text_versions();
    r.set_exposed(2 as usize, false);
    // Exposure is checked before the version: a hidden node is NotExposed even
    // with a matching base version.
    assert outcome_eq(authorize_text_write(r, tv, 2 as usize, 0 as u64), Outcome::NotExposed);
}
