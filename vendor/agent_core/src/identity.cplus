// vendor/agent_core/src/identity.cplus
//
// The agent-surface identity / registry layer (plan.agent-core.md §2, §3).
//
// This is the framework-agnostic core: no AppKit, no MCP. It owns the one
// structure every other capability reuses — the agent-id tree — and the rule
// that turns a node into a stable, addressable handle:
//
//   - the developer sets the id; it is auto-generated only when absent (§3);
//   - a fixed-position node's auto-id is `parent/role#index` (stable because the
//     position is stable);
//   - a list item's auto-id is `parent/key`, where the key is the item's data
//     identity, not its position (the React-`key` rule: position shifts on
//     insert, data identity does not);
//   - the root is `app`; windows and dialogs are ordinary children of it.
//
// All auto-ids are derived purely from (parent id, role, sibling index, key) —
// no clock, no randomness — so the same tree yields identical ids across runs
// (the build-time-stable decision in plan.agent.md). `test_deterministic_rebuild`
// guards this.
//
// Storage layout. NodeId is a `usize` index into parallel arrays:
//
//   ids    : Vec[string]  — owns each resolved-id buffer.
//   roles  : Vec[Role]    — Copy per-node role.
//   parents: Vec[Option[usize]] — Copy per-node parent.
//   index  : id bytes -> NodeId (reverse lookup). Keys are `str` views into the
//            `ids` buffers; the map never owns the bytes, so it does not free
//            them on drop. The buffers stay valid for the registry's lifetime
//            because a Vec grow copies the string fat-pointers, not the heap
//            bytes they point at.
//
// The load-bearing ordering rule (learned the hard way): take a `str` view of an
// id only AFTER the owning `string` has been moved into `ids`. Taking the view
// first and then moving the string makes the move-checker still drop the
// original binding, double-freeing the buffer the Vec now owns. So `push_node`
// pushes, then reads the stored copy back via `id_view` (which uses
// `Vec::at(i) -> Option[*string]`, a bounds-checked pointer into live storage);
// the returned `str` aliases the live Vec buffer with no extra free.
//
// `Vec::at` is bounds-checked, but every NodeId accessor still asserts
// `is_valid(node)` first so an out-of-range handle aborts at the API boundary
// with a clear cause rather than surfacing as a `None`.

import "stdlib/vec" as vec;
import "stdlib/option" as option;
import "stdlib/result" as result;
import "stdlib/hash_map" as hash_map;
import "stdlib/text" as text;

extern fn snprintf(s: *u8, size: usize, format: *u8, ...) -> i32;

// The curated role vocabulary (plan.agent-core.md §9). Tiny and fixed; grows
// deliberately as real widgets land.
enum Role {
    Button,
    Text,
    Input,
    List,
    Group,
    Window,
}

// The stable tag a role contributes to an auto-id path segment.
fn role_tag(r: Role) -> str {
    return match r {
        Role::Button => "button",
        Role::Text => "text",
        Role::Input => "input",
        Role::List => "list",
        Role::Group => "group",
        Role::Window => "window",
    };
}

fn role_index(r: Role) -> i32 {
    return match r {
        Role::Button => 0,
        Role::Text => 1,
        Role::Input => 2,
        Role::List => 3,
        Role::Group => 4,
        Role::Window => 5,
    };
}

fn role_eq(a: Role, b: Role) -> bool {
    return role_index(a) == role_index(b);
}

// One node as surfaced by `describe` (plan.agent-core.md §4): the curated view
// the agent consumes. `parent` is the NodeId of the parent (None for the root),
// so the flat list reconstructs the tree. `actionable` is the resolved affordance
// ceiling (enabled AND not observe-only), i.e. whether the agent may act on it.
struct NodeView {
    id: text::Text,
    role: Role,
    name: text::Text,
    parent: option::Option[usize],
    enabled: bool,
    actionable: bool,
}

// `parent/tag#index` as an owned string. snprintf truncates rather than
// overflowing the fixed buffer, so a pathologically deep tree degrades to a
// shorter id rather than corrupting memory.
fn make_path_id(parent: str, tag: str, index: usize) -> text::Text {
    var buf: [u8; 256] = [0u8; 256];
    let n: i32 = unsafe {
        snprintf(#addr_of(buf) as *u8, 256 as usize,
        #str_ptr("%.*s/%.*s#%llu\0"),
        #str_len(parent) as i32, #str_ptr(parent),
        #str_len(tag) as i32, #str_ptr(tag),
        index as u64)
    };
    let view: str = unsafe { #str_from_raw_parts(#addr_of(buf) as *u8, n as usize) };
    return view.to_text();
}

// `parent/key` as an owned string (the list-item form).
fn make_key_id(parent: str, key: u64) -> text::Text {
    var buf: [u8; 256] = [0u8; 256];
    let n: i32 = unsafe {
        snprintf(#addr_of(buf) as *u8, 256 as usize,
        #str_ptr("%.*s/%llu\0"),
        #str_len(parent) as i32, #str_ptr(parent), key)
    };
    let view: str = unsafe { #str_from_raw_parts(#addr_of(buf) as *u8, n as usize) };
    return view.to_text();
}

// Per-node fields beyond identity (plan.agent-core.md §4): the accessible
// `name` (label) and the `state` the agent reads. `enabled` mirrors the widget's
// own enabled/disabled; `actionable` is the affordance ceiling — false means the
// agent may see the node but never act on it (observe-only). Both default true
// and are narrowed via setters. Defaults: name "" (no label yet).
struct Registry {
    ids: vec::Vec[text::Text],
    roles: vec::Vec[Role],
    parents: vec::Vec[option::Option[usize]],
    names: vec::Vec[text::Text],
    enabled: vec::Vec[bool],
    actionable: vec::Vec[bool],
    exposed: vec::Vec[bool],
    index: hash_map::HashMap[str, usize],
    sibling_counts: hash_map::HashMap[usize, usize],
}

// A fresh registry already contains the application root: NodeId 0, id "app",
// role Group. Windows and dialogs attach to it via `add_child`.
fn new() -> Registry {
    var r: Registry = Registry {
        ids: vec::new::[text::Text](),
        roles: vec::new::[Role](),
        parents: vec::new::[option::Option[usize]](),
        names: vec::new::[text::Text](),
        enabled: vec::new::[bool](),
        actionable: vec::new::[bool](),
        exposed: vec::new::[bool](),
        index: hash_map::new::[str, usize](),
        sibling_counts: hash_map::new::[usize, usize](),
    };
    // The app root is always exposed: it is the agent-visible tree's root.
    r.push_node("app".to_text(), Role::Group, option::Option[usize]::None, true);
    return r;
}

impl Registry {
    // The application root (always NodeId 0).
    fn root(this) -> usize {
        return 0 as usize;
    }

    fn len(this) -> usize {
        return this.ids.len();
    }

    fn is_valid(this, node: usize) -> bool {
        return node < this.ids.len();
    }

    // Add a child under `parent`. With a dev-set id, that id is used verbatim;
    // without one, the auto-id is `parent/role#index` at the parent's next
    // sibling slot.
    fn add_child(ref this, parent: usize, dev_id: option::Option[str], role: Role) -> usize {
        assert this.is_valid(parent);
        let idx: usize = this.next_sibling_index(parent);
        // A dev-set id is the developer tagging this node into the agent view
        // (exposure, plan.agent-core.md §3/§6). An auto-id'd node is tracked for
        // tree completeness but not exposed; override with `set_exposed`.
        let tagged: bool = match dev_id {
            option::Option[str]::Some(_) => true,
            option::Option[str]::None => false,
        };
        // The id expression is passed inline, not via `let id = ...; push_node(id)`:
        // moving a named local `string` into a method call double-frees it on a
        // current cpc build, while an inline temporary is consumed correctly.
        return this.push_node(
            match dev_id {
                option::Option[str]::Some(d) => d.to_text(),
                option::Option[str]::None => {
                    let pid: str = this.id_view(parent);
                    make_path_id(pid, role_tag(role), idx)
                }
            },
            role, option::Option[usize]::Some(parent), tagged);
    }

    // Add a list item under `parent`, keyed by its data identity. Without a
    // dev-set id the auto-id is `parent/key`, stable across reorder/insert
    // because `key` is the data id, not the position.
    fn add_item(ref this, parent: usize, dev_id: option::Option[str], role: Role, key: u64) -> usize {
        assert this.is_valid(parent);
        // Consume a sibling slot so a later non-keyed sibling does not collide
        // with an item's implicit position.
        let _idx: usize = this.next_sibling_index(parent);
        let tagged: bool = match dev_id {
            option::Option[str]::Some(_) => true,
            option::Option[str]::None => false,
        };
        // Inline id expression (no `let id = ...`): see add_child for why.
        return this.push_node(
            match dev_id {
                option::Option[str]::Some(d) => d.to_text(),
                option::Option[str]::None => {
                    let pid: str = this.id_view(parent);
                    make_key_id(pid, key)
                }
            },
            role, option::Option[usize]::Some(parent), tagged);
    }

    // The resolved agent-id of a node, as a view into registry-owned storage.
    fn resolved_id(this, node: usize) -> str {
        assert this.is_valid(node);
        return this.id_view(node);
    }

    fn role_of(this, node: usize) -> Role {
        assert this.is_valid(node);
        return match this.roles.at(node) {
            option::Option[*Role]::Some(p) => unsafe { *p },
            option::Option[*Role]::None => Role::Group,
        };
    }

    fn parent_of(this, node: usize) -> option::Option[usize] {
        assert this.is_valid(node);
        return match this.parents.at(node) {
            option::Option[*option::Option[usize]]::Some(p) => unsafe { *p },
            option::Option[*option::Option[usize]]::None => option::Option[usize]::None,
        };
    }

    // --- node state (plan.agent-core.md §4) -----------------------------

    // Set the accessible name (label) the agent reads for this node.
    fn set_name(ref this, node: usize, name: str) {
        assert this.is_valid(node);
        this.names.set(node, name.to_text());
        return;
    }

    // The accessible name, as a view into registry-owned storage ("" if unset).
    fn name_of(this, node: usize) -> str {
        assert this.is_valid(node);
        return match this.names.at(node) {
            option::Option[*text::Text]::Some(p) => unsafe { (*p).as_str() },
            option::Option[*text::Text]::None => "",
        };
    }

    fn set_enabled(ref this, node: usize, on: bool) {
        assert this.is_valid(node);
        this.enabled.set(node, on);
        return;
    }

    fn is_enabled(this, node: usize) -> bool {
        assert this.is_valid(node);
        return match this.enabled.at(node) {
            option::Option[*bool]::Some(p) => unsafe { *p },
            option::Option[*bool]::None => false,
        };
    }

    // Narrow the affordance ceiling: the agent may see this node but never act
    // on it. The widget stays interactive for the user; only the agent is barred.
    fn set_observe_only(ref this, node: usize) {
        assert this.is_valid(node);
        this.actionable.set(node, false);
        return;
    }

    // Whether the agent may act on this node (the affordance ceiling). A node is
    // agent-actionable only if it is both enabled and not observe-only.
    fn is_agent_actionable(this, node: usize) -> bool {
        assert this.is_valid(node);
        let ceiling: bool = match this.actionable.at(node) {
            option::Option[*bool]::Some(p) => unsafe { *p },
            option::Option[*bool]::None => false,
        };
        return ceiling && this.is_enabled(node);
    }

    // --- exposure (plan.agent-core.md §6, layer 1) ----------------------

    // Whether this node is in the agent-visible tree. Default: dev-tagged nodes
    // are exposed, auto-id'd nodes are not (the root is always exposed).
    fn is_exposed(this, node: usize) -> bool {
        assert this.is_valid(node);
        return match this.exposed.at(node) {
            option::Option[*bool]::Some(p) => unsafe { *p },
            option::Option[*bool]::None => false,
        };
    }

    // Override exposure: opt an auto-id'd node in (e.g. list rows), or hide a
    // tagged one. Omission is still the strongest sensitivity control.
    fn set_exposed(ref this, node: usize, on: bool) {
        assert this.is_valid(node);
        this.exposed.set(node, on);
        return;
    }

    // The curated UI description (plan.agent-core.md §4, §5.1): the agent-visible
    // tree. Only exposed nodes appear; each node's `parent` is its nearest
    // exposed ancestor, so unexposed intermediates collapse and the tree stays
    // connected. NodeId order means parents precede children.
    fn describe(this) -> vec::Vec[NodeView] {
        var out: vec::Vec[NodeView] = vec::new::[NodeView]();
        let n: usize = this.ids.len();
        var i: usize = 0 as usize;
        while i < n {
            if this.is_exposed(i) {
                out.push(NodeView {
                    id: this.id_view(i).to_text(),
                    role: this.role_of(i),
                    name: this.name_of(i).to_text(),
                    parent: this.nearest_exposed_ancestor(i),
                    enabled: this.is_enabled(i),
                    actionable: this.is_agent_actionable(i),
                });
            }
            i = i +% (1 as usize);
        }
        return out;
    }

    // Resolve an agent-id to its NodeId, or None if no node carries it.
    fn lookup(this, id: str) -> option::Option[usize] {
        return match this.index.get(id) {
            result::Result[usize, result::IoError]::Ok(n) => option::Option[usize]::Some(n),
            result::Result[usize, result::IoError]::Err(_) => option::Option[usize]::None,
        };
    }

    fn contains(this, id: str) -> bool {
        return this.index.contains_key(id);
    }

    // --- internal -------------------------------------------------------

    // View node's resolved id as a `str` into registry-owned storage. Reads the
    // non-Copy `string` element through `at` (a bounds-checked pointer); the
    // deref is safe because callers `assert is_valid`/just pushed, and the
    // returned view aliases the live buffer the Vec still owns.
    fn id_view(this, node: usize) -> str {
        return match this.ids.at(node) {
            option::Option[*text::Text]::Some(p) => unsafe { (*p).as_str() },
            option::Option[*text::Text]::None => "",
        };
    }

    // Append a node, registering its id in the reverse index. Move the owning
    // string into `ids` FIRST, then take the index key as a view of the stored
    // copy (`id_view`). Taking the view before the move would double-free on
    // drop (see the ordering rule at the top of this file).
    fn push_node(ref this, take id: text::Text, role: Role, parent: option::Option[usize], exposed: bool) -> usize {
        let node_id: usize = this.ids.len();
        this.ids.push(id);
        this.index.insert(this.id_view(node_id), node_id);
        this.roles.push(role);
        this.parents.push(parent);
        this.names.push("".to_text());
        this.enabled.push(true);
        this.actionable.push(true);
        this.exposed.push(exposed);
        return node_id;
    }

    // Walk up to the nearest exposed ancestor (the agent-visible parent). Returns
    // None only for the root. The root is always exposed, so this terminates.
    fn nearest_exposed_ancestor(this, node: usize) -> option::Option[usize] {
        var cur: option::Option[usize] = this.parent_of(node);
        loop {
            match cur {
                option::Option[usize]::Some(p) => {
                    if this.is_exposed(p) {
                        return option::Option[usize]::Some(p);
                    }
                    cur = this.parent_of(p);
                }
                option::Option[usize]::None => {
                    return option::Option[usize]::None;
                }
            }
        }
        return option::Option[usize]::None;
    }

    fn next_sibling_index(ref this, parent: usize) -> usize {
        let cur: usize = match this.sibling_counts.get(parent) {
            result::Result[usize, result::IoError]::Ok(x) => x,
            result::Result[usize, result::IoError]::Err(_) => 0 as usize,
        };
        this.sibling_counts.insert(parent, cur +% (1 as usize));
        return cur;
    }
}

// ====================================================================
// Tests
// ====================================================================

fn none_str() -> option::Option[str] {
    return option::Option[str]::None;
}

#[test]
fn test_root_exists() {
    let r: Registry = new();
    assert r.len() == (1 as usize);
    assert r.root() == (0 as usize);
    assert r.contains("app");
    assert r.resolved_id(r.root()) == "app";
    assert role_eq(r.role_of(r.root()), Role::Group);
}

#[test]
fn test_dev_id_wins() {
    var r: Registry = new();
    let root: usize = r.root();
    let btn: usize = r.add_child(root, option::Option[str]::Some("btn_login"), Role::Button);
    assert r.resolved_id(btn) == "btn_login";
    assert r.contains("btn_login");
    let found: usize = match r.lookup("btn_login") {
        option::Option[usize]::Some(n) => n,
        option::Option[usize]::None => 999 as usize,
    };
    assert found == btn;
}

#[test]
fn test_auto_id_fixed_position() {
    var r: Registry = new();
    let root: usize = r.root();
    let b0: usize = r.add_child(root, none_str(), Role::Button);
    let b1: usize = r.add_child(root, none_str(), Role::Button);
    assert r.resolved_id(b0) == "app/button#0";
    assert r.resolved_id(b1) == "app/button#1";
}

#[test]
fn test_auto_id_distinct_roles() {
    var r: Registry = new();
    let root: usize = r.root();
    let b: usize = r.add_child(root, none_str(), Role::Button);
    let t: usize = r.add_child(root, none_str(), Role::Text);
    // The role tag keeps siblings distinct even off a shared index counter.
    assert (r.resolved_id(b) == r.resolved_id(t)) == false;
    assert r.resolved_id(b) == "app/button#0";
    assert r.resolved_id(t) == "app/text#1";
}

#[test]
fn test_nested_path() {
    var r: Registry = new();
    let root: usize = r.root();
    let g: usize = r.add_child(root, none_str(), Role::Group);
    let b: usize = r.add_child(g, none_str(), Role::Button);
    assert r.resolved_id(g) == "app/group#0";
    assert r.resolved_id(b) == "app/group#0/button#0";
}

#[test]
fn test_keyed_item_id() {
    var r: Registry = new();
    let root: usize = r.root();
    let list: usize = r.add_child(root, option::Option[str]::Some("todo_list"), Role::List);
    let item: usize = r.add_item(list, none_str(), Role::Group, 42 as u64);
    assert r.resolved_id(list) == "todo_list";
    assert r.resolved_id(item) == "todo_list/42";
    assert r.contains("todo_list/42");
}

#[test]
fn test_keyed_items_distinct_and_addressable() {
    var r: Registry = new();
    let root: usize = r.root();
    let list: usize = r.add_child(root, option::Option[str]::Some("list"), Role::List);
    let a: usize = r.add_item(list, none_str(), Role::Group, 1 as u64);
    let b: usize = r.add_item(list, none_str(), Role::Group, 2 as u64);
    assert r.resolved_id(a) == "list/1";
    assert r.resolved_id(b) == "list/2";
    let fa: usize = match r.lookup("list/1") {
        option::Option[usize]::Some(n) => n, option::Option[usize]::None => 999 as usize,
    };
    let fb: usize = match r.lookup("list/2") {
        option::Option[usize]::Some(n) => n, option::Option[usize]::None => 999 as usize,
    };
    assert fa == a;
    assert fb == b;
}

#[test]
fn test_role_and_parent_recorded() {
    var r: Registry = new();
    let root: usize = r.root();
    let b: usize = r.add_child(root, none_str(), Role::Button);
    assert role_eq(r.role_of(b), Role::Button);
    let p: usize = match r.parent_of(b) {
        option::Option[usize]::Some(n) => n, option::Option[usize]::None => 999 as usize,
    };
    assert p == root;
    // The root has no parent.
    let root_has_parent: bool = match r.parent_of(root) {
        option::Option[usize]::Some(_) => true, option::Option[usize]::None => false,
    };
    assert root_has_parent == false;
}

// Negative coverage: a miss yields None, not a wrong node, not a crash.
#[test]
fn test_lookup_miss_returns_none() {
    let r: Registry = new();
    assert (r.contains("nope")) == false;
    let missed: bool = match r.lookup("does/not/exist") {
        option::Option[usize]::Some(_) => false,
        option::Option[usize]::None => true,
    };
    assert missed;
}

// Negative coverage: is_valid rejects an out-of-range handle, so callers can
// pre-check before hitting an accessor's bounds assert.
#[test]
fn test_is_valid_rejects_out_of_range() {
    let r: Registry = new();
    assert r.is_valid(0 as usize);
    assert (r.is_valid(1 as usize)) == false;
    assert (r.is_valid(9999 as usize)) == false;
}

// Build-time stability: the same tree, built twice, yields identical ids. This
// is the load-bearing guarantee that lets an agent's saved handles survive a
// restart.
#[test]
fn test_deterministic_rebuild() {
    var r1: Registry = new();
    let root1: usize = r1.root();
    let g1: usize = r1.add_child(root1, none_str(), Role::Group);
    let _b1: usize = r1.add_child(g1, none_str(), Role::Button);
    let l1: usize = r1.add_child(root1, option::Option[str]::Some("items"), Role::List);
    let i1: usize = r1.add_item(l1, none_str(), Role::Group, 7 as u64);

    var r2: Registry = new();
    let root2: usize = r2.root();
    let g2: usize = r2.add_child(root2, none_str(), Role::Group);
    let _b2: usize = r2.add_child(g2, none_str(), Role::Button);
    let l2: usize = r2.add_child(root2, option::Option[str]::Some("items"), Role::List);
    let i2: usize = r2.add_item(l2, none_str(), Role::Group, 7 as u64);

    assert r1.resolved_id(g1) == r2.resolved_id(g2);
    assert r1.resolved_id(l1) == r2.resolved_id(l2);
    assert r1.resolved_id(i1) == r2.resolved_id(i2);
    assert r1.len() == r2.len();
}

// Memory safety: a populated registry drops cleanly (Vec[string] frees each id
// once; views and the reverse index hold non-owning copies). ASan in `cpc test`
// catches a double free or leak here.
#[test]
fn test_drop_no_double_free() {
    var r: Registry = new();
    let root: usize = r.root();
    var i: usize = 0 as usize;
    while i < (32 as usize) {
        let _c: usize = r.add_child(root, none_str(), Role::Button);
        i = i +% (1 as usize);
    }
    assert r.len() == (33 as usize);
    // r drops at scope exit.
}

// --- node state + describe (slice 2) ---------------------------------

#[test]
fn test_name_defaults_empty_and_sets() {
    var r: Registry = new();
    let root: usize = r.root();
    let b: usize = r.add_child(root, option::Option[str]::Some("btn"), Role::Button);
    assert #str_len(r.name_of(b)) == (0 as usize);
    r.set_name(b, "Log In");
    assert r.name_of(b) == "Log In";
    // overwrite frees the old name buffer (ASan would catch a leak/double free).
    r.set_name(b, "Sign In");
    assert r.name_of(b) == "Sign In";
}

#[test]
fn test_state_defaults_and_ceiling() {
    var r: Registry = new();
    let root: usize = r.root();
    let b: usize = r.add_child(root, option::Option[str]::Some("btn"), Role::Button);
    // Defaults: enabled and agent-actionable.
    assert r.is_enabled(b);
    assert r.is_agent_actionable(b);
    // observe-only narrows the ceiling but leaves the widget enabled.
    r.set_observe_only(b);
    assert r.is_enabled(b);
    assert (r.is_agent_actionable(b)) == false;
}

#[test]
fn test_disabled_is_not_actionable() {
    var r: Registry = new();
    let root: usize = r.root();
    let b: usize = r.add_child(root, option::Option[str]::Some("btn"), Role::Button);
    r.set_enabled(b, false);
    assert (r.is_enabled(b)) == false;
    // A disabled node is never agent-actionable, even though not observe-only.
    assert (r.is_agent_actionable(b)) == false;
}

#[test]
fn test_describe_lists_every_node_with_fields() {
    var r: Registry = new();
    let root: usize = r.root();
    let btn: usize = r.add_child(root, option::Option[str]::Some("btn_login"), Role::Button);
    r.set_name(btn, "Log In");
    let v: vec::Vec[NodeView] = r.describe();
    assert v.len() == r.len();
    // NodeId order: index 0 = app root, index `btn` = the button.
    match v.at(btn) {
        option::Option[*NodeView]::Some(p) => {
            assert unsafe { (*p).id.as_str() } == "btn_login";
            assert role_eq(unsafe { (*p).role }, Role::Button);
            assert unsafe { (*p).name.as_str() } == "Log In";
            assert unsafe { (*p).actionable };
            let parent: usize = match unsafe { (*p).parent } {
                option::Option[usize]::Some(x) => x,
                option::Option[usize]::None => 999 as usize,
            };
            assert parent == root;
        }
        option::Option[*NodeView]::None => { assert false; }
    }
    return;
}

#[test]
fn test_describe_reflects_ceiling() {
    var r: Registry = new();
    let root: usize = r.root();
    let b: usize = r.add_child(root, option::Option[str]::Some("danger"), Role::Button);
    r.set_observe_only(b);
    let v: vec::Vec[NodeView] = r.describe();
    match v.at(b) {
        option::Option[*NodeView]::Some(p) => {
            assert unsafe { (*p).enabled };
            assert (unsafe { (*p).actionable }) == false;
        }
        option::Option[*NodeView]::None => { assert false; }
    }
    return;
}

// Memory safety: describe() returns a Vec[NodeView] that owns two strings per
// node; it must drop each exactly once.
#[test]
fn test_describe_drop_no_double_free() {
    var r: Registry = new();
    let root: usize = r.root();
    var i: usize = 0 as usize;
    while i < (16 as usize) {
        let c: usize = r.add_child(root, none_str(), Role::Text);
        r.set_name(c, "row");
        r.set_exposed(c, true);
        i = i +% (1 as usize);
    }
    let v: vec::Vec[NodeView] = r.describe();
    assert v.len() == (17 as usize);
    // v and r both drop at scope exit; no buffer freed twice.
}

// --- exposure / curation (auth layer 1) ------------------------------

#[test]
fn test_tagged_exposed_auto_hidden() {
    var r: Registry = new();
    let root: usize = r.root();
    let tagged: usize = r.add_child(root, option::Option[str]::Some("btn"), Role::Button);
    let auto: usize = r.add_child(root, none_str(), Role::Group);
    assert r.is_exposed(root);
    assert r.is_exposed(tagged);
    assert (r.is_exposed(auto)) == false;
}

#[test]
fn test_describe_prunes_unexposed_and_reparents() {
    var r: Registry = new();
    let root: usize = r.root();
    // root -> group (auto, hidden) -> btn (tagged, exposed)
    let group: usize = r.add_child(root, none_str(), Role::Group);
    let btn: usize = r.add_child(group, option::Option[str]::Some("btn"), Role::Button);
    let v: vec::Vec[NodeView] = r.describe();
    // Only root + btn are visible; the auto group is pruned.
    assert v.len() == (2 as usize);
    // btn re-parents to the nearest exposed ancestor (root), not the hidden group.
    var found_btn: bool = false;
    var i: usize = 0 as usize;
    while i < v.len() {
        match v.at(i) {
            option::Option[*NodeView]::Some(p) => {
                if unsafe { (*p).id.as_str() } == "btn" {
                    found_btn = true;
                    let parent: usize = match unsafe { (*p).parent } {
                        option::Option[usize]::Some(x) => x,
                        option::Option[usize]::None => 999 as usize,
                    };
                    assert parent == root;
                }
            }
            option::Option[*NodeView]::None => { assert false; }
        }
        i = i +% (1 as usize);
    }
    assert found_btn;
}

#[test]
fn test_set_exposed_opts_auto_node_in() {
    var r: Registry = new();
    let root: usize = r.root();
    let list: usize = r.add_child(root, option::Option[str]::Some("list"), Role::List);
    let row: usize = r.add_item(list, none_str(), Role::Group, 7 as u64);
    assert (r.is_exposed(row)) == false;
    r.set_exposed(row, true);
    assert r.is_exposed(row);
    // describe now includes root + list + row.
    let v: vec::Vec[NodeView] = r.describe();
    assert v.len() == (3 as usize);
}

#[test]
fn test_set_exposed_can_hide_tagged_node() {
    var r: Registry = new();
    let root: usize = r.root();
    let secret: usize = r.add_child(root, option::Option[str]::Some("secret"), Role::Text);
    assert r.is_exposed(secret);
    r.set_exposed(secret, false);
    let v: vec::Vec[NodeView] = r.describe();
    // Only the root remains visible.
    assert v.len() == (1 as usize);
}
