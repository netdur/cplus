// Proof harness: tests cpc-bindgen-GENERATED Foundation bindings (NSScanner)
// against the live framework — exercises BOOL <-> bool (get + set).

import "./scanner" as scanner;
import "./timezone" as timezone;
import "./date" as date;
import "stdlib/vec" as vec;
import "stdlib/text" as text;
import "stdlib/option" as option;

#[test]
fn generated_scanner_bool_roundtrip() {
    let s: scanner::Scanner = scanner::Scanner::new("123");
    s.set_case_sensitive(true);
    assert s.case_sensitive() == true;
    s.set_case_sensitive(false);
    assert s.case_sensitive() == false;
    return;
}

// `isAtEnd` lives in the NSExtendedScanner *category* — exercises that category
// methods are merged into the class's impl.
#[test]
fn generated_scanner_category_is_at_end() {
    let empty: scanner::Scanner = scanner::Scanner::new("");
    assert empty.is_at_end() == true;
    let nonempty: scanner::Scanner = scanner::Scanner::new("abc");
    assert nonempty.is_at_end() == false;
    return;
}

// NSArray<NSString *> -> Vec[Text]: knownTimeZoneNames is a class property (in
// the NSExtendedTimeZone category) returning hundreds of zone-name strings.
#[test]
fn generated_timezone_string_array() {
    let names: vec::Vec[text::Text] = timezone::TimeZone::known_time_zone_names();
    assert names.count() > (100 as usize);
    return;
}

// Float/double scalars (params + returns): +dateWithTimeIntervalSince1970:
// takes an f64, -timeIntervalSince1970 returns one. Round-trip 1000.0s.
#[test]
fn generated_date_f64_roundtrip() {
    let d: date::Date = date::Date::date_with_time_interval_since1970(1000.0 as f64);
    let secs: f64 = d.time_interval_since1970();
    assert secs > (999.5 as f64);
    assert secs < (1000.5 as f64);
    return;
}

// Nullable factory -> Option[Self]: +timeZoneWithName: returns a wrapped
// TimeZone for a real zone, None for a bogus name.
#[test]
fn generated_timezone_nullable_factory() {
    match timezone::TimeZone::time_zone_with_name("America/New_York") {
        option::Option[timezone::TimeZone]::Some(tz) => { assert true; }
        option::Option[timezone::TimeZone]::None => { assert false; }
    }
    match timezone::TimeZone::time_zone_with_name("Bogus/Nonsense-Zone") {
        option::Option[timezone::TimeZone]::Some(tz) => { assert false; }
        option::Option[timezone::TimeZone]::None => { assert true; }
    }
    return;
}

// Factory-returns-Self: scannerWithString: is a class factory returning the
// class's own type, so it yields a wrapped Scanner (not a raw handle).
#[test]
fn generated_scanner_factory_returns_self() {
    let sc: scanner::Scanner = scanner::Scanner::scanner_with_string("");
    assert sc.is_at_end() == true;
    return;
}
