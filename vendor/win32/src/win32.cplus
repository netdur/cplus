// Umbrella facade for the native Win32 bindings — import this for the flat
// type surface (`win32::Window`, `win32::Button`, …), or import the narrower
// modules directly (`import "win32/controls" as controls;`). Mirrors appkit's
// `appkit.cplus` and gtk's `gtk.cplus`.
//
// The Windows GUI backend: direct `extern fn` calls to user32/gdi32/comctl32/
// comdlg32 — all shipped with Windows, on the linker's default search path, so
// nothing needs installing. See README.md.

import "./core" as core;
import "./window" as window;
import "./controls" as controls;
import "./menu" as menu;
import "./dialogs" as dialogs;
import "./graphics" as graphics;

type Window = window::Window;

type Button = controls::Button;
type Label = controls::Label;
type Edit = controls::Edit;
type CheckBox = controls::CheckBox;
type RadioButton = controls::RadioButton;
type ComboBox = controls::ComboBox;
type ListBox = controls::ListBox;
type ProgressBar = controls::ProgressBar;
type TrackBar = controls::TrackBar;
type GroupBox = controls::GroupBox;

type Menu = menu::Menu;

type Painter = graphics::Painter;
type Color = graphics::Color;

// Message box button-set / result constants live on `dialogs`.

// Run the application message loop until the window closes. Returns the
// WM_QUIT code. The appkit/gtk `app.run()` analogue.
fn run() -> i32 { return core::run(); }

// Pop a modal message box (delegates to `dialogs::message_box`).
fn message_box(parent: *u8, text: *u8, caption: *u8) -> i32 {
    return dialogs::message_box(parent, text, caption);
}
