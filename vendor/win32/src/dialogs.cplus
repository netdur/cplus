// win32/dialogs.cplus — modal dialogs (the gtk `dialogs` analogue).
//
// `message_box` is the AlertDialog analogue (user32 MessageBoxA). `open_file`
// / `save_file` are the FileDialog analogue (comdlg32 common dialogs); they
// fill a caller-provided buffer with the chosen path and return whether the
// user confirmed. File dialogs are modal and interactive, so they are not
// exercised by the headless test suite.

import "./core" as core;

#[link_name = "MessageBoxA"]
extern fn MessageBoxA(hwnd: *u8, text: *u8, caption: *u8, ty: u32) -> i32;
#[link_name = "GetOpenFileNameA"]
extern fn GetOpenFileNameA(ofn: *u8) -> i32;
#[link_name = "GetSaveFileNameA"]
extern fn GetSaveFileNameA(ofn: *u8) -> i32;

extern fn malloc(n: usize) -> *u8;
extern fn free(p: *u8);
extern fn memset(p: *u8, c: i32, n: usize) -> *u8;

// MessageBox button sets.
fn mb_ok() -> u32 { return 0x0000 as u32; }
fn mb_okcancel() -> u32 { return 0x0001 as u32; }
fn mb_yesno() -> u32 { return 0x0004 as u32; }
fn mb_yesnocancel() -> u32 { return 0x0003 as u32; }
// MessageBox icons.
fn mb_iconinformation() -> u32 { return 0x0040 as u32; }
fn mb_iconwarning() -> u32 { return 0x0030 as u32; }
fn mb_iconerror() -> u32 { return 0x0010 as u32; }
fn mb_iconquestion() -> u32 { return 0x0020 as u32; }
// MessageBox results.
fn id_ok() -> i32 { return 1 as i32; }
fn id_cancel() -> i32 { return 2 as i32; }
fn id_yes() -> i32 { return 6 as i32; }
fn id_no() -> i32 { return 7 as i32; }

// A plain OK message box. Returns id_ok.
fn message_box(parent: *u8, text: *u8, caption: *u8) -> i32 {
    return { MessageBoxA(parent, text, caption, mb_ok()) };
}

// A message box with an explicit button-set / icon `ty` (OR the mb_* consts).
// Returns the pressed-button id (id_ok / id_cancel / id_yes / id_no).
fn message_box_ex(parent: *u8, text: *u8, caption: *u8, ty: u32) -> i32 {
    return { MessageBoxA(parent, text, caption, ty) };
}

// OPENFILENAMEA is 152 bytes on x64. We set the minimal fields: size, owner,
// filter, the file buffer + its capacity, and the standard flags.
fn ofn_bytes() -> usize { return 152 as usize; }
fn ofn_file_must_exist() -> u32 { return 0x00001000 as u32; }
fn ofn_path_must_exist() -> u32 { return 0x00000800 as u32; }
fn ofn_explorer() -> u32 { return 0x00080000 as u32; }
fn ofn_overwrite_prompt() -> u32 { return 0x00000002 as u32; }

fn build_ofn(parent: *u8, filter: *u8, buf: *u8, max: i32, flags: u32) -> *u8 {
    let ofn: *u8 = { malloc(ofn_bytes()) };
    { memset(ofn, 0 as i32, ofn_bytes()); }
    { *((ofn + (0 as usize)) as *u32) = ofn_bytes() as u32; }   // lStructSize
    { *((ofn + (8 as usize)) as **u8) = parent; }               // hwndOwner
    { *((ofn + (24 as usize)) as **u8) = filter; }              // lpstrFilter
    { *((ofn + (48 as usize)) as **u8) = buf; }                 // lpstrFile
    { *((ofn + (56 as usize)) as *u32) = max as u32; }          // nMaxFile
    { *((ofn + (96 as usize)) as *u32) = flags; }               // Flags
    return ofn;
}

// Show the open-file dialog. `filter` is a double-NUL-terminated pair list
// (e.g. "Text\0*.txt\0All\0*.*\0\0"); `buf`/`max` receive the chosen path.
// Returns true if the user confirmed a file.
fn open_file(parent: *u8, filter: *u8, buf: *u8, max: i32) -> bool {
    { *buf = 0 as u8; }
    let flags: u32 = ofn_file_must_exist()|ofn_path_must_exist()|ofn_explorer();
    let ofn: *u8 = build_ofn(parent, filter, buf, max, flags);
    let ok: i32 = { GetOpenFileNameA(ofn) };
    { free(ofn); }
    return ok != (0 as i32);
}

// Show the save-file dialog. Same buffer contract as `open_file`.
fn save_file(parent: *u8, filter: *u8, buf: *u8, max: i32) -> bool {
    { *buf = 0 as u8; }
    let flags: u32 = ofn_path_must_exist()|ofn_explorer()|ofn_overwrite_prompt();
    let ofn: *u8 = build_ofn(parent, filter, buf, max, flags);
    let ok: i32 = { GetSaveFileNameA(ofn) };
    { free(ofn); }
    return ok != (0 as i32);
}
