#[link_name = "InitCommonControlsEx"]
extern fn InitCommonControlsEx(icc: *u8) -> i32;
#[link_name = "GetWindowLongPtrA"]
extern fn GetWindowLongPtrA(hwnd: *u8, idx: i32) -> i64;

// ---- callback shapes ----
// Command handler (button click, menu item, …): (sender_hwnd, user_data).
// Paint handler: (window_hwnd, hdc). Close handler: (window_hwnd, user_data).
// These mirror gtk's `fn(*u8, *u8)` signal handlers.

// One registered command id -> handler row.
#[repr(C)]
struct CmdEntry {
    id: u32,
    cb: fn(*u8, *u8),
    opaque user: *u8,
}

// Per-window dispatch table. `next_id` hands out unique control ids starting
// at 100 (below the common-dialog reserved range). The paint/close handlers
// are gated by their `has_*` flags; their fn fields hold a no-op until set.
#[repr(C)]
struct Dispatch {
    count: i32,
    cap: i32,
    next_id: i32,
    has_paint: i32,
    has_close: i32,
    opaque entries: *u8,
    paint_cb: fn(*u8, *u8),
    opaque paint_user: *u8,
    close_cb: fn(*u8, *u8),
    opaque close_user: *u8,
}

fn dispatch_bytes() -> usize { return 80 as usize; }
fn cmdentry_bytes() -> usize { return 24 as usize; }

// ---- constants ----
fn ws_overlappedwindow() -> u32 { return 0x00CF0000 as u32; }
fn ws_child() -> u32 { return 0x40000000 as u32; }
fn ws_visible() -> u32 { return 0x10000000 as u32; }
fn ws_child_visible() -> u32 { return 0x50000000 as u32; }
fn ws_tabstop() -> u32 { return 0x00010000 as u32; }
fn ws_border() -> u32 { return 0x00800000 as u32; }
fn cw_usedefault() -> i32 { return (0x80000000 as u32) as i32; }
fn sw_show() -> i32 { return 5 as i32; }
fn idc_arrow() -> *u8 { return 32512 as *u8; }
fn color_window_brush() -> *u8 { return 6 as *u8; }

fn wm_destroy() -> u32 { return 0x0002 as u32; }
fn wm_close() -> u32 { return 0x0010 as u32; }
fn wm_command() -> u32 { return 0x0111 as u32; }
fn wm_paint() -> u32 { return 0x000F as u32; }
fn wm_timer() -> u32 { return 0x0113 as u32; }

fn close_timer_id() -> usize { return 0xC105E as usize; }
fn window_class_name() -> *u8 { return { #str_ptr("CplusWin32Window\0") }; }
fn prop_name() -> *u8 { return { #str_ptr("CplusWin32Disp\0") }; }

fn ptr_is_null(p: *u8) -> bool {
    let null_p: *u8 = { 0 as *u8 };
    return p == null_p;
}

// No-op handler stored in the paint/close slots until a real one is set.
fn noop_handler(a: *u8, b: *u8) {
    return;
}

// Allocate + initialize a dispatch table for a freshly created window.
fn make_dispatch() -> *u8 {
    let raw: *u8 = { malloc(dispatch_bytes()) };
    { memset(raw, 0 as i32, dispatch_bytes()); }
    let d: *Dispatch = { raw as *Dispatch };
    { (*d).count = 0 as i32; }
    { (*d).cap = 8 as i32; }
    { (*d).next_id = 100 as i32; }
    { (*d).has_paint = 0 as i32; }
    { (*d).has_close = 0 as i32; }
    { (*d).entries = { malloc(cmdentry_bytes() *% (8 as usize)) }; }
    { (*d).paint_cb = noop_handler; }
    { (*d).close_cb = noop_handler; }
    return raw;
}

fn get_dispatch(hwnd: *u8) -> *u8 {
    return { GetPropA(hwnd, prop_name()) };
}

// Reserve a fresh control id in `hwnd`'s table (does not register a handler).
fn alloc_command_id(hwnd: *u8) -> u32 {
    let p: *u8 = get_dispatch(hwnd);
    if ptr_is_null(p) { return 0 as u32; }
    let d: *Dispatch = { p as *Dispatch };
    let id: i32 = { (*d).next_id };
    { (*d).next_id = id +% (1 as i32); }
    return id as u32;
}

// Bind `cb`/`user` to command id `id` in `hwnd`'s table (grows it as needed).
fn set_command(hwnd: *u8, id: u32, cb: fn(*u8, *u8), user: *u8) {
    let p: *u8 = get_dispatch(hwnd);
    if ptr_is_null(p) { return; }
    let d: *Dispatch = { p as *Dispatch };
    var n: i32 = { (*d).count };
    var cap: i32 = { (*d).cap };
    if n == cap {
        cap = cap *% (2 as i32);
        let grown: *u8 = { realloc({ (*d).entries }, cmdentry_bytes() *% (cap as usize)) };
        { (*d).entries = grown; }
        { (*d).cap = cap; }
    }
    let arr: *CmdEntry = { { (*d).entries } as *CmdEntry };
    let e: *CmdEntry = { arr + (n as usize) };
    { (*e).id = id; }
    { (*e).cb = cb; }
    { (*e).user = user; }
    { (*d).count = n +% (1 as i32); }
    return;
}

// Register a window-level close handler (fired on WM_CLOSE before destroy).
fn set_close_handler(hwnd: *u8, cb: fn(*u8, *u8), user: *u8) {
    let p: *u8 = get_dispatch(hwnd);
    if ptr_is_null(p) { return; }
    let d: *Dispatch = { p as *Dispatch };
    { (*d).close_cb = cb; }
    { (*d).close_user = user; }
    { (*d).has_close = 1 as i32; }
    return;
}

// Register a paint handler (fired inside WM_PAINT with the device context).
fn set_paint_handler(hwnd: *u8, cb: fn(*u8, *u8), user: *u8) {
    let p: *u8 = get_dispatch(hwnd);
    if ptr_is_null(p) { return; }
    let d: *Dispatch = { p as *Dispatch };
    { (*d).paint_cb = cb; }
    { (*d).paint_user = user; }
    { (*d).has_paint = 1 as i32; }
    return;
}

// The single window procedure for every win32::Window. Routes commands and
// paints to the window's dispatch table; falls back to DefWindowProcA.
fn win_proc(hwnd: *u8, msg: u32, w: u64, l: i64) -> i64 {
    if msg == wm_destroy() {
        { PostQuitMessage(0 as i32); }
        return 0 as i64;
    }
    let p: *u8 = { GetPropA(hwnd, prop_name()) };
    if ptr_is_null(p) {
        return { DefWindowProcA(hwnd, msg, w, l) };
    }
    let d: *Dispatch = { p as *Dispatch };
    if msg == wm_command() {
        let id: u32 = (w & (0xFFFF as u64)) as u32;
        let n: i32 = { (*d).count };
        let arr: *CmdEntry = { { (*d).entries } as *CmdEntry };
        var i: i32 = 0;
        while i < n {
            let e: *CmdEntry = { arr + (i as usize) };
            if { (*e).id } == id {
                let f: fn(*u8, *u8) = { (*e).cb };
                let u: *u8 = { (*e).user };
                f(l as *u8, u);
                return 0 as i64;
            }
            i = i +% (1 as i32);
        }
        return { DefWindowProcA(hwnd, msg, w, l) };
    }
    if msg == wm_close() {
        if { (*d).has_close } == (1 as i32) {
            let f: fn(*u8, *u8) = { (*d).close_cb };
            let u: *u8 = { (*d).close_user };
            f(hwnd, u);
        }
        { DestroyWindow(hwnd); }
        return 0 as i64;
    }
    if msg == wm_paint() {
        if { (*d).has_paint } == (1 as i32) {
            let ps: *u8 = { malloc(72 as usize) };
            let hdc: *u8 = { BeginPaint(hwnd, ps) };
            let f: fn(*u8, *u8) = { (*d).paint_cb };
            f(hwnd, hdc);
            { EndPaint(hwnd, ps); }
            { free(ps); }
            return 0 as i64;
        }
        return { DefWindowProcA(hwnd, msg, w, l) };
    }
    if msg == wm_timer() {
        if w == (close_timer_id() as u64) {
            { KillTimer(hwnd, close_timer_id()); }
            { DestroyWindow(hwnd); }
            return 0 as i64;
        }
    }
    return { DefWindowProcA(hwnd, msg, w, l) };
}

// ---- WNDCLASSEXA (80 bytes; `fn`-typed wndproc field) ----
#[repr(C)]
struct WndClassExA {
    cbSize: u32,
    style: u32,
    lpfnWndProc: fn(*u8, u32, u64, i64) -> i64,
    cbClsExtra: i32,
    cbWndExtra: i32,
    opaque hInstance: *u8,
    opaque hIcon: *u8,
    opaque hCursor: *u8,
    opaque hbrBackground: *u8,
    opaque lpszMenuName: *u8,
    opaque lpszClassName: *u8,
    opaque hIconSm: *u8,
}

// Register the shared window class (a second call for the same name is a
// harmless no-op — RegisterClassExA returns 0, which we ignore).
fn register_window_class(hinst: *u8) {
    let raw: *u8 = { malloc(80 as usize) };
    { memset(raw, 0 as i32, 80 as usize); }
    let wc: *WndClassExA = { raw as *WndClassExA };
    { (*wc).cbSize = 80 as u32; }
    { (*wc).style = 0x0003 as u32; }
    { (*wc).lpfnWndProc = win_proc; }
    { (*wc).hInstance = hinst; }
    { (*wc).hCursor = { LoadCursorA(0 as *u8, idc_arrow()) }; }
    { (*wc).hbrBackground = color_window_brush(); }
    { (*wc).lpszClassName = window_class_name(); }
    { RegisterClassExA(raw); }
    { free(raw); }
    init_common_controls();
    return;
}

// Load the comctl32 common-control classes (progress / track bars) so they can
// be created. INITCOMMONCONTROLSEX is { dwSize: u32; dwICC: u32 } (8 bytes);
// ICC_WIN95_CLASSES = 0xFF pulls in the lot. Idempotent.
fn init_common_controls() {
    let icc: *u8 = { malloc(8 as usize) };
    let size_slot: *u32 = { icc as *u32 };
    { *size_slot = 8 as u32; }
    let flags_slot: *u32 = { (icc + (4 as usize)) as *u32 };
    { *flags_slot = 0xFF as u32; }
    { InitCommonControlsEx(icc); }
    { free(icc); }
    return;
}

// The application message loop. Returns the WM_QUIT code.
fn run() -> i32 {
    let msg: *u8 = { malloc(48 as usize) };
    var r: i32 = { GetMessageA(msg, 0 as *u8, 0 as u32, 0 as u32) };
    while r > (0 as i32) {
        { TranslateMessage(msg); }
        { DispatchMessageA(msg); }
        r = { GetMessageA(msg, 0 as *u8, 0 as u32, 0 as u32) };
    }
    { free(msg); }
    return 0 as i32;
}

// ---- thin wrappers the other modules call (so only core touches the FFI) ----

fn module_handle() -> *u8 { return { GetModuleHandleA(0 as *u8) }; }

// The HINSTANCE that owns `hwnd` (GWLP_HINSTANCE = -6). Lets a control derive
// the instance from its parent instead of threading it through every call.
fn window_hinst(hwnd: *u8) -> *u8 {
    return { GetWindowLongPtrA(hwnd, (0 as i32) -% (6 as i32)) } as *u8;
}

// Create a window or child control. `parent`/`menu` are 0 for a top-level
// window; for a child control, `parent` is the owner HWND and `menu` carries
// the control id (cast from u32). Returns the new HWND.
fn create_window(hinst: *u8, class_name: *u8, title: *u8, style: u32,
                 x: i32, y: i32, w: i32, h: i32, parent: *u8, menu: *u8) -> *u8 {
    return { CreateWindowExA(0 as u32, class_name, title, style,
                             x, y, w, h, parent, menu, hinst, 0 as *u8) };
}

// Build a dispatch table for `hwnd` and attach it via SetPropA.
fn attach_dispatch(hwnd: *u8) {
    { SetPropA(hwnd, prop_name(), make_dispatch()); }
    return;
}

fn show_window(hwnd: *u8) {
    { ShowWindow(hwnd, sw_show()); }
    { UpdateWindow(hwnd); }
    return;
}

fn set_text(hwnd: *u8, text: *u8) {
    { SetWindowTextA(hwnd, text); }
    return;
}

fn get_text_into(hwnd: *u8, buf: *u8, max: i32) -> i32 {
    return { GetWindowTextA(hwnd, buf, max) };
}

fn text_length(hwnd: *u8) -> i32 {
    return { GetWindowTextLengthA(hwnd) };
}

fn send(hwnd: *u8, msg: u32, w: u64, l: i64) -> i64 {
    return { SendMessageA(hwnd, msg, w, l) };
}

fn set_enabled(hwnd: *u8, on: bool) {
    if on { { EnableWindow(hwnd, 1 as i32); } } else { { EnableWindow(hwnd, 0 as i32); } }
    return;
}

fn move_control(hwnd: *u8, x: i32, y: i32, w: i32, h: i32) {
    { MoveWindow(hwnd, x, y, w, h, 1 as i32); }
    return;
}

fn invalidate(hwnd: *u8) {
    { InvalidateRect(hwnd, 0 as *u8, 1 as i32); }
    return;
}

fn schedule_close(hwnd: *u8, ms: u32) {
    { SetTimer(hwnd, close_timer_id(), ms, 0 as *u8); }
    return;
}

fn set_window_menu(hwnd: *u8, menu: *u8) {
    { SetMenu(hwnd, menu); }
    { DrawMenuBar(hwnd); }
    return;
}

// ---- pure-logic tests ----
// Style-flag packing and the WM_COMMAND id extraction in `win_proc` are plain
// bit arithmetic over the documented Win32 constants — host-runnable, no FFI.

#[test]
fn test_ws_child_visible_is_child_or_visible() {
    // The convenience constant must equal the OR of its two parts.
    assert ws_child_visible() == (ws_child() | ws_visible());
}

#[test]
fn test_child_style_packs_tabstop() {
    // The style a Button is created with: child + visible + tabstop.
    let style: u32 = ws_child_visible() | ws_tabstop();
    assert (style & ws_tabstop()) == ws_tabstop();
    assert (style & ws_child()) == ws_child();
    assert (style & ws_visible()) == ws_visible();
}

#[test]
fn test_wm_command_id_extraction() {
    // `win_proc` recovers a control id from the low word of wParam:
    // (w & 0xFFFF). The high word (notification code) must be discarded.
    let wparam: u64 = ((5 as u64) << (16 as u64)) | (123 as u64);
    let id: u32 = (wparam & (0xFFFF as u64)) as u32;
    assert id == (123 as u32);
}

#[test]
fn test_dispatch_first_id_is_100() {
    // The dispatch table hands out ids starting at 100 (below the
    // common-dialog reserved range); make_dispatch seeds next_id = 100.
    let d: *u8 = make_dispatch();
    let dp: *Dispatch = { d as *Dispatch };
    let id: i32 = { (*dp).next_id };
    { free({ (*dp).entries }); }
    { free(d); }
    assert id == (100 as i32);
}
