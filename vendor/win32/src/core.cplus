// win32/core.cplus — the engine shared by every win32 module.
//
// Holds the low-level user32/gdi32 externs, the window class + the single
// routing window-procedure, and the per-window **dispatch table** that turns
// Win32's WM_COMMAND / WM_PAINT / WM_CLOSE messages into calls to plain C+
// `fn` handlers (Win32 has no per-control signal objects — the parent window
// proc receives everything, keyed by control id). The table lives on the heap
// and is attached to its window with SetPropA, so the static window proc can
// recover it from just the HWND. This is the GTK `g_signal_connect` analogue.

extern fn malloc(n: usize) -> *u8;
extern fn realloc(p: *u8, n: usize) -> *u8;
extern fn free(p: *u8);
extern fn memset(p: *u8, c: i32, n: usize) -> *u8;

// ---- user32 / kernel32 (ANSI variants) ----
#[link_name = "GetModuleHandleA"]
extern fn GetModuleHandleA(name: *u8) -> *u8;
#[link_name = "LoadCursorA"]
extern fn LoadCursorA(hinst: *u8, name: *u8) -> *u8;
#[link_name = "RegisterClassExA"]
extern fn RegisterClassExA(wc: *u8) -> u16;
#[link_name = "CreateWindowExA"]
extern fn CreateWindowExA(
    ex_style: u32, class_name: *u8, window_name: *u8, style: u32,
    x: i32, y: i32, w: i32, h: i32,
    parent: *u8, menu: *u8, hinst: *u8, param: *u8,
) -> *u8;
#[link_name = "DefWindowProcA"]
extern fn DefWindowProcA(hwnd: *u8, msg: u32, w: u64, l: i64) -> i64;
#[link_name = "ShowWindow"]
extern fn ShowWindow(hwnd: *u8, cmd: i32) -> i32;
#[link_name = "UpdateWindow"]
extern fn UpdateWindow(hwnd: *u8) -> i32;
#[link_name = "DestroyWindow"]
extern fn DestroyWindow(hwnd: *u8) -> i32;
#[link_name = "PostQuitMessage"]
extern fn PostQuitMessage(code: i32);
#[link_name = "GetMessageA"]
extern fn GetMessageA(msg: *u8, hwnd: *u8, min: u32, max: u32) -> i32;
#[link_name = "TranslateMessage"]
extern fn TranslateMessage(msg: *u8) -> i32;
#[link_name = "DispatchMessageA"]
extern fn DispatchMessageA(msg: *u8) -> i64;
#[link_name = "SetPropA"]
extern fn SetPropA(hwnd: *u8, name: *u8, data: *u8) -> i32;
#[link_name = "GetPropA"]
extern fn GetPropA(hwnd: *u8, name: *u8) -> *u8;
#[link_name = "RemovePropA"]
extern fn RemovePropA(hwnd: *u8, name: *u8) -> *u8;
#[link_name = "SetTimer"]
extern fn SetTimer(hwnd: *u8, id: usize, elapse: u32, proc: *u8) -> usize;
#[link_name = "KillTimer"]
extern fn KillTimer(hwnd: *u8, id: usize) -> i32;
#[link_name = "BeginPaint"]
extern fn BeginPaint(hwnd: *u8, ps: *u8) -> *u8;
#[link_name = "EndPaint"]
extern fn EndPaint(hwnd: *u8, ps: *u8) -> i32;
#[link_name = "SetWindowTextA"]
extern fn SetWindowTextA(hwnd: *u8, text: *u8) -> i32;
#[link_name = "GetWindowTextA"]
extern fn GetWindowTextA(hwnd: *u8, buf: *u8, max: i32) -> i32;
#[link_name = "GetWindowTextLengthA"]
extern fn GetWindowTextLengthA(hwnd: *u8) -> i32;
#[link_name = "SendMessageA"]
