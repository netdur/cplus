// vendor/static-arena/src/static-arena.cplus — fixed-size stack arena.
//
// A bump-pointer arena whose buffer lives entirely on the stack (or
// in `static mut` storage). No `malloc`, no `free`. Composes with the
// v0.0.10 `#[no_alloc]` real-time contract.
//
// Why several types? C+ doesn't yet have const-generic struct params
// (`struct Arena[const N: usize]`), so we ship two fixed-size shapes
// covering common buffer sizes. If your workload needs a different
// size, copy one of these structs and swap the `[u8; N]` constants
// (the `buf` field length and the `capacity` constant).
//
// **Size ceiling**: ~128 KiB. By-value struct returns from `new()`
// trigger multiple stack copies (~3-4× the struct size) in the
// current codegen, so a `StaticArena256K` constructed via `new()`
// overflows the default 8 MiB stack. The proper fix is sret for
// large returns (a compiler improvement); until then, anything
// bigger than 64 KiB should live in `static mut` storage and be
// referenced by pointer rather than constructed on the stack.

import "stdlib/option" as option;

extern fn memset(dst: *u8, c: i32, n: usize) -> *u8;
extern fn memcpy(dst: *u8, src: *u8, n: usize) -> *u8;

// ---- StaticArena16K (16 KiB) ----

pub struct StaticArena16K {
    pub buf: [u8; 16384],
    pub used: usize,
}

impl StaticArena16K {
    pub fn new() -> StaticArena16K {
        return StaticArena16K { buf: [0u8; 16384], used: 0 as usize };
    }

    pub fn capacity(self) -> usize { return 16384 as usize; }
    pub fn used_bytes(self) -> usize { return self.used; }
    pub fn remaining(self) -> usize { return (16384 as usize) -% self.used; }
    pub fn reset(mut self) { self.used = 0 as usize; return; }

    pub fn alloc_bytes(mut self, n: usize) -> option::Option[*u8] {
        return self.alloc_bytes_aligned(n, 8 as usize);
    }

    pub fn alloc_bytes_aligned(mut self, n: usize, align: usize) -> option::Option[*u8] {
        let mut align: usize = align;
        if align == (0 as usize) { align = 1 as usize; }
        let buf_base: usize = unsafe { #addr_of(self) as usize };
        let cursor: usize = buf_base +% self.used;
        let remainder: usize = cursor % align;
        let aligned: usize = if remainder == (0 as usize) { cursor } else { cursor +% (align -% remainder) };
        let new_offset: usize = (aligned -% buf_base) +% n;
        if new_offset > (16384 as usize) {
            return option::Option[*u8]::None;
        }
        self.used = new_offset;
        return option::Option[*u8]::Some(unsafe { aligned as *u8 });
    }

    pub fn alloc_zeroed_bytes(mut self, n: usize) -> option::Option[*u8] {
        let opt: option::Option[*u8] = self.alloc_bytes(n);
        guard let option::Option[*u8]::Some(p) = opt else {
            return option::Option[*u8]::None;
        };
        unsafe { memset(p, 0 as i32, n); }
        return option::Option[*u8]::Some(p);
    }

    pub fn alloc_str(mut self, s: str) -> option::Option[str] {
        let n: usize = #str_len(s);
        let opt: option::Option[*u8] = self.alloc_bytes(n);
        guard let option::Option[*u8]::Some(p) = opt else {
            return option::Option[str]::None;
        };
        unsafe { memcpy(p, #str_ptr(s), n); }
        return option::Option[str]::Some(unsafe { #str_from_raw_parts(p, n) });
    }
}

// ---- StaticArena64K (64 KiB) ----

pub struct StaticArena64K {
    pub buf: [u8; 65536],
    pub used: usize,
}

impl StaticArena64K {
    pub fn new() -> StaticArena64K {
        return StaticArena64K { buf: [0u8; 65536], used: 0 as usize };
    }

    pub fn capacity(self) -> usize { return 65536 as usize; }
    pub fn used_bytes(self) -> usize { return self.used; }
    pub fn remaining(self) -> usize { return (65536 as usize) -% self.used; }
    pub fn reset(mut self) { self.used = 0 as usize; return; }

    pub fn alloc_bytes(mut self, n: usize) -> option::Option[*u8] {
        return self.alloc_bytes_aligned(n, 8 as usize);
    }

    pub fn alloc_bytes_aligned(mut self, n: usize, align: usize) -> option::Option[*u8] {
        let mut align: usize = align;
        if align == (0 as usize) { align = 1 as usize; }
        let buf_base: usize = unsafe { #addr_of(self) as usize };
        let cursor: usize = buf_base +% self.used;
        let remainder: usize = cursor % align;
        let aligned: usize = if remainder == (0 as usize) { cursor } else { cursor +% (align -% remainder) };
        let new_offset: usize = (aligned -% buf_base) +% n;
        if new_offset > (65536 as usize) {
            return option::Option[*u8]::None;
        }
        self.used = new_offset;
        return option::Option[*u8]::Some(unsafe { aligned as *u8 });
    }
}

// ---------------- Unit tests ----------------

#[test]
fn test_16k_new_starts_empty() {
    let a: StaticArena16K = StaticArena16K::new();
    assert a.used_bytes() == (0 as usize);
    assert a.capacity() == (16384 as usize);
    assert a.remaining() == (16384 as usize);
}

#[test]
fn test_16k_alloc_bytes_advances_cursor() {
    let mut a: StaticArena16K = StaticArena16K::new();
    let opt: option::Option[*u8] = a.alloc_bytes(64 as usize);
    guard let option::Option[*u8]::Some(_p) = opt else {
        assert false;
        return;
    };
    assert a.used_bytes() >= (64 as usize);
}

#[test]
fn test_16k_alloc_returns_none_on_overflow() {
    let mut a: StaticArena16K = StaticArena16K::new();
    let opt: option::Option[*u8] = a.alloc_bytes(20000 as usize);
    match opt {
        option::Option[*u8]::Some(_) => { assert false; }
        option::Option[*u8]::None => { assert true; }
    };
}

#[test]
fn test_16k_reset_recovers_capacity() {
    let mut a: StaticArena16K = StaticArena16K::new();
    let _p1: option::Option[*u8] = a.alloc_bytes(100 as usize);
    let _p2: option::Option[*u8] = a.alloc_bytes(200 as usize);
    assert a.used_bytes() > (0 as usize);
    a.reset();
    assert a.used_bytes() == (0 as usize);
}

#[test]
fn test_16k_alloc_zeroed_writes_zeros() {
    let mut a: StaticArena16K = StaticArena16K::new();
    let opt: option::Option[*u8] = a.alloc_zeroed_bytes(32 as usize);
    guard let option::Option[*u8]::Some(p) = opt else {
        assert false;
        return;
    };
    let b0: u8 = unsafe { *p };
    let b31: u8 = unsafe { *(p + 31) };
    assert b0 == (0 as u8);
    assert b31 == (0 as u8);
}

#[test]
fn test_16k_alloc_str_round_trip() {
    let mut a: StaticArena16K = StaticArena16K::new();
    let opt: option::Option[str] = a.alloc_str("hello");
    guard let option::Option[str]::Some(s) = opt else {
        assert false;
        return;
    };
    assert #str_len(s) == (5 as usize);
    let p: *u8 = #str_ptr(s);
    assert unsafe { *p } == ('h' as u8);
    assert unsafe { *(p + 4) } == ('o' as u8);
}

#[test]
fn test_64k_capacity_matches() {
    let a: StaticArena64K = StaticArena64K::new();
    assert a.capacity() == (65536 as usize);
}
