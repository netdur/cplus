// `MTLTextureType` (NS_ENUM)
enum TextureType {
    _1D,
    _1DArray,
    _2D,
    _2DArray,
    _2DMultisample,
    Cube,
    CubeArray,
    _3D,
    _2DMultisampleArray,
    TextureBuffer,
}

fn texture_type_raw(v: TextureType) -> i64 {
    return match v {
        TextureType::_1D => { 0 as i64 },
        TextureType::_1DArray => { 1 as i64 },
        TextureType::_2D => { 2 as i64 },
        TextureType::_2DArray => { 3 as i64 },
        TextureType::_2DMultisample => { 4 as i64 },
        TextureType::Cube => { 5 as i64 },
        TextureType::CubeArray => { 6 as i64 },
        TextureType::_3D => { 7 as i64 },
        TextureType::_2DMultisampleArray => { 8 as i64 },
        TextureType::TextureBuffer => { 9 as i64 },
    };
}

fn texture_type_from_raw(raw: i64) -> TextureType {
    if raw == (1 as i64) { return TextureType::_1DArray; }
    if raw == (2 as i64) { return TextureType::_2D; }
    if raw == (3 as i64) { return TextureType::_2DArray; }
    if raw == (4 as i64) { return TextureType::_2DMultisample; }
    if raw == (5 as i64) { return TextureType::Cube; }
    if raw == (6 as i64) { return TextureType::CubeArray; }
    if raw == (7 as i64) { return TextureType::_3D; }
    if raw == (8 as i64) { return TextureType::_2DMultisampleArray; }
    if raw == (9 as i64) { return TextureType::TextureBuffer; }
    return TextureType::_1D;
}

// `MTLCPUCacheMode` (NS_ENUM)
enum CPUCacheMode {
    DefaultCache,
    WriteCombined,
}

fn c_p_u_cache_mode_raw(v: CPUCacheMode) -> i64 {
    return match v {
        CPUCacheMode::DefaultCache => { 0 as i64 },
        CPUCacheMode::WriteCombined => { 1 as i64 },
    };
}

fn c_p_u_cache_mode_from_raw(raw: i64) -> CPUCacheMode {
    if raw == (1 as i64) { return CPUCacheMode::WriteCombined; }
    return CPUCacheMode::DefaultCache;
}

// `MTLStorageMode` (NS_ENUM)
enum StorageMode {
    Shared,
    Managed,
    Private,
    Memoryless,
}

fn storage_mode_raw(v: StorageMode) -> i64 {
    return match v {
        StorageMode::Shared => { 0 as i64 },
        StorageMode::Managed => { 1 as i64 },
        StorageMode::Private => { 2 as i64 },
        StorageMode::Memoryless => { 3 as i64 },
    };
}

fn storage_mode_from_raw(raw: i64) -> StorageMode {
    if raw == (1 as i64) { return StorageMode::Managed; }
    if raw == (2 as i64) { return StorageMode::Private; }
    if raw == (3 as i64) { return StorageMode::Memoryless; }
    return StorageMode::Shared;
}

// `MTLHazardTrackingMode` (NS_ENUM)
enum HazardTrackingMode {
