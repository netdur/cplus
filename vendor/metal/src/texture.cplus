// `MTLSparsePageSize` (NS_ENUM)
enum SparsePageSize {
    _16,
    _64,
    _256,
}

fn sparse_page_size_raw(v: SparsePageSize) -> i64 {
    return match v {
        SparsePageSize::_16 => { 101 as i64 },
        SparsePageSize::_64 => { 102 as i64 },
        SparsePageSize::_256 => { 103 as i64 },
    };
}

fn sparse_page_size_from_raw(raw: i64) -> SparsePageSize {
    if raw == (102 as i64) { return SparsePageSize::_64; }
    if raw == (103 as i64) { return SparsePageSize::_256; }
    return SparsePageSize::_16;
}

