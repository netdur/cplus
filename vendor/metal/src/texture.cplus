    if raw == (2 as i64) { return TextureSparseTier::_2; }
    return TextureSparseTier::None;
}

// `MTLSharedTextureHandle` (Foundation/ObjC). Non-owning handle (factory/singleton); `opaque`, no drop.
struct SharedTextureHandle {
    opaque _obj: *u8,
}

impl SharedTextureHandle {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> SharedTextureHandle { return SharedTextureHandle { _obj: ptr }; }

    fn device(this) -> *u8 {
        return rt::msg_id(this._obj, rt::sel(#str_ptr("device\0")));
    }

    fn label(this) -> option::Option[text::Text] {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("label\0")));
        return bridge::to_text_option(ns);
    }

}

