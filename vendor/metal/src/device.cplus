}

// `MTLGPUFamily` (NS_ENUM)
enum GPUFamily {
    Apple1,
    Apple2,
    Apple3,
    Apple4,
    Apple5,
    Apple6,
    Apple7,
    Apple8,
    Apple9,
    Apple10,
    Mac1,
    Mac2,
    Common1,
    Common2,
    Common3,
    MacCatalyst1,
    MacCatalyst2,
    Metal3,
    Metal4,
}

fn g_p_u_family_raw(v: GPUFamily) -> i64 {
    return match v {
        GPUFamily::Apple1 => { 1001 as i64 },
        GPUFamily::Apple2 => { 1002 as i64 },
        GPUFamily::Apple3 => { 1003 as i64 },
        GPUFamily::Apple4 => { 1004 as i64 },
        GPUFamily::Apple5 => { 1005 as i64 },
        GPUFamily::Apple6 => { 1006 as i64 },
        GPUFamily::Apple7 => { 1007 as i64 },
        GPUFamily::Apple8 => { 1008 as i64 },
        GPUFamily::Apple9 => { 1009 as i64 },
        GPUFamily::Apple10 => { 1010 as i64 },
        GPUFamily::Mac1 => { 2001 as i64 },
        GPUFamily::Mac2 => { 2002 as i64 },
        GPUFamily::Common1 => { 3001 as i64 },
        GPUFamily::Common2 => { 3002 as i64 },
        GPUFamily::Common3 => { 3003 as i64 },
        GPUFamily::MacCatalyst1 => { 4001 as i64 },
        GPUFamily::MacCatalyst2 => { 4002 as i64 },
        GPUFamily::Metal3 => { 5001 as i64 },
        GPUFamily::Metal4 => { 5002 as i64 },
    };
}

fn g_p_u_family_from_raw(raw: i64) -> GPUFamily {
    if raw == (1002 as i64) { return GPUFamily::Apple2; }
    if raw == (1003 as i64) { return GPUFamily::Apple3; }
    if raw == (1004 as i64) { return GPUFamily::Apple4; }
    if raw == (1005 as i64) { return GPUFamily::Apple5; }
    if raw == (1006 as i64) { return GPUFamily::Apple6; }
    if raw == (1007 as i64) { return GPUFamily::Apple7; }
    if raw == (1008 as i64) { return GPUFamily::Apple8; }
    if raw == (1009 as i64) { return GPUFamily::Apple9; }
    if raw == (1010 as i64) { return GPUFamily::Apple10; }
    if raw == (2001 as i64) { return GPUFamily::Mac1; }
    if raw == (2002 as i64) { return GPUFamily::Mac2; }
    if raw == (3001 as i64) { return GPUFamily::Common1; }
    if raw == (3002 as i64) { return GPUFamily::Common2; }
    if raw == (3003 as i64) { return GPUFamily::Common3; }
    if raw == (4001 as i64) { return GPUFamily::MacCatalyst1; }
    if raw == (4002 as i64) { return GPUFamily::MacCatalyst2; }
    if raw == (5001 as i64) { return GPUFamily::Metal3; }
    if raw == (5002 as i64) { return GPUFamily::Metal4; }
    return GPUFamily::Apple1;
}

