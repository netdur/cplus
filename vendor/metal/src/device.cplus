// vendor/metal/src/device.cplus — MTLDevice wrapper and resource creation.

import "./runtime" as runtime;
import "./buffer" as buffer;
import "./queue" as queue;
import "./pipeline" as pipeline;
import "stdlib/result" as result;

struct Device {
    raw: *u8,
}

fn default() -> result::Result[Device, runtime::MetalError] {
    let dev_raw: *u8 = runtime::mtl_create_system_default_device();
    if dev_raw == { 0 as *u8 } {
        return result::Result[Device, runtime::MetalError]::Err(runtime::MetalError::NoDefaultDevice);
    }
    return result::Result[Device, runtime::MetalError]::Ok(Device { raw: dev_raw });
}

impl Device {
    fn new_command_queue(this) -> queue::CommandQueue {
        if this.raw == { 0 as *u8 } {
            return queue::CommandQueue { raw: { 0 as *u8 } };
        }
        let selector: *u8 = runtime::sel(#str_ptr("newCommandQueue\0"));
        let queue_raw: *u8 = runtime::msg_id(this.raw, selector);
        return queue::CommandQueue { raw: queue_raw };
    }

    fn new_library_with_data(this, data: u8[]) -> result::Result[pipeline::Library, runtime::MetalError] {
        if this.raw == { 0 as *u8 } {
            return result::Result[pipeline::Library, runtime::MetalError]::Err(runtime::MetalError::LibraryLoadFailed);
        }
        let data_ptr: *u8 = { #slice_ptr(data) };
        let data_len: usize = #slice_len(data);
        // Per Apple docs: `dispatch_data_create(buf, len, NULL queue,
        // NULL destructor)` defaults to DISPATCH_DATA_DESTRUCTOR_DEFAULT,
        // which copies the buffer — so `data` itself is safe to drop
        // after this call. The returned dispatch_data object is +1
        // retained though; release it after Metal has consumed it to
        // avoid a per-shader-load leak (pre-fix it leaked silently).
        let dispatch_data: *u8 = runtime::ns_dispatch_data(data_ptr, data_len);

        let selector: *u8 = runtime::sel(#str_ptr("newLibraryWithData:error:\0"));
        let null_err: *u8 = { 0 as *u8 };
        let lib_raw: *u8 = runtime::msg_id_id_ptr(this.raw, selector, dispatch_data, null_err);
        runtime::release(dispatch_data);

        if lib_raw == { 0 as *u8 } {
            return result::Result[pipeline::Library, runtime::MetalError]::Err(runtime::MetalError::LibraryLoadFailed);
        }
        return result::Result[pipeline::Library, runtime::MetalError]::Ok(pipeline::Library { raw: lib_raw });
    }

    fn new_buffer(this, len: usize) -> buffer::Buffer {
        if this.raw == { 0 as *u8 } {
            return buffer::Buffer { raw: { 0 as *u8 }, size: 0 as usize };
        }
        let selector: *u8 = runtime::sel(#str_ptr("newBufferWithLength:options:\0"));
        let buf_raw: *u8 = runtime::msg_id_usize_u64(this.raw, selector, len, 0 as u64);
        return buffer::Buffer { raw: buf_raw, size: len };
    }

    fn new_buffer_from_slice(this, slice: u8[]) -> buffer::Buffer {
        if this.raw == { 0 as *u8 } {
            return buffer::Buffer { raw: { 0 as *u8 }, size: 0 as usize };
        }
        let ptr: *u8 = { #slice_ptr(slice) };
        let len: usize = #slice_len(slice);
        let selector: *u8 = runtime::sel(#str_ptr("newBufferWithBytes:length:options:\0"));
        let buf_raw: *u8 = runtime::msg_id_ptr_len_opt(this.raw, selector, ptr, len, 0 as u64);
        return buffer::Buffer { raw: buf_raw, size: len };
    }

    fn new_compute_pipeline_state(
        this,
        function: pipeline::Function,
    ) -> result::Result[pipeline::ComputePipelineState, runtime::MetalError] {
        return pipeline::ComputePipelineState::new(this.raw, function);
    }

    fn drop(ref this) {
        runtime::release(this.raw);
        this.raw = { 0 as *u8 };
        return;
    }
}

// ---------------- Unit tests ----------------
// G-029 fix wires `[link]` frameworks/libs from the package manifest
// into `cpc test`'s link line, so these tests can resolve to the real
// Metal/Foundation/objc symbols.

#[test]
fn test_default_returns_ok_on_macos() {
    // Every supported macOS test host has a default Metal device. If
    // this ever fails on a real machine it's a Metal-availability issue,
    // not a code bug.
    guard let result::Result[Device, runtime::MetalError]::Ok(d) = default() else {
        assert false;
        return;
    };
    assert { #addr(d.raw) } != (0 as usize);
}

#[test]
fn test_default_device_can_make_command_queue() {
    guard let result::Result[Device, runtime::MetalError]::Ok(dev) = default() else {
        assert false;
        return;
    };
    let q: queue::CommandQueue = dev.new_command_queue();
    assert { #addr(q.raw) } != (0 as usize);
}

#[test]
fn test_default_device_can_make_buffer() {
    guard let result::Result[Device, runtime::MetalError]::Ok(dev) = default() else {
        assert false;
        return;
    };
    let buf: buffer::Buffer = dev.new_buffer(64 as usize);
    assert { #addr(buf.raw) } != (0 as usize);
    assert buf.size == (64 as usize);
}
