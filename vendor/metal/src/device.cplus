// `MTLBuffer` (ObjC protocol). Non-owning handle; `opaque`, no drop.
struct Buffer {
    opaque _obj: *u8,
}

impl Buffer {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> Buffer { return Buffer { _obj: ptr }; }

}

