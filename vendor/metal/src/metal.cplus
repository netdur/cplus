        return Device::from_raw(rt::msg_id(this._obj, rt::sel(#str_ptr("device\0"))));
    }

    fn function_type(this) -> FunctionType {
        return function_type_from_raw(rt::msg_i64(this._obj, rt::sel(#str_ptr("functionType\0"))));
    }

    fn patch_type(this) -> PatchType {
        return patch_type_from_raw(rt::msg_i64(this._obj, rt::sel(#str_ptr("patchType\0"))));
    }

    fn patch_control_point_count(this) -> i64 {
        return rt::msg_i64(this._obj, rt::sel(#str_ptr("patchControlPointCount\0")));
    }

    fn vertex_attributes(this) -> vec::Vec[VertexAttribute] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("vertexAttributes\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[VertexAttribute] = vec::Vec[VertexAttribute]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(VertexAttribute::from_raw(rt::msg_id_u64(arr, at_sel, i)));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn stage_input_attributes(this) -> vec::Vec[Attribute] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("stageInputAttributes\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[Attribute] = vec::Vec[Attribute]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(Attribute::from_raw(rt::msg_id_u64(arr, at_sel, i)));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn name(this) -> text::Text {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("name\0")));
        return bridge::to_text(ns);
    }

    fn function_constants_dictionary(this) -> string_map::StringMap[FunctionConstant] {
        let dict: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("functionConstantsDictionary\0")));
        let keys: *u8 = rt::msg_id(dict, rt::sel(#str_ptr("allKeys\0")));
        let n: u64 = rt::msg_u64(keys, rt::sel(#str_ptr("count\0")));
        var out: string_map::StringMap[FunctionConstant] = string_map::new::[FunctionConstant]();
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        let obj_sel: *u8 = rt::sel(#str_ptr("objectForKey:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            let nskey: *u8 = rt::msg_id_u64(keys, at_sel, i);
            let nsval: *u8 = rt::msg_id_id(dict, obj_sel, nskey);
            out.insert(bridge::to_text(nskey), FunctionConstant::from_raw(nsval));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn options(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("options\0")));
    }

}

