    }

    fn binary_archives(this) -> vec::Vec[BinaryArchive] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("binaryArchives\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[BinaryArchive] = vec::Vec[BinaryArchive]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(BinaryArchive::from_raw(rt::msg_id_u64(arr, at_sel, i)));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn set_binary_archives(this, binary_archives: vec::Vec[BinaryArchive]) {
        let arr_binary_archives: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
        let add_sel_binary_archives: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_binary_archives: usize = binary_archives.count();
        var i_binary_archives: usize = 0 as usize;
        while i_binary_archives < n_binary_archives {
            match binary_archives.at_ptr(i_binary_archives) {
                option::Option[*BinaryArchive]::Some(e_binary_archives) => { rt::msg_void_id(arr_binary_archives, add_sel_binary_archives, (*e_binary_archives).raw()); }
                option::Option[*BinaryArchive]::None => {}
            }
            i_binary_archives = i_binary_archives +% (1 as usize);
        }
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setBinaryArchives:\0")), arr_binary_archives);
    }

}

