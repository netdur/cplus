            var vj: u64 = 0 as u64;
            while vj < vn {
                vvec.append(MTL4FunctionDescriptor::from_raw(rt::msg_id_u64(nsval, at_sel, vj)));
                vj = vj +% (1 as u64);
            }
            out.insert(bridge::to_text(nskey), vvec);
            i = i +% (1 as u64);
        }
        return out;
    }

    fn set_groups(this, groups: string_map::StringMap[vec::Vec[MTL4FunctionDescriptor]]) {
        let dict_groups: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableDictionary\0")), rt::sel(#str_ptr("dictionary\0")));
        let dset_groups: *u8 = rt::sel(#str_ptr("setObject:forKey:\0"));
        let dcap_groups: usize = groups.slot_capacity();
        var dsi_groups: usize = 0 as usize;
        while dsi_groups < dcap_groups {
            match groups.value_ptr_at_slot(dsi_groups) {
                option::Option[*vec::Vec[MTL4FunctionDescriptor]]::Some(dvp_groups) => {
                    match groups.key_ptr_at_slot(dsi_groups) {
                        option::Option[*text::Text]::Some(dkp_groups) => {
                    let dval_groups: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
                    let dadd_groups: *u8 = rt::sel(#str_ptr("addObject:\0"));
                    let dan_groups: usize = (*dvp_groups).count();
                    var daj_groups: usize = 0 as usize;
                    while daj_groups < dan_groups {
                        match (*dvp_groups).at_ptr(daj_groups) {
                            option::Option[*MTL4FunctionDescriptor]::Some(dae_groups) => { rt::msg_void_id(dval_groups, dadd_groups, (*dae_groups).raw()); }
                            option::Option[*MTL4FunctionDescriptor]::None => {}
                        }
                        daj_groups = daj_groups +% (1 as usize);
                    }
                            rt::msg_void_id_id(dict_groups, dset_groups, dval_groups, bridge::nsstring((*dkp_groups).view()));
                        }
                        option::Option[*text::Text]::None => {}
                    }
                }
                option::Option[*vec::Vec[MTL4FunctionDescriptor]]::None => {}
            }
            dsi_groups = dsi_groups +% (1 as usize);
        }
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setGroups:\0")), dict_groups);
    }

}

