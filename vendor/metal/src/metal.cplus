fn argument_type_raw(v: ArgumentType) -> i64 {
    return match v {
        ArgumentType::Buffer => { 0 as i64 },
        ArgumentType::ThreadgroupMemory => { 1 as i64 },
        ArgumentType::Texture => { 2 as i64 },
        ArgumentType::Sampler => { 3 as i64 },
        ArgumentType::ImageblockData => { 16 as i64 },
        ArgumentType::Imageblock => { 17 as i64 },
        ArgumentType::VisibleFunctionTable => { 24 as i64 },
        ArgumentType::PrimitiveAccelerationStructure => { 25 as i64 },
        ArgumentType::InstanceAccelerationStructure => { 26 as i64 },
        ArgumentType::IntersectionFunctionTable => { 27 as i64 },
    };
}

fn argument_type_from_raw(raw: i64) -> ArgumentType {
    if raw == (1 as i64) { return ArgumentType::ThreadgroupMemory; }
    if raw == (2 as i64) { return ArgumentType::Texture; }
    if raw == (3 as i64) { return ArgumentType::Sampler; }
    if raw == (16 as i64) { return ArgumentType::ImageblockData; }
    if raw == (17 as i64) { return ArgumentType::Imageblock; }
    if raw == (24 as i64) { return ArgumentType::VisibleFunctionTable; }
    if raw == (25 as i64) { return ArgumentType::PrimitiveAccelerationStructure; }
    if raw == (26 as i64) { return ArgumentType::InstanceAccelerationStructure; }
    if raw == (27 as i64) { return ArgumentType::IntersectionFunctionTable; }
    return ArgumentType::Buffer;
}

// `MTLBindingAccess` (NS_ENUM)
enum BindingAccess {
    ReadOnly,
    ReadWrite,
    WriteOnly,
    MTLArgumentAccessReadOnly,
    MTLArgumentAccessReadWrite,
    MTLArgumentAccessWriteOnly,
}

fn binding_access_raw(v: BindingAccess) -> i64 {
    return match v {
        BindingAccess::ReadOnly => { 0 as i64 },
        BindingAccess::ReadWrite => { 1 as i64 },
        BindingAccess::WriteOnly => { 2 as i64 },
        BindingAccess::MTLArgumentAccessReadOnly => { 0 as i64 },
        BindingAccess::MTLArgumentAccessReadWrite => { 1 as i64 },
        BindingAccess::MTLArgumentAccessWriteOnly => { 2 as i64 },
    };
}

fn binding_access_from_raw(raw: i64) -> BindingAccess {
    if raw == (1 as i64) { return BindingAccess::ReadWrite; }
    if raw == (2 as i64) { return BindingAccess::WriteOnly; }
    if raw == (0 as i64) { return BindingAccess::MTLArgumentAccessReadOnly; }
    if raw == (1 as i64) { return BindingAccess::MTLArgumentAccessReadWrite; }
    if raw == (2 as i64) { return BindingAccess::MTLArgumentAccessWriteOnly; }
    return BindingAccess::ReadOnly;
}

