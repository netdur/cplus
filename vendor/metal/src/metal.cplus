// `MTLCounterSet` (ObjC protocol). Non-owning handle; `opaque`, no drop.
struct CounterSet {
    opaque _obj: *u8,
}

impl CounterSet {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> CounterSet { return CounterSet { _obj: ptr }; }

    fn name(this) -> text::Text {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("name\0")));
        return bridge::to_text(ns);
    }

    fn counters(this) -> vec::Vec[Counter] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("counters\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[Counter] = vec::Vec[Counter]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(Counter::from_raw(rt::msg_id_u64(arr, at_sel, i)));
            i = i +% (1 as u64);
        }
        return out;
    }

}

