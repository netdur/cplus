        }
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setFunctionDescriptors:\0")), arr_function_descriptors);
    }

    fn private_function_descriptors(this) -> vec::Vec[MTL4FunctionDescriptor] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("privateFunctionDescriptors\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
