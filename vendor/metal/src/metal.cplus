// `MTLCaptureScope` (ObjC protocol). Non-owning handle; `opaque`, no drop.
struct CaptureScope {
    opaque _obj: *u8,
}

impl CaptureScope {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> CaptureScope { return CaptureScope { _obj: ptr }; }

    fn begin_scope(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("beginScope\0")));
    }

    fn end_scope(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("endScope\0")));
    }

    fn label(this) -> option::Option[text::Text] {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("label\0")));
        return bridge::to_text_option(ns);
    }

    fn set_label(this, label: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setLabel:\0")), bridge::nsstring(label));
    }

    fn device(this) -> Device {
        return Device::from_raw(rt::msg_id(this._obj, rt::sel(#str_ptr("device\0"))));
    }

    fn command_queue(this) -> option::Option[CommandQueue] {
        let obj: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("commandQueue\0")));
        if obj == { 0 as *u8 } {
            return option::Option[CommandQueue]::None;
