        LanguageVersion::_4_0 => { 262144 as i64 },
    };
}

fn language_version_from_raw(raw: i64) -> LanguageVersion {
    if raw == (65537 as i64) { return LanguageVersion::_1_1; }
    if raw == (65538 as i64) { return LanguageVersion::_1_2; }
    if raw == (131072 as i64) { return LanguageVersion::_2_0; }
    if raw == (131073 as i64) { return LanguageVersion::_2_1; }
    if raw == (131074 as i64) { return LanguageVersion::_2_2; }
