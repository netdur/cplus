struct ComputePipelineState {
    opaque _obj: *u8,
}

impl ComputePipelineState {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> ComputePipelineState { return ComputePipelineState { _obj: ptr }; }

    fn function_handle_with_name(this, name: str) -> option::Option[FunctionHandle] {
        let obj: *u8 = rt::msg_id_id(this._obj, rt::sel(#str_ptr("functionHandleWithName:\0")), bridge::nsstring(name));
        if obj == { 0 as *u8 } {
            return option::Option[FunctionHandle]::None;
        }
        return option::some(FunctionHandle::from_raw(obj));
    }

    fn function_handle_with_binary_function(this, function: MTL4BinaryFunction) -> option::Option[FunctionHandle] {
        let obj: *u8 = rt::msg_id_id(this._obj, rt::sel(#str_ptr("functionHandleWithBinaryFunction:\0")), function.raw());
        if obj == { 0 as *u8 } {
            return option::Option[FunctionHandle]::None;
        }
        return option::some(FunctionHandle::from_raw(obj));
    }

    fn new_compute_pipeline_state_with_binary_functions(this, additional_binary_functions: vec::Vec[MTL4BinaryFunction], error: *u8) -> option::Option[ComputePipelineState] {
        let arr_additional_binary_functions: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
        let add_sel_additional_binary_functions: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_additional_binary_functions: usize = additional_binary_functions.count();
        var i_additional_binary_functions: usize = 0 as usize;
        while i_additional_binary_functions < n_additional_binary_functions {
            match additional_binary_functions.at_ptr(i_additional_binary_functions) {
                option::Option[*MTL4BinaryFunction]::Some(e_additional_binary_functions) => { rt::msg_void_id(arr_additional_binary_functions, add_sel_additional_binary_functions, (*e_additional_binary_functions).raw()); }
                option::Option[*MTL4BinaryFunction]::None => {}
            }
            i_additional_binary_functions = i_additional_binary_functions +% (1 as usize);
        }
        let obj: *u8 = rt::msg_id_id_id(this._obj, rt::sel(#str_ptr("newComputePipelineStateWithBinaryFunctions:error:\0")), arr_additional_binary_functions, error);
        if obj == { 0 as *u8 } {
            return option::Option[ComputePipelineState]::None;
        }
        return option::some(ComputePipelineState::from_raw(obj));
    }

    fn imageblock_memory_length_for_dimensions(this, imageblock_dimensions: Size) -> u64 {
        return objc_msg_u64_Size(this._obj, rt::sel(#str_ptr("imageblockMemoryLengthForDimensions:\0")), imageblock_dimensions);
    }

    fn function_handle_with_function(this, function: Function) -> option::Option[FunctionHandle] {
        let obj: *u8 = rt::msg_id_id(this._obj, rt::sel(#str_ptr("functionHandleWithFunction:\0")), function.raw());
        if obj == { 0 as *u8 } {
            return option::Option[FunctionHandle]::None;
        }
        return option::some(FunctionHandle::from_raw(obj));
    }

    fn new_compute_pipeline_state_with_additional_binary_functions(this, functions: vec::Vec[Function], error: *u8) -> option::Option[ComputePipelineState] {
        let arr_functions: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
        let add_sel_functions: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_functions: usize = functions.count();
        var i_functions: usize = 0 as usize;
        while i_functions < n_functions {
            match functions.at_ptr(i_functions) {
                option::Option[*Function]::Some(e_functions) => { rt::msg_void_id(arr_functions, add_sel_functions, (*e_functions).raw()); }
                option::Option[*Function]::None => {}
            }
            i_functions = i_functions +% (1 as usize);
        }
        let obj: *u8 = rt::msg_id_id_id(this._obj, rt::sel(#str_ptr("newComputePipelineStateWithAdditionalBinaryFunctions:error:\0")), arr_functions, error);
        if obj == { 0 as *u8 } {
            return option::Option[ComputePipelineState]::None;
        }
        return option::some(ComputePipelineState::from_raw(obj));
    }

    fn new_visible_function_table_with_descriptor(this, descriptor: VisibleFunctionTableDescriptor) -> option::Option[VisibleFunctionTable] {
        let obj: *u8 = rt::msg_id_id(this._obj, rt::sel(#str_ptr("newVisibleFunctionTableWithDescriptor:\0")), descriptor.raw());
        if obj == { 0 as *u8 } {
            return option::Option[VisibleFunctionTable]::None;
        }
        return option::some(VisibleFunctionTable::from_raw(obj));
    }

    fn new_intersection_function_table_with_descriptor(this, descriptor: IntersectionFunctionTableDescriptor) -> option::Option[IntersectionFunctionTable] {
        let obj: *u8 = rt::msg_id_id(this._obj, rt::sel(#str_ptr("newIntersectionFunctionTableWithDescriptor:\0")), descriptor.raw());
        if obj == { 0 as *u8 } {
            return option::Option[IntersectionFunctionTable]::None;
        }
        return option::some(IntersectionFunctionTable::from_raw(obj));
    }

    fn label(this) -> option::Option[text::Text] {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("label\0")));
        return bridge::to_text_option(ns);
    }

    fn reflection(this) -> option::Option[ComputePipelineReflection] {
        let obj: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("reflection\0")));
        if obj == { 0 as *u8 } {
            return option::Option[ComputePipelineReflection]::None;
        }
        return option::some(ComputePipelineReflection::from_raw(obj));
    }

    fn device(this) -> Device {
        return Device::from_raw(rt::msg_id(this._obj, rt::sel(#str_ptr("device\0"))));
    }

    fn max_total_threads_per_threadgroup(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("maxTotalThreadsPerThreadgroup\0")));
    }

    fn thread_execution_width(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("threadExecutionWidth\0")));
    }

    fn static_threadgroup_memory_length(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("staticThreadgroupMemoryLength\0")));
    }

    fn support_indirect_command_buffers(this) -> bool {
        return rt::msg_i8(this._obj, rt::sel(#str_ptr("supportIndirectCommandBuffers\0"))) != (0 as i8);
    }

    fn gpu_resource_i_d(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("gpuResourceID\0")));
    }

    fn shader_validation(this) -> ShaderValidation {
