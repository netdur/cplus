// `MTLTextureUsage` (NS_OPTIONS) — bitfield; combine with `|`.
const texture_usage_unknown: u64 = 0 as u64;
const texture_usage_shader_read: u64 = 1 as u64;
const texture_usage_shader_write: u64 = 2 as u64;
const texture_usage_render_target: u64 = 4 as u64;
const texture_usage_pixel_format_view: u64 = 16 as u64;
const texture_usage_shader_atomic: u64 = 32 as u64;

// `MTLTextureType` (NS_ENUM)
enum TextureType {
    _1D,
    _1DArray,
    _2D,
    _2DArray,
    _2DMultisample,
    Cube,
    CubeArray,
    _3D,
    _2DMultisampleArray,
    TextureBuffer,
}

fn texture_type_raw(v: TextureType) -> i64 {
    return match v {
        TextureType::_1D => { 0 as i64 },
        TextureType::_1DArray => { 1 as i64 },
        TextureType::_2D => { 2 as i64 },
        TextureType::_2DArray => { 3 as i64 },
        TextureType::_2DMultisample => { 4 as i64 },
        TextureType::Cube => { 5 as i64 },
        TextureType::CubeArray => { 6 as i64 },
        TextureType::_3D => { 7 as i64 },
        TextureType::_2DMultisampleArray => { 8 as i64 },
        TextureType::TextureBuffer => { 9 as i64 },
    };
}

fn texture_type_from_raw(raw: i64) -> TextureType {
    if raw == (1 as i64) { return TextureType::_1DArray; }
    if raw == (2 as i64) { return TextureType::_2D; }
    if raw == (3 as i64) { return TextureType::_2DArray; }
    if raw == (4 as i64) { return TextureType::_2DMultisample; }
    if raw == (5 as i64) { return TextureType::Cube; }
    if raw == (6 as i64) { return TextureType::CubeArray; }
    if raw == (7 as i64) { return TextureType::_3D; }
    if raw == (8 as i64) { return TextureType::_2DMultisampleArray; }
    if raw == (9 as i64) { return TextureType::TextureBuffer; }
    return TextureType::_1D;
}

// `MTLTextureCompressionType` (NS_ENUM)
enum TextureCompressionType {
    Lossless,
    Lossy,
}

fn texture_compression_type_raw(v: TextureCompressionType) -> i64 {
    return match v {
        TextureCompressionType::Lossless => { 0 as i64 },
        TextureCompressionType::Lossy => { 1 as i64 },
    };
}

fn texture_compression_type_from_raw(raw: i64) -> TextureCompressionType {
    if raw == (1 as i64) { return TextureCompressionType::Lossy; }
    return TextureCompressionType::Lossless;
}

// `MTLSparsePageSize` (NS_ENUM)
enum SparsePageSize {
    _16,
