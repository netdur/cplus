        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(CounterSet::from_raw(rt::msg_id_u64(arr, at_sel, i)));
            i = i +% (1 as u64);
        }
        return out;
    }

