// vendor/metal/src/metal.cplus — Main facade for the Metal package.

import "stdlib/result" as result;
import "./device" as device;
import "./queue" as queue;
import "./pipeline" as pipeline;
import "./buffer" as buffer;
import "./runtime" as runtime;
import "./mps" as mps;

type Device = device::Device;
type CommandQueue = queue::CommandQueue;
type CommandBuffer = queue::CommandBuffer;
type ComputeCommandEncoder = queue::ComputeCommandEncoder;
type Library = pipeline::Library;
type Function = pipeline::Function;
type ComputePipelineState = pipeline::ComputePipelineState;
type Buffer = buffer::Buffer;
type MTLSize = runtime::MTLSize;
type MetalError = runtime::MetalError;

fn default_device() -> result::Result[device::Device, runtime::MetalError] {
    return device::default();
}
