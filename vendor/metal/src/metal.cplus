    fn counter_sets(this) -> vec::Vec[CounterSet] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("counterSets\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
