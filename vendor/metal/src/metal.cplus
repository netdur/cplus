// `MTLTensorExtents` (Foundation/ObjC). Owned via alloc/init; `drop` releases the +1.
struct TensorExtents {
    _obj: *u8,
}

impl TensorExtents {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> TensorExtents { return TensorExtents { _obj: ptr }; }

    // SKIPPED `initWithRank:values:`: init arg shape not yet modelled
    // SKIPPED `extentAtDimensionIndex:`: (return, arg) shape not yet modelled
    fn rank(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("rank\0")));
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }
}

// `MTLTensorDescriptor` (Foundation/ObjC). Non-owning handle (factory/singleton); `opaque`, no drop.
struct TensorDescriptor {
    opaque _obj: *u8,
}

impl TensorDescriptor {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> TensorDescriptor { return TensorDescriptor { _obj: ptr }; }

    fn dimensions(this) -> TensorExtents {
        return TensorExtents::from_raw(rt::msg_id(this._obj, rt::sel(#str_ptr("dimensions\0"))));
    }

    fn set_dimensions(this, dimensions: TensorExtents) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setDimensions:\0")), dimensions.raw());
    }

    fn strides(this) -> option::Option[TensorExtents] {
        let obj: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("strides\0")));
        if obj == { 0 as *u8 } {
            return option::Option[TensorExtents]::None;
        }
        return option::some(TensorExtents::from_raw(obj));
