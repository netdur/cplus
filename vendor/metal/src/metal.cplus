// `MTLLinkedFunctions` (Foundation/ObjC). Non-owning handle (factory/singleton); `opaque`, no drop.
struct LinkedFunctions {
    opaque _obj: *u8,
}

impl LinkedFunctions {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> LinkedFunctions { return LinkedFunctions { _obj: ptr }; }

    fn linked_functions() -> LinkedFunctions {
        return LinkedFunctions { _obj: rt::msg_id(rt::get_class(#str_ptr("MTLLinkedFunctions\0")), rt::sel(#str_ptr("linkedFunctions\0"))) };
    }

    fn functions(this) -> vec::Vec[Function] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("functions\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[Function] = vec::Vec[Function]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(Function::from_raw(rt::msg_id_u64(arr, at_sel, i)));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn set_functions(this, functions: vec::Vec[Function]) {
        let arr_functions: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
        let add_sel_functions: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_functions: usize = functions.count();
        var i_functions: usize = 0 as usize;
        while i_functions < n_functions {
            match functions.at_ptr(i_functions) {
                option::Option[*Function]::Some(e_functions) => { rt::msg_void_id(arr_functions, add_sel_functions, (*e_functions).raw()); }
                option::Option[*Function]::None => {}
            }
            i_functions = i_functions +% (1 as usize);
        }
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setFunctions:\0")), arr_functions);
    }

    fn binary_functions(this) -> vec::Vec[Function] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("binaryFunctions\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[Function] = vec::Vec[Function]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(Function::from_raw(rt::msg_id_u64(arr, at_sel, i)));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn set_binary_functions(this, binary_functions: vec::Vec[Function]) {
        let arr_binary_functions: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
        let add_sel_binary_functions: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_binary_functions: usize = binary_functions.count();
        var i_binary_functions: usize = 0 as usize;
        while i_binary_functions < n_binary_functions {
            match binary_functions.at_ptr(i_binary_functions) {
                option::Option[*Function]::Some(e_binary_functions) => { rt::msg_void_id(arr_binary_functions, add_sel_binary_functions, (*e_binary_functions).raw()); }
                option::Option[*Function]::None => {}
            }
            i_binary_functions = i_binary_functions +% (1 as usize);
        }
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setBinaryFunctions:\0")), arr_binary_functions);
    }

    fn groups(this) -> string_map::StringMap[vec::Vec[Function]] {
        let dict: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("groups\0")));
        let keys: *u8 = rt::msg_id(dict, rt::sel(#str_ptr("allKeys\0")));
        let n: u64 = rt::msg_u64(keys, rt::sel(#str_ptr("count\0")));
        var out: string_map::StringMap[vec::Vec[Function]] = string_map::new::[vec::Vec[Function]]();
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        let obj_sel: *u8 = rt::sel(#str_ptr("objectForKey:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            let nskey: *u8 = rt::msg_id_u64(keys, at_sel, i);
            let nsval: *u8 = rt::msg_id_id(dict, obj_sel, nskey);
            let vn: u64 = rt::msg_u64(nsval, rt::sel(#str_ptr("count\0")));
            var vvec: vec::Vec[Function] = vec::Vec[Function]::with_capacity(vn as usize);
            var vj: u64 = 0 as u64;
            while vj < vn {
                vvec.append(Function::from_raw(rt::msg_id_u64(nsval, at_sel, vj)));
                vj = vj +% (1 as u64);
            }
            out.insert(bridge::to_text(nskey), vvec);
            i = i +% (1 as u64);
        }
        return out;
    }

    fn set_groups(this, groups: string_map::StringMap[vec::Vec[Function]]) {
        let dict_groups: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableDictionary\0")), rt::sel(#str_ptr("dictionary\0")));
        let dset_groups: *u8 = rt::sel(#str_ptr("setObject:forKey:\0"));
        let dcap_groups: usize = groups.slot_capacity();
        var dsi_groups: usize = 0 as usize;
        while dsi_groups < dcap_groups {
            match groups.value_ptr_at_slot(dsi_groups) {
                option::Option[*vec::Vec[Function]]::Some(dvp_groups) => {
                    match groups.key_ptr_at_slot(dsi_groups) {
                        option::Option[*text::Text]::Some(dkp_groups) => {
                    let dval_groups: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
                    let dadd_groups: *u8 = rt::sel(#str_ptr("addObject:\0"));
                    let dan_groups: usize = (*dvp_groups).count();
                    var daj_groups: usize = 0 as usize;
                    while daj_groups < dan_groups {
                        match (*dvp_groups).at_ptr(daj_groups) {
                            option::Option[*Function]::Some(dae_groups) => { rt::msg_void_id(dval_groups, dadd_groups, (*dae_groups).raw()); }
                            option::Option[*Function]::None => {}
                        }
                        daj_groups = daj_groups +% (1 as usize);
                    }
                            rt::msg_void_id_id(dict_groups, dset_groups, dval_groups, bridge::nsstring((*dkp_groups).view()));
                        }
                        option::Option[*text::Text]::None => {}
                    }
                }
                option::Option[*vec::Vec[Function]]::None => {}
            }
            dsi_groups = dsi_groups +% (1 as usize);
        }
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setGroups:\0")), dict_groups);
    }

    fn private_functions(this) -> vec::Vec[Function] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("privateFunctions\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[Function] = vec::Vec[Function]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(Function::from_raw(rt::msg_id_u64(arr, at_sel, i)));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn set_private_functions(this, private_functions: vec::Vec[Function]) {
        let arr_private_functions: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
        let add_sel_private_functions: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_private_functions: usize = private_functions.count();
        var i_private_functions: usize = 0 as usize;
        while i_private_functions < n_private_functions {
            match private_functions.at_ptr(i_private_functions) {
                option::Option[*Function]::Some(e_private_functions) => { rt::msg_void_id(arr_private_functions, add_sel_private_functions, (*e_private_functions).raw()); }
                option::Option[*Function]::None => {}
            }
            i_private_functions = i_private_functions +% (1 as usize);
        }
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setPrivateFunctions:\0")), arr_private_functions);
    }

}

