    opaque _obj: *u8,
}

impl StructType {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> StructType { return StructType { _obj: ptr }; }

    fn member_by_name(this, name: str) -> option::Option[StructMember] {
        let obj: *u8 = rt::msg_id_id(this._obj, rt::sel(#str_ptr("memberByName:\0")), bridge::nsstring(name));
        if obj == { 0 as *u8 } {
            return option::Option[StructMember]::None;
        }
        return option::some(StructMember::from_raw(obj));
    }

    fn members(this) -> vec::Vec[StructMember] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("members\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[StructMember] = vec::Vec[StructMember]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(StructMember::from_raw(rt::msg_id_u64(arr, at_sel, i)));
            i = i +% (1 as u64);
        }
        return out;
    }

}

