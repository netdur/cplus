        var i_function_descriptors: usize = 0 as usize;
        while i_function_descriptors < n_function_descriptors {
            match function_descriptors.at_ptr(i_function_descriptors) {
                option::Option[*MTL4FunctionDescriptor]::Some(e_function_descriptors) => { rt::msg_void_id(arr_function_descriptors, add_sel_function_descriptors, (*e_function_descriptors).raw()); }
                option::Option[*MTL4FunctionDescriptor]::None => {}
