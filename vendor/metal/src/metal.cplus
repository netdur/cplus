// `MTLCompileOptions` (Foundation/ObjC). Non-owning handle (factory/singleton); `opaque`, no drop.
struct CompileOptions {
    opaque _obj: *u8,
}

impl CompileOptions {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> CompileOptions { return CompileOptions { _obj: ptr }; }

    fn preprocessor_macros(this) -> string_map::StringMap[AnyObject] {
        let dict: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("preprocessorMacros\0")));
        let keys: *u8 = rt::msg_id(dict, rt::sel(#str_ptr("allKeys\0")));
        let n: u64 = rt::msg_u64(keys, rt::sel(#str_ptr("count\0")));
        var out: string_map::StringMap[AnyObject] = string_map::new::[AnyObject]();
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        let obj_sel: *u8 = rt::sel(#str_ptr("objectForKey:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            let nskey: *u8 = rt::msg_id_u64(keys, at_sel, i);
            let nsval: *u8 = rt::msg_id_id(dict, obj_sel, nskey);
            out.insert(bridge::to_text(nskey), AnyObject::from_raw(nsval));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn set_preprocessor_macros(this, preprocessor_macros: string_map::StringMap[AnyObject]) {
        let dict_preprocessor_macros: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableDictionary\0")), rt::sel(#str_ptr("dictionary\0")));
        let dset_preprocessor_macros: *u8 = rt::sel(#str_ptr("setObject:forKey:\0"));
        let dcap_preprocessor_macros: usize = preprocessor_macros.slot_capacity();
        var dsi_preprocessor_macros: usize = 0 as usize;
        while dsi_preprocessor_macros < dcap_preprocessor_macros {
            match preprocessor_macros.value_ptr_at_slot(dsi_preprocessor_macros) {
                option::Option[*AnyObject]::Some(dvp_preprocessor_macros) => {
                    match preprocessor_macros.key_ptr_at_slot(dsi_preprocessor_macros) {
                        option::Option[*text::Text]::Some(dkp_preprocessor_macros) => {
                    let dval_preprocessor_macros: *u8 = (*dvp_preprocessor_macros).raw();
                            rt::msg_void_id_id(dict_preprocessor_macros, dset_preprocessor_macros, dval_preprocessor_macros, bridge::nsstring((*dkp_preprocessor_macros).view()));
                        }
                        option::Option[*text::Text]::None => {}
                    }
                }
                option::Option[*AnyObject]::None => {}
            }
            dsi_preprocessor_macros = dsi_preprocessor_macros +% (1 as usize);
        }
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setPreprocessorMacros:\0")), dict_preprocessor_macros);
    }

    fn fast_math_enabled(this) -> bool {
        return rt::msg_i8(this._obj, rt::sel(#str_ptr("fastMathEnabled\0"))) != (0 as i8);
    }

    fn set_fast_math_enabled(this, fast_math_enabled: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setFastMathEnabled:\0")), fast_math_enabled as i8);
    }

    fn math_mode(this) -> MathMode {
        return math_mode_from_raw(rt::msg_i64(this._obj, rt::sel(#str_ptr("mathMode\0"))));
    }

    fn set_math_mode(this, math_mode: MathMode) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setMathMode:\0")), math_mode_raw(math_mode));
    }

    fn math_floating_point_functions(this) -> MathFloatingPointFunctions {
        return math_floating_point_functions_from_raw(rt::msg_i64(this._obj, rt::sel(#str_ptr("mathFloatingPointFunctions\0"))));
    }

    fn set_math_floating_point_functions(this, math_floating_point_functions: MathFloatingPointFunctions) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setMathFloatingPointFunctions:\0")), math_floating_point_functions_raw(math_floating_point_functions));
    }

    fn language_version(this) -> LanguageVersion {
        return language_version_from_raw(rt::msg_i64(this._obj, rt::sel(#str_ptr("languageVersion\0"))));
    }

    fn set_language_version(this, language_version: LanguageVersion) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setLanguageVersion:\0")), language_version_raw(language_version));
    }

    fn library_type(this) -> LibraryType {
        return library_type_from_raw(rt::msg_i64(this._obj, rt::sel(#str_ptr("libraryType\0"))));
    }

    fn set_library_type(this, library_type: LibraryType) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setLibraryType:\0")), library_type_raw(library_type));
    }

    fn install_name(this) -> option::Option[text::Text] {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("installName\0")));
        return bridge::to_text_option(ns);
    }

    fn set_install_name(this, install_name: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setInstallName:\0")), bridge::nsstring(install_name));
    }

    fn libraries(this) -> vec::Vec[DynamicLibrary] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("libraries\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[DynamicLibrary] = vec::Vec[DynamicLibrary]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(DynamicLibrary::from_raw(rt::msg_id_u64(arr, at_sel, i)));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn set_libraries(this, libraries: vec::Vec[DynamicLibrary]) {
        let arr_libraries: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
        let add_sel_libraries: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_libraries: usize = libraries.count();
        var i_libraries: usize = 0 as usize;
        while i_libraries < n_libraries {
            match libraries.at_ptr(i_libraries) {
                option::Option[*DynamicLibrary]::Some(e_libraries) => { rt::msg_void_id(arr_libraries, add_sel_libraries, (*e_libraries).raw()); }
                option::Option[*DynamicLibrary]::None => {}
            }
            i_libraries = i_libraries +% (1 as usize);
        }
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setLibraries:\0")), arr_libraries);
    }

    fn preserve_invariance(this) -> bool {
        return rt::msg_i8(this._obj, rt::sel(#str_ptr("preserveInvariance\0"))) != (0 as i8);
    }

    fn set_preserve_invariance(this, preserve_invariance: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setPreserveInvariance:\0")), preserve_invariance as i8);
    }

    fn optimization_level(this) -> LibraryOptimizationLevel {
        return library_optimization_level_from_raw(rt::msg_i64(this._obj, rt::sel(#str_ptr("optimizationLevel\0"))));
    }

    fn set_optimization_level(this, optimization_level: LibraryOptimizationLevel) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setOptimizationLevel:\0")), library_optimization_level_raw(optimization_level));
    }

    fn compile_symbol_visibility(this) -> CompileSymbolVisibility {
        return compile_symbol_visibility_from_raw(rt::msg_i64(this._obj, rt::sel(#str_ptr("compileSymbolVisibility\0"))));
    }

    fn set_compile_symbol_visibility(this, compile_symbol_visibility: CompileSymbolVisibility) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setCompileSymbolVisibility:\0")), compile_symbol_visibility_raw(compile_symbol_visibility));
    }

    fn allow_referencing_undefined_symbols(this) -> bool {
        return rt::msg_i8(this._obj, rt::sel(#str_ptr("allowReferencingUndefinedSymbols\0"))) != (0 as i8);
