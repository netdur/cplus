// `MTLStitchedLibraryDescriptor` (Foundation/ObjC). Non-owning handle (factory/singleton); `opaque`, no drop.
struct StitchedLibraryDescriptor {
    opaque _obj: *u8,
}

impl StitchedLibraryDescriptor {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> StitchedLibraryDescriptor { return StitchedLibraryDescriptor { _obj: ptr }; }

    fn function_graphs(this) -> vec::Vec[FunctionStitchingGraph] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("functionGraphs\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[FunctionStitchingGraph] = vec::Vec[FunctionStitchingGraph]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(FunctionStitchingGraph::from_raw(rt::retain(rt::msg_id_u64(arr, at_sel, i))));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn set_function_graphs(this, function_graphs: vec::Vec[FunctionStitchingGraph]) {
        let arr_function_graphs: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
        let add_sel_function_graphs: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_function_graphs: usize = function_graphs.count();
        var i_function_graphs: usize = 0 as usize;
        while i_function_graphs < n_function_graphs {
            match function_graphs.at_ptr(i_function_graphs) {
                option::Option[*FunctionStitchingGraph]::Some(e_function_graphs) => { rt::msg_void_id(arr_function_graphs, add_sel_function_graphs, (*e_function_graphs).raw()); }
                option::Option[*FunctionStitchingGraph]::None => {}
            }
            i_function_graphs = i_function_graphs +% (1 as usize);
        }
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setFunctionGraphs:\0")), arr_function_graphs);
    }

    fn functions(this) -> vec::Vec[Function] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("functions\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[Function] = vec::Vec[Function]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(Function::from_raw(rt::msg_id_u64(arr, at_sel, i)));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn set_functions(this, functions: vec::Vec[Function]) {
        let arr_functions: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
        let add_sel_functions: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_functions: usize = functions.count();
        var i_functions: usize = 0 as usize;
        while i_functions < n_functions {
            match functions.at_ptr(i_functions) {
                option::Option[*Function]::Some(e_functions) => { rt::msg_void_id(arr_functions, add_sel_functions, (*e_functions).raw()); }
                option::Option[*Function]::None => {}
            }
            i_functions = i_functions +% (1 as usize);
        }
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setFunctions:\0")), arr_functions);
    }

    fn binary_archives(this) -> vec::Vec[BinaryArchive] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("binaryArchives\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[BinaryArchive] = vec::Vec[BinaryArchive]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(BinaryArchive::from_raw(rt::msg_id_u64(arr, at_sel, i)));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn set_binary_archives(this, binary_archives: vec::Vec[BinaryArchive]) {
        let arr_binary_archives: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
        let add_sel_binary_archives: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_binary_archives: usize = binary_archives.count();
        var i_binary_archives: usize = 0 as usize;
        while i_binary_archives < n_binary_archives {
            match binary_archives.at_ptr(i_binary_archives) {
                option::Option[*BinaryArchive]::Some(e_binary_archives) => { rt::msg_void_id(arr_binary_archives, add_sel_binary_archives, (*e_binary_archives).raw()); }
                option::Option[*BinaryArchive]::None => {}
