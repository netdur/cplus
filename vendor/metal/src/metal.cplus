}

impl ResidencySet {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> ResidencySet { return ResidencySet { _obj: ptr }; }

    fn request_residency(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("requestResidency\0")));
    }

    fn end_residency(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("endResidency\0")));
    }

    fn add_allocation(this, allocation: Allocation) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("addAllocation:\0")), allocation.raw());
    }

    fn add_allocations(this, allocations: *u8, count: u64) {
        rt::msg_void_id_u64(this._obj, rt::sel(#str_ptr("addAllocations:count:\0")), allocations, count);
    }

    fn remove_allocation(this, allocation: Allocation) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("removeAllocation:\0")), allocation.raw());
    }

    fn remove_allocations(this, allocations: *u8, count: u64) {
        rt::msg_void_id_u64(this._obj, rt::sel(#str_ptr("removeAllocations:count:\0")), allocations, count);
    }

    fn remove_all_allocations(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("removeAllAllocations\0")));
    }

    fn contains_allocation(this, an_allocation: Allocation) -> bool {
        return rt::msg_i8_id(this._obj, rt::sel(#str_ptr("containsAllocation:\0")), an_allocation.raw()) != (0 as i8);
    }

    fn commit(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("commit\0")));
    }

    fn device(this) -> Device {
        return Device::from_raw(rt::msg_id(this._obj, rt::sel(#str_ptr("device\0"))));
    }

    fn label(this) -> option::Option[text::Text] {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("label\0")));
        return bridge::to_text_option(ns);
    }

    fn allocated_size(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("allocatedSize\0")));
    }

    fn all_allocations(this) -> vec::Vec[Allocation] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("allAllocations\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[Allocation] = vec::Vec[Allocation]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(Allocation::from_raw(rt::msg_id_u64(arr, at_sel, i)));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn allocation_count(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("allocationCount\0")));
    }

}

