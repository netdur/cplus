    fn error(this) -> option::Option[*u8] {
        let obj: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("error\0")));
        return bridge::obj_option(obj);
    }

}

// `MTLIOScratchBuffer` (ObjC protocol). Non-owning handle; `opaque`, no drop.
struct IOScratchBuffer {
    opaque _obj: *u8,
}

impl IOScratchBuffer {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> IOScratchBuffer { return IOScratchBuffer { _obj: ptr }; }

    fn buffer(this) -> Buffer {
        return Buffer::from_raw(rt::msg_id(this._obj, rt::sel(#str_ptr("buffer\0"))));
    }

}

// `MTLIOScratchBufferAllocator` (ObjC protocol). Non-owning handle; `opaque`, no drop.
struct IOScratchBufferAllocator {
    opaque _obj: *u8,
}

impl IOScratchBufferAllocator {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> IOScratchBufferAllocator { return IOScratchBufferAllocator { _obj: ptr }; }

    fn new_scratch_buffer_with_minimum_size(this, minimum_size: u64) -> option::Option[IOScratchBuffer] {
        let obj: *u8 = rt::msg_id_u64(this._obj, rt::sel(#str_ptr("newScratchBufferWithMinimumSize:\0")), minimum_size);
        if obj == { 0 as *u8 } {
            return option::Option[IOScratchBuffer]::None;
        }
        return option::some(IOScratchBuffer::from_raw(obj));
    }

}

// `MTLResourceViewPool` (ObjC protocol). Non-owning handle; `opaque`, no drop.
struct ResourceViewPool {
    opaque _obj: *u8,
}

impl ResourceViewPool {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> ResourceViewPool { return ResourceViewPool { _obj: ptr }; }

    // SKIPPED `copyResourceViewsFromPool:sourceRange:destinationIndex:`: (return, arg) shape not yet modelled
    fn base_resource_i_d(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("baseResourceID\0")));
    }

    fn resource_view_count(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("resourceViewCount\0")));
    }

    fn device(this) -> Device {
        return Device::from_raw(rt::msg_id(this._obj, rt::sel(#str_ptr("device\0"))));
    }

    fn label(this) -> option::Option[text::Text] {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("label\0")));
        return bridge::to_text_option(ns);
    }

}

