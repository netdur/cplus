// `MTLCommandBufferEncoderInfo` (ObjC protocol). Non-owning handle; `opaque`, no drop.
struct CommandBufferEncoderInfo {
    opaque _obj: *u8,
}

impl CommandBufferEncoderInfo {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> CommandBufferEncoderInfo { return CommandBufferEncoderInfo { _obj: ptr }; }

    fn label(this) -> text::Text {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("label\0")));
        return bridge::to_text(ns);
    }

    fn debug_signposts(this) -> vec::Vec[text::Text] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("debugSignposts\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[text::Text] = vec::Vec[text::Text]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            let value: *u8 = rt::msg_id_u64(arr, at_sel, i);
            out.append(bridge::to_text(value));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn error_state(this) -> CommandEncoderErrorState {
        return command_encoder_error_state_from_raw(rt::msg_i64(this._obj, rt::sel(#str_ptr("errorState\0"))));
    }

}

