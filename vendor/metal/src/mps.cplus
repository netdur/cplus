// vendor/metal/src/mps.cplus — Metal Performance Shaders bindings.
//
// MPS ships Apple's hand-tuned matmul / conv / FFT / softmax /
// reductions for every Apple Silicon generation. This module exposes
// the matmul + matvec primitives — the "I have large numbers to crush"
// answer on Apple hardware, used by `proves/vector_search_server/` and
// any consumer that wants to dispatch a precompiled compute kernel
// from C+.
//
// Position: see docs/GPU.md. C+ is a CONSUMER of GPU vendor SDKs, not
// a provider of a unified compute abstraction. MPS *is* Apple's tuned
// implementation; we bind it, we don't reimplement it.
//
// API shape mirrors the rest of vendor/metal: every wrapper carries
// `pub raw: *u8` (the ObjC object pointer), every wrapper has a `Drop`
// impl that `objc_release`s the pointer, factories return
// `Result[T, MetalError]` for the failure paths Apple actually
// reports.

import "./runtime" as runtime;
import "./buffer" as buffer;
import "./device" as device;
import "./queue" as queue;
import "stdlib/result" as result;

extern fn objc_getClass(name: *u8) -> *u8;

// ---------------- MPS data types ----------------
//
// MPSDataType is a 32-bit packed enum where the high bits encode the
// data-type family (Float / Int / UInt / Bool / Normalized) and the
// low bits encode the bit-width. The constants below match Apple's
// header values verbatim (MPSCoreTypes.h):
//
//   MPSDataTypeFloatBit         = 0x10000000
//   MPSDataTypeFloat32          = MPSDataTypeFloatBit | 32 = 0x10000020
//   MPSDataTypeFloat16          = MPSDataTypeFloatBit | 16 = 0x10000010
//   MPSDataTypeSignedBit        = 0x20000000
//   MPSDataTypeInt32            = MPSDataTypeSignedBit | 32 = 0x20000020
//   MPSDataTypeInt8             = MPSDataTypeSignedBit | 8  = 0x20000008
//   MPSDataTypeUInt32           = 32 (no high-bit family)
//   MPSDataTypeUInt8            = 8
//
// We expose only the dtypes used by the matmul/matvec surface. Add
// more as workloads require.

pub enum DataType {
    F32,
    F16,
    I32,
    I8,
    U32,
    U8,
}

fn dtype_to_raw(d: DataType) -> u32 {
    let v: u32 = match d {
        DataType::F32 => 0x10000020 as u32,
        DataType::F16 => 0x10000010 as u32,
        DataType::I32 => 0x20000020 as u32,
        DataType::I8 => 0x20000008 as u32,
        DataType::U32 => 32 as u32,
        DataType::U8 => 8 as u32,
    };
    return v;
}

// ---------------- MPSMatrixDescriptor ----------------
//
// Describes the shape + dtype + stride of a matrix view into an
// MTLBuffer. The descriptor itself owns no buffer storage — it's
// just metadata. Apple's API: `+matrixDescriptorWithRows:columns:
// rowBytes:dataType:` returns an autoreleased descriptor.

pub struct MatrixDescriptor {
    pub raw: *u8,
}

impl MatrixDescriptor {
    pub fn new(rows: usize, columns: usize, row_bytes: usize, dtype: DataType) -> MatrixDescriptor {
        let cls: *u8 = unsafe { objc_getClass(#str_ptr("MPSMatrixDescriptor\0")) };
        let dt: u32 = dtype_to_raw(dtype);
        let raw: *u8 = unsafe {
            #msg_send(
                cls,
                "matrixDescriptorWithRows:columns:rowBytes:dataType:",
                rows as u64,
                columns as u64,
                row_bytes as u64,
                dt as u64,
            ) -> *u8
        };
        // `+matrixDescriptorWith...` returns +0 (autoreleased). Retain
        // so our `Drop` impl doesn't release something we don't own.
        if raw != unsafe { 0 as *u8 } {
            unsafe { #msg_send(raw, "retain") -> *u8; }
        }
        return MatrixDescriptor { raw: raw };
    }

    fn drop(mut this) {
        runtime::release(this.raw);
        this.raw = unsafe { 0 as *u8 };
        return;
    }
}

// ---------------- MPSMatrix ----------------
//
// Couples an MTLBuffer with an MPSMatrixDescriptor. The MPSMatrix
// retains the buffer internally, so the caller can drop their
// `metal::Buffer` after passing it here (or keep it, either works).
//
// We hold `raw` for the MPSMatrix object only; the underlying buffer
// is the consumer's lifetime concern.

pub struct Matrix {
    pub raw: *u8,
}

impl Matrix {
    // Takes both `buf` and `desc` by `borrow` because MPSMatrix
    // internally `retain`s the underlying MTLBuffer and MPSMatrixDescriptor.
    // Caller keeps owning their original handles; both refcounts are
    // released independently at scope exit (callers' Drops + MPSMatrix's
    // Drop when this wrapper goes out of scope).
    pub fn new(borrow buf: buffer::Buffer, borrow desc: MatrixDescriptor) -> Matrix {
        let cls: *u8 = unsafe { objc_getClass(#str_ptr("MPSMatrix\0")) };
        let alloc_obj: *u8 = unsafe { #msg_send(cls, "alloc") -> *u8 };
        let initialized: *u8 = unsafe {
            #msg_send(alloc_obj, "initWithBuffer:descriptor:", buf.raw, desc.raw) -> *u8
        };
        return Matrix { raw: initialized };
    }

    fn drop(mut this) {
        runtime::release(this.raw);
        this.raw = unsafe { 0 as *u8 };
        return;
    }
}

// ---------------- MPSMatrixMultiplication ----------------
//
// Apple's tuned matmul kernel. The init takes the device + transpose
// flags + shape + alpha/beta scalars; encode is where the work is
// scheduled onto a command buffer.
//
// Operates on f32 / f16 matrices (other dtypes need MPSMatrixDecomposition
// or different MPS classes — out of scope for the matmul primitive).

pub struct MatrixMultiplication {
    pub raw: *u8,
}

impl MatrixMultiplication {
    pub fn new(
        borrow dev: device::Device,
        transpose_left: bool,
        transpose_right: bool,
        result_rows: usize,
        result_columns: usize,
        interior_columns: usize,
        alpha: f64,
        beta: f64,
    ) -> result::Result[MatrixMultiplication, runtime::MetalError] {
        let cls: *u8 = unsafe { objc_getClass(#str_ptr("MPSMatrixMultiplication\0")) };
        let alloc_obj: *u8 = unsafe { #msg_send(cls, "alloc") -> *u8 };
        // BOOL is 1 byte on aarch64-darwin; pass as i8.
        let tl: i8 = if transpose_left { 1 as i8 } else { 0 as i8 };
        let tr: i8 = if transpose_right { 1 as i8 } else { 0 as i8 };
        let initialized: *u8 = unsafe {
            #msg_send(
                alloc_obj,
                "initWithDevice:transposeLeft:transposeRight:resultRows:resultColumns:interiorColumns:alpha:beta:",
                dev.raw,
                tl,
                tr,
                result_rows as u64,
                result_columns as u64,
                interior_columns as u64,
                alpha,
                beta,
            ) -> *u8
        };
        if initialized == unsafe { 0 as *u8 } {
            return result::Result[MatrixMultiplication, runtime::MetalError]::Err(
                runtime::MetalError::PipelineCreationFailed,
            );
        }
        return result::Result[MatrixMultiplication, runtime::MetalError]::Ok(
            MatrixMultiplication { raw: initialized },
        );
    }

    // Borrow everything: encodeToCommandBuffer does NOT transfer
    // ownership of any arg. The kernel is recorded into the command
    // buffer; encoding doesn't release any of these objects. Caller
    // keeps using them (commit / wait_until_completed on cmd_buf,
    // read-back on `out`).
    pub fn encode_to(
        this,
        borrow cmd_buf: queue::CommandBuffer,
        borrow lhs: Matrix,
        borrow rhs: Matrix,
        borrow out: Matrix,
    ) {
        unsafe {
            #msg_send(
                this.raw,
                "encodeToCommandBuffer:leftMatrix:rightMatrix:resultMatrix:",
                cmd_buf.raw,
                lhs.raw,
                rhs.raw,
                out.raw,
            );
        }
        return;
    }

    fn drop(mut this) {
        runtime::release(this.raw);
        this.raw = unsafe { 0 as *u8 };
        return;
    }
}

// ---------------- MPSMatrixVectorMultiplication ----------------
//
// Matrix×vector — same shape rules as matmul but optimized for the
// matvec case. Apple's API treats this as a separate class because
// the dispatch geometry is different (one threadgroup per row vs the
// tile-based matmul layout).

pub struct MatrixVectorMultiplication {
    pub raw: *u8,
}

impl MatrixVectorMultiplication {
    pub fn new(
        borrow dev: device::Device,
        transpose: bool,
        rows: usize,
        columns: usize,
        alpha: f64,
        beta: f64,
    ) -> result::Result[MatrixVectorMultiplication, runtime::MetalError] {
        let cls: *u8 = unsafe { objc_getClass(#str_ptr("MPSMatrixVectorMultiplication\0")) };
        let alloc_obj: *u8 = unsafe { #msg_send(cls, "alloc") -> *u8 };
        let t: i8 = if transpose { 1 as i8 } else { 0 as i8 };
        let initialized: *u8 = unsafe {
            #msg_send(
                alloc_obj,
                "initWithDevice:transpose:rows:columns:alpha:beta:",
                dev.raw,
                t,
                rows as u64,
                columns as u64,
                alpha,
                beta,
            ) -> *u8
        };
        if initialized == unsafe { 0 as *u8 } {
            return result::Result[MatrixVectorMultiplication, runtime::MetalError]::Err(
                runtime::MetalError::PipelineCreationFailed,
            );
        }
        return result::Result[MatrixVectorMultiplication, runtime::MetalError]::Ok(
            MatrixVectorMultiplication { raw: initialized },
        );
    }

    // Note on the vector arguments: MPSMatrixVectorMultiplication's
    // encode method takes MPSVector inputs. We don't yet bind
    // MPSVector — for now, callers represent vectors as a 1×N or N×1
    // MPSMatrix and use MatrixMultiplication instead. Adding MPSVector
    // is a follow-up when a consumer needs the optimized matvec path
    // beyond what matmul-with-1D-shape gives.

    fn drop(mut this) {
        runtime::release(this.raw);
        this.raw = unsafe { 0 as *u8 };
        return;
    }
}

// ---------------- Unit tests ----------------
//
// MPS depends on a real Metal device + the MetalPerformanceShaders
// framework. Tests run on macOS only and produce a real GPU dispatch
// for the correctness check.

#[test]
fn test_dtype_raw_values_match_apple_headers() {
    // Pin the MPSDataType enum values against Apple's published
    // constants. If these ever drift, ALL existing matmuls will
    // silently mis-interpret their buffers — make the breakage loud.
    assert dtype_to_raw(DataType::F32) == (0x10000020 as u32);
    assert dtype_to_raw(DataType::F16) == (0x10000010 as u32);
    assert dtype_to_raw(DataType::I32) == (0x20000020 as u32);
    assert dtype_to_raw(DataType::I8) == (0x20000008 as u32);
    assert dtype_to_raw(DataType::U32) == (32 as u32);
    assert dtype_to_raw(DataType::U8) == (8 as u32);
}

#[test]
fn test_matrix_descriptor_constructs() {
    let d: MatrixDescriptor = MatrixDescriptor::new(
        4 as usize, 4 as usize, (4 *% 4) as usize, DataType::F32,
    );
    assert unsafe { d.raw as usize } != (0 as usize);
}

#[test]
fn test_matrix_constructs_from_buffer() {
    guard let result::Result[device::Device, runtime::MetalError]::Ok(dev) = device::default() else {
        assert false;
        return;
    };
    let buf: buffer::Buffer = dev.new_buffer((4 *% 4 *% 4) as usize);
    let desc: MatrixDescriptor = MatrixDescriptor::new(
        4 as usize, 4 as usize, (4 *% 4) as usize, DataType::F32,
    );
    let m: Matrix = Matrix::new(buf, desc);
    assert unsafe { m.raw as usize } != (0 as usize);
}

#[test]
fn test_matrix_multiplication_constructs() {
    guard let result::Result[device::Device, runtime::MetalError]::Ok(dev) = device::default() else {
        assert false;
        return;
    };
    guard let result::Result[MatrixMultiplication, runtime::MetalError]::Ok(mm) = MatrixMultiplication::new(
        dev,
        false, false,
        4 as usize, 4 as usize, 4 as usize,
        1.0f64, 0.0f64,
    ) else {
        assert false;
        return;
    };
    assert unsafe { mm.raw as usize } != (0 as usize);
}

#[test]
fn test_2x2_matmul_identity_correctness() {
    // A = [[1, 2], [3, 4]]     I = [[1, 0], [0, 1]]    A * I = A
    // All matrices row-major f32. Buffer layout: 4 floats = 16 bytes.
    guard let result::Result[device::Device, runtime::MetalError]::Ok(dev) = device::default() else {
        assert false;
        return;
    };

    let a_data: [f32; 4] = [1.0f32, 2.0f32, 3.0f32, 4.0f32];
    let i_data: [f32; 4] = [1.0f32, 0.0f32, 0.0f32, 1.0f32];

    let buf_a: buffer::Buffer = dev.new_buffer_from_slice(
        unsafe { #slice_from_raw_parts(#addr_of(a_data) as *u8, 16 as usize) },
    );
    let buf_i: buffer::Buffer = dev.new_buffer_from_slice(
        unsafe { #slice_from_raw_parts(#addr_of(i_data) as *u8, 16 as usize) },
    );
    let buf_c: buffer::Buffer = dev.new_buffer(16 as usize);

    let desc_a: MatrixDescriptor = MatrixDescriptor::new(2 as usize, 2 as usize, 8 as usize, DataType::F32);
    let desc_i: MatrixDescriptor = MatrixDescriptor::new(2 as usize, 2 as usize, 8 as usize, DataType::F32);
    let desc_c: MatrixDescriptor = MatrixDescriptor::new(2 as usize, 2 as usize, 8 as usize, DataType::F32);

    // `Matrix::new` takes `borrow` on both args — buffer + descriptor
    // are still owned by the caller after this; MPSMatrix retains them
    // internally. We need this so `buf_c` survives below for readback.
    let m_a: Matrix = Matrix::new(buf_a, desc_a);
    let m_i: Matrix = Matrix::new(buf_i, desc_i);
    let m_c: Matrix = Matrix::new(buf_c, desc_c);

    guard let result::Result[MatrixMultiplication, runtime::MetalError]::Ok(mm) = MatrixMultiplication::new(
        dev,
        false, false,
        2 as usize, 2 as usize, 2 as usize,
        1.0f64, 0.0f64,
    ) else {
        assert false;
        return;
    };

    let queue: queue::CommandQueue = dev.new_command_queue();
    let cmd_buf: queue::CommandBuffer = queue.new_command_buffer();
    mm.encode_to(cmd_buf, m_a, m_i, m_c);
    cmd_buf.commit();
    cmd_buf.wait_until_completed();

    // Read back. The result must equal A bit-for-bit.
    let mut out: [f32; 4] = [0.0f32, 0.0f32, 0.0f32, 0.0f32];
    let _copied: usize = buf_c.copy_to_slice(
        unsafe { #slice_from_raw_parts(#addr_of(out) as *u8, 16 as usize) },
    );
    assert out[0] == 1.0f32;
    assert out[1] == 2.0f32;
    assert out[2] == 3.0f32;
    assert out[3] == 4.0f32;
}
