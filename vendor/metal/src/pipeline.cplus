// vendor/metal/src/pipeline.cplus — shader libraries and pipelines.

import "./runtime" as runtime;
import "stdlib/result" as result;

pub struct Library {
    pub raw: *u8,
}

pub struct Function {
    pub raw: *u8,
}

pub struct ComputePipelineState {
    pub raw: *u8,
}

impl Library {
    pub fn new_function(this, name: str) -> result::Result[Function, runtime::MetalError] {
        if this.raw == unsafe { 0 as *u8 } {
            return result::Result[Function, runtime::MetalError]::Err(runtime::MetalError::FunctionNotFound);
        }
        let ns_name: *u8 = runtime::ns_string(name);
        let selector: *u8 = runtime::sel(#str_ptr("newFunctionWithName:\0"));
        let func_raw: *u8 = runtime::msg_id_id(this.raw, selector, ns_name);
        // `stringWithBytes:length:encoding:` returns an autoreleased
        // NSString. Without an autorelease pool active (the typical case
        // outside an AppKit run loop), it would leak. Release explicitly:
        // `newFunctionWithName:` retains the name internally if it needs
        // it past the call, so it's safe to drop our reference here.
        runtime::release(ns_name);
        if func_raw == unsafe { 0 as *u8 } {
            return result::Result[Function, runtime::MetalError]::Err(runtime::MetalError::FunctionNotFound);
        }
        return result::Result[Function, runtime::MetalError]::Ok(Function { raw: func_raw });
    }

    fn drop(ref this) {
        runtime::release(this.raw);
        this.raw = unsafe { 0 as *u8 };
        return;
    }
}

impl Function {
    fn drop(ref this) {
        runtime::release(this.raw);
        this.raw = unsafe { 0 as *u8 };
        return;
    }
}

impl ComputePipelineState {
    pub fn new(device_raw: *u8, function: Function) -> result::Result[ComputePipelineState, runtime::MetalError] {
        // v0.0.12 — `borrow function`: `newComputePipelineStateWithFunction:`
        // retains the function internally if it keeps it. The caller may
        // want to create multiple pipelines from the same function (the
        // standard ObjC pattern); consuming it precluded that. Pre-fix
        // post-v0.0.10 default-move dropped the cpc Function wrapper at
        // fn-exit, releasing the underlying MTLFunction before Metal had
        // safely retained it.
        if device_raw == unsafe { 0 as *u8 } || function.raw == unsafe { 0 as *u8 } {
            return result::Result[ComputePipelineState, runtime::MetalError]::Err(runtime::MetalError::PipelineCreationFailed);
        }
        let selector: *u8 = runtime::sel(#str_ptr("newComputePipelineStateWithFunction:error:\0"));
        let null_err: *u8 = unsafe { 0 as *u8 };
        let pipeline_raw: *u8 = runtime::msg_id_pipeline(device_raw, selector, function.raw, null_err);
        if pipeline_raw == unsafe { 0 as *u8 } {
            return result::Result[ComputePipelineState, runtime::MetalError]::Err(runtime::MetalError::PipelineCreationFailed);
        }
        return result::Result[ComputePipelineState, runtime::MetalError]::Ok(ComputePipelineState { raw: pipeline_raw });
    }

    fn drop(ref this) {
        runtime::release(this.raw);
        this.raw = unsafe { 0 as *u8 };
        return;
    }
}
