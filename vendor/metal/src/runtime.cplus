// vendor/metal/src/runtime.cplus — Objective-C runtime bindings and helpers for Metal.
//
// **String literal convention.** Every Objective-C selector and class
// name passed to `sel()` / `cls()` is a `\0`-terminated C string. We
// write them as plain `str` literals with a trailing `\0`, then call
// `#str_ptr(...)` to get the `*u8` start address. The trailing NUL is
// what `sel_registerName` / `objc_getClass` actually scan for; cpc's
// `str` is just a (ptr, len) view that happens to include the NUL.
// Note that `#str_len("Foo\0")` returns 4, NOT 3 — the NUL counts as a
// byte. If you ever pass these strings to a `(ptr, len)` API, slice
// off the trailing byte first.

extern fn objc_getClass(name: *u8) -> *u8;
extern fn sel_registerName(name: *u8) -> *u8;
extern fn objc_release(obj: *u8);
extern fn dispatch_data_create(buffer: *u8, size: usize, queue: *u8, destructor: *u8) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id(recv: *u8, sel: *u8) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_id(recv: *u8, sel: *u8, arg: *u8) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_id_ptr(recv: *u8, sel: *u8, arg: *u8, err_out: *u8) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_void(recv: *u8, sel: *u8);

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_ptr_len_opt(recv: *u8, sel: *u8, ptr: *u8, len: usize, opts: u64) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_ptr_len_enc(recv: *u8, sel: *u8, ptr: *u8, len: usize, enc: u64) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_ptr_len_free(recv: *u8, sel: *u8, ptr: *u8, len: usize, free_when_done: i8) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_buf_idx(recv: *u8, sel: *u8, buf: *u8, offset: usize, idx: usize);

#[link_name = "objc_msgSend"]
extern fn objc_msg_ptr(recv: *u8, sel: *u8) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_u64(recv: *u8, sel: *u8) -> u64;

#[link_name = "objc_msgSend"]
extern fn objc_msg_u64_u64(recv: *u8, sel: *u8, arg: u64) -> u64;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_usize_u64(recv: *u8, sel: *u8, len: usize, opts: u64) -> *u8;

extern fn MTLCreateSystemDefaultDevice() -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_pipeline(recv: *u8, sel: *u8, fn_obj: *u8, err_out: *u8) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_pipeline(recv: *u8, sel: *u8, pipeline: *u8);

#[repr(C)]
struct MTLSize {
    width: usize,
    height: usize,
    depth: usize,
}

// Structured error type for Metal operations. Replaces the v0.0.9
// `Option[T]` factory returns — callers get a discriminant instead
// of an unspecific `None`, so they can distinguish "no Metal device
// on this host" from "shader compile failed" without parsing
// NSError strings.
enum MetalError {
    NoDefaultDevice,
    LibraryLoadFailed,
    FunctionNotFound,
    PipelineCreationFailed,
}

#[link_name = "objc_msgSend"]
extern fn objc_msg_dispatch(
    recv: *u8,
    sel: *u8,
    groups: *MTLSize,
    per_group: *MTLSize,
);

// Helpers
fn cls(name: *u8) -> *u8 {
    return unsafe { objc_getClass(name) };
}

fn sel(name: *u8) -> *u8 {
    return unsafe { sel_registerName(name) };
}

fn msg_id(recv: *u8, selector: *u8) -> *u8 {
    return unsafe { objc_msg_id(recv, selector) };
}

fn msg_id_id(recv: *u8, selector: *u8, arg: *u8) -> *u8 {
    return unsafe { objc_msg_id_id(recv, selector, arg) };
}

fn msg_id_id_ptr(recv: *u8, selector: *u8, arg: *u8, err_out: *u8) -> *u8 {
    return unsafe { objc_msg_id_id_ptr(recv, selector, arg, err_out) };
}

fn msg_void(recv: *u8, selector: *u8) {
    unsafe { objc_msg_void(recv, selector); };
}

fn msg_id_ptr_len_opt(recv: *u8, selector: *u8, ptr: *u8, len: usize, opts: u64) -> *u8 {
    return unsafe { objc_msg_id_ptr_len_opt(recv, selector, ptr, len, opts) };
}

fn msg_void_buf_idx(recv: *u8, selector: *u8, buf: *u8, offset: usize, idx: usize) {
    unsafe { objc_msg_void_buf_idx(recv, selector, buf, offset, idx); };
}

fn msg_ptr(recv: *u8, selector: *u8) -> *u8 {
    return unsafe { objc_msg_ptr(recv, selector) };
}

fn msg_u64(recv: *u8, selector: *u8) -> u64 {
    return unsafe { objc_msg_u64(recv, selector) };
}

fn msg_id_usize_u64(recv: *u8, selector: *u8, len: usize, opts: u64) -> *u8 {
    return unsafe { objc_msg_id_usize_u64(recv, selector, len, opts) };
}

fn mtl_create_system_default_device() -> *u8 {
    return unsafe { MTLCreateSystemDefaultDevice() };
}

// Release a +1-retained Objective-C object. Safe to call with a null
// pointer (objc_release tolerates nil).
fn release(obj: *u8) {
    if obj == unsafe { 0 as *u8 } { return; }
    unsafe { objc_release(obj); }
    return;
}

fn msg_id_pipeline(recv: *u8, selector: *u8, fn_obj: *u8, err_out: *u8) -> *u8 {
    return unsafe { objc_msg_id_pipeline(recv, selector, fn_obj, err_out) };
}

fn msg_void_pipeline(recv: *u8, selector: *u8, pipeline: *u8) {
    unsafe { objc_msg_void_pipeline(recv, selector, pipeline); };
}

fn msg_dispatch(recv: *u8, selector: *u8, groups: MTLSize, per_group: MTLSize) {
    // v0.0.9 follow-up (addr_of): pre-`addr_of` this had to malloc
    // a 48-byte slot, memcpy both MTLSize args in, dispatch, and free.
    // Now the by-value parameters live on the stack and we pass their
    // addresses directly. Net: 0 mallocs per dispatch call.
    unsafe { objc_msg_dispatch(recv, selector, #addr_of(groups), #addr_of(per_group)); }
    return;
}

// Converts a C+ str to an Objective-C NSString.
// Retains or copies the string bytes.
fn ns_string(s: str) -> *u8 {
    let clazz: *u8 = cls(#str_ptr("NSString\0"));
    let selector: *u8 = sel(#str_ptr("stringWithBytes:length:encoding:\0"));
    let utf8_encoding: u64 = 4 as u64; // NSUTF8StringEncoding
    return unsafe { objc_msg_id_ptr_len_enc(clazz, selector, #str_ptr(s), #str_len(s), utf8_encoding) };
}

// Wraps pre-allocated bytes as an NSData without copying them.
fn ns_data_view(ptr: *u8, len: usize) -> *u8 {
    let clazz: *u8 = cls(#str_ptr("NSData\0"));
    let selector: *u8 = sel(#str_ptr("dataWithBytesNoCopy:length:freeWhenDone:\0"));
    return unsafe { objc_msg_id_ptr_len_free(clazz, selector, ptr, len, 0 as i8) };
}

// Creates a dispatch_data_t from raw bytes.
fn ns_dispatch_data(ptr: *u8, len: usize) -> *u8 {
    return unsafe { dispatch_data_create(ptr, len, 0 as *u8, 0 as *u8) };
}

// ---------------- Unit tests ----------------
// Selector and class registration are pure runtime queries — safe to
// run in unit-test context. ns_string/ns_data_view return objects we
// can interrogate via length selectors without any GPU side effects.

#[test]
fn test_sel_registers_known_selector() {
    let s: *u8 = sel(#str_ptr("alloc\0"));
    assert unsafe { s as usize } != (0 as usize);
}

#[test]
fn test_cls_resolves_nsstring() {
    let c: *u8 = cls(#str_ptr("NSString\0"));
    assert unsafe { c as usize } != (0 as usize);
}

#[test]
fn test_cls_unknown_class_is_null() {
    let c: *u8 = cls(#str_ptr("NoSuchClassName_zzz\0"));
    assert unsafe { c as usize } == (0 as usize);
}

#[test]
fn test_ns_string_round_trips_length() {
    let s: *u8 = ns_string("hello");
    assert unsafe { s as usize } != (0 as usize);
    let len_sel: *u8 = sel(#str_ptr("length\0"));
    let n: u64 = msg_u64(s, len_sel);
    assert n == (5 as u64);
    release(s);
}

#[test]
fn test_release_tolerates_null() {
    release(unsafe { 0 as *u8 });
    assert true;
}
