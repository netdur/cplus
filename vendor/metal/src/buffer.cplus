// vendor/metal/src/buffer.cplus — GPU device buffer operations.

import "./runtime" as runtime;

extern fn memcpy(dest: *u8, src: *u8, n: usize) -> *u8;

pub struct Buffer {
    pub raw: *u8,
    pub size: usize,
}

impl Buffer {
    pub fn contents(this) -> *u8 {
        if this.raw == unsafe { 0 as *u8 } {
            return unsafe { 0 as *u8 };
        }
        let selector: *u8 = runtime::sel(#str_ptr("contents\0"));
        return runtime::msg_ptr(this.raw, selector);
    }

    // v0.0.9 follow-up: `copy_to_slice` / `copy_from_slice` now
    // **return the byte count actually transferred** instead of
    // silently truncating. The caller can compare against
    // `#slice_len(slice)` to detect a too-small buffer; pre-fix
    // they got no signal at all.
    pub fn copy_to_slice(this, slice: u8[]) -> usize {
        let n: usize = #slice_len(slice);
        let src: *u8 = this.contents();
        if src == unsafe { 0 as *u8 } {
            return 0 as usize;
        }
        let dest: *u8 = unsafe { #slice_ptr(slice) };
        let bytes_to_copy: usize = if n < this.size { n } else { this.size };
        if bytes_to_copy > (0 as usize) {
            unsafe { memcpy(dest, src, bytes_to_copy); }
        }
        return bytes_to_copy;
    }

    pub fn copy_from_slice(this, slice: u8[]) -> usize {
        let n: usize = #slice_len(slice);
        let dest: *u8 = this.contents();
        if dest == unsafe { 0 as *u8 } {
            return 0 as usize;
        }
        let src: *u8 = unsafe { #slice_ptr(slice) };
        let bytes_to_copy: usize = if n < this.size { n } else { this.size };
        if bytes_to_copy > (0 as usize) {
            unsafe { memcpy(dest, src, bytes_to_copy); }
        }
        return bytes_to_copy;
    }

    fn drop(ref this) {
        runtime::release(this.raw);
        this.raw = unsafe { 0 as *u8 };
        return;
    }
}
