    OneMinusBlendAlpha,
    Source1Color,
    OneMinusSource1Color,
    Source1Alpha,
    OneMinusSource1Alpha,
    Unspecialized,
}

fn blend_factor_raw(v: BlendFactor) -> i64 {
    return match v {
        BlendFactor::Zero => { 0 as i64 },
        BlendFactor::One => { 1 as i64 },
        BlendFactor::SourceColor => { 2 as i64 },
        BlendFactor::OneMinusSourceColor => { 3 as i64 },
        BlendFactor::SourceAlpha => { 4 as i64 },
        BlendFactor::OneMinusSourceAlpha => { 5 as i64 },
        BlendFactor::DestinationColor => { 6 as i64 },
        BlendFactor::OneMinusDestinationColor => { 7 as i64 },
        BlendFactor::DestinationAlpha => { 8 as i64 },
        BlendFactor::OneMinusDestinationAlpha => { 9 as i64 },
        BlendFactor::SourceAlphaSaturated => { 10 as i64 },
        BlendFactor::BlendColor => { 11 as i64 },
        BlendFactor::OneMinusBlendColor => { 12 as i64 },
        BlendFactor::BlendAlpha => { 13 as i64 },
        BlendFactor::OneMinusBlendAlpha => { 14 as i64 },
        BlendFactor::Source1Color => { 15 as i64 },
        BlendFactor::OneMinusSource1Color => { 16 as i64 },
        BlendFactor::Source1Alpha => { 17 as i64 },
        BlendFactor::OneMinusSource1Alpha => { 18 as i64 },
        BlendFactor::Unspecialized => { 19 as i64 },
    };
}

fn blend_factor_from_raw(raw: i64) -> BlendFactor {
    if raw == (1 as i64) { return BlendFactor::One; }
    if raw == (2 as i64) { return BlendFactor::SourceColor; }
    if raw == (3 as i64) { return BlendFactor::OneMinusSourceColor; }
    if raw == (4 as i64) { return BlendFactor::SourceAlpha; }
    if raw == (5 as i64) { return BlendFactor::OneMinusSourceAlpha; }
    if raw == (6 as i64) { return BlendFactor::DestinationColor; }
    if raw == (7 as i64) { return BlendFactor::OneMinusDestinationColor; }
    if raw == (8 as i64) { return BlendFactor::DestinationAlpha; }
    if raw == (9 as i64) { return BlendFactor::OneMinusDestinationAlpha; }
    if raw == (10 as i64) { return BlendFactor::SourceAlphaSaturated; }
    if raw == (11 as i64) { return BlendFactor::BlendColor; }
    if raw == (12 as i64) { return BlendFactor::OneMinusBlendColor; }
    if raw == (13 as i64) { return BlendFactor::BlendAlpha; }
    if raw == (14 as i64) { return BlendFactor::OneMinusBlendAlpha; }
    if raw == (15 as i64) { return BlendFactor::Source1Color; }
    if raw == (16 as i64) { return BlendFactor::OneMinusSource1Color; }
    if raw == (17 as i64) { return BlendFactor::Source1Alpha; }
    if raw == (18 as i64) { return BlendFactor::OneMinusSource1Alpha; }
    if raw == (19 as i64) { return BlendFactor::Unspecialized; }
    return BlendFactor::Zero;
}

