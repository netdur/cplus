    fn from_raw(ptr: *u8) -> Library { return Library { _obj: ptr }; }

    fn new_function_with_name(this, function_name: str) -> option::Option[Function] {
        let obj: *u8 = rt::msg_id_id(this._obj, rt::sel(#str_ptr("newFunctionWithName:\0")), bridge::nsstring(function_name));
        if obj == { 0 as *u8 } {
            return option::Option[Function]::None;
        }
        return option::some(Function::from_raw(obj));
    }

    // SKIPPED `newFunctionWithName:constantValues:error:`: (return, arg) shape not yet modelled
    // SKIPPED `newFunctionWithName:constantValues:completionHandler:`: block-method msgSend shape not modelled
    fn reflection_for_function_with_name(this, function_name: str) -> option::Option[FunctionReflection] {
        let obj: *u8 = rt::msg_id_id(this._obj, rt::sel(#str_ptr("reflectionForFunctionWithName:\0")), bridge::nsstring(function_name));
        if obj == { 0 as *u8 } {
            return option::Option[FunctionReflection]::None;
        }
        return option::some(FunctionReflection::from_raw(obj));
    }

    // SKIPPED `newFunctionWithDescriptor:completionHandler:`: block-method msgSend shape not modelled
    // SKIPPED `newFunctionWithDescriptor:error:`: (return, arg) shape not yet modelled
    // SKIPPED `newIntersectionFunctionWithDescriptor:completionHandler:`: block-method msgSend shape not modelled
    // SKIPPED `newIntersectionFunctionWithDescriptor:error:`: (return, arg) shape not yet modelled
    fn label(this) -> option::Option[text::Text] {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("label\0")));
        return bridge::to_text_option(ns);
    }

    fn set_label(this, label: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setLabel:\0")), bridge::nsstring(label));
    }

    fn device(this) -> Device {
        return Device::from_raw(rt::msg_id(this._obj, rt::sel(#str_ptr("device\0"))));
    }

    fn function_names(this) -> vec::Vec[text::Text] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("functionNames\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[text::Text] = vec::Vec[text::Text]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            let value: *u8 = rt::msg_id_u64(arr, at_sel, i);
            out.append(bridge::to_text(value));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn type_(this) -> LibraryType {
        return library_type_from_raw(rt::msg_i64(this._obj, rt::sel(#str_ptr("type\0"))));
    }

    fn install_name(this) -> option::Option[text::Text] {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("installName\0")));
        return bridge::to_text_option(ns);
    }

