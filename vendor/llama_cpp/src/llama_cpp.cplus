// vendor/llama_cpp/src/llama_cpp.cplus — C+ facade for llama.cpp's C API.
//
// Raw bindings are generated by cpc-bindgen from curated C headers:
//   - upstream/llama_cplus.h -> src/raw.cplus
//   - upstream/mtmd_cplus.h  -> src/mtmd_raw.cplus
//
// No C++ llama.cpp internals are bound. Multimodal support is exposed through
// the experimental C mtmd API and should remain isolated behind small wrappers.
//
// Naming-guideline notes (naming_guideline.md):
//   - raw handles are hidden behind `_`-prefixed `opaque` fields; the public
//     surface is role-named accessors and never exposes the void* handles.
//   - `load` collapses the old `LoadOptions` + `default_options()` pair into one
//     constructor with default-valued labeled params.
//   - absence/failure is a value: `Result`/`Option`/`Status`, never a sentinel.
//   - the swifty generation entry point returns an owned `Text`; the lower-level
//     buffer-filling variants stay available for callers that own the storage.
//
// Deliberate deviation (thin-binding pragmatism, matching the appkit pass):
//   - the manual decode/sample/token-to-piece loop primitives keep their token
//     (`i32`) and byte-buffer (`u8[]`) shapes. They mirror libllama's own loop
//     contract one-to-one; wrapping each in an owning type would obscure, not
//     clarify, the lower-level surface. The high-level `generate` covers the
//     common path with `Text` + labeled params.

import "stdlib/result" as result;
import "stdlib/option" as option;
import "stdlib/text" as text;
import "./raw" as raw;
import "./mtmd_raw" as mtmd_raw;

extern fn malloc(n: usize) -> *u8;
extern fn free(p: *u8);

type ModelParams = raw::llama_model_params;
type ContextParams = raw::llama_context_params;
type Batch = raw::llama_batch;
type MtmdContextParams = mtmd_raw::mtmd_context_params;
type MtmdCaps = mtmd_raw::mtmd_caps;
type MtmdInputText = mtmd_raw::mtmd_input_text;
type MtmdDecoderPos = mtmd_raw::mtmd_decoder_pos;

enum LlamaError {
    LoadFailed,
    ContextFailed,
    NullHandle,
    InvalidArgument,
    TokenizeFailed,
    DecodeFailed,
    SampleFailed,
    OutputTooSmall,
}

struct Session {
    opaque _model: *(),
    opaque _ctx: *(),
    opaque _vocab: *(),
    opaque _sampler: *(),
}

struct MtmdContext {
    opaque _raw: *(),
}

struct Bitmap {
    opaque _raw: *(),
}

struct InputChunks {
    opaque _raw: *(),
}

fn null() -> *() {
    return { 0 as *() };
}

fn is_null(p: *()) -> bool {
    return p == null();
}

fn backend_init() {
    raw::llama_backend_init();
    return;
}

fn backend_free() {
    raw::llama_backend_free();
    return;
}

fn default_model_params() -> raw::llama_model_params {
    return raw::llama_model_default_params();
}

fn default_context_params() -> raw::llama_context_params {
    return raw::llama_context_default_params();
}

// Load a GGUF model from `path` into a ready-to-run session.
//
// The tuning knobs are labeled parameters with defaults, so the common call is
// just `load("model.gguf")`; override only what you need, in any order:
//   load("model.gguf", context_size: 8192, gpu_layers: 0)
//
// `threads <= 0` (the default) leaves llama.cpp's own thread auto-detection in
// place; a positive value pins both the generation and batch thread counts.
fn load(
    path: str,
    context_size: u32 = 4096 as u32,
    gpu_layers: i32 = -1,
    threads: i32 = 0,
) -> result::Result[Session, LlamaError] {
    var mp: raw::llama_model_params = raw::llama_model_default_params();
    mp.n_gpu_layers = gpu_layers;

    let model: *() = raw::llama_model_load_from_file({ #str_ptr(path) as *i8 }, mp);
    if is_null(model) {
        return result::Result[Session, LlamaError]::Err(LlamaError::LoadFailed);
    }

    var cp: raw::llama_context_params = raw::llama_context_default_params();
    cp.n_ctx = context_size;
    if threads > 0 {
        cp.n_threads = threads;
        cp.n_threads_batch = threads;
    }

    let ctx: *() = raw::llama_init_from_model(model, cp);
    if is_null(ctx) {
        raw::llama_model_free(model);
        return result::Result[Session, LlamaError]::Err(LlamaError::ContextFailed);
    }

    let sampler: *() = raw::llama_sampler_init_greedy();
    if is_null(sampler) {
        raw::llama_free(ctx);
        raw::llama_model_free(model);
        return result::Result[Session, LlamaError]::Err(LlamaError::ContextFailed);
    }

    let vocab: *() = raw::llama_model_get_vocab(model);
    return result::Result[Session, LlamaError]::Ok(Session {
        _model: model,
        _ctx: ctx,
        _vocab: vocab,
        _sampler: sampler,
    });
}

impl Session {
    // The context window size (tokens) this session was created with.
    fn context_size(this) -> u32 {
        if is_null(this._ctx) {
            return 0 as u32;
        }
        return raw::llama_n_ctx(this._ctx);
    }

    // The on-disk/in-memory size of the loaded model, in bytes.
    fn model_size(this) -> u64 {
        if is_null(this._model) {
            return 0 as u64;
        }
        return raw::llama_model_size(this._model);
    }

    // Tokenize `prompt` into the caller-provided `tokens` buffer.
    //
    // Returns the number of tokens written. `add_special`/`parse_special` mirror
    // llama.cpp's flags and default to `false`; the BOS/EOS-adding common path is
    // `tokenize(prompt, into: buf, add_special: true)`.
    fn tokenize(
        this,
        prompt: str,
        into: i32[],
        add_special: bool = false,
        parse_special: bool = false,
    ) -> result::Result[usize, LlamaError] {
        if is_null(this._vocab) {
            return result::Result[usize, LlamaError]::Err(LlamaError::NullHandle);
        }
        let cap: usize = #slice_len(into);
        if cap > (2147483647 as usize) || #str_len(prompt) > (2147483647 as usize) {
            return result::Result[usize, LlamaError]::Err(LlamaError::InvalidArgument);
        }
        let n: i32 = raw::llama_tokenize(
            this._vocab,
            { #str_ptr(prompt) as *i8 },
            #str_len(prompt) as i32,
            { #slice_ptr(into) },
            cap as i32,
            add_special,
            parse_special,
        );
        if n < 0 {
            return result::Result[usize, LlamaError]::Err(LlamaError::TokenizeFailed);
        }
        return result::Result[usize, LlamaError]::Ok(n as usize);
    }

    // Decode `tokens` through the context. Returns the count decoded.
    fn decode(this, tokens: i32[]) -> result::Result[usize, LlamaError] {
        if is_null(this._ctx) {
            return result::Result[usize, LlamaError]::Err(LlamaError::NullHandle);
        }
        let n: usize = #slice_len(tokens);
        if n == (0 as usize) || n > (2147483647 as usize) {
            return result::Result[usize, LlamaError]::Err(LlamaError::InvalidArgument);
        }
        let batch: raw::llama_batch = raw::llama_batch_get_one({ #slice_ptr(tokens) }, n as i32);
        let rc: i32 = raw::llama_decode(this._ctx, batch);
        if rc != 0 {
            return result::Result[usize, LlamaError]::Err(LlamaError::DecodeFailed);
        }
        return result::Result[usize, LlamaError]::Ok(n);
    }

    // Sample the next token greedily from the current logits, and accept it into
    // the sampler's history.
    fn sample(this) -> result::Result[i32, LlamaError] {
        if is_null(this._ctx) || is_null(this._sampler) {
            return result::Result[i32, LlamaError]::Err(LlamaError::NullHandle);
        }
        let token: i32 = raw::llama_sampler_sample(this._sampler, this._ctx, -1);
        if token < 0 {
            return result::Result[i32, LlamaError]::Err(LlamaError::SampleFailed);
        }
        raw::llama_sampler_accept(this._sampler, token);
        return result::Result[i32, LlamaError]::Ok(token);
    }

    // Is `token` an end-of-generation token for this model's vocabulary?
    fn is_end_of_generation(this, token: i32) -> bool {
        if is_null(this._vocab) {
            return true;
        }
        return raw::llama_vocab_is_eog(this._vocab, token);
    }

    // Render `token` into the caller-provided `into` buffer. Returns the number
    // of bytes written. `special` (default `false`) controls rendering of
    // control tokens.
    fn token_piece(
        this,
        token: i32,
        into: u8[],
        special: bool = false,
    ) -> result::Result[usize, LlamaError] {
        if is_null(this._vocab) {
            return result::Result[usize, LlamaError]::Err(LlamaError::NullHandle);
        }
        let cap: usize = #slice_len(into);
        if cap > (2147483647 as usize) {
            return result::Result[usize, LlamaError]::Err(LlamaError::InvalidArgument);
        }
        let n: i32 = raw::llama_token_to_piece(
            this._vocab,
            token,
            { #slice_ptr(into) as *i8 },
            cap as i32,
            0,
            special,
        );
        if n < 0 {
            return result::Result[usize, LlamaError]::Err(LlamaError::OutputTooSmall);
        }
        return result::Result[usize, LlamaError]::Ok(n as usize);
    }

    // Greedily generate up to `max_new_tokens` from `prompt`, returning the
    // decoded continuation as an owned `Text`.
    //
    // This is the high-level entry point: it owns the token scratch buffer and
    // the output string, so the caller does not size anything. Generation stops
    // at the model's end-of-generation token or after `max_new_tokens`.
    fn generate(
        this,
        prompt: str,
        max_new_tokens: i32 = 256,
    ) -> result::Result[text::Text, LlamaError] {
        if is_null(this._ctx) || is_null(this._vocab) || is_null(this._sampler) {
            return result::Result[text::Text, LlamaError]::Err(LlamaError::NullHandle);
        }
        if max_new_tokens <= 0 || #str_len(prompt) > (2147483647 as usize) {
            return result::Result[text::Text, LlamaError]::Err(LlamaError::InvalidArgument);
        }

        let needed_raw: i32 = raw::llama_tokenize(
            this._vocab,
            { #str_ptr(prompt) as *i8 },
            #str_len(prompt) as i32,
            { 0 as *i32 },
            0,
            true,
            true,
        );
        let needed: i32 = if needed_raw < 0 { 0 - needed_raw } else { needed_raw };
        if needed <= 0 {
            return result::Result[text::Text, LlamaError]::Err(LlamaError::TokenizeFailed);
        }

        let bytes: usize = (needed as usize) *% #size_of::[i32]();
        let raw_tokens: *u8 = { malloc(bytes) };
        if raw_tokens == { 0 as *u8 } {
            return result::Result[text::Text, LlamaError]::Err(LlamaError::InvalidArgument);
        }
        let token_ptr: *i32 = { raw_tokens as *i32 };
        let got: i32 = raw::llama_tokenize(
            this._vocab,
            { #str_ptr(prompt) as *i8 },
            #str_len(prompt) as i32,
            token_ptr,
            needed,
            true,
            true,
        );
        if got <= 0 {
            { free(raw_tokens); }
            return result::Result[text::Text, LlamaError]::Err(LlamaError::TokenizeFailed);
        }

        let prompt_tokens: i32[] = { #slice_from_raw_parts(token_ptr, got as usize) };
        guard let result::Result[usize, LlamaError]::Ok(_decoded_prompt) =
            this.decode(prompt_tokens) else {
            { free(raw_tokens); }
            return result::Result[text::Text, LlamaError]::Err(LlamaError::DecodeFailed);
        };
        { free(raw_tokens); }

        var out: text::Text = text::new();
        // A token renders to at most ~128 UTF-8 bytes; this scratch covers it.
        let piece_cap: usize = 256 as usize;
        let piece_raw: *u8 = { malloc(piece_cap) };
        if piece_raw == { 0 as *u8 } {
            return result::Result[text::Text, LlamaError]::Err(LlamaError::InvalidArgument);
        }
        let piece_buf: u8[] = { #slice_from_raw_parts(piece_raw, piece_cap) };

        var i: i32 = 0;
        while i < max_new_tokens {
            guard let result::Result[i32, LlamaError]::Ok(token) = this.sample() else {
                { free(piece_raw); }
                return result::Result[text::Text, LlamaError]::Err(LlamaError::SampleFailed);
            };
            if this.is_end_of_generation(token) {
                { free(piece_raw); }
                return result::Result[text::Text, LlamaError]::Ok(out);
            }
            guard let result::Result[usize, LlamaError]::Ok(n_piece) =
                this.token_piece(token, into: piece_buf) else {
                { free(piece_raw); }
                return result::Result[text::Text, LlamaError]::Err(LlamaError::OutputTooSmall);
            };
            if n_piece > (0 as usize) {
                let piece: str = { #str_from_raw_parts(piece_raw, n_piece) };
                out.append(piece);
            }

            let one: [i32; 1] = [token];
            let one_slice: i32[] = { #slice_from_raw_parts(#addr_of(one[0]), 1 as usize) };
            guard let result::Result[usize, LlamaError]::Ok(_decoded) =
                this.decode(one_slice) else {
                { free(piece_raw); }
                return result::Result[text::Text, LlamaError]::Err(LlamaError::DecodeFailed);
            };
            i = i + 1;
        }
        { free(piece_raw); }
        return result::Result[text::Text, LlamaError]::Ok(out);
    }

    fn drop(ref this) {
        if !is_null(this._sampler) {
            raw::llama_sampler_free(this._sampler);
            this._sampler = null();
        }
        if !is_null(this._ctx) {
            raw::llama_free(this._ctx);
            this._ctx = null();
        }
        if !is_null(this._model) {
            raw::llama_model_free(this._model);
            this._model = null();
        }
        this._vocab = null();
        return;
    }
}

// ---------------- Multimodal (mtmd C API) ---------------------------------

fn mtmd_default_params() -> mtmd_raw::mtmd_context_params {
    return mtmd_raw::mtmd_context_params_default();
}

fn mtmd_caps_from_file(path: str) -> mtmd_raw::mtmd_caps {
    return mtmd_raw::mtmd_get_cap_from_file({ #str_ptr(path) as *i8 });
}

fn mtmd_init(
    session: Session,
    mmproj_path: str,
    params: mtmd_raw::mtmd_context_params,
) -> result::Result[MtmdContext, LlamaError] {
    if is_null(session._model) {
        return result::Result[MtmdContext, LlamaError]::Err(LlamaError::NullHandle);
    }
    let raw_ctx: *() = mtmd_raw::mtmd_init_from_file(
        { #str_ptr(mmproj_path) as *i8 },
        session._model,
        params,
    );
    if is_null(raw_ctx) {
        return result::Result[MtmdContext, LlamaError]::Err(LlamaError::LoadFailed);
    }
    return result::Result[MtmdContext, LlamaError]::Ok(MtmdContext { _raw: raw_ctx });
}

impl MtmdContext {
    fn supports_vision(this) -> bool {
        if is_null(this._raw) {
            return false;
        }
        return mtmd_raw::mtmd_support_vision(this._raw);
    }

    fn supports_audio(this) -> bool {
        if is_null(this._raw) {
            return false;
        }
        return mtmd_raw::mtmd_support_audio(this._raw);
    }

    fn drop(ref this) {
        if !is_null(this._raw) {
            mtmd_raw::mtmd_free(this._raw);
            this._raw = null();
        }
        return;
    }
}

fn bitmap_rgb(width: u32, height: u32, rgb: u8[]) -> result::Result[Bitmap, LlamaError] {
    let raw_bitmap: *() = mtmd_raw::mtmd_bitmap_init(width, height, { #slice_ptr(rgb) });
    if is_null(raw_bitmap) {
        return result::Result[Bitmap, LlamaError]::Err(LlamaError::InvalidArgument);
    }
    return result::Result[Bitmap, LlamaError]::Ok(Bitmap { _raw: raw_bitmap });
}

impl Bitmap {
    fn drop(ref this) {
        if !is_null(this._raw) {
            mtmd_raw::mtmd_bitmap_free(this._raw);
            this._raw = null();
        }
        return;
    }
}

// ---------------- Tests ---------------------------------------------------
//
// These exercise the pure-logic guard paths and small helpers that do NOT call
// into libllama: a session with null handles short-circuits every accessor and
// fallible method before any `llama_*` symbol is reached, and its `drop` is a
// no-op (all handles already null). So they run host-side with no model loaded
// and no libllama linked. The real model-loading paths are integration-tested
// against a built libllama, out of scope for these unit tests.

#[test]
fn test_null_helpers() {
    assert is_null(null());
    let p: *() = { 1 as *() };
    assert !is_null(p);
}

fn null_session() -> Session {
    return Session {
        _model: null(),
        _ctx: null(),
        _vocab: null(),
        _sampler: null(),
    };
}

#[test]
fn test_null_session_accessors_are_safe() {
    let s: Session = null_session();
    assert s.context_size() == (0 as u32);
    assert s.model_size() == (0 as u64);
    // A model with no vocabulary treats every token as end-of-generation, which
    // is the safe answer for a generation loop that must terminate.
    assert s.is_end_of_generation(0);
}

#[test]
fn test_tokenize_on_null_vocab_reports_null_handle() {
    let s: Session = null_session();
    var buf: [i32; 4] = [0, 0, 0, 0];
    let into: i32[] = { #slice_from_raw_parts(#addr_of(buf[0]), 4 as usize) };
    match s.tokenize("hello", into: into) {
        result::Result[usize, LlamaError]::Err(e) => { assert e == LlamaError::NullHandle; }
        result::Result[usize, LlamaError]::Ok(_n) => { assert false; }
    }
    return;
}

#[test]
fn test_decode_empty_is_invalid_argument() {
    let s: Session = null_session();
    let empty: i32[] = { #slice_from_raw_parts({ 0 as *i32 }, 0 as usize) };
    // ctx is null, so the null-handle guard fires first.
    match s.decode(empty) {
        result::Result[usize, LlamaError]::Err(e) => { assert e == LlamaError::NullHandle; }
        result::Result[usize, LlamaError]::Ok(_n) => { assert false; }
    }
    return;
}

#[test]
fn test_sample_on_null_handles_reports_null_handle() {
    let s: Session = null_session();
    match s.sample() {
        result::Result[i32, LlamaError]::Err(e) => { assert e == LlamaError::NullHandle; }
        result::Result[i32, LlamaError]::Ok(_t) => { assert false; }
    }
    return;
}

#[test]
fn test_token_piece_on_null_vocab_reports_null_handle() {
    let s: Session = null_session();
    var buf: [u8; 8] = [0 as u8, 0 as u8, 0 as u8, 0 as u8, 0 as u8, 0 as u8, 0 as u8, 0 as u8];
    let into: u8[] = { #slice_from_raw_parts(#addr_of(buf[0]), 8 as usize) };
    match s.token_piece(0, into: into) {
        result::Result[usize, LlamaError]::Err(e) => { assert e == LlamaError::NullHandle; }
        result::Result[usize, LlamaError]::Ok(_n) => { assert false; }
    }
    return;
}

#[test]
fn test_generate_on_null_handles_reports_null_handle() {
    let s: Session = null_session();
    match s.generate("hi") {
        result::Result[text::Text, LlamaError]::Err(e) => { assert e == LlamaError::NullHandle; }
        result::Result[text::Text, LlamaError]::Ok(_t) => { assert false; }
    }
    return;
}

#[test]
fn test_generate_rejects_nonpositive_budget() {
    // Use non-null sentinel handles so the budget check (not the null guard) is
    // the path under test. No libllama call happens: the `max_new_tokens <= 0`
    // guard returns before tokenization.
    let s: Session = Session {
        _model: { 1 as *() },
        _ctx: { 1 as *() },
        _vocab: { 1 as *() },
        _sampler: { 1 as *() },
    };
    match s.generate("hi", max_new_tokens: 0) {
        result::Result[text::Text, LlamaError]::Err(e) => { assert e == LlamaError::InvalidArgument; }
        result::Result[text::Text, LlamaError]::Ok(_t) => { assert false; }
    }
    // Defuse drop: these are fake handles, never hand them to llama_*_free.
    var sink: Session = s;
    sink._model = null();
    sink._ctx = null();
    sink._vocab = null();
    sink._sampler = null();
}

#[test]
fn test_mtmd_and_bitmap_null_guards() {
    let c: MtmdContext = MtmdContext { _raw: null() };
    assert !c.supports_vision();
    assert !c.supports_audio();
}
