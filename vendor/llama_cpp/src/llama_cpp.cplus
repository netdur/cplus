// vendor/llama_cpp/src/llama_cpp.cplus — C+ facade for llama.cpp's C API.
//
// Raw bindings are generated by cpc-bindgen from curated C headers:
//   - upstream/llama_cplus.h -> src/raw.cplus
//   - upstream/mtmd_cplus.h  -> src/mtmd_raw.cplus
//
// No C++ llama.cpp internals are bound. Multimodal support is exposed through
// the experimental C mtmd API and should remain isolated behind small wrappers.

import "stdlib/result" as result;
import "./raw" as raw;
import "./mtmd_raw" as mtmd_raw;

extern fn malloc(n: usize) -> *u8;
extern fn free(p: *u8);

pub type ModelParams = raw::llama_model_params;
pub type ContextParams = raw::llama_context_params;
pub type Batch = raw::llama_batch;
pub type MtmdContextParams = mtmd_raw::mtmd_context_params;
pub type MtmdCaps = mtmd_raw::mtmd_caps;
pub type MtmdInputText = mtmd_raw::mtmd_input_text;
pub type MtmdDecoderPos = mtmd_raw::mtmd_decoder_pos;

pub enum LlamaError {
    LoadFailed,
    ContextFailed,
    NullHandle,
    InvalidArgument,
    TokenizeFailed,
    DecodeFailed,
    SampleFailed,
    OutputTooSmall,
}

pub struct LoadOptions {
    pub n_ctx: u32,
    pub n_gpu_layers: i32,
    pub n_threads: i32,
}

pub struct Session {
    opaque model: *(),
    opaque ctx: *(),
    opaque vocab: *(),
    opaque sampler: *(),
}

pub struct MtmdContext {
    opaque raw: *(),
}

pub struct Bitmap {
    opaque raw: *(),
}

pub struct InputChunks {
    opaque raw: *(),
}

fn null() -> *() {
    return unsafe { 0 as *() };
}

fn is_null(p: *()) -> bool {
    return p == null();
}

fn bool_i8(v: bool) -> i8 {
    return if v { 1 as i8 } else { 0 as i8 };
}

pub fn default_options() -> LoadOptions {
    return LoadOptions {
        n_ctx: 4096 as u32,
        n_gpu_layers: -1,
        n_threads: 0,
    };
}

pub fn backend_init() {
    raw::llama_backend_init();
    return;
}

pub fn backend_free() {
    raw::llama_backend_free();
    return;
}

pub fn default_model_params() -> raw::llama_model_params {
    return raw::llama_model_default_params();
}

pub fn default_context_params() -> raw::llama_context_params {
    return raw::llama_context_default_params();
}

pub fn load(path: str, opts: LoadOptions) -> result::Result[Session, LlamaError] {
    var mp: raw::llama_model_params = raw::llama_model_default_params();
    mp.n_gpu_layers = opts.n_gpu_layers;

    let model: *() = raw::llama_model_load_from_file(unsafe { #str_ptr(path) as *i8 }, mp);
    if is_null(model) {
        return result::Result[Session, LlamaError]::Err(LlamaError::LoadFailed);
    }

    var cp: raw::llama_context_params = raw::llama_context_default_params();
    cp.n_ctx = opts.n_ctx;
    if opts.n_threads > 0 {
        cp.n_threads = opts.n_threads;
        cp.n_threads_batch = opts.n_threads;
    }

    let ctx: *() = raw::llama_init_from_model(model, cp);
    if is_null(ctx) {
        raw::llama_model_free(model);
        return result::Result[Session, LlamaError]::Err(LlamaError::ContextFailed);
    }

    let sampler: *() = raw::llama_sampler_init_greedy();
    if is_null(sampler) {
        raw::llama_free(ctx);
        raw::llama_model_free(model);
        return result::Result[Session, LlamaError]::Err(LlamaError::ContextFailed);
    }

    let vocab: *() = raw::llama_model_get_vocab(model);
    return result::Result[Session, LlamaError]::Ok(Session {
        model: model,
        ctx: ctx,
        vocab: vocab,
        sampler: sampler,
    });
}

impl Session {
    pub fn n_ctx(this) -> u32 {
        if is_null(this.ctx) {
            return 0 as u32;
        }
        return raw::llama_n_ctx(this.ctx);
    }

    pub fn model_size(this) -> u64 {
        if is_null(this.model) {
            return 0 as u64;
        }
        return raw::llama_model_size(this.model);
    }

    fn drop(ref this) {
        if !is_null(this.sampler) {
            raw::llama_sampler_free(this.sampler);
            this.sampler = null();
        }
        if !is_null(this.ctx) {
            raw::llama_free(this.ctx);
            this.ctx = null();
        }
        if !is_null(this.model) {
            raw::llama_model_free(this.model);
            this.model = null();
        }
        this.vocab = null();
        return;
    }
}

pub fn tokenize_to(
    borrow session: Session,
    text: str,
    tokens: i32[],
    add_special: bool,
    parse_special: bool,
) -> result::Result[usize, LlamaError] {
    if is_null(session.vocab) {
        return result::Result[usize, LlamaError]::Err(LlamaError::NullHandle);
    }
    let cap: usize = #slice_len(tokens);
    if cap > (2147483647 as usize) || #str_len(text) > (2147483647 as usize) {
        return result::Result[usize, LlamaError]::Err(LlamaError::InvalidArgument);
    }
    let n: i32 = raw::llama_tokenize(
        session.vocab,
        unsafe { #str_ptr(text) as *i8 },
        #str_len(text) as i32,
        unsafe { #slice_ptr(tokens) },
        cap as i32,
        add_special,
        parse_special,
    );
    if n < 0 {
        return result::Result[usize, LlamaError]::Err(LlamaError::TokenizeFailed);
    }
    return result::Result[usize, LlamaError]::Ok(n as usize);
}

pub fn decode_tokens(borrow session: Session, tokens: i32[]) -> result::Result[usize, LlamaError] {
    if is_null(session.ctx) {
        return result::Result[usize, LlamaError]::Err(LlamaError::NullHandle);
    }
    let n: usize = #slice_len(tokens);
    if n == (0 as usize) || n > (2147483647 as usize) {
        return result::Result[usize, LlamaError]::Err(LlamaError::InvalidArgument);
    }
    let batch: raw::llama_batch = raw::llama_batch_get_one(unsafe { #slice_ptr(tokens) }, n as i32);
    let rc: i32 = raw::llama_decode(session.ctx, batch);
    if rc != 0 {
        return result::Result[usize, LlamaError]::Err(LlamaError::DecodeFailed);
    }
    return result::Result[usize, LlamaError]::Ok(n);
}

pub fn sample_greedy(borrow session: Session) -> result::Result[i32, LlamaError] {
    if is_null(session.ctx) || is_null(session.sampler) {
        return result::Result[i32, LlamaError]::Err(LlamaError::NullHandle);
    }
    let token: i32 = raw::llama_sampler_sample(session.sampler, session.ctx, -1);
    if token < 0 {
        return result::Result[i32, LlamaError]::Err(LlamaError::SampleFailed);
    }
    raw::llama_sampler_accept(session.sampler, token);
    return result::Result[i32, LlamaError]::Ok(token);
}

pub fn is_eog(borrow session: Session, token: i32) -> bool {
    if is_null(session.vocab) {
        return true;
    }
    return raw::llama_vocab_is_eog(session.vocab, token);
}

pub fn token_to_piece_into(
    borrow session: Session,
    token: i32,
    buf: u8[],
    special: bool,
) -> result::Result[usize, LlamaError] {
    if is_null(session.vocab) {
        return result::Result[usize, LlamaError]::Err(LlamaError::NullHandle);
    }
    let cap: usize = #slice_len(buf);
    if cap > (2147483647 as usize) {
        return result::Result[usize, LlamaError]::Err(LlamaError::InvalidArgument);
    }
    let n: i32 = raw::llama_token_to_piece(
        session.vocab,
        token,
        unsafe { #slice_ptr(buf) as *i8 },
        cap as i32,
        0,
        special,
    );
    if n < 0 {
        return result::Result[usize, LlamaError]::Err(LlamaError::OutputTooSmall);
    }
    return result::Result[usize, LlamaError]::Ok(n as usize);
}

fn copy_piece_to_out(
    borrow session: Session,
    token: i32,
    out: u8[],
    offset: usize,
) -> result::Result[usize, LlamaError] {
    if offset >= #slice_len(out) {
        return result::Result[usize, LlamaError]::Err(LlamaError::OutputTooSmall);
    }
    let ptr: *u8 = unsafe { #slice_ptr(out) + offset };
    let rem: usize = #slice_len(out) -% offset;
    let slice: u8[] = unsafe { #slice_from_raw_parts(ptr, rem) };
    return token_to_piece_into(session, token, slice, false);
}

pub fn generate_greedy_into(
    borrow session: Session,
    prompt: str,
    max_new_tokens: i32,
    out: u8[],
) -> result::Result[usize, LlamaError] {
    if is_null(session.ctx) || is_null(session.vocab) || is_null(session.sampler) {
        return result::Result[usize, LlamaError]::Err(LlamaError::NullHandle);
    }
    if max_new_tokens <= 0 || #str_len(prompt) > (2147483647 as usize) {
        return result::Result[usize, LlamaError]::Err(LlamaError::InvalidArgument);
    }

    let needed_raw: i32 = raw::llama_tokenize(
        session.vocab,
        unsafe { #str_ptr(prompt) as *i8 },
        #str_len(prompt) as i32,
        unsafe { 0 as *i32 },
        0,
        true,
        true,
    );
    let needed: i32 = if needed_raw < 0 { 0 - needed_raw } else { needed_raw };
    if needed <= 0 {
        return result::Result[usize, LlamaError]::Err(LlamaError::TokenizeFailed);
    }

    let bytes: usize = (needed as usize) *% #size_of::[i32]();
    let raw_tokens: *u8 = unsafe { malloc(bytes) };
    if raw_tokens == unsafe { 0 as *u8 } {
        return result::Result[usize, LlamaError]::Err(LlamaError::InvalidArgument);
    }
    let token_ptr: *i32 = unsafe { raw_tokens as *i32 };
    let got: i32 = raw::llama_tokenize(
        session.vocab,
        unsafe { #str_ptr(prompt) as *i8 },
        #str_len(prompt) as i32,
        token_ptr,
        needed,
        true,
        true,
    );
    if got <= 0 {
        unsafe { free(raw_tokens); }
        return result::Result[usize, LlamaError]::Err(LlamaError::TokenizeFailed);
    }

    let prompt_tokens: i32[] = unsafe { #slice_from_raw_parts(token_ptr, got as usize) };
    guard let result::Result[usize, LlamaError]::Ok(_decoded_prompt) =
        decode_tokens(session, prompt_tokens) else {
        unsafe { free(raw_tokens); }
        return result::Result[usize, LlamaError]::Err(LlamaError::DecodeFailed);
    };
    unsafe { free(raw_tokens); }

    var written: usize = 0 as usize;
    var i: i32 = 0;
    while i < max_new_tokens {
        guard let result::Result[i32, LlamaError]::Ok(token) = sample_greedy(session) else {
            return result::Result[usize, LlamaError]::Err(LlamaError::SampleFailed);
        };
        if is_eog(session, token) {
            return result::Result[usize, LlamaError]::Ok(written);
        }
        guard let result::Result[usize, LlamaError]::Ok(n_piece) =
            copy_piece_to_out(session, token, out, written) else {
            return result::Result[usize, LlamaError]::Err(LlamaError::OutputTooSmall);
        };
        written = written +% n_piece;

        let one: [i32; 1] = [token];
        let one_slice: i32[] = unsafe { #slice_from_raw_parts(#addr_of(one[0]), 1 as usize) };
        guard let result::Result[usize, LlamaError]::Ok(_decoded) =
            decode_tokens(session, one_slice) else {
            return result::Result[usize, LlamaError]::Err(LlamaError::DecodeFailed);
        };
        i = i + 1;
    }
    return result::Result[usize, LlamaError]::Ok(written);
}

// ---------------- Multimodal (mtmd C API) ---------------------------------

pub fn mtmd_default_params() -> mtmd_raw::mtmd_context_params {
    return mtmd_raw::mtmd_context_params_default();
}

pub fn mtmd_caps_from_file(path: str) -> mtmd_raw::mtmd_caps {
    return mtmd_raw::mtmd_get_cap_from_file(unsafe { #str_ptr(path) as *i8 });
}

pub fn mtmd_init(
    borrow session: Session,
    mmproj_path: str,
    params: mtmd_raw::mtmd_context_params,
) -> result::Result[MtmdContext, LlamaError] {
    if is_null(session.model) {
        return result::Result[MtmdContext, LlamaError]::Err(LlamaError::NullHandle);
    }
    let raw_ctx: *() = mtmd_raw::mtmd_init_from_file(
        unsafe { #str_ptr(mmproj_path) as *i8 },
        session.model,
        params,
    );
    if is_null(raw_ctx) {
        return result::Result[MtmdContext, LlamaError]::Err(LlamaError::LoadFailed);
    }
    return result::Result[MtmdContext, LlamaError]::Ok(MtmdContext { raw: raw_ctx });
}

impl MtmdContext {
    pub fn supports_vision(this) -> bool {
        if is_null(this.raw) {
            return false;
        }
        return mtmd_raw::mtmd_support_vision(this.raw);
    }

    pub fn supports_audio(this) -> bool {
        if is_null(this.raw) {
            return false;
        }
        return mtmd_raw::mtmd_support_audio(this.raw);
    }

    fn drop(ref this) {
        if !is_null(this.raw) {
            mtmd_raw::mtmd_free(this.raw);
            this.raw = null();
        }
        return;
    }
}

pub fn bitmap_rgb(width: u32, height: u32, rgb: u8[]) -> result::Result[Bitmap, LlamaError] {
    let raw_bitmap: *() = mtmd_raw::mtmd_bitmap_init(width, height, unsafe { #slice_ptr(rgb) });
    if is_null(raw_bitmap) {
        return result::Result[Bitmap, LlamaError]::Err(LlamaError::InvalidArgument);
    }
    return result::Result[Bitmap, LlamaError]::Ok(Bitmap { raw: raw_bitmap });
}

impl Bitmap {
    fn drop(ref this) {
        if !is_null(this.raw) {
            mtmd_raw::mtmd_bitmap_free(this.raw);
            this.raw = null();
        }
        return;
    }
}

