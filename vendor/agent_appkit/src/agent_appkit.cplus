// agent_appkit — the AppKit backend for the agent surface (Theme B, Iris GAP 1).
//
// `open(window)` walks a live NSView hierarchy into a `Surface`: the agent-core
// identity tree (ids / roles / enabled state / exposure) plus a NodeId->NSView
// map and the text-version state. From a `Surface` you get:
//
//   - the READ path: `describe()` -> `Vec[UiNode]`, a live snapshot
//     ({ id, role, class_name, frame, is_hidden, text, parent }). This is how an
//     agent sees the UI (describe_ui, not screenshots).
//   - the WRITE path: `click` / `set_text` / `scroll_to`, each gated through the
//     framework-agnostic `agent_core::surface` authorization brain (exposure +
//     affordance ceiling + optimistic-concurrency version) — the real widget I/O
//     happens only when the core returns `Allowed`.
//
// The agent-visible/actionable surface is the *exposed* subset: a node is
// exposed iff it was tagged with `set_agent_id` (the developer curates what the
// agent can touch). Untagged views are still walked for tree completeness but
// are NotExposed, so actions on them are refused.
//
// The walk is a recursive DFS (pre-order); recursion depth tracks view-tree
// depth, which is shallow in practice. NSView frames come back via
// `rt::msg_rect` (NSRect is an HFA of four doubles, returned in registers on
// arm64).

import "stdlib/vec" as vec;
import "stdlib/option" as option;
import "stdlib/text" as text;
import "appkit/runtime" as rt;
import "appkit/convert" as convert;
import "agent_core/identity" as identity;
import "agent_core/surface" as surface;
import "agent_core/events" as events;

fn null() -> *u8 {
    return unsafe { 0 as *u8 };
}

fn is_null(p: *u8) -> bool {
    return p == null();
}

// ---- agent-id tagging -------------------------------------------------------

// A unique, stable address used as the associated-object key for the pinned
// agent-id. The byte's value is irrelevant — only its address matters.
static mut AGENT_ID_KEY: u8 = 0;

fn agent_id_key() -> *u8 {
    return unsafe { #addr_of(AGENT_ID_KEY) };
}

// Pin a stable agent-id on a view (developer tagging). The walk uses a pinned id
// as the node's developer id, which both (a) keeps the resolved agent-id stable
// across re-layouts and (b) marks the node *exposed* — i.e. part of the curated
// surface the agent may act on. Stored as an associated, retained NSString
// (OBJC_ASSOCIATION_RETAIN_NONATOMIC = 1).
pub fn set_agent_id(view: *u8, id: str) {
    let ns: *u8 = convert::cplus_str_to_nsstring(id);
    rt::set_associated_object(view, agent_id_key(), ns, 1 as usize);
}

// Read a view's pinned agent-id, or None if it was never tagged.
pub fn get_agent_id(view: *u8) -> option::Option[text::Text] {
    let ns: *u8 = rt::get_associated_object(view, agent_id_key());
    if is_null(ns) {
        return option::Option[text::Text]::None;
    }
    return option::Option[text::Text]::Some(convert::nsstring_to_cplus_string(ns));
}

// ---- the describe_ui snapshot node ------------------------------------------

// One node of the describe_ui snapshot. `id` is the resolved agent-id; `role` is
// the curated role; `class_name` is the AppKit class (e.g. "NSButton"); `frame`
// is the view's frame in its superview's coordinates; `text` is the live label /
// content; `actionable` is whether the agent may act on it (exposed + enabled +
// not observe-only). `parent` indexes into the returned `Vec[UiNode]` (None for
// the window root), so the flat list reconstructs the tree.
pub struct UiNode {
    pub id: text::Text,
    pub role: identity::Role,
    pub class_name: text::Text,
    pub frame: rt::Rect,
    pub is_hidden: bool,
    pub text: text::Text,
    pub actionable: bool,
    pub parent: option::Option[usize],
}

// ---- role classification ----------------------------------------------------

fn is_kind(obj: *u8, class_name: *u8) -> bool {
    let cls: *u8 = rt::get_class(class_name);
    if is_null(cls) {
        return false;
    }
    return rt::msg_i8_id(obj, rt::sel(#str_ptr("isKindOfClass:\0")), cls) != (0 as i8);
}

fn responds_to(obj: *u8, selector_name: *u8) -> bool {
    let s: *u8 = rt::sel(selector_name);
    return rt::msg_i8_id(obj, rt::sel(#str_ptr("respondsToSelector:\0")), s) != (0 as i8);
}

// Map an AppKit view to the curated agent-core role vocabulary. NSTextField
// splits on editability (an editable field is an Input; a static label is Text);
// table/outline views are Lists; everything else (plain views, stacks, scroll
// views, boxes) is a structural Group.
fn classify(view: *u8) -> identity::Role {
    if is_kind(view, #str_ptr("NSButton\0")) {
        return identity::Role::Button;
    }
    if is_kind(view, #str_ptr("NSTextField\0")) {
        if rt::msg_i8(view, rt::sel(#str_ptr("isEditable\0"))) != (0 as i8) {
            return identity::Role::Input;
        }
        return identity::Role::Text;
    }
    if is_kind(view, #str_ptr("NSTextView\0")) {
        return identity::Role::Input;
    }
    if is_kind(view, #str_ptr("NSTableView\0")) || is_kind(view, #str_ptr("NSOutlineView\0")) {
        return identity::Role::List;
    }
    return identity::Role::Group;
}

// The live text a node carries: a window's title, a button's title, a text
// field's string value, a text view's string. Roles without inherent text
// return "".
fn node_text(view: *u8, role: identity::Role) -> text::Text {
    if identity::role_eq(role, identity::Role::Window) {
        let wt: *u8 = rt::msg_id(view, rt::sel(#str_ptr("title\0")));
        if !is_null(wt) {
            return convert::nsstring_to_cplus_string(wt);
        }
        return "".to_text();
    }
    if identity::role_eq(role, identity::Role::Button) {
        let t: *u8 = rt::msg_id(view, rt::sel(#str_ptr("title\0")));
        if !is_null(t) {
            return convert::nsstring_to_cplus_string(t);
        }
    }
    if identity::role_eq(role, identity::Role::Text) || identity::role_eq(role, identity::Role::Input) {
        // NSTextView's content is `string`; NSTextField's is `stringValue`.
        let sel_name: *u8 = if is_kind(view, #str_ptr("NSTextView\0")) {
            #str_ptr("string\0")
        } else {
            #str_ptr("stringValue\0")
        };
        let s: *u8 = rt::msg_id(view, rt::sel(sel_name));
        if !is_null(s) {
            return convert::nsstring_to_cplus_string(s);
        }
    }
    return "".to_text();
}

fn class_name_text(view: *u8) -> text::Text {
    let c: *u8 = rt::class_name(view);
    if is_null(c) {
        return "".to_text();
    }
    let view_str: str = unsafe { #str_from_raw_parts(c, c_strlen(c)) };
    return view_str.to_text();
}

// Length of a NUL-terminated C string (the class name from object_getClassName).
fn c_strlen(p: *u8) -> usize {
    let mut n: usize = 0 as usize;
    loop {
        let b: u8 = unsafe { *(p + n) };
        if b == (0 as u8) {
            break;
        }
        n = n +% (1 as usize);
    }
    return n;
}

// Live enabled state. NSControl responds to `isEnabled`; plain NSView / NSWindow
// do not — sending it would raise "unrecognized selector", so guard with
// `respondsToSelector:` and treat non-controls as enabled.
fn live_enabled(view: *u8) -> bool {
    if responds_to(view, #str_ptr("isEnabled\0")) {
        return rt::msg_i8(view, rt::sel(#str_ptr("isEnabled\0"))) != (0 as i8);
    }
    return true;
}

// Live hidden state. Views respond to `isHidden`; NSWindow does not (it has
// `isVisible`), so guard.
fn live_hidden(view: *u8) -> bool {
    if responds_to(view, #str_ptr("isHidden\0")) {
        return rt::msg_i8(view, rt::sel(#str_ptr("isHidden\0"))) != (0 as i8);
    }
    if responds_to(view, #str_ptr("isVisible\0")) {
        return rt::msg_i8(view, rt::sel(#str_ptr("isVisible\0"))) == (0 as i8);
    }
    return false;
}

// ---- notification -> verb translation ---------------------------------------

// Map an AppKit notification name to the curated agent-core `Verb`, or None if
// it isn't one the agent surface reports. The app installs the actual observers
// (NSNotificationCenter / target-action / delegate methods are closure-free C
// callbacks reaching app-global state, so observer *installation* is app policy,
// not the library's); this is the semantic translation those callbacks use, and
// `Surface::emit` is how a translated event reaches a subscriber. Verbs come
// from the W3C-a11y / AppKit-AX channels (plan.agent-core.md §7.2).
pub fn verb_for_notification(name: str) -> option::Option[events::Verb] {
    if name == "NSControlTextDidChangeNotification" {
        return option::Option[events::Verb]::Some(events::Verb::Changed);
    }
    if name == "NSControlTextDidEndEditingNotification" {
        return option::Option[events::Verb]::Some(events::Verb::Submitted);
    }
    if name == "NSTableViewSelectionDidChangeNotification" {
        return option::Option[events::Verb]::Some(events::Verb::Selected);
    }
    if name == "NSPopUpButtonWillPopUpNotification" {
        return option::Option[events::Verb]::Some(events::Verb::Opened);
    }
    if name == "NSWindowDidBecomeKeyNotification" {
        return option::Option[events::Verb]::Some(events::Verb::WindowOpened);
    }
    if name == "NSWindowWillCloseNotification" {
        return option::Option[events::Verb]::Some(events::Verb::WindowClosed);
    }
    return option::Option[events::Verb]::None;
}

// ---- subview iteration ------------------------------------------------------

fn subview_count(view: *u8) -> usize {
    let arr: *u8 = rt::msg_id(view, rt::sel(#str_ptr("subviews\0")));
    if is_null(arr) {
        return 0 as usize;
    }
    let n: i64 = rt::msg_i64(arr, rt::sel(#str_ptr("count\0")));
    return n as usize;
}

fn subview_at(view: *u8, i: usize) -> *u8 {
    let arr: *u8 = rt::msg_id(view, rt::sel(#str_ptr("subviews\0")));
    return rt::msg_id_u64(arr, rt::sel(#str_ptr("objectAtIndex:\0")), i as u64);
}

// ---- the Surface ------------------------------------------------------------

// A borrowed NSView wrapped as a nominal type so it can be stored in a `Vec`.
// (cpc's monomorphizer does not accept a bare raw pointer as a generic type
// argument — `Vec[*u8]` fails with "unknown type <raw-ptr>" — so the map is a
// `Vec[ViewRef]`.) `opaque` marks the pointer unaccounted-by-design.
struct ViewRef {
    opaque p: *u8,
}

// The live surface of one window: the identity tree, the NodeId->NSView map
// (index 0 is the synthetic app root, mapped to null), and the text-version
// state for optimistic-concurrency edits.
pub struct Surface {
    reg: identity::Registry,
    versions: surface::TextVersions,
    views: vec::Vec[ViewRef],
}

// Recursively register a view subtree: classify the view, add it to the
// identity tree (a pinned agent-id becomes the developer id, which also exposes
// the node), reflect its live enabled state, map NodeId->view, then recurse into
// its subviews in order (DFS pre-order). `views` stays index-aligned with the
// registry: every `add_child` is paired with exactly one `views.push`. Recursion
// depth is the view-tree depth (shallow in practice).
fn walk(mut reg: identity::Registry, mut views: vec::Vec[ViewRef], view: *u8, parent_reg: usize) {
    let role: identity::Role = classify(view);
    let pinned: option::Option[text::Text] = get_agent_id(view);
    let reg_node: usize = match pinned {
        option::Option[text::Text]::Some(t) => {
            reg.add_child(parent_reg, option::Option[str]::Some(unsafe { t.as_str() }), role)
        }
        option::Option[text::Text]::None => {
            reg.add_child(parent_reg, option::Option[str]::None, role)
        }
    };
    reg.set_enabled(reg_node, live_enabled(view));
    views.push(ViewRef { p: view });

    let n: usize = subview_count(view);
    let mut i: usize = 0 as usize;
    while i < n {
        walk(reg, views, subview_at(view, i), reg_node);
        i = i +% (1 as usize);
    }
    return;
}

// Walk a window's view hierarchy into a `Surface`. The window is the root node
// (role Window) under the registry's app root; its contentView subtree follows.
pub fn open(window: *u8) -> Surface {
    let mut reg: identity::Registry = identity::new();
    let mut views: vec::Vec[ViewRef] = vec::new::[ViewRef]();
    // NodeId 0 is the synthetic app root — no backing view.
    views.push(ViewRef { p: null() });

    if is_null(window) {
        return Surface { reg: reg, versions: surface::new_text_versions(), views: views };
    }

    let win_pinned: option::Option[text::Text] = get_agent_id(window);
    let win_reg: usize = match win_pinned {
        option::Option[text::Text]::Some(t) => {
            reg.add_child(reg.root(), option::Option[str]::Some(unsafe { t.as_str() }), identity::Role::Window)
        }
        option::Option[text::Text]::None => {
            reg.add_child(reg.root(), option::Option[str]::None, identity::Role::Window)
        }
    };
    views.push(ViewRef { p: window });

    let content: *u8 = rt::msg_id(window, rt::sel(#str_ptr("contentView\0")));
    if !is_null(content) {
        walk(reg, views, content, win_reg);
    }

    return Surface { reg: reg, versions: surface::new_text_versions(), views: views };
}

// Convenience: the read-only snapshot of a window in one call.
pub fn describe(window: *u8) -> vec::Vec[UiNode] {
    let s: Surface = open(window);
    return s.describe();
}

impl Surface {
    fn view_of(self, node: usize) -> *u8 {
        return match self.views.at(node) {
            option::Option[*ViewRef]::Some(r) => unsafe { (*r).p },
            option::Option[*ViewRef]::None => null(),
        };
    }

    // Live describe_ui snapshot. Reads each node's current frame / hidden / text
    // from its view, so it reflects state *now* (e.g. after a `set_text`). The
    // synthetic app root (NodeId 0) is omitted; snapshot index = NodeId - 1.
    pub fn describe(self) -> vec::Vec[UiNode] {
        let mut out: vec::Vec[UiNode] = vec::new::[UiNode]();
        let total: usize = self.reg.len();
        let mut node: usize = 1 as usize;
        while node < total {
            let view: *u8 = self.view_of(node);
            let role: identity::Role = self.reg.role_of(node);
            let parent: option::Option[usize] = match self.reg.parent_of(node) {
                option::Option[usize]::Some(p) => {
                    if p == (0 as usize) {
                        option::Option[usize]::None
                    } else {
                        option::Option[usize]::Some(p -% (1 as usize))
                    }
                }
                option::Option[usize]::None => option::Option[usize]::None,
            };
            out.push(UiNode {
                id: self.reg.resolved_id(node).to_text(),
                role: role,
                class_name: class_name_text(view),
                frame: rt::msg_rect(view, rt::sel(#str_ptr("frame\0"))),
                is_hidden: live_hidden(view),
                text: node_text(view, role),
                actionable: self.reg.is_exposed(node) && self.reg.is_agent_actionable(node),
                parent: parent,
            });
            node = node +% (1 as usize);
        }
        return out;
    }

    // EVENTS: translate a fired widget into an agent event. Resolves the source
    // agent-id to its NodeId and offers `{ source, verb }` to the subscriber
    // (which applies its own subtree/verb/role filter + backpressure). Returns
    // false if the id is unknown. The app's closure-free notification/action
    // callback calls this with the verb from `verb_for_notification` (or a
    // direct one, e.g. `Clicked` for a target-action). Events bubble: a
    // subscriber on an ancestor sees descendant events.
    pub fn emit(self, mut sub: events::Subscriber, source_id: str, verb: events::Verb) -> bool {
        match self.reg.lookup(source_id) {
            option::Option[usize]::Some(node) => {
                sub.offer(self.reg, events::event(node, verb));
                return true;
            }
            option::Option[usize]::None => {}
        }
        return false;
    }

    // The current text version of a node (for optimistic-concurrency edits).
    // 0 if the id is unknown or never edited.
    pub fn text_version(self, id: str) -> u64 {
        return match self.reg.lookup(id) {
            option::Option[usize]::Some(n) => self.versions.version_of(n),
            option::Option[usize]::None => 0 as u64,
        };
    }

    // WRITE: click a control. Authorized via the core (exposed + actionable);
    // on `Allowed`, sends `performClick:` to the backing view.
    pub fn click(self, id: str) -> surface::Outcome {
        match self.reg.lookup(id) {
            option::Option[usize]::Some(node) => {
                let oc: surface::Outcome = surface::authorize_action(self.reg, node);
                if !surface::outcome_eq(oc, surface::Outcome::Allowed) {
                    return oc;
                }
                rt::msg_void_id(self.view_of(node), rt::sel(#str_ptr("performClick:\0")), null());
                return surface::Outcome::Allowed;
            }
            option::Option[usize]::None => {}
        }
        return surface::Outcome::NotFound;
    }

    // WRITE: set a field's text with optimistic concurrency. `base_version` is
    // the version the agent last read (`text_version`); a racing edit yields
    // `VersionConflict`. On `Allowed`, sends `setStringValue:` then bumps.
    pub fn set_text(mut self, id: str, value: str, base_version: u64) -> surface::Outcome {
        match self.reg.lookup(id) {
            option::Option[usize]::Some(node) => {
                let oc: surface::Outcome =
                    surface::authorize_text_write(self.reg, self.versions, node, base_version);
                if !surface::outcome_eq(oc, surface::Outcome::Allowed) {
                    return oc;
                }
                let ns: *u8 = convert::cplus_str_to_nsstring(value);
                rt::msg_void_id(self.view_of(node), rt::sel(#str_ptr("setStringValue:\0")), ns);
                self.versions.bump(node);
                return surface::Outcome::Allowed;
            }
            option::Option[usize]::None => {}
        }
        return surface::Outcome::NotFound;
    }

    // READ/NAV: scroll a node's bounds into view. Authorized via `authorize_read`
    // (exposure required; the affordance ceiling does not apply to navigation).
    pub fn scroll_to(self, id: str) -> surface::Outcome {
        match self.reg.lookup(id) {
            option::Option[usize]::Some(node) => {
                let oc: surface::Outcome = surface::authorize_read(self.reg, node);
                if !surface::outcome_eq(oc, surface::Outcome::Allowed) {
                    return oc;
                }
                let v: *u8 = self.view_of(node);
                let b: rt::Rect = rt::msg_rect(v, rt::sel(#str_ptr("bounds\0")));
                rt::msg_void_rect(v, rt::sel(#str_ptr("scrollRectToVisible:\0")), b);
                return surface::Outcome::Allowed;
            }
            option::Option[usize]::None => {}
        }
        return surface::Outcome::NotFound;
    }
}
