// accelerate — C+ binding for Apple's Accelerate framework (BLAS/vDSP/...).
//
// The C-ABI declarations in cblas.cplus are auto-generated by cpc-bindgen from
// the SDK's <Accelerate/.../cblas.h>. This facade is the package entry; the
// test exercises a generated BLAS call against the real framework.

import "./cblas" as cblas;
import "./vdsp" as vdsp;
import "stdlib/vec" as vec;
import "stdlib/option" as option;

fn unwrap_f64(o: option::Option[f64]) -> f64 {
    return match o {
        option::Option[f64]::Some(x) => { x },
        option::Option[f64]::None => { -1.0 },
    };
}

#[test]
fn cblas_ddot_dot_product() {
    // x . y for x = [1,2,3], y = [4,5,6]  ->  4 + 10 + 18 = 32
    var x: vec::Vec[f64] = vec::Vec[f64]::with_capacity(3 as usize);
    x.append(1.0);
    x.append(2.0);
    x.append(3.0);
    var y: vec::Vec[f64] = vec::Vec[f64]::with_capacity(3 as usize);
    y.append(4.0);
    y.append(5.0);
    y.append(6.0);

    let xs: f64[] = x.as_slice();
    let ys: f64[] = y.as_slice();
    let xp: *f64 = { #slice_ptr(xs) };
    let yp: *f64 = { #slice_ptr(ys) };

    let d: f64 = cblas::cblas_ddot(3 as i32, xp, 1 as i32, yp, 1 as i32);
    assert d == 32.0;
    return;
}

#[test]
fn vdsp_sve_sum() {
    // vDSP_sve sums A[0..N] into *C.  sum([1,2,3,4]) = 10
    var a: vec::Vec[f32] = vec::Vec[f32]::with_capacity(4 as usize);
    a.append(1.0 as f32);
    a.append(2.0 as f32);
    a.append(3.0 as f32);
    a.append(4.0 as f32);
    let as_slice: f32[] = a.as_slice();
    let ap: *f32 = { #slice_ptr(as_slice) };

    var sum: f32 = 0.0 as f32;
    let sp: *f32 = { #addr_of(sum) };
    vdsp::vDSP_sve(ap, 1 as i64, sp, 4 as u64);
    assert sum == (10.0 as f32);
    return;
}

#[test]
fn cblas_dgemm_matrix_multiply() {
    // A(2x2) * B(2x2) = C, row-major, no transpose, using the GENERATED enum
    // constants (CblasRowMajor=101, CblasNoTrans=111).
    // A=[[1,2],[3,4]] B=[[5,6],[7,8]] -> C=[[19,22],[43,50]]
    var a: vec::Vec[f64] = vec::Vec[f64]::with_capacity(4 as usize);
    a.append(1.0); a.append(2.0); a.append(3.0); a.append(4.0);
    var b: vec::Vec[f64] = vec::Vec[f64]::with_capacity(4 as usize);
    b.append(5.0); b.append(6.0); b.append(7.0); b.append(8.0);
    var c: vec::Vec[f64] = vec::Vec[f64]::with_capacity(4 as usize);
    c.append(0.0); c.append(0.0); c.append(0.0); c.append(0.0);

    let asl: f64[] = a.as_slice();
    let bsl: f64[] = b.as_slice();
    let csl: f64[] = c.as_slice();
    let ap: *f64 = { #slice_ptr(asl) };
    let bp: *f64 = { #slice_ptr(bsl) };
    let cp: *f64 = { #slice_ptr(csl) };

    cblas::cblas_dgemm(
        cblas::CblasRowMajor(), cblas::CblasNoTrans(), cblas::CblasNoTrans(),
        2 as i32, 2 as i32, 2 as i32,
        1.0, ap, 2 as i32, bp, 2 as i32, 0.0, cp, 2 as i32,
    );

    assert unwrap_f64(c.at(0 as usize)) == 19.0;
    assert unwrap_f64(c.at(1 as usize)) == 22.0;
    assert unwrap_f64(c.at(2 as usize)) == 43.0;
    assert unwrap_f64(c.at(3 as usize)) == 50.0;
    return;
}

// Typed C struct pointer: construct a DSPSplitComplex (a generated #[repr(C)]
// struct) and pass &it (a *DSPSplitComplex) to vDSP. |3 + 4i|^2 = 25.
#[test]
fn vdsp_zvmags_typed_struct() {
    var real: vec::Vec[f32] = vec::Vec[f32]::with_capacity(1 as usize);
    real.append(3.0 as f32);
    var imag: vec::Vec[f32] = vec::Vec[f32]::with_capacity(1 as usize);
    imag.append(4.0 as f32);
    let rsl: f32[] = real.as_slice();
    let isl: f32[] = imag.as_slice();
    let rp: *f32 = { #slice_ptr(rsl) };
    let ip: *f32 = { #slice_ptr(isl) };

    var c: vdsp::DSPSplitComplex = vdsp::DSPSplitComplex_new(rp, ip);
    var out: f32 = 0.0 as f32;
    let cp: *vdsp::DSPSplitComplex = { #addr_of(c) };
    let op: *f32 = { #addr_of(out) };
    vdsp::vDSP_zvmags(cp, 1 as i64, op, 1 as i64, 1 as u64);
    assert out == (25.0 as f32);
    return;
}
