// facet_appkit — the AppKit construction renderer for facet.
//
// `render` walks a `facet::Node` and materializes the native NSView tree
// (identity -> native, the opposite direction from agent_appkit's introspection
// walk). `run` opens the Application + Window and mounts the rendered root.
//
// DISCOVERY-SPIKE OWNERSHIP NOTE: views are created with raw ObjC alloc/init and
// handed to their parent (which retains) without a balancing release, so each
// view leaks its initial +1. That is deliberate for the spike — it sidesteps the
// retained-tree ownership work (plan.opaque) and never crashes. Proper +1
// handoff is a later slice.

import "stdlib/option" as option;
import "appkit/runtime" as rt;
import "appkit/application" as application;
import "appkit/window" as window;
import "appkit/convert" as convert;
import "facet/facet" as facet;

fn rect(w: f64, h: f64) -> rt::Rect {
    return rt::Rect {
        origin: rt::Point { x: 0.0, y: 0.0 },
        size: rt::Size { width: w, height: h },
    };
}

// alloc + initWithFrame: for an ObjC view class named by `class` (a C string).
fn make_view(class: *u8, f: rt::Rect) -> *u8 {
    let cls: *u8 = rt::get_class(class);
    let a: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
    return rt::msg_init_with_frame(a, rt::sel(#str_ptr("initWithFrame:\0")), f);
}

// Walk a node into a native NSView; returns its raw pointer.
fn render(np: *facet::Node) -> *u8 {
    let k: u32 = { (*np).kind };

    if k == facet::kind_label() {
        let v: *u8 = make_view(#str_ptr("NSTextField\0"), rect(220.0, 24.0));
        rt::msg_void_i8(v, rt::sel(#str_ptr("setEditable:\0")), 0 as i8);
        rt::msg_void_i8(v, rt::sel(#str_ptr("setSelectable:\0")), 0 as i8);
        rt::msg_void_i8(v, rt::sel(#str_ptr("setBezeled:\0")), 0 as i8);
        rt::msg_void_i8(v, rt::sel(#str_ptr("setDrawsBackground:\0")), 0 as i8);
        let ns: *u8 = convert::cplus_str_to_nsstring({ (*np).text });
        rt::msg_void_id(v, rt::sel(#str_ptr("setStringValue:\0")), ns);
        return v;
    }

    if k == facet::kind_button() {
        let v: *u8 = make_view(#str_ptr("NSButton\0"), rect(220.0, 32.0));
        let ns: *u8 = convert::cplus_str_to_nsstring({ (*np).text });
        rt::msg_void_id(v, rt::sel(#str_ptr("setTitle:\0")), ns);
        rt::attach_callback(v, { (*np).click });
        return v;
    }

    // stack (vertical): NSStackView with arranged subviews.
    let sv: *u8 = make_view(#str_ptr("NSStackView\0"), rect(300.0, 400.0));
    rt::msg_void_i64(sv, rt::sel(#str_ptr("setOrientation:\0")), 1 as i64);
    rt::msg_void_f64(sv, rt::sel(#str_ptr("setSpacing:\0")), 8.0);
    let n: usize = { (*np).children.len() };
    var i: usize = 0 as usize;
    while i < n {
        match { (*np).children.at(i) } {
            option::Option[*facet::Node]::Some(cp) => {
                let cv: *u8 = render(cp);
                rt::msg_void_id(sv, rt::sel(#str_ptr("addArrangedSubview:\0")), cv);
            }
            option::Option[*facet::Node]::None => {}
        }
        i = i +% (1 as usize);
    }
    return sv;
}

// Open a window, mount the rendered tree, run the event loop (blocks).
fn run(root: facet::Node) {
    let pool: application::AutoreleasePool = application::AutoreleasePool::new();
    let app: application::Application = application::Application::shared();
    app.set_activation_policy(0 as i64);

    let win: window::Window = window::Window::new(rect(480.0, 320.0), 15 as u64, 2 as u64, 0 as i8);
    win.set_title(#str_ptr("facet\0"));

    let rv: *u8 = render({ #addr_of(root) });
    win.set_content_view(rv);

    win.make_key_and_order_front({ 0 as *u8 });
    app.activate(1 as i8);
    app.run();
    pool.drain();
    return;
}
