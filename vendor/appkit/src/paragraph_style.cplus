        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setHeaderLevel:\0")), header_level);
    }

}

// `NSTextBlock` (Foundation/ObjC). Non-owning handle (factory/singleton); `opaque`, no drop.
struct TextBlock {
    opaque _obj: *u8,
}

impl TextBlock {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> TextBlock { return TextBlock { _obj: ptr }; }

}

