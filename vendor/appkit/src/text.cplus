import "./runtime" as rt;
import "./convert" as bridge;
import "stdlib/text" as text;
import "stdlib/option" as option;

// GAP 4 note (v0.0.19) — TextView placeholder: `NSTextView` has NO native
// placeholder API (unlike `NSTextField`, which has `setPlaceholderString:`).
// There is no selector to bind — a placeholder is implemented in the app by
// overlaying a non-editable, gray `Label` inside the text view's frame and
// toggling its `setHidden:` from the text-change delegate (`textDidChange:` ->
// hide when `text()` is non-empty, show when empty). `controls::Label::wrapping`
// + `View::add_subview` give you the overlay; the delegate wiring is
// app-specific. (Provided as guidance rather than a binding because there is no
// underlying AppKit API to wrap.)
struct TextView {
    _obj: *u8,
}

impl TextView {
    fn raw(this) -> *u8 { return this._obj; }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn new(frame: rt::Rect) -> TextView {
        return TextView { _obj: rt::alloc_init_with_frame(#str_ptr("NSTextView\0"), frame) };
    }

    fn set_text(this, text: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setString:\0")), bridge::cplus_str_to_nsstring(text));
    }

    fn text(this) -> text::Text {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("string\0")));
        return bridge::nsstring_to_cplus_string(ns);
    }

    fn set_editable(this, editable: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setEditable:\0")), editable as i8);
    }

    fn set_selectable(this, selectable: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setSelectable:\0")), selectable as i8);
    }

    fn set_rich_text(this, rich: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setRichText:\0")), rich as i8);
    }

    fn set_font(this, font: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setFont:\0")), font);
    }

    fn set_text_color(this, color: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setTextColor:\0")), color);
    }

    fn set_delegate(this, delegate: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    }

    fn set_draws_background(this, draws: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setDrawsBackground:\0")), draws as i8);
    }
}

