    }

    fn add_entry(this, title: str) -> *u8 {
        return rt::msg_id_id(this._obj, rt::sel(#str_ptr("addEntry:\0")), bridge::cplus_str_to_nsstring(title));
    }

    fn set_interline_spacing(this, spacing: f64) {
        rt::msg_void_f64(this._obj, rt::sel(#str_ptr("setInterlineSpacing:\0")), spacing);
    }
}
