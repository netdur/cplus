    pub fn new(frame: rt::Rect) -> Form {
        return Form { obj: rt::alloc_init_with_frame(#str_ptr("NSForm\0"), frame) };
    }

    pub fn add_entry(self, title: *u8) -> *u8 {
        return rt::msg_id_id(self.obj, rt::sel(#str_ptr("addEntry:\0")), rt::ns_string(title));
    }

    // v0.0.7 Slice 5.1: pre-built-NSString variant.
