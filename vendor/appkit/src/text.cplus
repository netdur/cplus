        return rt::msg_id_id(self.obj, rt::sel(#str_ptr("addEntry:\0")), title_ns);
    }

    pub fn set_interline_spacing(self, spacing: f64) {
        rt::msg_void_f64(self.obj, rt::sel(#str_ptr("setInterlineSpacing:\0")), spacing);
    }
