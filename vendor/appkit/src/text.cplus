struct ComboBox {
    _obj: *u8,
}

impl ComboBox {
    fn raw(this) -> *u8 { return this._obj; }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn new(frame: rt::Rect) -> ComboBox {
        return ComboBox { _obj: rt::alloc_init_with_frame(#str_ptr("NSComboBox\0"), frame) };
    }

    fn add_item(this, item: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("addItemWithObjectValue:\0")), bridge::cplus_str_to_nsstring(item));
    }

    fn remove_all_items(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("removeAllItems\0")));
    }

    fn select_item(this, at: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("selectItemAtIndex:\0")), at);
    }

    // `indexOfSelectedItem` is -1 when nothing is selected; expose that as `None`.
    fn selected_index(this) -> option::Option[i64] {
        let idx: i64 = rt::msg_i64(this._obj, rt::sel(#str_ptr("indexOfSelectedItem\0")));
        if idx < (0 as i64) {
            return option::Option[i64]::None;
        }
        return option::some(idx);
    }

    fn set_delegate(this, delegate: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    }
}

