import "./runtime" as rt;

// GAP 4 note (v0.0.19) — TextView placeholder: `NSTextView` has NO native
// placeholder API (unlike `NSTextField`, which has `setPlaceholderString:`).
// There is no selector to bind — a placeholder is implemented in the app by
// overlaying a non-editable, gray `TextField` label inside the text view's
// frame and toggling its `setHidden:` from the text-change delegate
// (`textDidChange:` -> hide when `string()` is non-empty, show when empty).
// `controls::TextField::new_wrapping_label` + `View::add_subview` give you the
// overlay; the delegate wiring is app-specific. (Provided as guidance rather
// than a binding because there is no underlying AppKit API to wrap.)
pub struct TextView {
    pub obj: *u8,
}

impl TextView {
    fn drop(ref this) {
        rt::release(this.obj);
    }

    pub fn new(frame: rt::Rect) -> TextView {
        return TextView { obj: rt::alloc_init_with_frame(#str_ptr("NSTextView\0"), frame) };
    }

    pub fn set_string(this, val: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setString:\0")), rt::ns_string(val));
    }

    // v0.0.7 Slice 5.1: pre-built-NSString variant. See window.cplus
    // for the rationale.
    pub fn set_string_ns(this, val_ns: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setString:\0")), val_ns);
    }

    pub fn string(this) -> *u8 {
        return rt::msg_id(this.obj, rt::sel(#str_ptr("string\0")));
    }

    pub fn set_editable(this, flag: i8) {
        rt::msg_void_i8(this.obj, rt::sel(#str_ptr("setEditable:\0")), flag);
    }

    pub fn set_selectable(this, flag: i8) {
        rt::msg_void_i8(this.obj, rt::sel(#str_ptr("setSelectable:\0")), flag);
    }

    pub fn set_rich_text(this, flag: i8) {
        rt::msg_void_i8(this.obj, rt::sel(#str_ptr("setRichText:\0")), flag);
    }

    pub fn set_font(this, font: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setFont:\0")), font);
    }

    pub fn set_text_color(this, color: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setTextColor:\0")), color);
    }

    pub fn set_delegate(this, delegate: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    }

    pub fn set_draws_background(this, flag: i8) {
        rt::msg_void_i8(this.obj, rt::sel(#str_ptr("setDrawsBackground:\0")), flag);
    }
}

