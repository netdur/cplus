import "./runtime" as rt;

pub struct TextView {
    pub obj: *u8,
}

impl TextView {
    fn drop(mut self) {
        rt::release(self.obj);
    }

    pub fn new(frame: rt::Rect) -> TextView {
        return TextView { obj: rt::alloc_init_with_frame(#str_ptr("NSTextView\0"), frame) };
    }

    pub fn set_string(self, val: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setString:\0")), rt::ns_string(val));
    }

    // v0.0.7 Slice 5.1: pre-built-NSString variant. See window.cplus
    // for the rationale.
    pub fn set_string_ns(self, val_ns: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setString:\0")), val_ns);
    }

    pub fn string(self) -> *u8 {
        return rt::msg_id(self.obj, rt::sel(#str_ptr("string\0")));
    }

    pub fn set_editable(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(#str_ptr("setEditable:\0")), flag);
    }

    pub fn set_selectable(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(#str_ptr("setSelectable:\0")), flag);
    }

    pub fn set_rich_text(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(#str_ptr("setRichText:\0")), flag);
    }

    pub fn set_font(self, font: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setFont:\0")), font);
    }

    pub fn set_text_color(self, color: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setTextColor:\0")), color);
    }

    pub fn set_delegate(self, delegate: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    }
}

