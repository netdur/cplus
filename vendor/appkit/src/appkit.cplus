// `NSTextAlternatives` (Foundation/ObjC). Owned via alloc/init; `drop` releases the +1.
struct TextAlternatives {
    _obj: *u8,
}

impl TextAlternatives {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> TextAlternatives { return TextAlternatives { _obj: ptr }; }

    fn new(primary_string: str, alternative_strings: vec::Vec[text::Text]) -> TextAlternatives {
        let cls: *u8 = rt::get_class(#str_ptr("NSTextAlternatives\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        return TextAlternatives { _obj: rt::msg_id_id_id(alloced, rt::sel(#str_ptr("initWithPrimaryString:alternativeStrings:\0")), bridge::nsstring(primary_string), bridge::nsarray_of_text(alternative_strings)) };
    }

    fn note_selected_alternative_string(this, alternative_string: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("noteSelectedAlternativeString:\0")), bridge::nsstring(alternative_string));
    }

    fn primary_string(this) -> text::Text {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("primaryString\0")));
        return bridge::to_text(ns);
    }

    fn alternative_strings(this) -> vec::Vec[text::Text] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("alternativeStrings\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[text::Text] = vec::Vec[text::Text]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            let value: *u8 = rt::msg_id_u64(arr, at_sel, i);
            out.append(bridge::to_text(value));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }
}

