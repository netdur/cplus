fn ns_string(utf8: *u8) -> *u8 {
    return runtime::ns_string(utf8);
}

fn create_app_delegate(should_terminate_imp: fn(*u8, *u8, *u8) -> i8) -> *u8 {
    return application::create_app_delegate(should_terminate_imp);
}
