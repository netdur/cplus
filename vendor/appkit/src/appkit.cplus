        let arr: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMenuItem\0")), rt::sel(#str_ptr("writingToolsItems\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[MenuItem] = vec::Vec[MenuItem]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(MenuItem::from_raw(rt::retain(rt::msg_id_u64(arr, at_sel, i))));
            i = i +% (1 as u64);
