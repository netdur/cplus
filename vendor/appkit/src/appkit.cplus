            match prefetch_items_at_index_paths.at_ptr(i_prefetch_items_at_index_paths) {
                option::Option[*IndexPath]::Some(e_prefetch_items_at_index_paths) => { rt::msg_void_id(arr_prefetch_items_at_index_paths, add_sel_prefetch_items_at_index_paths, (*e_prefetch_items_at_index_paths).raw()); }
                option::Option[*IndexPath]::None => {}
