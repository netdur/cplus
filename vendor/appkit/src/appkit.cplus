        let dict_text_highlight_attributes: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableDictionary\0")), rt::sel(#str_ptr("dictionary\0")));
        let dset_text_highlight_attributes: *u8 = rt::sel(#str_ptr("setObject:forKey:\0"));
        let dcap_text_highlight_attributes: usize = text_highlight_attributes.slot_capacity();
