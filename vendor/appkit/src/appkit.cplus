    fn dragging_image_components_with_frame(this, frame: rt::Rect, in_view: View) -> vec::Vec[DraggingImageComponent] {
        let arr: *u8 = rt::msg_id_rect_id(this._obj, rt::sel(#str_ptr("draggingImageComponentsWithFrame:inView:\0")), frame, in_view.raw());
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[DraggingImageComponent] = vec::Vec[DraggingImageComponent]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(DraggingImageComponent::from_raw(rt::retain(rt::msg_id_u64(arr, at_sel, i))));
            i = i +% (1 as u64);
        }
        return out;
    }

