        let add_sel_subviews: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_subviews: usize = subviews.count();
        var i_subviews: usize = 0 as usize;
        while i_subviews < n_subviews {
            match subviews.at_ptr(i_subviews) {
                option::Option[*View]::Some(e_subviews) => { rt::msg_void_id(arr_subviews, add_sel_subviews, (*e_subviews).raw()); }
