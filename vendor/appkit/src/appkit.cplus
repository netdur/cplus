        }
        return option::some(AlignmentFeedbackToken::from_raw(obj));
    }

    fn alignment_feedback_token_for_vertical_movement_in_view(this, view: View, previous_y: f64, aligned_y: f64, default_y: f64) -> option::Option[AlignmentFeedbackToken] {
        let obj: *u8 = rt::msg_id_id_f64_f64_f64(this._obj, rt::sel(#str_ptr("alignmentFeedbackTokenForVerticalMovementInView:previousY:alignedY:defaultY:\0")), view.raw(), previous_y, aligned_y, default_y);
        if obj == { 0 as *u8 } {
            return option::Option[AlignmentFeedbackToken]::None;
        }
        return option::some(AlignmentFeedbackToken::from_raw(obj));
    }

    fn perform_feedback(this, alignment_feedback_tokens: vec::Vec[AlignmentFeedbackToken], performance_time: HapticFeedbackPerformanceTime) {
        let arr_alignment_feedback_tokens: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
        let add_sel_alignment_feedback_tokens: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_alignment_feedback_tokens: usize = alignment_feedback_tokens.count();
        var i_alignment_feedback_tokens: usize = 0 as usize;
        while i_alignment_feedback_tokens < n_alignment_feedback_tokens {
            match alignment_feedback_tokens.at_ptr(i_alignment_feedback_tokens) {
                option::Option[*AlignmentFeedbackToken]::Some(e_alignment_feedback_tokens) => { rt::msg_void_id(arr_alignment_feedback_tokens, add_sel_alignment_feedback_tokens, (*e_alignment_feedback_tokens).raw()); }
                option::Option[*AlignmentFeedbackToken]::None => {}
            }
            i_alignment_feedback_tokens = i_alignment_feedback_tokens +% (1 as usize);
        }
        rt::msg_void_id_i64(this._obj, rt::sel(#str_ptr("performFeedback:performanceTime:\0")), arr_alignment_feedback_tokens, haptic_feedback_performance_time_raw(performance_time));
    }

    fn input_event_mask() -> u64 {
        return rt::msg_u64(rt::get_class(#str_ptr("NSAlignmentFeedbackFilter\0")), rt::sel(#str_ptr("inputEventMask\0")));
    }

}

