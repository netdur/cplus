// `NSPrintInfo` (Foundation/ObjC). Owned via alloc/init; `drop` releases the +1.
struct PrintInfo {
    _obj: *u8,
}

impl PrintInfo {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> PrintInfo { return PrintInfo { _obj: ptr }; }

    fn new_with_dictionary(attributes: string_map::StringMap[AnyObject]) -> PrintInfo {
        let cls: *u8 = rt::get_class(#str_ptr("NSPrintInfo\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let dict_attributes: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableDictionary\0")), rt::sel(#str_ptr("dictionary\0")));
        let dset_attributes: *u8 = rt::sel(#str_ptr("setObject:forKey:\0"));
        let dcap_attributes: usize = attributes.slot_capacity();
        var dsi_attributes: usize = 0 as usize;
        while dsi_attributes < dcap_attributes {
            match attributes.value_ptr_at_slot(dsi_attributes) {
                option::Option[*AnyObject]::Some(dvp_attributes) => {
                    match attributes.key_ptr_at_slot(dsi_attributes) {
                        option::Option[*text::Text]::Some(dkp_attributes) => {
                    let dval_attributes: *u8 = (*dvp_attributes).raw();
                            rt::msg_void_id_id(dict_attributes, dset_attributes, dval_attributes, bridge::nsstring((*dkp_attributes).view()));
                        }
                        option::Option[*text::Text]::None => {}
                    }
                }
                option::Option[*AnyObject]::None => {}
            }
            dsi_attributes = dsi_attributes +% (1 as usize);
        }
        return PrintInfo { _obj: rt::msg_id_id(alloced, rt::sel(#str_ptr("initWithDictionary:\0")), dict_attributes) };
    }

