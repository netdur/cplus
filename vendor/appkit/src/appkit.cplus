    fn check_text_in_range(this, range: rt::Range, types: u64, options: string_map::StringMap[AnyObject]) {
        let dict_options: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableDictionary\0")), rt::sel(#str_ptr("dictionary\0")));
        let dset_options: *u8 = rt::sel(#str_ptr("setObject:forKey:\0"));
        let dcap_options: usize = options.slot_capacity();
        var dsi_options: usize = 0 as usize;
        while dsi_options < dcap_options {
            match options.value_ptr_at_slot(dsi_options) {
                option::Option[*AnyObject]::Some(dvp_options) => {
                    match options.key_ptr_at_slot(dsi_options) {
                        option::Option[*text::Text]::Some(dkp_options) => {
                    let dval_options: *u8 = (*dvp_options).raw();
                            rt::msg_void_id_id(dict_options, dset_options, dval_options, bridge::nsstring((*dkp_options).view()));
                        }
                        option::Option[*text::Text]::None => {}
                    }
                }
                option::Option[*AnyObject]::None => {}
            }
            dsi_options = dsi_options +% (1 as usize);
        }
        objc_msg_void_range_u64_id(this._obj, rt::sel(#str_ptr("checkTextInRange:types:options:\0")), range, types, dict_options);
    }

