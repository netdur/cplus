        return rt::msg_i8_id(this._obj, rt::sel(#str_ptr("setName:\0")), bridge::nsstring(string)) != (0 as i8);
    }

    fn can_init_with_pasteboard(pasteboard: Pasteboard) -> bool {
        return rt::msg_i8_id(rt::get_class(#str_ptr("NSSound\0")), rt::sel(#str_ptr("canInitWithPasteboard:\0")), pasteboard.raw()) != (0 as i8);
