    }

    fn volume(this) -> f32 {
        return rt::msg_f32(this._obj, rt::sel(#str_ptr("volume\0")));
    }

    fn set_volume(this, volume: f32) {
        rt::msg_void_f32(this._obj, rt::sel(#str_ptr("setVolume:\0")), volume);
    }

    fn current_time(this) -> f64 {
