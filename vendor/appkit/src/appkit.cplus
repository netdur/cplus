    fn write_objects(this, objects: vec::Vec[PasteboardWriting]) -> bool {
        let arr_objects: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
        let add_sel_objects: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_objects: usize = objects.count();
        var i_objects: usize = 0 as usize;
        while i_objects < n_objects {
            match objects.at_ptr(i_objects) {
                option::Option[*PasteboardWriting]::Some(e_objects) => { rt::msg_void_id(arr_objects, add_sel_objects, (*e_objects).raw()); }
                option::Option[*PasteboardWriting]::None => {}
            }
            i_objects = i_objects +% (1 as usize);
        }
        return rt::msg_i8_id(this._obj, rt::sel(#str_ptr("writeObjects:\0")), arr_objects) != (0 as i8);
    }

