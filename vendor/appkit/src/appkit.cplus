        rt::msg_void_id(this._obj, rt::sel(#str_ptr("writeToPasteboard:\0")), pasteboard.raw());
    }

    fn play(this) -> bool {
        return rt::msg_i8(this._obj, rt::sel(#str_ptr("play\0"))) != (0 as i8);
    }

