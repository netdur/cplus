        let arr_class_array: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
        let add_sel_class_array: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_class_array: usize = class_array.count();
        var i_class_array: usize = 0 as usize;
        while i_class_array < n_class_array {
            match class_array.at_ptr(i_class_array) {
                option::Option[*AnyObject]::Some(e_class_array) => { rt::msg_void_id(arr_class_array, add_sel_class_array, (*e_class_array).raw()); }
