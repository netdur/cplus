// `NSCell` (Foundation/ObjC). Owned via alloc/init; `drop` releases the +1.
struct Cell {
    _obj: *u8,
}

impl Cell {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> Cell { return Cell { _obj: ptr }; }

    fn new() -> Cell {
        let cls: *u8 = rt::get_class(#str_ptr("NSCell\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        return Cell { _obj: rt::msg_id(alloced, rt::sel(#str_ptr("init\0"))) };
    }

    fn init_text_cell(this, string: str) -> *u8 {
        return rt::msg_id_id(this._obj, rt::sel(#str_ptr("initTextCell:\0")), bridge::nsstring(string));
    }

    fn init_image_cell(this, image: Image) -> *u8 {
        return rt::msg_id_id(this._obj, rt::sel(#str_ptr("initImageCell:\0")), image.raw());
