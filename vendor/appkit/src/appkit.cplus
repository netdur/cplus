        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("registeredDraggedTypes\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[text::Text] = vec::Vec[text::Text]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            let value: *u8 = rt::msg_id_u64(arr, at_sel, i);
            out.append(bridge::to_text(value));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn enter_full_screen_mode(this, screen: Screen, with_options: string_map::StringMap[AnyObject]) -> bool {
        let dict_with_options: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableDictionary\0")), rt::sel(#str_ptr("dictionary\0")));
        let dset_with_options: *u8 = rt::sel(#str_ptr("setObject:forKey:\0"));
        let dcap_with_options: usize = with_options.slot_capacity();
        var dsi_with_options: usize = 0 as usize;
        while dsi_with_options < dcap_with_options {
            match with_options.value_ptr_at_slot(dsi_with_options) {
                option::Option[*AnyObject]::Some(dvp_with_options) => {
                    match with_options.key_ptr_at_slot(dsi_with_options) {
                        option::Option[*text::Text]::Some(dkp_with_options) => {
                    let dval_with_options: *u8 = (*dvp_with_options).raw();
                            rt::msg_void_id_id(dict_with_options, dset_with_options, dval_with_options, bridge::nsstring((*dkp_with_options).view()));
                        }
                        option::Option[*text::Text]::None => {}
                    }
                }
                option::Option[*AnyObject]::None => {}
            }
            dsi_with_options = dsi_with_options +% (1 as usize);
        }
        return rt::msg_i8_id_id(this._obj, rt::sel(#str_ptr("enterFullScreenMode:withOptions:\0")), screen.raw(), dict_with_options) != (0 as i8);
    }

    fn exit_full_screen_mode_with_options(this, options: string_map::StringMap[AnyObject]) {
        let dict_options: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableDictionary\0")), rt::sel(#str_ptr("dictionary\0")));
        let dset_options: *u8 = rt::sel(#str_ptr("setObject:forKey:\0"));
        let dcap_options: usize = options.slot_capacity();
        var dsi_options: usize = 0 as usize;
        while dsi_options < dcap_options {
            match options.value_ptr_at_slot(dsi_options) {
                option::Option[*AnyObject]::Some(dvp_options) => {
                    match options.key_ptr_at_slot(dsi_options) {
                        option::Option[*text::Text]::Some(dkp_options) => {
                    let dval_options: *u8 = (*dvp_options).raw();
                            rt::msg_void_id_id(dict_options, dset_options, dval_options, bridge::nsstring((*dkp_options).view()));
                        }
                        option::Option[*text::Text]::None => {}
                    }
                }
                option::Option[*AnyObject]::None => {}
            }
            dsi_options = dsi_options +% (1 as usize);
        }
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("exitFullScreenModeWithOptions:\0")), dict_options);
    }

