// `NSSound` (Foundation/ObjC). Owned via alloc/init; `drop` releases the +1.
struct Sound {
    _obj: *u8,
}

impl Sound {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> Sound { return Sound { _obj: ptr }; }

    fn sound_named(name: str) -> option::Option[Sound] {
        let obj: *u8 = rt::msg_id_id(rt::get_class(#str_ptr("NSSound\0")), rt::sel(#str_ptr("soundNamed:\0")), bridge::nsstring(name));
        if obj == { 0 as *u8 } {
            return option::Option[Sound]::None;
        }
        return option::some(Sound { _obj: rt::retain(obj) });
    }

    fn new(url: URL, by_ref: bool) -> Sound {
        let cls: *u8 = rt::get_class(#str_ptr("NSSound\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        return Sound { _obj: rt::msg_id_id_i8(alloced, rt::sel(#str_ptr("initWithContentsOfURL:byReference:\0")), url.raw(), by_ref as i8) };
    }

    fn new_with_contents_of_file_by_reference(path: str, by_ref: bool) -> Sound {
        let cls: *u8 = rt::get_class(#str_ptr("NSSound\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        return Sound { _obj: rt::msg_id_id_i8(alloced, rt::sel(#str_ptr("initWithContentsOfFile:byReference:\0")), bridge::nsstring(path), by_ref as i8) };
    }

    fn new_with_data(data: Data) -> Sound {
        let cls: *u8 = rt::get_class(#str_ptr("NSSound\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        return Sound { _obj: rt::msg_id_id(alloced, rt::sel(#str_ptr("initWithData:\0")), data.raw()) };
