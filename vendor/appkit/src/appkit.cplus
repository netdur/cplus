// `NSMutableSet` (Foundation/ObjC). Non-owning handle (factory/singleton); `opaque`, no drop.
struct MutableSet {
    opaque _obj: *u8,
}

impl MutableSet {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> MutableSet { return MutableSet { _obj: ptr }; }

}

