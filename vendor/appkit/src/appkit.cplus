                    let dval_text_highlight_attributes: *u8 = (*dvp_text_highlight_attributes).raw();
                            rt::msg_void_id_id(dict_text_highlight_attributes, dset_text_highlight_attributes, dval_text_highlight_attributes, bridge::nsstring((*dkp_text_highlight_attributes).view()));
                        }
                        option::Option[*text::Text]::None => {}
                    }
                }
                option::Option[*AnyObject]::None => {}
            }
            dsi_text_highlight_attributes = dsi_text_highlight_attributes +% (1 as usize);
