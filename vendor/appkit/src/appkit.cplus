        return rt::msg_i8(this._obj, rt::sel(#str_ptr("resume\0"))) != (0 as i8);
    }

    fn stop(this) -> bool {
        return rt::msg_i8(this._obj, rt::sel(#str_ptr("stop\0"))) != (0 as i8);
    }

    fn set_channel_mapping(this, channel_mapping: Array) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setChannelMapping:\0")), channel_mapping.raw());
    }

    fn channel_mapping(this) -> option::Option[Array] {
        let obj: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("channelMapping\0")));
        if obj == { 0 as *u8 } {
            return option::Option[Array]::None;
        }
        return option::some(Array::from_raw(obj));
    }

    fn name(this) -> option::Option[text::Text] {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("name\0")));
        return bridge::to_text_option(ns);
    }

    fn sound_unfiltered_types() -> vec::Vec[text::Text] {
        let arr: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSSound\0")), rt::sel(#str_ptr("soundUnfilteredTypes\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[text::Text] = vec::Vec[text::Text]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            let value: *u8 = rt::msg_id_u64(arr, at_sel, i);
            out.append(bridge::to_text(value));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn is_playing(this) -> bool {
        return rt::msg_i8(this._obj, rt::sel(#str_ptr("isPlaying\0"))) != (0 as i8);
    }

