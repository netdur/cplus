// `NSLayoutGuide` (Foundation/ObjC). Non-owning handle (factory/singleton); `opaque`, no drop.
struct LayoutGuide {
    opaque _obj: *u8,
}

impl LayoutGuide {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> LayoutGuide { return LayoutGuide { _obj: ptr }; }

    fn constraints_affecting_layout_for_orientation(this, orientation: LayoutConstraintOrientation) -> vec::Vec[LayoutConstraint] {
        let arr: *u8 = rt::msg_id_i64(this._obj, rt::sel(#str_ptr("constraintsAffectingLayoutForOrientation:\0")), layout_constraint_orientation_raw(orientation));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[LayoutConstraint] = vec::Vec[LayoutConstraint]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(LayoutConstraint::from_raw(rt::msg_id_u64(arr, at_sel, i)));
            i = i +% (1 as u64);
        }
        return out;
    }

