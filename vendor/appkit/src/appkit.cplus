        }
        return option::some(AlignmentFeedbackToken::from_raw(obj));
    }

    fn alignment_feedback_token_for_horizontal_movement_in_view(this, view: View, previous_x: f64, aligned_x: f64, default_x: f64) -> option::Option[AlignmentFeedbackToken] {
        let obj: *u8 = rt::msg_id_id_f64_f64_f64(this._obj, rt::sel(#str_ptr("alignmentFeedbackTokenForHorizontalMovementInView:previousX:alignedX:defaultX:\0")), view.raw(), previous_x, aligned_x, default_x);
        if obj == { 0 as *u8 } {
