    fn alignment_feedback_token_for_movement_in_view(this, view: View, previous_point: rt::Point, aligned_point: rt::Point, default_point: rt::Point) -> option::Option[AlignmentFeedbackToken] {
        let obj: *u8 = rt::msg_id_id_point_point_point(this._obj, rt::sel(#str_ptr("alignmentFeedbackTokenForMovementInView:previousPoint:alignedPoint:defaultPoint:\0")), view.raw(), previous_point, aligned_point, default_point);
        if obj == { 0 as *u8 } {
