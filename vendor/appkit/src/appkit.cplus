    }

    fn set_loops(this, loops: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setLoops:\0")), loops as i8);
    }

    fn playback_device_identifier(this) -> text::Text {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("playbackDeviceIdentifier\0")));
        return bridge::to_text(ns);
    }

