    fn begin_dragging_session_with_items(this, items: vec::Vec[DraggingItem], event: Event, source: DraggingSource) -> DraggingSession {
        let arr_items: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
        let add_sel_items: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_items: usize = items.count();
        var i_items: usize = 0 as usize;
        while i_items < n_items {
            match items.at_ptr(i_items) {
                option::Option[*DraggingItem]::Some(e_items) => { rt::msg_void_id(arr_items, add_sel_items, (*e_items).raw()); }
                option::Option[*DraggingItem]::None => {}
            }
            i_items = i_items +% (1 as usize);
        }
        return DraggingSession::from_raw(rt::msg_id_id_id_id(this._obj, rt::sel(#str_ptr("beginDraggingSessionWithItems:event:source:\0")), arr_items, event.raw(), source.raw()));
    }

