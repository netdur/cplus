    }

    fn drop(ref this) {
        rt::release(this._obj);
    }
}

// `NSView` (Foundation/ObjC). Owned via alloc/init; `drop` releases the +1.
struct View {
    _obj: *u8,
}

impl View {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> View { return View { _obj: ptr }; }

    fn new(frame_rect: rt::Rect) -> View {
        let cls: *u8 = rt::get_class(#str_ptr("NSView\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        return View { _obj: rt::msg_id_rect(alloced, rt::sel(#str_ptr("initWithFrame:\0")), frame_rect) };
    }

    fn new_with_coder(coder: *u8) -> View {
        let cls: *u8 = rt::get_class(#str_ptr("NSView\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        return View { _obj: rt::msg_id_id(alloced, rt::sel(#str_ptr("initWithCoder:\0")), coder) };
    }

    fn is_descendant_of(this, view: View) -> bool {
        return rt::msg_i8_id(this._obj, rt::sel(#str_ptr("isDescendantOf:\0")), view.raw()) != (0 as i8);
