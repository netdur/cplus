        while dsi_text_highlight_attributes < dcap_text_highlight_attributes {
            match text_highlight_attributes.value_ptr_at_slot(dsi_text_highlight_attributes) {
                option::Option[*AnyObject]::Some(dvp_text_highlight_attributes) => {
                    match text_highlight_attributes.key_ptr_at_slot(dsi_text_highlight_attributes) {
