    fn set_titlebar_accessory_view_controllers(this, titlebar_accessory_view_controllers: vec::Vec[TitlebarAccessoryViewController]) {
        let arr_titlebar_accessory_view_controllers: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
        let add_sel_titlebar_accessory_view_controllers: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_titlebar_accessory_view_controllers: usize = titlebar_accessory_view_controllers.count();
        var i_titlebar_accessory_view_controllers: usize = 0 as usize;
        while i_titlebar_accessory_view_controllers < n_titlebar_accessory_view_controllers {
            match titlebar_accessory_view_controllers.at_ptr(i_titlebar_accessory_view_controllers) {
                option::Option[*TitlebarAccessoryViewController]::Some(e_titlebar_accessory_view_controllers) => { rt::msg_void_id(arr_titlebar_accessory_view_controllers, add_sel_titlebar_accessory_view_controllers, (*e_titlebar_accessory_view_controllers).raw()); }
                option::Option[*TitlebarAccessoryViewController]::None => {}
            }
            i_titlebar_accessory_view_controllers = i_titlebar_accessory_view_controllers +% (1 as usize);
        }
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setTitlebarAccessoryViewControllers:\0")), arr_titlebar_accessory_view_controllers);
    }

