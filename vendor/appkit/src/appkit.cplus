// `NSFontChanging` (ObjC protocol). Non-owning handle; `opaque`, no drop.
struct FontChanging {
    opaque _obj: *u8,
}

impl FontChanging {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> FontChanging { return FontChanging { _obj: ptr }; }

    fn change_font(this, sender: FontManager) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("changeFont:\0")), sender.raw());
    }

    fn valid_modes_for_font_panel(this, font_panel: FontPanel) -> u64 {
        return rt::msg_u64_id(this._obj, rt::sel(#str_ptr("validModesForFontPanel:\0")), font_panel.raw());
    }

}

