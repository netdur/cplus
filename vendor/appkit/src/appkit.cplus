        let arr_views: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
        let add_sel_views: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_views: usize = views.count();
        var i_views: usize = 0 as usize;
        while i_views < n_views {
            match views.at_ptr(i_views) {
                option::Option[*View]::Some(e_views) => { rt::msg_void_id(arr_views, add_sel_views, (*e_views).raw()); }
                option::Option[*View]::None => {}
