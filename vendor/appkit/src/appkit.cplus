    fn order_front_standard_about_panel_with_options(this, options_dictionary: string_map::StringMap[AnyObject]) {
        let dict_options_dictionary: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableDictionary\0")), rt::sel(#str_ptr("dictionary\0")));
        let dset_options_dictionary: *u8 = rt::sel(#str_ptr("setObject:forKey:\0"));
        let dcap_options_dictionary: usize = options_dictionary.slot_capacity();
        var dsi_options_dictionary: usize = 0 as usize;
        while dsi_options_dictionary < dcap_options_dictionary {
            match options_dictionary.value_ptr_at_slot(dsi_options_dictionary) {
                option::Option[*AnyObject]::Some(dvp_options_dictionary) => {
                    match options_dictionary.key_ptr_at_slot(dsi_options_dictionary) {
                        option::Option[*text::Text]::Some(dkp_options_dictionary) => {
                    let dval_options_dictionary: *u8 = (*dvp_options_dictionary).raw();
                            rt::msg_void_id_id(dict_options_dictionary, dset_options_dictionary, dval_options_dictionary, bridge::nsstring((*dkp_options_dictionary).view()));
                        }
                        option::Option[*text::Text]::None => {}
                    }
                }
                option::Option[*AnyObject]::None => {}
            }
            dsi_options_dictionary = dsi_options_dictionary +% (1 as usize);
        }
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("orderFrontStandardAboutPanelWithOptions:\0")), dict_options_dictionary);
    }

