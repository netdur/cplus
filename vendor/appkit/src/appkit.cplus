    fn completions_for_partial_word_range(this, char_range: rt::Range, index_of_selected_item: *u8) -> vec::Vec[text::Text] {
        let arr: *u8 = rt::msg_id_range_id(this._obj, rt::sel(#str_ptr("completionsForPartialWordRange:indexOfSelectedItem:\0")), char_range, index_of_selected_item);
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[text::Text] = vec::Vec[text::Text]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            let value: *u8 = rt::msg_id_u64(arr, at_sel, i);
            out.append(bridge::to_text(value));
            i = i +% (1 as u64);
        }
        return out;
    }

