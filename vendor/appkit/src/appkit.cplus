        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setPlaybackDeviceIdentifier:\0")), bridge::nsstring(playback_device_identifier));
    }

    fn sound_unfiltered_file_types() -> option::Option[Array] {
        let obj: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSSound\0")), rt::sel(#str_ptr("soundUnfilteredFileTypes\0")));
        if obj == { 0 as *u8 } {
            return option::Option[Array]::None;
        }
        return option::some(Array::from_raw(obj));
    }

    fn sound_unfiltered_pasteboard_types() -> option::Option[Array] {
        let obj: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSSound\0")), rt::sel(#str_ptr("soundUnfilteredPasteboardTypes\0")));
        if obj == { 0 as *u8 } {
            return option::Option[Array]::None;
        }
        return option::some(Array::from_raw(obj));
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }
}

