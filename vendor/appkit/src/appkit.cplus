// `NSFormCell` (Foundation/ObjC). Owned via alloc/init; `drop` releases the +1.
struct FormCell {
    _obj: *u8,
}

impl FormCell {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> FormCell { return FormCell { _obj: ptr }; }

    fn init_text_cell(this, string: str) -> *u8 {
        return rt::msg_id_id(this._obj, rt::sel(#str_ptr("initTextCell:\0")), bridge::nsstring(string));
    }

    fn new(coder: *u8) -> FormCell {
        let cls: *u8 = rt::get_class(#str_ptr("NSFormCell\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        return FormCell { _obj: rt::msg_id_id(alloced, rt::sel(#str_ptr("initWithCoder:\0")), coder) };
    }

    fn init_image_cell(this, image: Image) -> *u8 {
        return rt::msg_id_id(this._obj, rt::sel(#str_ptr("initImageCell:\0")), image.raw());
    }

    fn title_width(this, size: rt::Size) -> f64 {
        return rt::msg_f64_size(this._obj, rt::sel(#str_ptr("titleWidth:\0")), size);
    }

    // SKIPPED `titleWidth`: method `title_width` already defined
    fn set_title_width(this, title_width: f64) {
        rt::msg_void_f64(this._obj, rt::sel(#str_ptr("setTitleWidth:\0")), title_width);
    }

    fn title(this) -> text::Text {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("title\0")));
        return bridge::to_text(ns);
    }

