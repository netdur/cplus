    }

    fn color_using_color_space_name_device(this, name: str, device_description: string_map::StringMap[AnyObject]) -> option::Option[Color] {
        let dict_device_description: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableDictionary\0")), rt::sel(#str_ptr("dictionary\0")));
        let dset_device_description: *u8 = rt::sel(#str_ptr("setObject:forKey:\0"));
        let dcap_device_description: usize = device_description.slot_capacity();
        var dsi_device_description: usize = 0 as usize;
        while dsi_device_description < dcap_device_description {
            match device_description.value_ptr_at_slot(dsi_device_description) {
                option::Option[*AnyObject]::Some(dvp_device_description) => {
                    match device_description.key_ptr_at_slot(dsi_device_description) {
                        option::Option[*text::Text]::Some(dkp_device_description) => {
                    let dval_device_description: *u8 = (*dvp_device_description).raw();
                            rt::msg_void_id_id(dict_device_description, dset_device_description, dval_device_description, bridge::nsstring((*dkp_device_description).view()));
                        }
                        option::Option[*text::Text]::None => {}
                    }
                }
                option::Option[*AnyObject]::None => {}
            }
            dsi_device_description = dsi_device_description +% (1 as usize);
        }
        let obj: *u8 = rt::msg_id_id_id(this._obj, rt::sel(#str_ptr("colorUsingColorSpaceName:device:\0")), bridge::nsstring(name), dict_device_description);
        if obj == { 0 as *u8 } {
            return option::Option[Color]::None;
        }
        return option::some(Color::from_raw(obj));
    }

    fn color_using_color_space_name(this, name: str) -> option::Option[Color] {
        let obj: *u8 = rt::msg_id_id(this._obj, rt::sel(#str_ptr("colorUsingColorSpaceName:\0")), bridge::nsstring(name));
        if obj == { 0 as *u8 } {
            return option::Option[Color]::None;
        }
        return option::some(Color::from_raw(obj));
    }

