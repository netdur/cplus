        let arr: *u8 = rt::msg_id_i64(this._obj, rt::sel(#str_ptr("writableTypesForSaveOperation:\0")), save_operation_type_raw(save_operation));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[text::Text] = vec::Vec[text::Text]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            let value: *u8 = rt::msg_id_u64(arr, at_sel, i);
