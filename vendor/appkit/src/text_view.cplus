        var dsi_selected_text_attributes: usize = 0 as usize;
        while dsi_selected_text_attributes < dcap_selected_text_attributes {
            match selected_text_attributes.value_ptr_at_slot(dsi_selected_text_attributes) {
                option::Option[*AnyObject]::Some(dvp_selected_text_attributes) => {
                    match selected_text_attributes.key_ptr_at_slot(dsi_selected_text_attributes) {
                        option::Option[*text::Text]::Some(dkp_selected_text_attributes) => {
                    let dval_selected_text_attributes: *u8 = (*dvp_selected_text_attributes).raw();
                            rt::msg_void_id_id(dict_selected_text_attributes, dset_selected_text_attributes, dval_selected_text_attributes, bridge::nsstring((*dkp_selected_text_attributes).view()));
                        }
                        option::Option[*text::Text]::None => {}
                    }
                }
                option::Option[*AnyObject]::None => {}
            }
            dsi_selected_text_attributes = dsi_selected_text_attributes +% (1 as usize);
        }
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setSelectedTextAttributes:\0")), dict_selected_text_attributes);
