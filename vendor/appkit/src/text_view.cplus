        let add_sel_ranges: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_ranges: usize = ranges.count();
        var i_ranges: usize = 0 as usize;
        while i_ranges < n_ranges {
            match ranges.at_ptr(i_ranges) {
                option::Option[*Value]::Some(e_ranges) => { rt::msg_void_id(arr_ranges, add_sel_ranges, (*e_ranges).raw()); }
                option::Option[*Value]::None => {}
            }
            i_ranges = i_ranges +% (1 as usize);
