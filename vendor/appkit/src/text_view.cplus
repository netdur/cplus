    fn set_typing_attributes(this, typing_attributes: string_map::StringMap[AnyObject]) {
        let dict_typing_attributes: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableDictionary\0")), rt::sel(#str_ptr("dictionary\0")));
        let dset_typing_attributes: *u8 = rt::sel(#str_ptr("setObject:forKey:\0"));
        let dcap_typing_attributes: usize = typing_attributes.slot_capacity();
        var dsi_typing_attributes: usize = 0 as usize;
        while dsi_typing_attributes < dcap_typing_attributes {
            match typing_attributes.value_ptr_at_slot(dsi_typing_attributes) {
                option::Option[*AnyObject]::Some(dvp_typing_attributes) => {
                    match typing_attributes.key_ptr_at_slot(dsi_typing_attributes) {
                        option::Option[*text::Text]::Some(dkp_typing_attributes) => {
                    let dval_typing_attributes: *u8 = (*dvp_typing_attributes).raw();
                            rt::msg_void_id_id(dict_typing_attributes, dset_typing_attributes, dval_typing_attributes, bridge::nsstring((*dkp_typing_attributes).view()));
                        }
                        option::Option[*text::Text]::None => {}
                    }
                }
                option::Option[*AnyObject]::None => {}
            }
            dsi_typing_attributes = dsi_typing_attributes +% (1 as usize);
        }
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setTypingAttributes:\0")), dict_typing_attributes);
    }

