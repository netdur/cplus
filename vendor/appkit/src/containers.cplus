    fn new(frame: rt::Rect) -> TabView {
        return TabView { _obj: rt::alloc_init_with_frame(#str_ptr("NSTabView\0"), frame) };
    }

    fn add_item(this, item: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("addTabViewItem:\0")), item);
    }

    fn select_item(this, at: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("selectTabViewItemAtIndex:\0")), at);
    }

    fn set_delegate(this, delegate: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    }
}

struct TabViewItem {
    _obj: *u8,
}

impl TabViewItem {
    fn raw(this) -> *u8 { return this._obj; }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn new(identifier: str) -> TabViewItem {
        let cls: *u8 = rt::get_class(#str_ptr("NSTabViewItem\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let ns_id: *u8 = bridge::cplus_str_to_nsstring(identifier);
        return TabViewItem { _obj: rt::msg_id_id(alloced, rt::sel(#str_ptr("initWithIdentifier:\0")), ns_id) };
    }

    fn set_label(this, label: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setLabel:\0")), bridge::cplus_str_to_nsstring(label));
    }

    fn set_view(this, view: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setView:\0")), view);
    }

    // NSTabViewController.addTabViewItem: requires every NSTabViewItem
    // to have a non-nil viewController. Plain NSTabView is happy with
    // just a view (or nothing); the controller variant insists on the
    // typed parent. See `appkit_vendor_package_smoke` for the failure
    // mode when this is skipped.
    fn set_view_controller(this, view_controller: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setViewController:\0")), view_controller);
    }
}

