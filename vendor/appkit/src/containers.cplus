import "./runtime" as rt;
import "./convert" as bridge;

struct SplitView {
    _obj: *u8,
}

impl SplitView {
    fn raw(this) -> *u8 { return this._obj; }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn new(frame: rt::Rect) -> SplitView {
        return SplitView { _obj: rt::alloc_init_with_frame(#str_ptr("NSSplitView\0"), frame) };
    }

    fn add_arranged_subview(this, view: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("addArrangedSubview:\0")), view);
    }

    fn set_vertical(this, vertical: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setVertical:\0")), vertical as i8);
    }

    fn set_divider_style(this, style: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setDividerStyle:\0")), style);
    }

    fn set_delegate(this, delegate: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    }
}

