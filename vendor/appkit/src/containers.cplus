import "./runtime" as rt;

struct SplitView {
    obj: *u8,
}

impl SplitView {
    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn new(frame: rt::Rect) -> SplitView {
        return SplitView { obj: rt::alloc_init_with_frame(#str_ptr("NSSplitView\0"), frame) };
    }

    fn add_arranged_subview(this, view: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("addArrangedSubview:\0")), view);
    }

    fn set_vertical(this, flag: i8) {
        rt::msg_void_i8(this.obj, rt::sel(#str_ptr("setVertical:\0")), flag);
    }

    fn set_divider_style(this, style: i64) {
        rt::msg_void_i64(this.obj, rt::sel(#str_ptr("setDividerStyle:\0")), style);
    }

    fn set_delegate(this, delegate: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    }
}

struct TabView {
    obj: *u8,
}

impl TabView {
    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn new(frame: rt::Rect) -> TabView {
        return TabView { obj: rt::alloc_init_with_frame(#str_ptr("NSTabView\0"), frame) };
    }

    fn add_tab_view_item(this, item: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("addTabViewItem:\0")), item);
    }

    fn select_tab_view_item_at_index(this, index: i64) {
        rt::msg_void_i64(this.obj, rt::sel(#str_ptr("selectTabViewItemAtIndex:\0")), index);
    }

    fn set_delegate(this, delegate: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    }
}

struct TabViewItem {
    obj: *u8,
}

impl TabViewItem {
    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn new(identifier: *u8) -> TabViewItem {
        return TabViewItem { obj: rt::alloc_init_with_identifier(#str_ptr("NSTabViewItem\0"), identifier) };
    }

    fn set_label(this, label: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setLabel:\0")), rt::ns_string(label));
    }

    fn set_view(this, view: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setView:\0")), view);
    }

    // NSTabViewController.addTabViewItem: requires every NSTabViewItem
    // to have a non-nil viewController. Plain NSTabView is happy with
    // just a view (or nothing); the controller variant insists on the
    // typed parent. See `appkit_vendor_package_smoke` for the failure
    // mode when this is skipped.
    fn set_view_controller(this, view_controller: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setViewController:\0")), view_controller);
    }
}

