struct Popover {
    obj: *u8,
}

impl Popover {
    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn new() -> Popover {
        return Popover { obj: rt::alloc_init(#str_ptr("NSPopover\0")) };
    }

    fn set_content_view_controller(this, controller: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setContentViewController:\0")), controller);
    }

    fn set_behavior(this, behavior: i64) {
        rt::msg_void_i64(this.obj, rt::sel(#str_ptr("setBehavior:\0")), behavior);
    }

    fn close(this) {
        rt::msg_void(this.obj, rt::sel(#str_ptr("close\0")));
    }
}
