pub struct Popover {
    pub obj: *u8,
}

impl Popover {
    fn drop(mut self) {
        rt::release(self.obj);
    }

    pub fn new() -> Popover {
        return Popover { obj: rt::alloc_init(#str_ptr("NSPopover\0")) };
    }

    pub fn set_content_view_controller(self, controller: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setContentViewController:\0")), controller);
    }

    pub fn set_behavior(self, behavior: i64) {
        rt::msg_void_i64(self.obj, rt::sel(#str_ptr("setBehavior:\0")), behavior);
    }

    pub fn close(self) {
        rt::msg_void(self.obj, rt::sel(#str_ptr("close\0")));
    }
}
