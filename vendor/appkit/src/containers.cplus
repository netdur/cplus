import "./runtime" as rt;

pub struct SplitView {
    pub obj: *u8,
}

impl SplitView {
    fn drop(mut self) {
        rt::release(self.obj);
    }

    pub fn new(frame: rt::Rect) -> SplitView {
        return SplitView { obj: rt::alloc_init_with_frame(#str_ptr("NSSplitView\0"), frame) };
    }

    pub fn add_arranged_subview(self, view: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("addArrangedSubview:\0")), view);
    }

    pub fn set_vertical(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(#str_ptr("setVertical:\0")), flag);
    }

    pub fn set_divider_style(self, style: i64) {
        rt::msg_void_i64(self.obj, rt::sel(#str_ptr("setDividerStyle:\0")), style);
    }

    pub fn set_delegate(self, delegate: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    }
}

pub struct TabView {
    pub obj: *u8,
}

impl TabView {
    fn drop(mut self) {
        rt::release(self.obj);
    }

    pub fn new(frame: rt::Rect) -> TabView {
        return TabView { obj: rt::alloc_init_with_frame(#str_ptr("NSTabView\0"), frame) };
    }

    pub fn add_tab_view_item(self, item: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("addTabViewItem:\0")), item);
    }

    pub fn select_tab_view_item_at_index(self, index: i64) {
        rt::msg_void_i64(self.obj, rt::sel(#str_ptr("selectTabViewItemAtIndex:\0")), index);
    }

    pub fn set_delegate(self, delegate: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    }
}

pub struct TabViewItem {
    pub obj: *u8,
}

impl TabViewItem {
    fn drop(mut self) {
        rt::release(self.obj);
    }

    pub fn new(identifier: *u8) -> TabViewItem {
        return TabViewItem { obj: rt::alloc_init_with_identifier(#str_ptr("NSTabViewItem\0"), identifier) };
    }

    pub fn set_label(self, label: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setLabel:\0")), rt::ns_string(label));
    }

    pub fn set_view(self, view: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setView:\0")), view);
    }

    // NSTabViewController.addTabViewItem: requires every NSTabViewItem
    // to have a non-nil viewController. Plain NSTabView is happy with
    // just a view (or nothing); the controller variant insists on the
    // typed parent. See `appkit_vendor_package_smoke` for the failure
    // mode when this is skipped.
    pub fn set_view_controller(self, view_controller: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setViewController:\0")), view_controller);
    }
}

