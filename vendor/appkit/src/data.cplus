import "./runtime" as rt;
import "./convert" as bridge;
import "stdlib/option" as option;

// Synthesize an `NSTableViewDataSource` object from two C+ implementations and
// return a `+1`-owned handle (alloc/new). This is the documented delegate
// pattern (plan.appkit.md §3): the app writes the Objective-C method bodies
// directly — same shape as `create_app_delegate` — and the runtime registers
// them on a fresh `CTableDataSource` class.
//
//   row_count_imp: `(self, _cmd, tableView) -> NSInteger`
//                  implements `-numberOfRowsInTableView:`.
//   value_imp:     `(self, _cmd, tableView, column, row) -> id`
//                  implements `-tableView:objectValueForTableColumn:row:`
//                  (return an `NSString*`, e.g. via `rt::ns_string`).
//
// Callbacks are closure-free (locked principle #2): reach app state through a
// `static mut`, an associated object on the table, or a global. Wrap the
// returned handle in an owner that releases it, or keep it alive for the
// table's lifetime; the data source is not retained by the table.
fn create_table_data_source(
    row_count_imp: fn(*u8, *u8, *u8) -> i64,
    value_imp: fn(*u8, *u8, *u8, *u8, i64) -> *u8,
) -> *u8 {
    let existing: *u8 = rt::get_class(#str_ptr("CTableDataSource\0"));
    var cls: *u8 = existing;
    if existing == { 0 as *u8 } {
        let nsobject: *u8 = rt::get_class(#str_ptr("NSObject\0"));
        cls = rt::allocate_class_pair(nsobject, #str_ptr("CTableDataSource\0"), 0 as usize);
        let _a: i8 = rt::add_method_i64_id(
            cls,
            rt::sel(#str_ptr("numberOfRowsInTableView:\0")),
            row_count_imp,
            #str_ptr("q@:@\0"),
        );
        let _b: i8 = rt::add_method_id_table_value(
            cls,
            rt::sel(#str_ptr("tableView:objectValueForTableColumn:row:\0")),
            value_imp,
            #str_ptr("@@:@@q\0"),
        );
        rt::register_class_pair(cls);
    }
    return rt::msg_id(cls, rt::sel(#str_ptr("new\0")));
}

// Synthesize an `NSTableViewDelegate` for selection handling and return a
// `+1`-owned handle. Wire it with `table.set_delegate(...)`.
//
//   selection_changed_imp: `(self, _cmd, notification)` implements
//   `-tableViewSelectionDidChange:`. Read the new selection inside it with
//   `TableView::selected_row()` (reach the table via a `static mut`, an
//   associated object, or `[notification object]`).
fn create_table_delegate(selection_changed_imp: fn(*u8, *u8, *u8)) -> *u8 {
    let existing: *u8 = rt::get_class(#str_ptr("CTableDelegate\0"));
    var cls: *u8 = existing;
    if existing == { 0 as *u8 } {
        let nsobject: *u8 = rt::get_class(#str_ptr("NSObject\0"));
        cls = rt::allocate_class_pair(nsobject, #str_ptr("CTableDelegate\0"), 0 as usize);
        let _a: i8 = rt::add_action_method(
            cls,
            rt::sel(#str_ptr("tableViewSelectionDidChange:\0")),
            selection_changed_imp,
            #str_ptr("v@:@\0"),
        );
        rt::register_class_pair(cls);
    }
    return rt::msg_id(cls, rt::sel(#str_ptr("new\0")));
}

// Owned (+1 via alloc/initWithFrame:); a scroll view (its document view) or a
// parent retains it. `drop` releases this wrapper's +1 (plan.appkit.md §2).
struct TableView {
    _obj: *u8,
}

impl TableView {
    fn raw(this) -> *u8 { return this._obj; }

    fn new(frame: rt::Rect) -> TableView {
        return TableView { _obj: rt::alloc_init_with_frame(#str_ptr("NSTableView\0"), frame) };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn add_column(this, column: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("addTableColumn:\0")), column);
    }

    fn remove_column(this, column: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("removeTableColumn:\0")), column);
    }

    fn reload_data(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("reloadData\0")));
    }

    // The index of the selected row, or `None` if nothing is selected (AppKit's
    // `selectedRow` is -1 in that case). Read this from a selection delegate
    // (see `create_table_delegate`) to drive a master/detail UI.
    fn selected_row(this) -> option::Option[i64] {
        let row: i64 = rt::msg_i64(this._obj, rt::sel(#str_ptr("selectedRow\0")));
        if row < (0 as i64) {
            return option::Option[i64]::None;
        }
        return option::some(row);
    }

    fn set_delegate(this, delegate: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    }

    fn set_data_source(this, data_source: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setDataSource:\0")), data_source);
    }

    fn set_row_height(this, height: f64) {
        rt::msg_void_f64(this._obj, rt::sel(#str_ptr("setRowHeight:\0")), height);
    }
}

// Owned (+1 via alloc/initWithIdentifier:); the table retains it on
// `addTableColumn:`. `drop` releases this wrapper's +1 (plan.appkit.md §2).
struct TableColumn {
    _obj: *u8,
}

impl TableColumn {
    fn raw(this) -> *u8 { return this._obj; }

    fn new(identifier: str) -> TableColumn {
        let cls: *u8 = rt::get_class(#str_ptr("NSTableColumn\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let ns_id: *u8 = bridge::cplus_str_to_nsstring(identifier);
        return TableColumn { _obj: rt::msg_id_id(alloced, rt::sel(#str_ptr("initWithIdentifier:\0")), ns_id) };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn set_title(this, title: str) {
        let header_cell = rt::msg_id(this._obj, rt::sel(#str_ptr("headerCell\0")));
        rt::msg_void_id(header_cell, rt::sel(#str_ptr("setStringValue:\0")), bridge::cplus_str_to_nsstring(title));
    }

    fn set_width(this, width: f64) {
        rt::msg_void_f64(this._obj, rt::sel(#str_ptr("setWidth:\0")), width);
    }

    fn set_min_width(this, width: f64) {
        rt::msg_void_f64(this._obj, rt::sel(#str_ptr("setMinWidth:\0")), width);
    }

    fn set_max_width(this, width: f64) {
        rt::msg_void_f64(this._obj, rt::sel(#str_ptr("setMaxWidth:\0")), width);
    }
}

