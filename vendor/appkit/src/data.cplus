import "./runtime" as rt;

pub struct TableView {
    pub obj: *u8,
}

impl TableView {
    pub fn new(frame: rt::Rect) -> TableView {
        return TableView { obj: rt::alloc_init_with_frame(str_ptr("NSTableView\0"), frame) };
    }

    pub fn add_table_column(self, column: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("addTableColumn:\0")), column);
    }

    pub fn remove_table_column(self, column: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("removeTableColumn:\0")), column);
    }

    pub fn reload_data(self) {
        rt::msg_void(self.obj, rt::sel(str_ptr("reloadData\0")));
    }

    pub fn set_delegate(self, delegate: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setDelegate:\0")), delegate);
    }

    pub fn set_data_source(self, data_source: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setDataSource:\0")), data_source);
    }

    pub fn set_row_height(self, height: f64) {
        rt::msg_void_f64(self.obj, rt::sel(str_ptr("setRowHeight:\0")), height);
    }
}

pub struct TableColumn {
    pub obj: *u8,
}

impl TableColumn {
    pub fn new(identifier: *u8) -> TableColumn {
        return TableColumn { obj: rt::alloc_init_with_identifier(str_ptr("NSTableColumn\0"), identifier) };
    }

    pub fn set_title(self, title: *u8) {
        let header_cell = rt::msg_id(self.obj, rt::sel(str_ptr("headerCell\0")));
        rt::msg_void_id(header_cell, rt::sel(str_ptr("setStringValue:\0")), rt::ns_string(title));
    }

    pub fn set_width(self, width: f64) {
        rt::msg_void_f64(self.obj, rt::sel(str_ptr("setWidth:\0")), width);
    }

    pub fn set_min_width(self, width: f64) {
        rt::msg_void_f64(self.obj, rt::sel(str_ptr("setMinWidth:\0")), width);
    }

    pub fn set_max_width(self, width: f64) {
        rt::msg_void_f64(self.obj, rt::sel(str_ptr("setMaxWidth:\0")), width);
    }
}

