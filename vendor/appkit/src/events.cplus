// NSEvent — key/mouse event introspection (plan.appkit.md §3/§4).
//
// AppKit delivers an `NSEvent*` to handlers (e.g. an overridden `keyDown:` /
// `mouseDown:`, or a monitor). These helpers read its fields without each
// call site re-deriving selectors, and name the `NSEventType` /
// `NSEventModifierFlags` constants. Events are owned by AppKit for the
// duration of the dispatch, so nothing here is wrapped or released.

import "./runtime" as rt;

// ---- NSEventType (the values a handler switches on) ----

pub fn type_left_mouse_down() -> i64 { return 1 as i64; }
pub fn type_left_mouse_up() -> i64 { return 2 as i64; }
pub fn type_right_mouse_down() -> i64 { return 3 as i64; }
pub fn type_right_mouse_up() -> i64 { return 4 as i64; }
pub fn type_mouse_moved() -> i64 { return 5 as i64; }
pub fn type_left_mouse_dragged() -> i64 { return 6 as i64; }
pub fn type_key_down() -> i64 { return 10 as i64; }
pub fn type_key_up() -> i64 { return 11 as i64; }
pub fn type_flags_changed() -> i64 { return 12 as i64; }
pub fn type_scroll_wheel() -> i64 { return 22 as i64; }

// ---- NSEventModifierFlags (a bitmask on `modifier_flags`) ----

pub fn mod_caps_lock() -> u64 { return 65536 as u64; }    // 1 << 16
pub fn mod_shift() -> u64 { return 131072 as u64; }       // 1 << 17
pub fn mod_control() -> u64 { return 262144 as u64; }     // 1 << 18
pub fn mod_option() -> u64 { return 524288 as u64; }      // 1 << 19
pub fn mod_command() -> u64 { return 1048576 as u64; }    // 1 << 20
pub fn mod_function() -> u64 { return 8388608 as u64; }   // 1 << 23

// True if `flags` (from `modifier_flags`) has every bit in `mask` set.
pub fn has_modifier(flags: u64, mask: u64) -> i8 {
    if (flags & mask) == mask {
        return 1 as i8;
    }
    return 0 as i8;
}

// ---- Accessors on an `NSEvent*` ----

pub fn event_type(ev: *u8) -> i64 {
    return rt::msg_i64(ev, rt::sel(str_ptr("type\0")));
}

pub fn modifier_flags(ev: *u8) -> u64 {
    return rt::msg_u64(ev, rt::sel(str_ptr("modifierFlags\0")));
}

// Virtual key code (hardware-dependent); valid for key events.
pub fn key_code(ev: *u8) -> i64 {
    return rt::msg_i64(ev, rt::sel(str_ptr("keyCode\0")));
}

// Whether a key-down event is an auto-repeat.
pub fn is_a_repeat(ev: *u8) -> i8 {
    return rt::msg_i64(ev, rt::sel(str_ptr("isARepeat\0"))) as i8;
}

// Mouse-button number (0 left, 1 right, …); valid for mouse events.
pub fn button_number(ev: *u8) -> i64 {
    return rt::msg_i64(ev, rt::sel(str_ptr("buttonNumber\0")));
}

// Click count for mouse events (2 = double-click).
pub fn click_count(ev: *u8) -> i64 {
    return rt::msg_i64(ev, rt::sel(str_ptr("clickCount\0")));
}

// Cursor location in the event window's base coordinate system.
pub fn location_in_window(ev: *u8) -> rt::Point {
    return rt::msg_point(ev, rt::sel(str_ptr("locationInWindow\0")));
}

// The characters generated by a key event, as an `NSString*` (null for
// non-key events). Pair with `convert::nsstring_to_cplus_string`.
pub fn characters_ns(ev: *u8) -> *u8 {
    return rt::msg_id(ev, rt::sel(str_ptr("characters\0")));
}
