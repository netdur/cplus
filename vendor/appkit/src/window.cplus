    if raw == (274877906944 as i64) { return EventMask::ChangeMode; }
    if raw == (1099511627776 as i64) { return EventMask::MouseCancelled; }
    if raw == (9223372036854775807 as i64) { return EventMask::Any; }
    return EventMask::LeftMouseDown;
}

// `NSWindowBackingLocation` (NS_ENUM)
enum WindowBackingLocation {
    Default,
    VideoMemory,
    MainMemory,
}

fn window_backing_location_raw(v: WindowBackingLocation) -> i64 {
    return match v {
        WindowBackingLocation::Default => { 0 as i64 },
        WindowBackingLocation::VideoMemory => { 1 as i64 },
        WindowBackingLocation::MainMemory => { 2 as i64 },
    };
}

fn window_backing_location_from_raw(raw: i64) -> WindowBackingLocation {
    if raw == (1 as i64) { return WindowBackingLocation::VideoMemory; }
    if raw == (2 as i64) { return WindowBackingLocation::MainMemory; }
    return WindowBackingLocation::Default;
}

