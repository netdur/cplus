import "./runtime" as rt;

// Synthesize an `NSWindowDelegate` from two C+ method bodies and return a
// `+1`-owned handle (the documented delegate pattern, plan.appkit.md Â§3 â€”
// same shape as `create_app_delegate` / `create_table_data_source`). Wire it
// with `window.set_delegate(...)`.
//
//   should_close_imp: `(self, _cmd, sender) -> BOOL` implements
//                     `-windowShouldClose:` (return 1 to allow the close).
//   will_close_imp:   `(self, _cmd, notification)` implements
//                     `-windowWillClose:` (teardown hook; no return).
//
// Callbacks are closure-free â€” reach app state through a `static mut`, an
// associated object, or a global.
fn create_window_delegate(
    should_close_imp: fn(*u8, *u8, *u8) -> i8,
    will_close_imp: fn(*u8, *u8, *u8),
) -> *u8 {
    let existing: *u8 = rt::get_class(#str_ptr("CWindowDelegate\0"));
    var cls: *u8 = existing;
    if existing == { 0 as *u8 } {
        let nsobject: *u8 = rt::get_class(#str_ptr("NSObject\0"));
        cls = rt::allocate_class_pair(nsobject, #str_ptr("CWindowDelegate\0"), 0 as usize);
        let _a: i8 = rt::add_terminate_method(
            cls,
            rt::sel(#str_ptr("windowShouldClose:\0")),
            should_close_imp,
            #str_ptr("c@:@\0"),
        );
        let _b: i8 = rt::add_action_method(
            cls,
            rt::sel(#str_ptr("windowWillClose:\0")),
            will_close_imp,
            #str_ptr("v@:@\0"),
        );
        rt::register_class_pair(cls);
    }
    return rt::msg_id(cls, rt::sel(#str_ptr("new\0")));
}

struct Window {
    opaque obj: *u8,
}

impl Window {
    fn raw(this) -> *u8 { return this.obj; }

    fn new(frame: rt::Rect, style_mask: u64, backing: u64, defer_flag: i8) -> Window {
        let nswindow_cls: *u8 = rt::get_class(#str_ptr("NSWindow\0"));
        let window_alloc: *u8 = rt::msg_id(nswindow_cls, rt::sel(#str_ptr("alloc\0")));
        let window: *u8 = rt::msg_init_window(
            window_alloc,
            rt::sel(#str_ptr("initWithContentRect:styleMask:backing:defer:\0")),
            frame,
            style_mask,
            backing,
            defer_flag,
        );
        return Window { obj: window };
    }

    fn set_title(this, title: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setTitle:\0")), rt::ns_string(title));
    }

    // v0.0.7 Slice 5.1: pre-built-NSString variant. Use this from
    // callers that already have an `NSString*` (e.g. from
    // `bridge::cplus_string_to_nsstring` on dynamic content); the
    // `set_title` variant above wraps a C-string literal via
    // `rt::ns_string` and is the right choice for `"Hi\0"`-shape args.
    fn set_title_ns(this, title_ns: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setTitle:\0")), title_ns);
    }

    fn center(this) {
        rt::msg_void(this.obj, rt::sel(#str_ptr("center\0")));
    }

    fn content_view(this) -> *u8 {
        return rt::msg_id(this.obj, rt::sel(#str_ptr("contentView\0")));
    }

    fn set_content_view(this, view: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setContentView:\0")), view);
    }

    fn make_key_and_order_front(this, sender: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("makeKeyAndOrderFront:\0")), sender);
    }

    fn order_front(this, sender: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("orderFront:\0")), sender);
    }

    fn close(this) {
        rt::msg_void(this.obj, rt::sel(#str_ptr("close\0")));
    }

    fn set_background_color(this, color: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setBackgroundColor:\0")), color);
    }

    fn set_delegate(this, delegate: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    }

    fn set_toolbar(this, toolbar: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setToolbar:\0")), toolbar);
    }

    // GAP 4 (v0.0.19): control how the toolbar integrates with the titlebar
    // (`setToolbarStyle:`, macOS 11+). `style` is an `NSWindowToolbarStyle`:
    // 0 automatic, 1 expanded, 2 preference, 3 unified, 4 unifiedCompact.
    fn set_toolbar_style(this, style: i64) {
        rt::msg_void_i64(this.obj, rt::sel(#str_ptr("setToolbarStyle:\0")), style);
    }

    fn set_min_size(this, size: rt::Size) {
        rt::msg_void_size(this.obj, rt::sel(#str_ptr("setMinSize:\0")), size);
    }

    fn set_max_size(this, size: rt::Size) {
        rt::msg_void_size(this.obj, rt::sel(#str_ptr("setMaxSize:\0")), size);
    }

    fn set_titlebar_appears_transparent(this, flag: i8) {
        rt::msg_void_i8(this.obj, rt::sel(#str_ptr("setTitlebarAppearsTransparent:\0")), flag);
    }

    fn set_title_visibility(this, visibility: i64) {
        rt::msg_void_i64(this.obj, rt::sel(#str_ptr("setTitleVisibility:\0")), visibility);
    }
}
