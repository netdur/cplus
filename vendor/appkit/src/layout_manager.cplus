// `NSTextLayoutOrientationProvider` (ObjC protocol). Non-owning handle; `opaque`, no drop.
struct TextLayoutOrientationProvider {
    opaque _obj: *u8,
}

impl TextLayoutOrientationProvider {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> TextLayoutOrientationProvider { return TextLayoutOrientationProvider { _obj: ptr }; }

    fn layout_orientation(this) -> TextLayoutOrientation {
        return text_layout_orientation_from_raw(rt::msg_i64(this._obj, rt::sel(#str_ptr("layoutOrientation\0"))));
    }

}

