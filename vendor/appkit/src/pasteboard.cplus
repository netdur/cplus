// NSPasteboard — the system clipboard (plan.appkit.md §4).
//
// `Pasteboard` wraps a shared `NSPasteboard`. The general pasteboard is a
// process-wide singleton owned by AppKit, so the wrapper is `opaque` (a
// borrowed handle) and has no `drop` — releasing it would over-release a
// system object (plan.appkit.md §2, the non-owned case).
//
// The string API uses the UTI for `NSPasteboardTypeString`
// (`public.utf8-plain-text`). The clipboard is writer-clears-then-writes:
// `clear` returns a change count, and every `set_*` must follow a `clear`.

import "./runtime" as rt;
import "./convert" as bridge;
import "stdlib/text" as text;
import "stdlib/option" as option;
import "stdlib/status" as status;

struct Pasteboard {
    opaque _obj: *u8,
}

// NSPasteboardTypeString, as an NSString. Built per call (autoreleased, +0);
// the active autorelease pool reclaims it.
fn type_string() -> *u8 {
    return rt::ns_string(#str_ptr("public.utf8-plain-text\0"));
}

impl Pasteboard {
    fn raw(this) -> *u8 { return this._obj; }

    // The shared system clipboard.
    fn general() -> Pasteboard {
        let cls: *u8 = rt::get_class(#str_ptr("NSPasteboard\0"));
        let pb: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("generalPasteboard\0")));
        return Pasteboard { _obj: pb };
    }

    // Remove the current contents and declare ownership; returns the new
    // change count. Call before any `set_*`.
    fn clear(this) -> i64 {
        return rt::msg_i64(this._obj, rt::sel(#str_ptr("clearContents\0")));
    }

    // Write plain text to the clipboard. Returns `Status::Ok` on success, or
    // `Status::InvalidInput` if AppKit rejected the write (the most common cause
    // is not having declared ownership via a preceding `clear`). The caller is
    // responsible for that `clear`.
    fn set_string(this, text: str) -> status::Status {
        let ok: i8 = rt::msg_i8_id_id(
            this._obj,
            rt::sel(#str_ptr("setString:forType:\0")),
            bridge::cplus_str_to_nsstring(text),
            type_string(),
        );
        if ok != (0 as i8) {
            return status::Status::Ok;
        }
        return status::Status::InvalidInput;
    }

    // Read the plain-text contents as an owned `Text`, or `None` if the
    // clipboard holds no string of that type.
    fn string(this) -> option::Option[text::Text] {
        let ns: *u8 = rt::msg_id_id(this._obj, rt::sel(#str_ptr("stringForType:\0")), type_string());
        return bridge::nsstring_to_text_option(ns);
    }
}
