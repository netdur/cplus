        return rt::msg_i64(this._obj, rt::sel(#str_ptr("gState\0")));
    }

    fn allocate_g_state(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("allocateGState\0")));
    }

    fn release_g_state(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("releaseGState\0")));
    }

    fn set_up_g_state(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("setUpGState\0")));
    }

    fn renew_g_state(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("renewGState\0")));
    }

    fn writing_tools_coordinator(this) -> option::Option[*u8] {
        let obj: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("writingToolsCoordinator\0")));
        return bridge::obj_option(obj);
    }

    fn set_writing_tools_coordinator(this, writing_tools_coordinator: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setWritingToolsCoordinator:\0")), writing_tools_coordinator);
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }
}

