import "./runtime" as rt;

pub struct View {
    pub obj: *u8,
}

impl View {
    pub fn new(frame: rt::Rect) -> View {
        let nsview_cls: *u8 = rt::get_class(str_ptr("NSView\0"));
        let view_alloc: *u8 = rt::msg_id(nsview_cls, rt::sel(str_ptr("alloc\0")));
        let view: *u8 = rt::msg_init_with_frame(view_alloc, rt::sel(str_ptr("initWithFrame:\0")), frame);
        return View { obj: view };
    }

    pub fn add_subview(self, view: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("addSubview:\0")), view);
    }

    pub fn set_frame(self, frame: rt::Rect) {
        rt::msg_void_rect(self.obj, rt::sel(str_ptr("setFrame:\0")), frame);
    }

    pub fn set_autoresizing_mask(self, mask: u64) {
        rt::msg_void_u64(self.obj, rt::sel(str_ptr("setAutoresizingMask:\0")), mask);
    }

    pub fn set_hidden(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(str_ptr("setHidden:\0")), flag);
    }

    pub fn set_wants_layer(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(str_ptr("setWantsLayer:\0")), flag);
    }

    pub fn set_needs_display(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(str_ptr("setNeedsDisplay:\0")), flag);
    }
}

pub struct StackView {
    pub obj: *u8,
}

impl StackView {
    pub fn new(frame: rt::Rect) -> StackView {
        let cls: *u8 = rt::get_class(str_ptr("NSStackView\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(str_ptr("alloc\0")));
        let view: *u8 = rt::msg_init_with_frame(alloced, rt::sel(str_ptr("initWithFrame:\0")), frame);
        return StackView { obj: view };
    }

    pub fn add_view(self, view: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("addArrangedSubview:\0")), view);
    }

    pub fn remove_view(self, view: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("removeArrangedSubview:\0")), view);
    }

    pub fn set_orientation(self, orientation: i64) {
        rt::msg_void_i64(self.obj, rt::sel(str_ptr("setOrientation:\0")), orientation);
    }

    pub fn set_spacing(self, spacing: f64) {
        rt::msg_void_f64(self.obj, rt::sel(str_ptr("setSpacing:\0")), spacing);
    }

    pub fn set_edge_insets(self, top: f64, left: f64, bottom: f64, right: f64) {
        let insets = rt::EdgeInsets { top: top, left: left, bottom: bottom, right: right };
        rt::msg_void_edge_insets(self.obj, rt::sel(str_ptr("setEdgeInsets:\0")), insets);
    }

    pub fn set_alignment(self, align: i64) {
        rt::msg_void_i64(self.obj, rt::sel(str_ptr("setAlignment:\0")), align);
    }

    pub fn set_distribution(self, dist: i64) {
        rt::msg_void_i64(self.obj, rt::sel(str_ptr("setDistribution:\0")), dist);
    }
}

pub struct ScrollView {
    pub obj: *u8,
}

impl ScrollView {
    pub fn new(frame: rt::Rect) -> ScrollView {
        let cls: *u8 = rt::get_class(str_ptr("NSScrollView\0"));
