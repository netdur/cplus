}

pub struct Box {
    pub obj: *u8,
}

impl Box {
    pub fn new(frame: rt::Rect) -> Box {
        let cls: *u8 = rt::get_class(str_ptr("NSBox\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(str_ptr("alloc\0")));
        let view: *u8 = rt::msg_init_with_frame(alloced, rt::sel(str_ptr("initWithFrame:\0")), frame);
        return Box { obj: view };
    }

    pub fn set_title(self, title: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setTitle:\0")), rt::ns_string(title));
    }

    pub fn set_content_view(self, view: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setContentView:\0")), view);
    }

    pub fn set_box_type(self, box_type: i64) {
        rt::msg_void_i64(self.obj, rt::sel(str_ptr("setBoxType:\0")), box_type);
    }
}

pub struct Scroller {
    pub obj: *u8,
}

impl Scroller {
    pub fn new(frame: rt::Rect) -> Scroller {
        return Scroller { obj: rt::alloc_init_with_frame(str_ptr("NSScroller\0"), frame) };
    }

    pub fn set_double_value(self, value: f64) {
        rt::msg_void_f64(self.obj, rt::sel(str_ptr("setDoubleValue:\0")), value);
    }

    pub fn set_knob_proportion(self, proportion: f64) {
        rt::msg_void_f64(self.obj, rt::sel(str_ptr("setKnobProportion:\0")), proportion);
    }
}

pub struct BackgroundExtensionView {
    pub obj: *u8,
}

impl BackgroundExtensionView {
    pub fn new(frame: rt::Rect) -> BackgroundExtensionView {
        return BackgroundExtensionView { obj: rt::alloc_init_with_frame(str_ptr("NSBackgroundExtensionView\0"), frame) };
    }
}
