    return unsafe { objc_msg_i64(recv, selector) };
}

// No-arg `NSRect` getter — `-[NSView frame]` / `bounds`.
fn msg_rect(recv: *u8, selector: *u8) -> Rect {
    return unsafe { objc_msg_rect(recv, selector) };
}

// id-returning message with one unsigned-integer arg — `-[NSArray objectAtIndex:]`.
fn msg_id_u64(recv: *u8, selector: *u8, a: u64) -> *u8 {
    return unsafe { objc_msg_id_u64(recv, selector, a) };
}

// The object's runtime class name as a C string (`const char *`).
fn class_name(obj: *u8) -> *u8 {
    return unsafe { object_getClassName(obj) };
}

fn msg_i8(recv: *u8, selector: *u8) -> i8 {
    return unsafe { objc_msg_i8(recv, selector) };
}

fn msg_i64_id(recv: *u8, selector: *u8, a: *u8) -> i64 {
    return unsafe { objc_msg_i64_id(recv, selector, a) };
}

fn msg_id_id_id_i64(recv: *u8, selector: *u8, a: *u8, b: *u8, c: i64) -> *u8 {
    return unsafe { objc_msg_id_id_id_i64(recv, selector, a, b, c) };
}

fn msg_i64_id_i64(recv: *u8, selector: *u8, a: *u8, b: i64) -> i64 {
    return unsafe { objc_msg_i64_id_i64(recv, selector, a, b) };
}

fn msg_u64(recv: *u8, selector: *u8) -> u64 {
    return unsafe { objc_msg_u64(recv, selector) };
}

fn msg_point(recv: *u8, selector: *u8) -> Point {
    return unsafe { objc_msg_point(recv, selector) };
}

fn msg_f64(recv: *u8, selector: *u8) -> f64 {
    return unsafe { objc_msg_f64(recv, selector) };
}

fn msg_id_rgba(recv: *u8, selector: *u8, r: f64, g: f64, b: f64, a: f64) -> *u8 {
    return unsafe { objc_msg_id_rgba(recv, selector, r, g, b, a) };
}

fn ns_string(utf8: *u8) -> *u8 {
    let cls: *u8 = get_class(#str_ptr("NSString\0"));
    let selector: *u8 = sel(#str_ptr("stringWithUTF8String:\0"));
    return msg_id_id(cls, selector, utf8);
}

// Generic NSMutableArray helpers (used by delegate methods that return
// identifier arrays, e.g. the toolbar delegate).
fn new_mutable_array() -> *u8 {
    return msg_id(get_class(#str_ptr("NSMutableArray\0")), sel(#str_ptr("array\0")));
}

fn array_add_string(arr: *u8, s: *u8) {
    msg_void_id(arr, sel(#str_ptr("addObject:\0")), ns_string(s));
}

// ---------------------------------------------------------------------------
// Ownership / Drop model (plan.appkit.md §2)
// ---------------------------------------------------------------------------
//
// ObjC objects are reference-counted. A C+ wrapper that *owns* its `obj`
// holds exactly one strong reference and releases it once in `fn drop`. The
// rule is "+1 normal form": whatever the construction path, the wrapper ends
// up holding +1, and `drop` balances it.
//
//   - alloc/init, new, copy, mutableCopy  -> already +1; hold it, release in drop.
//   - convenience constructors (e.g. `stringWith…`, `colorWith…`, factory
//     getters) return an autoreleased +0 object; `retain` it on capture to
//     reach +1, then release in drop.
//   - a handle the wrapper does NOT own (a shared singleton like
//     `generalPasteboard`, or a child view whose parent retains it) is left
//     `opaque` and has no drop — releasing it would over-release.
//
// Adding `fn drop` makes a wrapper non-Copy; `this`/`mut this` method
// receivers are borrows (they do not consume), so builder chaining is
// unaffected. The owner must keep the wrapper alive as long as the UI needs
// the object (store it in a long-lived value); a top-level object that nothing
// else retains must not be dropped while still on screen.
//
// `retain` returns its argument so call sites can write `this.obj =
// rt::retain(x)` in one line.

fn retain(obj: *u8) -> *u8 {
    return unsafe { objc_retain(obj) };
}

fn release(obj: *u8) {
    unsafe { objc_release(obj); };
}

fn autorelease(obj: *u8) -> *u8 {
    return unsafe { objc_autorelease(obj) };
}

// The object's current strong reference count. Mainly a test/debug aid —
// production ownership should follow the +1 rule above, not inspect counts.
fn retain_count(obj: *u8) -> i64 {
    return msg_i64(obj, sel(#str_ptr("retainCount\0")));
}

fn alloc_init(class_name: *u8) -> *u8 {
    let cls: *u8 = get_class(class_name);
    let alloced: *u8 = msg_id(cls, sel(#str_ptr("alloc\0")));
    return msg_id(alloced, sel(#str_ptr("init\0")));
}

fn new_object(class_name: *u8) -> *u8 {
    return msg_id(get_class(class_name), sel(#str_ptr("new\0")));
}

fn alloc_init_with_frame(class_name: *u8, frame: Rect) -> *u8 {
    let cls: *u8 = get_class(class_name);
    let alloced: *u8 = msg_id(cls, sel(#str_ptr("alloc\0")));
    return msg_init_with_frame(alloced, sel(#str_ptr("initWithFrame:\0")), frame);
}

fn alloc_init_with_identifier(class_name: *u8, identifier: *u8) -> *u8 {
    let cls: *u8 = get_class(class_name);
    let alloced: *u8 = msg_id(cls, sel(#str_ptr("alloc\0")));
    return msg_id_id(alloced, sel(#str_ptr("initWithIdentifier:\0")), ns_string(identifier));
}

fn set_target_action(obj: *u8, target: *u8, action: *u8) {
    msg_void_id(obj, sel(#str_ptr("setTarget:\0")), target);
    msg_void_id(obj, sel(#str_ptr("setAction:\0")), action);
}

fn attach_callback(obj: *u8, cb: fn(*u8)) {
    let target = get_action_target();
    set_target_action(obj, target, sel(#str_ptr("handleAction:\0")));
    set_associated_callback(obj, #str_ptr("cb_key\0"), cb, 0 as usize);
}

fn handle_action_callback(self_obj: *u8, _cmd: *u8, sender: *u8) {
    let cb: fn(*u8) = get_associated_callback(sender, #str_ptr("cb_key\0"));
    cb(sender);
}

fn get_action_target() -> *u8 {
    let target_cls: *u8 = get_class(#str_ptr("CActionTarget\0"));
    if target_cls != unsafe { 0 as *u8 } {
        let app: *u8 = msg_id(get_class(#str_ptr("NSApplication\0")), sel(#str_ptr("sharedApplication\0")));
        return get_associated_object(app, #str_ptr("action_target_inst\0"));
    }

    let nsobject_cls: *u8 = get_class(#str_ptr("NSObject\0"));
    let new_cls: *u8 = allocate_class_pair(nsobject_cls, #str_ptr("CActionTarget\0"), 0 as usize);
    let handle_action_sel: *u8 = sel(#str_ptr("handleAction:\0"));
    let _added: i8 = add_action_method(
        new_cls,
        handle_action_sel,
        handle_action_callback,
        #str_ptr("v@:@\0"),
    );
    register_class_pair(new_cls);

    let inst: *u8 = msg_id(new_cls, sel(#str_ptr("new\0")));
    let app: *u8 = msg_id(get_class(#str_ptr("NSApplication\0")), sel(#str_ptr("sharedApplication\0")));
    set_associated_object(app, #str_ptr("action_target_inst\0"), inst, 1 as usize);
    return inst;
}
