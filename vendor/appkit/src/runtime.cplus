#[link_name = "objc_msgSend"]
extern fn objc_msg_id_id(recv: *u8, sel: *u8, arg: *u8) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_2id(recv: *u8, sel: *u8, a: *u8, b: *u8) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_f64_f64(recv: *u8, sel: *u8, a: f64, b: f64) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_id_f64(recv: *u8, sel: *u8, a: *u8, b: f64) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_id(recv: *u8, sel: *u8, arg: *u8);

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_id_id(recv: *u8, sel: *u8, a: *u8, b: *u8);

// `(recv, sel, id, id, BOOL) -> void` — e.g.
