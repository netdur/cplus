}

fn msg_id_id_f64(recv: *u8, selector: *u8, a: *u8, b: f64) -> *u8 {
    return unsafe { objc_msg_id_id_f64(recv, selector, a, b) };
}

fn msg_void_id(recv: *u8, selector: *u8, arg: *u8) {
    unsafe { objc_msg_void_id(recv, selector, arg); };
}

fn msg_void_id_id(recv: *u8, selector: *u8, a: *u8, b: *u8) {
    unsafe { objc_msg_void_id_id(recv, selector, a, b); };
}

// `[recv selector:a withObject:b waitUntilDone:c]`-shaped send. Used for
