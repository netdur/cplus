#[repr(C)]
pub struct Point {
    pub x: f64,
    pub y: f64,
}

#[repr(C)]
pub struct Size {
    pub width: f64,
    pub height: f64,
}

#[repr(C)]
pub struct Rect {
    pub origin: Point,
    pub size: Size,
}

#[repr(C)]
pub struct EdgeInsets {
    pub top: f64,
    pub left: f64,
    pub bottom: f64,
    pub right: f64,
}

pub fn get_class(name: *u8) -> *u8 {
    return unsafe { objc_getClass(name) };
}

pub fn sel(name: *u8) -> *u8 {
    return unsafe { sel_registerName(name) };
}

pub fn allocate_class_pair(superclass: *u8, name: *u8, extra_bytes: usize) -> *u8 {
    return unsafe { objc_allocateClassPair(superclass, name, extra_bytes) };
}

pub fn register_class_pair(cls: *u8) {
    unsafe { objc_registerClassPair(cls); };
}

pub fn add_terminate_method(cls: *u8, selector: *u8, imp: fn(*u8, *u8, *u8) -> i8, types: *u8) -> i8 {
    return unsafe { class_addMethod_terminate(cls, selector, imp, types) };
}

pub fn add_action_method(cls: *u8, selector: *u8, imp: fn(*u8, *u8, *u8), types: *u8) -> i8 {
    return unsafe { class_addMethod_action(cls, selector, imp, types) };
}

pub fn set_associated_object(object: *u8, key: *u8, value: *u8, policy: usize) {
    unsafe { objc_setAssociatedObject(object, key, value, policy); };
}

pub fn get_associated_object(object: *u8, key: *u8) -> *u8 {
    return unsafe { objc_getAssociatedObject(object, key) };
}

pub fn set_associated_callback(object: *u8, key: *u8, value: fn(*u8), policy: usize) {
    unsafe { objc_setAssociatedObject_cb(object, key, value, policy); };
}

pub fn get_associated_callback(object: *u8, key: *u8) -> fn(*u8) {
    return unsafe { objc_getAssociatedObject_cb(object, key) };
}

pub fn msg_id(recv: *u8, selector: *u8) -> *u8 {
    return unsafe { objc_msg_id(recv, selector) };
}

