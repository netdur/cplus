// ObjC runtime and typed objc_msgSend helpers shared by the AppKit bindings.

extern fn objc_getClass(name: *u8) -> *u8;
extern fn sel_registerName(name: *u8) -> *u8;
extern fn objc_allocateClassPair(superclass: *u8, name: *u8, extra_bytes: usize) -> *u8;
extern fn objc_registerClassPair(cls: *u8);

#[link_name = "class_addMethod"]
extern fn class_addMethod_terminate(cls: *u8, sel: *u8, imp: fn(*u8, *u8, *u8) -> i8, types: *u8) -> i8;

#[link_name = "class_addMethod"]
extern fn class_addMethod_action(cls: *u8, sel: *u8, imp: fn(*u8, *u8, *u8), types: *u8) -> i8;

// Value-returning method IMPs for synthesized delegate / data-source classes.
// `_i64_id`: (self, _cmd, arg) -> NSInteger  — e.g. numberOfRowsInTableView:.
// `_id_table_value`: (self, _cmd, table, column, row) -> id — e.g.
// tableView:objectValueForTableColumn:row:.
#[link_name = "class_addMethod"]
extern fn class_addMethod_i64_id(cls: *u8, sel: *u8, imp: fn(*u8, *u8, *u8) -> i64, types: *u8) -> i8;

#[link_name = "class_addMethod"]
extern fn class_addMethod_id_table_value(cls: *u8, sel: *u8, imp: fn(*u8, *u8, *u8, *u8, i64) -> *u8, types: *u8) -> i8;

// `(self, _cmd, dirtyRect) -> void` with the rect passed by value — e.g. an
// NSView subclass's `drawRect:`.
#[link_name = "class_addMethod"]
extern fn class_addMethod_draw_rect(cls: *u8, sel: *u8, imp: fn(*u8, *u8, Rect), types: *u8) -> i8;

// `(self, _cmd, obj, n) -> NSInteger` — e.g. NSDraggingSource's
// `draggingSession:sourceOperationMaskForDraggingContext:`.
#[link_name = "class_addMethod"]
extern fn class_addMethod_i64_id_i64(cls: *u8, sel: *u8, imp: fn(*u8, *u8, *u8, i64) -> i64, types: *u8) -> i8;

#[link_name = "class_addMethod"]
extern fn class_addMethod_id_toolbar_array(cls: *u8, sel: *u8, imp: fn(*u8, *u8, *u8) -> *u8, types: *u8) -> i8;

#[link_name = "class_addMethod"]
extern fn class_addMethod_id_toolbar_item(cls: *u8, sel: *u8, imp: fn(*u8, *u8, *u8, *u8, i8) -> *u8, types: *u8) -> i8;

#[link_name = "objc_setAssociatedObject"]
extern fn objc_setAssociatedObject(object: *u8, key: *u8, value: *u8, policy: usize);

#[link_name = "objc_getAssociatedObject"]
extern fn objc_getAssociatedObject(object: *u8, key: *u8) -> *u8;

#[link_name = "objc_setAssociatedObject"]
extern fn objc_setAssociatedObject_cb(object: *u8, key: *u8, value: fn(*u8), policy: usize);

#[link_name = "objc_getAssociatedObject"]
extern fn objc_getAssociatedObject_cb(object: *u8, key: *u8) -> fn(*u8);

// ARC primitives (libobjc). `objc_retain` / `objc_release` are the same
// reference-counting calls ARC emits; we call them by hand. `objc_release`
// returns void.
#[link_name = "objc_retain"]
extern fn objc_retain(obj: *u8) -> *u8;

#[link_name = "objc_release"]
extern fn objc_release(obj: *u8);

#[link_name = "objc_autorelease"]
extern fn objc_autorelease(obj: *u8) -> *u8;

