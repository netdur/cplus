extern fn objc_msg_i64(recv: *u8, sel: *u8) -> i64;

// No-arg `BOOL` getter (e.g. `isEditable`, `isHidden`).
#[link_name = "objc_msgSend"]
extern fn objc_msg_i8(recv: *u8, sel: *u8) -> i8;

// No-arg `NSRect` getter (e.g. `-[NSView frame]`/`bounds`). NSRect is an HFA of
// four doubles, returned in v0–v3 on arm64 — plain objc_msgSend, not _stret.
#[link_name = "objc_msgSend"]
extern fn objc_msg_rect(recv: *u8, sel: *u8) -> Rect;

// objc_msgSend returning id with one unsigned-integer arg (e.g.
// `-[NSArray objectAtIndex:]`).
#[link_name = "objc_msgSend"]
extern fn objc_msg_id_u64(recv: *u8, sel: *u8, a: u64) -> *u8;

// The runtime class name of an object as a C string (`const char *`). From
// libobjc; used to label nodes by AppKit class during the view-tree walk.
extern fn object_getClassName(obj: *u8) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_i64_id(recv: *u8, sel: *u8, a: *u8) -> i64;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_id_id_i64(recv: *u8, sel: *u8, a: *u8, b: *u8, c: i64) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_id_id_id(recv: *u8, sel: *u8, a: *u8, b: *u8, c: *u8) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_rect_id(recv: *u8, sel: *u8, frame: Rect, arg: *u8);

#[link_name = "objc_msgSend"]
extern fn objc_msg_i64_id_i64(recv: *u8, sel: *u8, a: *u8, b: i64) -> i64;

#[link_name = "objc_msgSend"]
extern fn objc_msg_u64(recv: *u8, sel: *u8) -> u64;

// NSPoint is two CGFloats; on arm64/x86_64 a 2×f64 struct returns in
// registers, so the plain `objc_msgSend` (not `_stret`) is correct.
#[link_name = "objc_msgSend"]
extern fn objc_msg_point(recv: *u8, sel: *u8) -> Point;

#[link_name = "objc_msgSend"]
extern fn objc_msg_f64(recv: *u8, sel: *u8) -> f64;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_rgba(recv: *u8, sel: *u8, r: f64, g: f64, b: f64, a: f64) -> *u8;

#[repr(C)]
struct Point {
    x: f64,
    y: f64,
}

#[repr(C)]
struct Size {
    width: f64,
    height: f64,
}

#[repr(C)]
struct Rect {
    origin: Point,
    size: Size,
}

#[repr(C)]
struct EdgeInsets {
    top: f64,
    left: f64,
    bottom: f64,
    right: f64,
}

fn get_class(name: *u8) -> *u8 {
    return unsafe { objc_getClass(name) };
}

fn sel(name: *u8) -> *u8 {
    return unsafe { sel_registerName(name) };
}

fn allocate_class_pair(superclass: *u8, name: *u8, extra_bytes: usize) -> *u8 {
    return unsafe { objc_allocateClassPair(superclass, name, extra_bytes) };
}

fn register_class_pair(cls: *u8) {
    unsafe { objc_registerClassPair(cls); };
}

fn add_terminate_method(cls: *u8, selector: *u8, imp: fn(*u8, *u8, *u8) -> i8, types: *u8) -> i8 {
    return unsafe { class_addMethod_terminate(cls, selector, imp, types) };
}

fn add_action_method(cls: *u8, selector: *u8, imp: fn(*u8, *u8, *u8), types: *u8) -> i8 {
    return unsafe { class_addMethod_action(cls, selector, imp, types) };
}

// Add a `(self, _cmd, sender) -> void` method (the target-action / single-id
// shape, e.g. a synthesized `cplusScrollSelfVisible:`). `types` e.g. `"v@:@"`.
fn add_method_action(cls: *u8, selector: *u8, imp: fn(*u8, *u8, *u8), types: *u8) -> i8 {
    return unsafe { class_addMethod_action(cls, selector, imp, types) };
}

// Add an `(self, _cmd, arg) -> NSInteger` method (e.g. a data source's row
// count). `types` is the ObjC type encoding, e.g. `"q@:@"`.
fn add_method_i64_id(cls: *u8, selector: *u8, imp: fn(*u8, *u8, *u8) -> i64, types: *u8) -> i8 {
    return unsafe { class_addMethod_i64_id(cls, selector, imp, types) };
}

// Add an `(self, _cmd, table, column, row) -> id` method (e.g. a table data
// source's cell-value provider). `types` e.g. `"@@:@@q"`.
fn add_method_id_table_value(
    cls: *u8,
    selector: *u8,
    imp: fn(*u8, *u8, *u8, *u8, i64) -> *u8,
    types: *u8,
) -> i8 {
    return unsafe { class_addMethod_id_table_value(cls, selector, imp, types) };
}

// Add a `(self, _cmd, dirtyRect) -> void` method whose rect is passed by value
// (e.g. `-drawRect:`). `types` e.g. `"v@:{CGRect={CGPoint=dd}{CGSize=dd}}"`.
fn add_method_draw_rect(cls: *u8, selector: *u8, imp: fn(*u8, *u8, Rect), types: *u8) -> i8 {
    return unsafe { class_addMethod_draw_rect(cls, selector, imp, types) };
}

// Add a `(self, _cmd, obj, n) -> NSInteger` method (e.g. a drag source's
// operation-mask-for-context). `types` e.g. `"Q@:@q"`.
fn add_method_i64_id_i64(cls: *u8, selector: *u8, imp: fn(*u8, *u8, *u8, i64) -> i64, types: *u8) -> i8 {
    return unsafe { class_addMethod_i64_id_i64(cls, selector, imp, types) };
}

fn add_method_id_toolbar_array(cls: *u8, selector: *u8, imp: fn(*u8, *u8, *u8) -> *u8, types: *u8) -> i8 {
    return unsafe { class_addMethod_id_toolbar_array(cls, selector, imp, types) };
}

fn add_method_id_toolbar_item(cls: *u8, selector: *u8, imp: fn(*u8, *u8, *u8, *u8, i8) -> *u8, types: *u8) -> i8 {
    return unsafe { class_addMethod_id_toolbar_item(cls, selector, imp, types) };
}

fn set_associated_object(object: *u8, key: *u8, value: *u8, policy: usize) {
    unsafe { objc_setAssociatedObject(object, key, value, policy); };
}

fn get_associated_object(object: *u8, key: *u8) -> *u8 {
    return unsafe { objc_getAssociatedObject(object, key) };
}

fn set_associated_callback(object: *u8, key: *u8, value: fn(*u8), policy: usize) {
    unsafe { objc_setAssociatedObject_cb(object, key, value, policy); };
}

fn get_associated_callback(object: *u8, key: *u8) -> fn(*u8) {
    return unsafe { objc_getAssociatedObject_cb(object, key) };
}

fn msg_id(recv: *u8, selector: *u8) -> *u8 {
    return unsafe { objc_msg_id(recv, selector) };
}

fn msg_id_id(recv: *u8, selector: *u8, arg: *u8) -> *u8 {
    return unsafe { objc_msg_id_id(recv, selector, arg) };
}

// objc_msgSend returning id with two id args — e.g. `+[NSImage
// imageWithSystemSymbolName:accessibilityDescription:]` or `+[NSSet
// setWithObject:]`-style two-argument constructors.
fn msg_id_2id(recv: *u8, selector: *u8, a: *u8, b: *u8) -> *u8 {
    return unsafe { objc_msg_id_2id(recv, selector, a, b) };
}

fn msg_id_id_id(recv: *u8, selector: *u8, a: *u8, b: *u8, c: *u8) -> *u8 {
    return unsafe { objc_msg_id_id_id_id(recv, selector, a, b, c) };
}

fn msg_id_f64_f64(recv: *u8, selector: *u8, a: f64, b: f64) -> *u8 {
