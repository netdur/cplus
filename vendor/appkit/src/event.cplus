    fn pointing_device_i_d(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("pointingDeviceID\0")));
    }

    fn system_tablet_i_d(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("systemTabletID\0")));
    }

    fn vendor_pointing_device_type(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("vendorPointingDeviceType\0")));
    }

    fn pointing_device_serial_number(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("pointingDeviceSerialNumber\0")));
    }

    fn unique_i_d(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("uniqueID\0")));
    }

    fn capability_mask(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("capabilityMask\0")));
    }

    fn pointing_device_type(this) -> PointingDeviceType {
        return pointing_device_type_from_raw(rt::msg_i64(this._obj, rt::sel(#str_ptr("pointingDeviceType\0"))));
    }

    fn is_entering_proximity(this) -> bool {
        return rt::msg_i8(this._obj, rt::sel(#str_ptr("isEnteringProximity\0"))) != (0 as i8);
    }

    fn phase(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("phase\0")));
    }

    fn stage(this) -> i64 {
        return rt::msg_i64(this._obj, rt::sel(#str_ptr("stage\0")));
    }

    fn stage_transition(this) -> f64 {
        return rt::msg_f64(this._obj, rt::sel(#str_ptr("stageTransition\0")));
    }

    fn associated_events_mask(this) -> u64 {
        return rt::msg_u64(this._obj, rt::sel(#str_ptr("associatedEventsMask\0")));
    }

    fn pressure_behavior(this) -> PressureBehavior {
        return pressure_behavior_from_raw(rt::msg_i64(this._obj, rt::sel(#str_ptr("pressureBehavior\0"))));
    }

    fn is_swipe_tracking_from_scroll_events_enabled() -> bool {
        return rt::msg_i8(rt::get_class(#str_ptr("NSEvent\0")), rt::sel(#str_ptr("isSwipeTrackingFromScrollEventsEnabled\0"))) != (0 as i8);
    }

    fn mouse_location() -> rt::Point {
        return rt::msg_point(rt::get_class(#str_ptr("NSEvent\0")), rt::sel(#str_ptr("mouseLocation\0")));
    }

    fn pressed_mouse_buttons() -> u64 {
        return rt::msg_u64(rt::get_class(#str_ptr("NSEvent\0")), rt::sel(#str_ptr("pressedMouseButtons\0")));
    }

    fn double_click_interval() -> f64 {
        return rt::msg_f64(rt::get_class(#str_ptr("NSEvent\0")), rt::sel(#str_ptr("doubleClickInterval\0")));
    }

    fn key_repeat_delay() -> f64 {
        return rt::msg_f64(rt::get_class(#str_ptr("NSEvent\0")), rt::sel(#str_ptr("keyRepeatDelay\0")));
    }

    fn key_repeat_interval() -> f64 {
        return rt::msg_f64(rt::get_class(#str_ptr("NSEvent\0")), rt::sel(#str_ptr("keyRepeatInterval\0")));
    }

}

