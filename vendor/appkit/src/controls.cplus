    fn new(frame: rt::Rect) -> Stepper {
        return Stepper { _obj: rt::alloc_init_with_frame(#str_ptr("NSStepper\0"), frame) };
    }

    fn set_value(this, value: f64) {
        rt::msg_void_f64(this._obj, rt::sel(#str_ptr("setDoubleValue:\0")), value);
    }

    fn value(this) -> f64 {
        return rt::msg_f64(this._obj, rt::sel(#str_ptr("doubleValue\0")));
    }

    fn set_min_value(this, value: f64) {
        rt::msg_void_f64(this._obj, rt::sel(#str_ptr("setMinValue:\0")), value);
    }

    fn set_max_value(this, value: f64) {
        rt::msg_void_f64(this._obj, rt::sel(#str_ptr("setMaxValue:\0")), value);
    }

    fn set_increment(this, value: f64) {
        rt::msg_void_f64(this._obj, rt::sel(#str_ptr("setIncrement:\0")), value);
    }

    fn set_on_change(this, cb: fn(*u8)) {
        rt::attach_callback(this._obj, cb);
    }
}

struct Switch {
    _obj: *u8,
}

impl Switch {
    fn raw(this) -> *u8 { return this._obj; }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn new(frame: rt::Rect) -> Switch {
        return Switch { _obj: rt::alloc_init_with_frame(#str_ptr("NSSwitch\0"), frame) };
    }

    // NSSwitch is binary (NSControlStateValue on=1 / off=0); read and write it
    // as a `bool` rather than the raw state integer.
    fn set_on(this, on: bool) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setState:\0")), on as i64);
    }

    fn is_on(this) -> bool {
        return rt::msg_i64(this._obj, rt::sel(#str_ptr("state\0"))) != (0 as i64);
    }

    fn set_on_change(this, cb: fn(*u8)) {
        rt::attach_callback(this._obj, cb);
    }
}

struct SegmentedControl {
    _obj: *u8,
}

impl SegmentedControl {
    fn raw(this) -> *u8 { return this._obj; }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn new(frame: rt::Rect) -> SegmentedControl {
        return SegmentedControl { _obj: rt::alloc_init_with_frame(#str_ptr("NSSegmentedControl\0"), frame) };
    }

    fn set_segment_count(this, count: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setSegmentCount:\0")), count);
    }

    fn set_label(this, label: str, for_segment: i64) {
        rt::msg_void_id_i64(this._obj, rt::sel(#str_ptr("setLabel:forSegment:\0")), bridge::cplus_str_to_nsstring(label), for_segment);
    }

    fn set_selected(this, selected: bool, for_segment: i64) {
        rt::msg_void_i8_i64(this._obj, rt::sel(#str_ptr("setSelected:forSegment:\0")), selected as i8, for_segment);
    }

    // `selectedSegment` is -1 when no segment is selected; expose that as `None`.
    fn selected_segment(this) -> option::Option[i64] {
        let seg: i64 = rt::msg_i64(this._obj, rt::sel(#str_ptr("selectedSegment\0")));
        if seg < (0 as i64) {
            return option::Option[i64]::None;
        }
        return option::some(seg);
    }

    fn set_on_change(this, cb: fn(*u8)) {
        rt::attach_callback(this._obj, cb);
    }
}

