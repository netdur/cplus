import "./runtime" as rt;

// Owned (+1 via alloc/initWithFrame:); a parent view retains it on add. `drop`
// releases this wrapper's +1 (plan.appkit.md §2). Hold the wrapper until after
// `addSubview:`.
pub struct TextField {
    pub obj: *u8,
}

impl TextField {
    pub fn new_label(frame: rt::Rect) -> TextField {
        let cls: *u8 = rt::get_class(str_ptr("NSTextField\0"));
        let label_alloc: *u8 = rt::msg_id(cls, rt::sel(str_ptr("alloc\0")));
        let label: *u8 = rt::msg_init_with_frame(label_alloc, rt::sel(str_ptr("initWithFrame:\0")), frame);
        return TextField { obj: label };
    }

    fn drop(mut self) {
        rt::release(self.obj);
    }

    pub fn new_input_field(frame: rt::Rect) -> TextField {
        let cls: *u8 = rt::get_class(str_ptr("NSTextField\0"));
        let field_alloc: *u8 = rt::msg_id(cls, rt::sel(str_ptr("alloc\0")));
        let field: *u8 = rt::msg_init_with_frame(field_alloc, rt::sel(str_ptr("initWithFrame:\0")), frame);
        return TextField { obj: field };
    }

    pub fn set_string_value(self, val: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setStringValue:\0")), rt::ns_string(val));
    }

    // v0.0.7 Slice 5.1: pre-built-NSString variant. See window.cplus
    // for the rationale.
    pub fn set_string_value_ns(self, val_ns: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setStringValue:\0")), val_ns);
    }

    pub fn string_value(self) -> *u8 {
        return rt::msg_id(self.obj, rt::sel(str_ptr("stringValue\0")));
    }

    pub fn set_placeholder_string(self, val: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setPlaceholderString:\0")), rt::ns_string(val));
    }

    pub fn set_placeholder_string_ns(self, val_ns: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setPlaceholderString:\0")), val_ns);
    }

    pub fn set_alignment(self, align: i64) {
        rt::msg_void_i64(self.obj, rt::sel(str_ptr("setAlignment:\0")), align);
    }

    pub fn set_bezeled(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(str_ptr("setBezeled:\0")), flag);
    }

    pub fn set_draws_background(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(str_ptr("setDrawsBackground:\0")), flag);
    }

    pub fn set_editable(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(str_ptr("setEditable:\0")), flag);
    }

    pub fn set_selectable(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(str_ptr("setSelectable:\0")), flag);
    }

    pub fn set_font(self, font: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setFont:\0")), font);
    }

    pub fn set_text_color(self, color: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setTextColor:\0")), color);
    }

    pub fn set_background_color(self, color: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setBackgroundColor:\0")), color);
    }
}

// Owned (+1 via alloc/initWithFrame:). Added to a parent view, which retains it;
// `drop` releases this wrapper's +1, so the control lives as long as the parent
// and is freed once the parent is (plan.appkit.md §2, "+1 normal form"). Hold
// the wrapper until after `addSubview:` — don't pass `Button::new(...).obj`
// inline.
pub struct Button {
    pub obj: *u8,
}

impl Button {
    pub fn new(frame: rt::Rect) -> Button {
        let cls: *u8 = rt::get_class(str_ptr("NSButton\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(str_ptr("alloc\0")));
        let btn: *u8 = rt::msg_init_with_frame(alloced, rt::sel(str_ptr("initWithFrame:\0")), frame);
        return Button { obj: btn };
    }

    fn drop(mut self) {
        rt::release(self.obj);
    }

    pub fn set_title(self, title: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setTitle:\0")), rt::ns_string(title));
    }

    // v0.0.7 Slice 5.1: pre-built-NSString variant.
    pub fn set_title_ns(self, title_ns: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setTitle:\0")), title_ns);
    }

    pub fn set_button_type(self, btn_type: u64) {
        rt::msg_void_u64(self.obj, rt::sel(str_ptr("setButtonType:\0")), btn_type);
    }

    pub fn set_bezel_style(self, style: u64) {
        rt::msg_void_u64(self.obj, rt::sel(str_ptr("setBezelStyle:\0")), style);
    }

    pub fn set_enabled(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(str_ptr("setEnabled:\0")), flag);
    }

    pub fn set_state(self, state: i64) {
        rt::msg_void_i64(self.obj, rt::sel(str_ptr("setState:\0")), state);
    }

    pub fn state(self) -> i64 {
        return rt::msg_i64(self.obj, rt::sel(str_ptr("state\0")));
    }

    pub fn set_on_click(self, cb: fn(*u8)) {
        rt::attach_callback(self.obj, cb);
    }
}

