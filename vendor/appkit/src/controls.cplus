import "./runtime" as rt;

// Owned (+1 via alloc/initWithFrame:); a parent view retains it on add. `drop`
// releases this wrapper's +1 (plan.appkit.md §2). Hold the wrapper until after
// `addSubview:`.
pub struct TextField {
    pub obj: *u8,
}

impl TextField {
    pub fn new_label(frame: rt::Rect) -> TextField {
        let cls: *u8 = rt::get_class(#str_ptr("NSTextField\0"));
        let label_alloc: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let label: *u8 = rt::msg_init_with_frame(label_alloc, rt::sel(#str_ptr("initWithFrame:\0")), frame);
        // Configure as a static label (like `+[NSTextField labelWithString:]`):
        // non-editable, non-selectable, no bezel, no drawn background — so it
        // renders as plain text and does NOT accept edits or dropped text. A
        // default NSTextField is editable + bezeled, which makes a "label"
        // behave like an input field (and silently accept drag-drops).
        rt::msg_void_i8(label, rt::sel(#str_ptr("setEditable:\0")), 0 as i8);
        rt::msg_void_i8(label, rt::sel(#str_ptr("setSelectable:\0")), 0 as i8);
        rt::msg_void_i8(label, rt::sel(#str_ptr("setBezeled:\0")), 0 as i8);
        rt::msg_void_i8(label, rt::sel(#str_ptr("setDrawsBackground:\0")), 0 as i8);
        return TextField { obj: label };
    }

    fn drop(mut self) {
        rt::release(self.obj);
    }

    // GAP 2 (v0.0.19): ownership transfer for the builder-returns-a-widget case.
    // `into_raw` hands this wrapper's +1 to the returned pointer and disarms its
    // drop (left holding nil), so the object survives a boundary the wrapper
    // can't (e.g. `fn make() -> *u8`); `from_raw` re-adopts it. See the full
    // explanation + the use-after-free trap on `view::View::into_raw`.
    pub fn into_raw(mut self) -> *u8 {
        let p: *u8 = self.obj;
        self.obj = unsafe { 0 as *u8 };
        return p;
    }

    pub fn from_raw(obj: *u8) -> TextField {
        return TextField { obj: obj };
    }

    pub fn new_input_field(frame: rt::Rect) -> TextField {
        let cls: *u8 = rt::get_class(#str_ptr("NSTextField\0"));
        let field_alloc: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let field: *u8 = rt::msg_init_with_frame(field_alloc, rt::sel(#str_ptr("initWithFrame:\0")), frame);
        return TextField { obj: field };
    }

    pub fn set_string_value(self, val: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setStringValue:\0")), rt::ns_string(val));
    }

    // v0.0.7 Slice 5.1: pre-built-NSString variant. See window.cplus
    // for the rationale.
    pub fn set_string_value_ns(self, val_ns: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setStringValue:\0")), val_ns);
    }

    pub fn string_value(self) -> *u8 {
        return rt::msg_id(self.obj, rt::sel(#str_ptr("stringValue\0")));
    }

    pub fn set_placeholder_string(self, val: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setPlaceholderString:\0")), rt::ns_string(val));
    }

    pub fn set_placeholder_string_ns(self, val_ns: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setPlaceholderString:\0")), val_ns);
    }

    pub fn set_alignment(self, align: i64) {
        rt::msg_void_i64(self.obj, rt::sel(#str_ptr("setAlignment:\0")), align);
    }

    pub fn set_bezeled(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(#str_ptr("setBezeled:\0")), flag);
    }

    pub fn set_draws_background(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(#str_ptr("setDrawsBackground:\0")), flag);
    }

    pub fn set_editable(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(#str_ptr("setEditable:\0")), flag);
    }

    pub fn set_selectable(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(#str_ptr("setSelectable:\0")), flag);
    }

    pub fn set_font(self, font: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setFont:\0")), font);
    }

    pub fn set_text_color(self, color: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setTextColor:\0")), color);
    }

    pub fn set_background_color(self, color: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setBackgroundColor:\0")), color);
    }

    // GAP 4 (v0.0.19): the focus-ring style (`setFocusRingType:`, an NSView
    // property). `t` is an `NSFocusRingType`: 0 default, 1 none, 2 exterior.
    // Common use: `1` to suppress the focus ring on a custom-styled field.
    pub fn set_focus_ring_type(self, t: i64) {
        rt::msg_void_i64(self.obj, rt::sel(#str_ptr("setFocusRingType:\0")), t);
    }

    // GAP 4 (v0.0.19): a multi-line, word-wrapping static label (the default
    // `new_label` is single-line and truncates). Same non-editable / no-bezel /
    // no-background config, plus wrapping enabled on the cell and an unbounded
    // line count. Give it a width and let height grow (or pin via constraints).
    pub fn new_wrapping_label(frame: rt::Rect) -> TextField {
        let cls: *u8 = rt::get_class(#str_ptr("NSTextField\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let label: *u8 = rt::msg_init_with_frame(alloced, rt::sel(#str_ptr("initWithFrame:\0")), frame);
        rt::msg_void_i8(label, rt::sel(#str_ptr("setEditable:\0")), 0 as i8);
        rt::msg_void_i8(label, rt::sel(#str_ptr("setSelectable:\0")), 0 as i8);
        rt::msg_void_i8(label, rt::sel(#str_ptr("setBezeled:\0")), 0 as i8);
        rt::msg_void_i8(label, rt::sel(#str_ptr("setDrawsBackground:\0")), 0 as i8);
        // Multi-line: no single-line mode, unbounded lines, and word-wrap on the
        // cell (NSLineBreakByWordWrapping = 0).
        rt::msg_void_i8(label, rt::sel(#str_ptr("setUsesSingleLineMode:\0")), 0 as i8);
        rt::msg_void_i64(label, rt::sel(#str_ptr("setMaximumNumberOfLines:\0")), 0 as i64);
        let cell: *u8 = rt::msg_id(label, rt::sel(#str_ptr("cell\0")));
        rt::msg_void_i8(cell, rt::sel(#str_ptr("setWraps:\0")), 1 as i8);
        rt::msg_void_i64(cell, rt::sel(#str_ptr("setLineBreakMode:\0")), 0 as i64);
        return TextField { obj: label };
    }
}

// Owned (+1 via alloc/initWithFrame:). Added to a parent view, which retains it;
// `drop` releases this wrapper's +1, so the control lives as long as the parent
// and is freed once the parent is (plan.appkit.md §2, "+1 normal form"). Hold
// the wrapper until after `addSubview:` — don't pass `Button::new(...).obj`
// inline.
pub struct Button {
    pub obj: *u8,
}

impl Button {
    pub fn new(frame: rt::Rect) -> Button {
        let cls: *u8 = rt::get_class(#str_ptr("NSButton\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let btn: *u8 = rt::msg_init_with_frame(alloced, rt::sel(#str_ptr("initWithFrame:\0")), frame);
        return Button { obj: btn };
    }

    fn drop(mut self) {
        rt::release(self.obj);
    }

    // GAP 2 (v0.0.19): ownership transfer for the builder-returns-a-widget case;
    // see `view::View::into_raw` for the full explanation + the use-after-free
    // trap it prevents.
    pub fn into_raw(mut self) -> *u8 {
        let p: *u8 = self.obj;
        self.obj = unsafe { 0 as *u8 };
        return p;
    }

    pub fn from_raw(obj: *u8) -> Button {
        return Button { obj: obj };
    }

    pub fn set_title(self, title: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setTitle:\0")), rt::ns_string(title));
    }

    // v0.0.7 Slice 5.1: pre-built-NSString variant.
    pub fn set_title_ns(self, title_ns: *u8) {
        rt::msg_void_id(self.obj, rt::sel(#str_ptr("setTitle:\0")), title_ns);
    }

    pub fn set_button_type(self, btn_type: u64) {
        rt::msg_void_u64(self.obj, rt::sel(#str_ptr("setButtonType:\0")), btn_type);
    }

    pub fn set_bezel_style(self, style: u64) {
        rt::msg_void_u64(self.obj, rt::sel(#str_ptr("setBezelStyle:\0")), style);
    }

    pub fn set_enabled(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(#str_ptr("setEnabled:\0")), flag);
    }

    pub fn set_state(self, state: i64) {
        rt::msg_void_i64(self.obj, rt::sel(#str_ptr("setState:\0")), state);
    }

    pub fn state(self) -> i64 {
        return rt::msg_i64(self.obj, rt::sel(#str_ptr("state\0")));
    }

    pub fn set_on_click(self, cb: fn(*u8)) {
        rt::attach_callback(self.obj, cb);
    }
}

pub struct Slider {
    pub obj: *u8,
}

impl Slider {
    fn drop(mut self) {
        rt::release(self.obj);
    }

    pub fn new(frame: rt::Rect) -> Slider {
        let cls: *u8 = rt::get_class(#str_ptr("NSSlider\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let slider: *u8 = rt::msg_init_with_frame(alloced, rt::sel(#str_ptr("initWithFrame:\0")), frame);
        return Slider { obj: slider };
    }

    // NSControl's value is a `double` (`doubleValue`/`setDoubleValue:`); use the
    // double ABI to match `setMinValue:`/`setMaxValue:` below (and the other
    // value controls). The legacy `floatValue` returns a 32-bit `float` and must
    // NOT be read through the f64 msgSend — that's an ABI mismatch.
    pub fn set_double_value(self, val: f64) {
        rt::msg_void_f64(self.obj, rt::sel(#str_ptr("setDoubleValue:\0")), val);
    }

    pub fn double_value(self) -> f64 {
        return rt::msg_f64(self.obj, rt::sel(#str_ptr("doubleValue\0")));
    }

    pub fn set_min_value(self, val: f64) {
        rt::msg_void_f64(self.obj, rt::sel(#str_ptr("setMinValue:\0")), val);
    }

    pub fn set_max_value(self, val: f64) {
        rt::msg_void_f64(self.obj, rt::sel(#str_ptr("setMaxValue:\0")), val);
    }

    pub fn set_on_change(self, cb: fn(*u8)) {
        rt::attach_callback(self.obj, cb);
    }
}

