pub struct PopUpButton {
    pub opaque obj: *u8,
}

impl PopUpButton {
    pub fn new(frame: rt::Rect, pulls_down: i8) -> PopUpButton {
        let cls = rt::get_class(str_ptr("NSPopUpButton\0"));
        let btn_alloc = rt::msg_id(cls, rt::sel(str_ptr("alloc\0")));
        let btn = rt::msg_init_popup(btn_alloc, rt::sel(str_ptr("initWithFrame:pullsDown:\0")), frame, pulls_down);
        return PopUpButton { obj: btn };
    }

    pub fn add_item(self, title: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("addItemWithTitle:\0")), rt::ns_string(title));
    }

    // v0.0.7 Slice 5.1: pre-built-NSString variant.
    pub fn add_item_ns(self, title_ns: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("addItemWithTitle:\0")), title_ns);
    }

    pub fn remove_all_items(self) {
        rt::msg_void(self.obj, rt::sel(str_ptr("removeAllItems\0")));
    }

    pub fn select_item_at_index(self, index: i64) {
        rt::msg_void_i64(self.obj, rt::sel(str_ptr("selectItemAtIndex:\0")), index);
    }

    pub fn index_of_selected_item(self) -> i64 {
        return rt::msg_i64(self.obj, rt::sel(str_ptr("indexOfSelectedItem\0")));
    }

    pub fn set_on_select(self, cb: fn(*u8)) {
        rt::attach_callback(self.obj, cb);
    }
}

