struct PathControl {
    _obj: *u8,
}

impl PathControl {
    fn raw(this) -> *u8 { return this._obj; }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn new(frame: rt::Rect) -> PathControl {
        return PathControl { _obj: rt::alloc_init_with_frame(#str_ptr("NSPathControl\0"), frame) };
    }

    fn set_url(this, url: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setURL:\0")), url);
    }

    // `URL` is nil when the control has no path set; expose that as `None`.
    fn url(this) -> option::Option[*u8] {
        let u: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("URL\0")));
        if u == { 0 as *u8 } {
            return option::Option[*u8]::None;
        }
        return option::some(u);
    }

    fn set_path_style(this, style: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setPathStyle:\0")), style);
    }
}
