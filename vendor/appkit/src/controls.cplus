import "./runtime" as rt;
import "./convert" as bridge;
import "stdlib/text" as text;
import "stdlib/option" as option;

// Owned (+1 via alloc/initWithFrame:); a parent view retains it on add. `drop`
// releases this wrapper's +1 (plan.appkit.md §2). Hold the wrapper until after
// `addSubview:`.
//
// `Label` is static display text — a pre-configured, non-editable NSTextField
// (the role Cocoa spells `+[NSTextField labelWithString:]`). For an editable
// input box, use `TextField`.
struct Label {
    _obj: *u8,
}

impl Label {
    fn raw(this) -> *u8 { return this._obj; }

    // A static, single-line label: non-editable, non-selectable, no bezel, no
    // drawn background — so it renders as plain text and does NOT accept edits
    // or dropped text. (A default NSTextField is editable + bezeled, which would
    // make a "label" behave like an input field and silently accept drops.)
    fn new(frame: rt::Rect) -> Label {
        let cls: *u8 = rt::get_class(#str_ptr("NSTextField\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let label: *u8 = rt::msg_init_with_frame(alloced, rt::sel(#str_ptr("initWithFrame:\0")), frame);
        rt::msg_void_i8(label, rt::sel(#str_ptr("setEditable:\0")), 0 as i8);
        rt::msg_void_i8(label, rt::sel(#str_ptr("setSelectable:\0")), 0 as i8);
        rt::msg_void_i8(label, rt::sel(#str_ptr("setBezeled:\0")), 0 as i8);
        rt::msg_void_i8(label, rt::sel(#str_ptr("setDrawsBackground:\0")), 0 as i8);
        return Label { _obj: label };
    }

    // A multi-line, word-wrapping static label (the default `new` is single-line
    // and truncates). Same non-editable / no-bezel / no-background config, plus
    // wrapping enabled on the cell and an unbounded line count. Give it a width
    // and let height grow (or pin via constraints).
    fn wrapping(frame: rt::Rect) -> Label {
        let cls: *u8 = rt::get_class(#str_ptr("NSTextField\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let label: *u8 = rt::msg_init_with_frame(alloced, rt::sel(#str_ptr("initWithFrame:\0")), frame);
        rt::msg_void_i8(label, rt::sel(#str_ptr("setEditable:\0")), 0 as i8);
        rt::msg_void_i8(label, rt::sel(#str_ptr("setSelectable:\0")), 0 as i8);
        rt::msg_void_i8(label, rt::sel(#str_ptr("setBezeled:\0")), 0 as i8);
        rt::msg_void_i8(label, rt::sel(#str_ptr("setDrawsBackground:\0")), 0 as i8);
        rt::msg_void_i8(label, rt::sel(#str_ptr("setUsesSingleLineMode:\0")), 0 as i8);
        rt::msg_void_i64(label, rt::sel(#str_ptr("setMaximumNumberOfLines:\0")), 0 as i64);
        let cell: *u8 = rt::msg_id(label, rt::sel(#str_ptr("cell\0")));
        rt::msg_void_i8(cell, rt::sel(#str_ptr("setWraps:\0")), 1 as i8);
        rt::msg_void_i64(cell, rt::sel(#str_ptr("setLineBreakMode:\0")), 0 as i64);
        return Label { _obj: label };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    // Ownership transfer for the builder-returns-a-widget case; see
    // `view::View::into_raw` for the full explanation + the use-after-free trap.
    fn into_raw(ref this) -> *u8 {
        let p: *u8 = this._obj;
        this._obj = { 0 as *u8 };
        return p;
    }

    fn from_raw(obj: *u8) -> Label {
        return Label { _obj: obj };
    }

    fn set_text(this, text: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setStringValue:\0")), bridge::cplus_str_to_nsstring(text));
    }

    fn text(this) -> text::Text {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("stringValue\0")));
        return bridge::nsstring_to_cplus_string(ns);
    }

    fn set_alignment(this, alignment: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setAlignment:\0")), alignment);
    }

    fn set_font(this, font: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setFont:\0")), font);
    }

    fn set_text_color(this, color: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setTextColor:\0")), color);
    }

    fn set_background_color(this, color: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setBackgroundColor:\0")), color);
    }

    fn set_draws_background(this, draws: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setDrawsBackground:\0")), draws as i8);
    }
}

// Owned (+1 via alloc/initWithFrame:). An editable single-line text input (the
// default NSTextField). Added to a parent view, which retains it; `drop`
// releases this wrapper's +1 (plan.appkit.md §2, "+1 normal form"). Hold the
// wrapper until after `addSubview:`. For static display text, use `Label`.
struct TextField {
    _obj: *u8,
}

impl TextField {
    fn raw(this) -> *u8 { return this._obj; }

    fn new(frame: rt::Rect) -> TextField {
        let cls: *u8 = rt::get_class(#str_ptr("NSTextField\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let field: *u8 = rt::msg_init_with_frame(alloced, rt::sel(#str_ptr("initWithFrame:\0")), frame);
        return TextField { _obj: field };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    // Ownership transfer for the builder-returns-a-widget case; see
    // `view::View::into_raw` for the full explanation + the use-after-free trap.
    fn into_raw(ref this) -> *u8 {
        let p: *u8 = this._obj;
        this._obj = { 0 as *u8 };
        return p;
    }

    fn from_raw(obj: *u8) -> TextField {
        return TextField { _obj: obj };
    }

    fn set_text(this, text: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setStringValue:\0")), bridge::cplus_str_to_nsstring(text));
    }

    fn text(this) -> text::Text {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("stringValue\0")));
        return bridge::nsstring_to_cplus_string(ns);
    }

    fn set_placeholder(this, text: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setPlaceholderString:\0")), bridge::cplus_str_to_nsstring(text));
    }

    fn set_alignment(this, alignment: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setAlignment:\0")), alignment);
    }

    fn set_bezeled(this, bezeled: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setBezeled:\0")), bezeled as i8);
    }

    fn set_draws_background(this, draws: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setDrawsBackground:\0")), draws as i8);
    }

    fn set_editable(this, editable: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setEditable:\0")), editable as i8);
    }

    fn set_selectable(this, selectable: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setSelectable:\0")), selectable as i8);
    }

    fn set_font(this, font: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setFont:\0")), font);
    }

    fn set_text_color(this, color: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setTextColor:\0")), color);
    }

    fn set_background_color(this, color: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setBackgroundColor:\0")), color);
    }

    // The focus-ring style (`setFocusRingType:`, an NSView property): 0 default,
    // 1 none, 2 exterior. Common use: `1` to suppress the focus ring on a
    // custom-styled field.
    fn set_focus_ring_type(this, kind: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setFocusRingType:\0")), kind);
    }
}

// Owned (+1 via alloc/initWithFrame:). Added to a parent view, which retains it;
// `drop` releases this wrapper's +1, so the control lives as long as the parent
// and is freed once the parent is (plan.appkit.md §2, "+1 normal form"). Hold
// the wrapper until after `addSubview:` — don't pass `Button::new(...).raw()`
// inline.
struct Button {
    _obj: *u8,
}

impl Button {
    fn raw(this) -> *u8 { return this._obj; }

    fn new(frame: rt::Rect) -> Button {
        let cls: *u8 = rt::get_class(#str_ptr("NSButton\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let btn: *u8 = rt::msg_init_with_frame(alloced, rt::sel(#str_ptr("initWithFrame:\0")), frame);
        return Button { _obj: btn };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    // Ownership transfer for the builder-returns-a-widget case; see
    // `view::View::into_raw` for the full explanation + the use-after-free trap.
    fn into_raw(ref this) -> *u8 {
        let p: *u8 = this._obj;
        this._obj = { 0 as *u8 };
        return p;
    }

    fn from_raw(obj: *u8) -> Button {
        return Button { _obj: obj };
    }

    fn set_title(this, title: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setTitle:\0")), bridge::cplus_str_to_nsstring(title));
    }

    fn set_button_type(this, kind: u64) {
        rt::msg_void_u64(this._obj, rt::sel(#str_ptr("setButtonType:\0")), kind);
    }

    fn set_bezel_style(this, style: u64) {
        rt::msg_void_u64(this._obj, rt::sel(#str_ptr("setBezelStyle:\0")), style);
    }

    fn set_enabled(this, enabled: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setEnabled:\0")), enabled as i8);
    }

    fn set_state(this, state: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setState:\0")), state);
    }

    fn state(this) -> i64 {
        return rt::msg_i64(this._obj, rt::sel(#str_ptr("state\0")));
    }

    fn set_on_click(this, cb: fn(*u8)) {
        rt::attach_callback(this._obj, cb);
    }
}

struct Slider {
    _obj: *u8,
}

impl Slider {
    fn raw(this) -> *u8 { return this._obj; }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn new(frame: rt::Rect) -> Slider {
        let cls: *u8 = rt::get_class(#str_ptr("NSSlider\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let slider: *u8 = rt::msg_init_with_frame(alloced, rt::sel(#str_ptr("initWithFrame:\0")), frame);
        return Slider { _obj: slider };
    }

    // NSControl's value is a `double` (`doubleValue`/`setDoubleValue:`); use the
    // double ABI to match `setMinValue:`/`setMaxValue:` below (and the other
    // value controls). The legacy `floatValue` returns a 32-bit `float` and must
    // NOT be read through the f64 msgSend — that's an ABI mismatch.
    fn set_value(this, value: f64) {
        rt::msg_void_f64(this._obj, rt::sel(#str_ptr("setDoubleValue:\0")), value);
    }

    fn value(this) -> f64 {
        return rt::msg_f64(this._obj, rt::sel(#str_ptr("doubleValue\0")));
    }

    fn set_min_value(this, value: f64) {
        rt::msg_void_f64(this._obj, rt::sel(#str_ptr("setMinValue:\0")), value);
    }

    fn set_max_value(this, value: f64) {
        rt::msg_void_f64(this._obj, rt::sel(#str_ptr("setMaxValue:\0")), value);
    }

    fn set_on_change(this, cb: fn(*u8)) {
        rt::attach_callback(this._obj, cb);
    }
}

struct ProgressIndicator {
    _obj: *u8,
}

impl ProgressIndicator {
    fn raw(this) -> *u8 { return this._obj; }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn new(frame: rt::Rect) -> ProgressIndicator {
        let cls: *u8 = rt::get_class(#str_ptr("NSProgressIndicator\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let pi: *u8 = rt::msg_init_with_frame(alloced, rt::sel(#str_ptr("initWithFrame:\0")), frame);
        return ProgressIndicator { _obj: pi };
    }

    fn set_value(this, value: f64) {
        rt::msg_void_f64(this._obj, rt::sel(#str_ptr("setDoubleValue:\0")), value);
    }

    fn value(this) -> f64 {
        return rt::msg_f64(this._obj, rt::sel(#str_ptr("doubleValue\0")));
    }

    fn set_indeterminate(this, indeterminate: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setIndeterminate:\0")), indeterminate as i8);
    }

    fn start_animation(this, sender: *u8 = 0 as *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("startAnimation:\0")), sender);
    }

    fn stop_animation(this, sender: *u8 = 0 as *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("stopAnimation:\0")), sender);
    }
}

struct PopUpButton {
    _obj: *u8,
}

impl PopUpButton {
    fn raw(this) -> *u8 { return this._obj; }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn new(frame: rt::Rect, pulls_down: bool) -> PopUpButton {
        let cls = rt::get_class(#str_ptr("NSPopUpButton\0"));
        let btn_alloc = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let btn = rt::msg_init_popup(btn_alloc, rt::sel(#str_ptr("initWithFrame:pullsDown:\0")), frame, pulls_down as i8);
        return PopUpButton { _obj: btn };
    }

    fn add_item(this, title: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("addItemWithTitle:\0")), bridge::cplus_str_to_nsstring(title));
    }

    fn remove_all_items(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("removeAllItems\0")));
    }

    fn select_item(this, at: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("selectItemAtIndex:\0")), at);
    }

    // `indexOfSelectedItem` is -1 when nothing is selected; expose that absence
    // as `None` rather than a sentinel.
    fn selected_index(this) -> option::Option[i64] {
        let idx: i64 = rt::msg_i64(this._obj, rt::sel(#str_ptr("indexOfSelectedItem\0")));
        if idx < (0 as i64) {
            return option::Option[i64]::None;
        }
        return option::some(idx);
    }

    fn set_on_select(this, cb: fn(*u8)) {
        rt::attach_callback(this._obj, cb);
    }
}

struct Stepper {
    _obj: *u8,
}

impl Stepper {
    fn raw(this) -> *u8 { return this._obj; }

