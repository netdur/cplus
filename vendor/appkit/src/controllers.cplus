import "./runtime" as rt;
import "stdlib/option" as option;

struct ViewController {
    _obj: *u8,
}

impl ViewController {
    fn raw(this) -> *u8 { return this._obj; }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn new() -> ViewController {
        return ViewController { _obj: rt::alloc_init(#str_ptr("NSViewController\0")) };
    }

    fn set_view(this, view: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setView:\0")), view);
    }

    fn view(this) -> *u8 {
        return rt::msg_id(this._obj, rt::sel(#str_ptr("view\0")));
    }
}

struct WindowController {
    _obj: *u8,
}

impl WindowController {
    fn raw(this) -> *u8 { return this._obj; }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn new() -> WindowController {
        return WindowController { _obj: rt::alloc_init(#str_ptr("NSWindowController\0")) };
    }

    fn set_window(this, window: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setWindow:\0")), window);
    }

    // The managed window (an `NSWindow*`), or `None` if none has been set.
    fn window(this) -> option::Option[*u8] {
        let w: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("window\0")));
        if w == { 0 as *u8 } {
            return option::Option[*u8]::None;
        }
        return option::some(w);
    }

    fn show_window(this, sender: *u8 = 0 as *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("showWindow:\0")), sender);
    }
}

