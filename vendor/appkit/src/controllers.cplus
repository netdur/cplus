import "./runtime" as rt;

struct ViewController {
    obj: *u8,
}

impl ViewController {
    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn new() -> ViewController {
        return ViewController { obj: rt::alloc_init(#str_ptr("NSViewController\0")) };
    }

    fn set_view(this, view: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setView:\0")), view);
    }

    fn view(this) -> *u8 {
        return rt::msg_id(this.obj, rt::sel(#str_ptr("view\0")));
    }
}

