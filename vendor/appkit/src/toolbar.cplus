import "./runtime" as rt;

struct Toolbar {
    obj: *u8,
}

impl Toolbar {
    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn new(identifier: *u8) -> Toolbar {
        return Toolbar { obj: rt::alloc_init_with_identifier(#str_ptr("NSToolbar\0"), identifier) };
    }

    fn set_delegate(this, delegate: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    }

    fn set_display_mode(this, mode: i64) {
        rt::msg_void_i64(this.obj, rt::sel(#str_ptr("setDisplayMode:\0")), mode);
    }

    fn set_allows_user_customization(this, flag: i8) {
        rt::msg_void_i8(this.obj, rt::sel(#str_ptr("setAllowsUserCustomization:\0")), flag);
    }

    // GAP 4 (v0.0.19): center a single toolbar item by identifier. Uses the
    // modern `centeredItemIdentifiers` (NSSet, macOS 13+) — wraps the one
    // identifier in an `NSSet` — rather than the deprecated singular
    // `centeredItemIdentifier`.
    fn set_centered_item(this, identifier: *u8) {
        let ns_id: *u8 = rt::ns_string(identifier);
        let set_cls: *u8 = rt::get_class(#str_ptr("NSSet\0"));
        let set: *u8 = rt::msg_id_id(set_cls, rt::sel(#str_ptr("setWithObject:\0")), ns_id);
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setCenteredItemIdentifiers:\0")), set);
    }
}

fn create_toolbar_delegate(
    item_for_id: fn(*u8, *u8, *u8, *u8, i8) -> *u8,
    default_ids: fn(*u8, *u8, *u8) -> *u8,
    allowed_ids: fn(*u8, *u8, *u8) -> *u8
) -> *u8 {
    let existing: *u8 = rt::get_class(#str_ptr("CToolbarDelegate\0"));
    var cls: *u8 = existing;
    if existing == unsafe { 0 as *u8 } {
        let nsobject: *u8 = rt::get_class(#str_ptr("NSObject\0"));
        cls = rt::allocate_class_pair(nsobject, #str_ptr("CToolbarDelegate\0"), 0 as usize);

        let _a: i8 = rt::add_method_id_toolbar_item(
            cls,
            rt::sel(#str_ptr("toolbar:itemForItemIdentifier:willBeInsertedIntoToolbar:\0")),
            item_for_id,
            #str_ptr("@@:@@c\0")
        );
        let _b: i8 = rt::add_method_id_toolbar_array(
            cls,
            rt::sel(#str_ptr("toolbarDefaultItemIdentifiers:\0")),
            default_ids,
            #str_ptr("@@:@\0")
        );
        let _c: i8 = rt::add_method_id_toolbar_array(
            cls,
            rt::sel(#str_ptr("toolbarAllowedItemIdentifiers:\0")),
            allowed_ids,
            #str_ptr("@@:@\0")
        );
        rt::register_class_pair(cls);
    }
    return rt::msg_id(cls, rt::sel(#str_ptr("new\0")));
}

struct ToolbarItem {
    obj: *u8,
}

impl ToolbarItem {
    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn new(identifier: *u8) -> ToolbarItem {
        let cls = rt::get_class(#str_ptr("NSToolbarItem\0"));
        let alloced = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let item = rt::msg_id_id(alloced, rt::sel(#str_ptr("initWithItemIdentifier:\0")), rt::ns_string(identifier));
        return ToolbarItem { obj: item };
    }

    fn set_label(this, label: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setLabel:\0")), rt::ns_string(label));
    }

    fn set_palette_label(this, label: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setPaletteLabel:\0")), rt::ns_string(label));
    }

    fn set_tool_tip(this, tip: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setToolTip:\0")), rt::ns_string(tip));
    }

    fn set_image(this, image: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setImage:\0")), image);
    }

    fn set_view(this, view: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setView:\0")), view);
    }

    fn set_target(this, target: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setTarget:\0")), target);
    }

    fn set_action(this, action: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setAction:\0")), action);
    }

    // GAP 4 (v0.0.19): pin a view-backed item's size. NOTE: `minSize`/`maxSize`
    // are deprecated (macOS 10–12) — Apple recommends letting the system measure
    // a `view`-backed item via Auto Layout constraints instead. They still
    // function; provided for parity, but prefer constraints on the item's view.
    fn set_min_size(this, size: rt::Size) {
        rt::msg_void_size(this.obj, rt::sel(#str_ptr("setMinSize:\0")), size);
    }

    fn set_max_size(this, size: rt::Size) {
        rt::msg_void_size(this.obj, rt::sel(#str_ptr("setMaxSize:\0")), size);
    }
}

struct ToolbarItemGroup {
    obj: *u8,
}

impl ToolbarItemGroup {
    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn new(identifier: *u8) -> ToolbarItemGroup {
        let cls = rt::get_class(#str_ptr("NSToolbarItemGroup\0"));
        let alloced = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let item = rt::msg_id_id(alloced, rt::sel(#str_ptr("initWithItemIdentifier:\0")), rt::ns_string(identifier));
        return ToolbarItemGroup { obj: item };
    }

    fn set_subitems(this, items: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setSubitems:\0")), items);
    }
}

struct StatusBar {
    opaque obj: *u8,
}

impl StatusBar {
    fn system() -> StatusBar {
        return StatusBar { obj: rt::msg_id(rt::get_class(#str_ptr("NSStatusBar\0")), rt::sel(#str_ptr("systemStatusBar\0"))) };
    }

    fn status_item_with_length(this, length: f64) -> *u8 {
        return rt::msg_id_f64(this.obj, rt::sel(#str_ptr("statusItemWithLength:\0")), length);
    }
}

struct StatusItem {
    opaque obj: *u8,
}

impl StatusItem {
    fn from_obj(obj: *u8) -> StatusItem {
        return StatusItem { obj: obj };
    }

    fn button(this) -> *u8 {
        return rt::msg_id(this.obj, rt::sel(#str_ptr("button\0")));
    }

    fn set_menu(this, menu: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setMenu:\0")), menu);
    }

    fn set_length(this, length: f64) {
        rt::msg_void_f64(this.obj, rt::sel(#str_ptr("setLength:\0")), length);
    }
}

struct StatusBarButton {
    opaque obj: *u8,
}

impl StatusBarButton {
    fn from_obj(obj: *u8) -> StatusBarButton {
        return StatusBarButton { obj: obj };
    }

    fn set_title(this, title: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setTitle:\0")), rt::ns_string(title));
    }

    fn set_image(this, image: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setImage:\0")), image);
    }

    fn set_on_click(this, cb: fn(*u8)) {
        rt::attach_callback(this.obj, cb);
    }
}

struct TouchBar {
    obj: *u8,
}

impl TouchBar {
    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn new() -> TouchBar {
        return TouchBar { obj: rt::alloc_init(#str_ptr("NSTouchBar\0")) };
    }

    fn set_delegate(this, delegate: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    }
}

struct TouchBarItem {
    obj: *u8,
}

impl TouchBarItem {
    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn new(identifier: *u8) -> TouchBarItem {
        return TouchBarItem { obj: rt::alloc_init_with_identifier(#str_ptr("NSTouchBarItem\0"), identifier) };
    }
}
