// NSNotificationCenter — the standard cross-object signal path
// (plan.appkit.md §3).
//
// The default center is a process-wide singleton owned by Foundation, so the
// `NotificationCenter` wrapper is `opaque` (a borrowed handle, no `drop`).
//
// `add_observer` is the load-bearing piece. Cocoa's `addObserver:selector:…`
// needs an Objective-C object + selector to call back; C+ has no objects, so we
// synthesize a tiny `CNotifyObserver` NSObject subclass (once) with a
// `handleNotification:` method whose IMP dispatches to a C+ `fn(*u8)` stashed on
// the instance via an associated object (the same trick `runtime::attach_callback`
// uses for target-action). Each subscription gets a fresh observer instance, so
// callbacks never collide.
//
// `add_observer` returns an `Observer` that **owns** the subscription: it holds
// the +1 on the observer instance and, in `drop`, both `removeObserver:` (so the
// center stops sending — it does not retain observers) and releases the instance.
// Keep the `Observer` alive for as long as you want the subscription; dropping it
// unsubscribes.

import "./runtime" as rt;

// The IMP for `handleNotification:` — (self, _cmd, notification). Reads the
// C+ callback associated with the observer instance and forwards the
// `NSNotification*`.
fn handle_notification(self_obj: *u8, _cmd: *u8, notification: *u8) {
    let cb: fn(*u8) = rt::get_associated_callback(self_obj, #str_ptr("notify_cb_key\0"));
    cb(notification);
}

// Lazily create (once) and return the `CNotifyObserver` class. Mirrors
// `runtime::get_action_target`'s class-synthesis pattern.
fn observer_class() -> *u8 {
    let existing: *u8 = rt::get_class(#str_ptr("CNotifyObserver\0"));
    if existing != unsafe { 0 as *u8 } {
        return existing;
    }
    let nsobject: *u8 = rt::get_class(#str_ptr("NSObject\0"));
    let cls: *u8 = rt::allocate_class_pair(nsobject, #str_ptr("CNotifyObserver\0"), 0 as usize);
    let _added: i8 = rt::add_action_method(
        cls,
        rt::sel(#str_ptr("handleNotification:\0")),
        handle_notification,
        #str_ptr("v@:@\0"),
    );
    rt::register_class_pair(cls);
    return cls;
}

fn default_center() -> *u8 {
    return rt::msg_id(
        rt::get_class(#str_ptr("NSNotificationCenter\0")),
        rt::sel(#str_ptr("defaultCenter\0")),
    );
}

// An owned subscription. Dropping it unsubscribes (`removeObserver:`) and
// releases the synthesized observer instance.
pub struct Observer {
    pub obj: *u8,
}

impl Observer {
    fn drop(ref this) {
        rt::msg_void_id(default_center(), rt::sel(#str_ptr("removeObserver:\0")), this.obj);
        rt::release(this.obj);
    }
}

pub struct NotificationCenter {
    pub opaque obj: *u8,
}

impl NotificationCenter {
    // The default (process-wide) notification center.
    pub fn default() -> NotificationCenter {
        return NotificationCenter { obj: default_center() };
    }

    // Post a notification by name, with no object/userInfo.
    pub fn post(this, name: *u8) {
        rt::msg_void_id_id(
            this.obj,
            rt::sel(#str_ptr("postNotificationName:object:\0")),
            rt::ns_string(name),
            unsafe { 0 as *u8 },
        );
    }

    // Post a pre-built `NSString*` name.
    pub fn post_ns(this, name_ns: *u8) {
        rt::msg_void_id_id(
            this.obj,
            rt::sel(#str_ptr("postNotificationName:object:\0")),
            name_ns,
            unsafe { 0 as *u8 },
        );
    }

    // Subscribe `cb` to notifications named `name` (from any object). The
    // returned `Observer` owns the subscription — keep it alive; drop it to
    // unsubscribe.
    pub fn add_observer(this, name: *u8, cb: fn(*u8)) -> Observer {
        let cls: *u8 = observer_class();
        let obs: *u8 = rt::msg_id(rt::msg_id(cls, rt::sel(#str_ptr("alloc\0"))), rt::sel(#str_ptr("init\0")));
        rt::set_associated_callback(obs, #str_ptr("notify_cb_key\0"), cb, 0 as usize);
        rt::msg_void_id_id_id_id(
            this.obj,
            rt::sel(#str_ptr("addObserver:selector:name:object:\0")),
            obs,
            rt::sel(#str_ptr("handleNotification:\0")),
            rt::ns_string(name),
            unsafe { 0 as *u8 },
        );
        return Observer { obj: obs };
    }
}
