import "./runtime" as rt;

struct Panel {
    obj: *u8,
}

impl Panel {
    fn raw(this) -> *u8 { return this.obj; }

    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn new(frame: rt::Rect, style_mask: u64, backing: u64, defer_flag: i8) -> Panel {
        let cls: *u8 = rt::get_class(#str_ptr("NSPanel\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let panel: *u8 = rt::msg_init_window(
            alloced,
            rt::sel(#str_ptr("initWithContentRect:styleMask:backing:defer:\0")),
            frame,
            style_mask,
            backing,
            defer_flag,
        );
        return Panel { obj: panel };
    }

    fn set_title(this, title: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setTitle:\0")), rt::ns_string(title));
    }

    fn make_key_and_order_front(this, sender: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("makeKeyAndOrderFront:\0")), sender);
    }

    fn close(this) {
        rt::msg_void(this.obj, rt::sel(#str_ptr("close\0")));
    }
}

struct SavePanel {
    opaque obj: *u8,
}

impl SavePanel {
    fn raw(this) -> *u8 { return this.obj; }

    fn shared() -> SavePanel {
        return SavePanel { obj: rt::msg_id(rt::get_class(#str_ptr("NSSavePanel\0")), rt::sel(#str_ptr("savePanel\0"))) };
    }

    fn set_title(this, title: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setTitle:\0")), rt::ns_string(title));
    }

    fn set_prompt(this, prompt: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setPrompt:\0")), rt::ns_string(prompt));
    }

    fn set_message(this, message: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setMessage:\0")), rt::ns_string(message));
    }

    fn set_name_field_string_value(this, value: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setNameFieldStringValue:\0")), rt::ns_string(value));
    }

    fn run_modal(this) -> i64 {
        return rt::msg_i64(this.obj, rt::sel(#str_ptr("runModal\0")));
    }

    fn url(this) -> *u8 {
        return rt::msg_id(this.obj, rt::sel(#str_ptr("URL\0")));
    }
}

struct OpenPanel {
    opaque obj: *u8,
}

impl OpenPanel {
    fn raw(this) -> *u8 { return this.obj; }

    fn shared() -> OpenPanel {
        return OpenPanel { obj: rt::msg_id(rt::get_class(#str_ptr("NSOpenPanel\0")), rt::sel(#str_ptr("openPanel\0"))) };
    }

    fn set_can_choose_files(this, flag: i8) {
        rt::msg_void_i8(this.obj, rt::sel(#str_ptr("setCanChooseFiles:\0")), flag);
    }

    fn set_can_choose_directories(this, flag: i8) {
        rt::msg_void_i8(this.obj, rt::sel(#str_ptr("setCanChooseDirectories:\0")), flag);
    }

    fn set_allows_multiple_selection(this, flag: i8) {
        rt::msg_void_i8(this.obj, rt::sel(#str_ptr("setAllowsMultipleSelection:\0")), flag);
    }

    fn run_modal(this) -> i64 {
        return rt::msg_i64(this.obj, rt::sel(#str_ptr("runModal\0")));
    }

    fn url(this) -> *u8 {
        return rt::msg_id(this.obj, rt::sel(#str_ptr("URL\0")));
    }

    fn urls(this) -> *u8 {
        return rt::msg_id(this.obj, rt::sel(#str_ptr("URLs\0")));
    }
}

