import "./runtime" as rt;
import "./convert" as bridge;
import "stdlib/option" as option;

struct Panel {
    _obj: *u8,
}

impl Panel {
    fn raw(this) -> *u8 { return this._obj; }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn new(frame: rt::Rect, style_mask: u64, backing: u64, defers: bool) -> Panel {
        let cls: *u8 = rt::get_class(#str_ptr("NSPanel\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let panel: *u8 = rt::msg_init_window(
            alloced,
            rt::sel(#str_ptr("initWithContentRect:styleMask:backing:defer:\0")),
            frame,
            style_mask,
            backing,
            defers as i8,
        );
        // SAFETY: this wrapper owns the +1 and releases it in `drop`. NSWindow's
        // default `releasedWhenClosed = YES` would release it a SECOND time when
        // the panel closes (double-free / use-after-free). Disable it so the
        // wrapper's `drop` is the sole release.
        rt::msg_void_i8(panel, rt::sel(#str_ptr("setReleasedWhenClosed:\0")), 0 as i8);
        return Panel { _obj: panel };
    }

    fn set_title(this, title: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setTitle:\0")), bridge::cplus_str_to_nsstring(title));
    }

    fn make_key_and_order_front(this, sender: *u8 = 0 as *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("makeKeyAndOrderFront:\0")), sender);
    }

    fn close(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("close\0")));
    }
}

struct SavePanel {
    opaque _obj: *u8,
}

impl SavePanel {
    fn raw(this) -> *u8 { return this._obj; }

    fn shared() -> SavePanel {
        return SavePanel { _obj: rt::msg_id(rt::get_class(#str_ptr("NSSavePanel\0")), rt::sel(#str_ptr("savePanel\0"))) };
    }

    fn set_title(this, title: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setTitle:\0")), bridge::cplus_str_to_nsstring(title));
    }

    fn set_prompt(this, prompt: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setPrompt:\0")), bridge::cplus_str_to_nsstring(prompt));
    }

    fn set_message(this, message: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setMessage:\0")), bridge::cplus_str_to_nsstring(message));
    }

    // Pre-fill the editable filename field.
    fn set_name(this, name: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setNameFieldStringValue:\0")), bridge::cplus_str_to_nsstring(name));
    }

    fn run_modal(this) -> i64 {
        return rt::msg_i64(this._obj, rt::sel(#str_ptr("runModal\0")));
    }

    // The chosen file URL (an `NSURL*`), or `None` if the user cancelled.
    fn url(this) -> option::Option[*u8] {
        let u: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("URL\0")));
        if u == { 0 as *u8 } {
            return option::Option[*u8]::None;
        }
        return option::some(u);
    }
}

struct OpenPanel {
    opaque _obj: *u8,
}

impl OpenPanel {
    fn raw(this) -> *u8 { return this._obj; }

    fn shared() -> OpenPanel {
        return OpenPanel { _obj: rt::msg_id(rt::get_class(#str_ptr("NSOpenPanel\0")), rt::sel(#str_ptr("openPanel\0"))) };
    }

    fn set_can_choose_files(this, can_choose: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setCanChooseFiles:\0")), can_choose as i8);
    }

    fn set_can_choose_directories(this, can_choose: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setCanChooseDirectories:\0")), can_choose as i8);
    }

    fn set_allows_multiple_selection(this, allows: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setAllowsMultipleSelection:\0")), allows as i8);
    }

    fn run_modal(this) -> i64 {
        return rt::msg_i64(this._obj, rt::sel(#str_ptr("runModal\0")));
    }

    // The chosen file URL (an `NSURL*`), or `None` if the user cancelled.
    fn url(this) -> option::Option[*u8] {
        let u: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("URL\0")));
        if u == { 0 as *u8 } {
            return option::Option[*u8]::None;
        }
        return option::some(u);
    }

    // The chosen file URLs as an `NSArray*` (empty if the user cancelled).
    fn urls(this) -> *u8 {
        return rt::msg_id(this._obj, rt::sel(#str_ptr("URLs\0")));
    }
}

