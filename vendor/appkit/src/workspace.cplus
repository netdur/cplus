// `NSWorkspaceAuthorization` (Foundation/ObjC). Non-owning handle (factory/singleton); `opaque`, no drop.
struct WorkspaceAuthorization {
    opaque _obj: *u8,
}

impl WorkspaceAuthorization {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> WorkspaceAuthorization { return WorkspaceAuthorization { _obj: ptr }; }

}

