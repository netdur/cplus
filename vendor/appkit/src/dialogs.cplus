import "./runtime" as rt;
import "./convert" as bridge;

// Owned wrapper (plan.appkit.md §2): `NSAlert` is created with `new` (+1) and
// is the canonical transient — built, shown with `run_modal`, then dropped. It
// is not added to a view hierarchy, so nothing else retains it; without a
// `drop` it leaks (one per dialog). `drop` releases the +1.
struct Alert {
    _obj: *u8,
}

impl Alert {
    fn raw(this) -> *u8 { return this._obj; }

    fn new() -> Alert {
        let cls = rt::get_class(#str_ptr("NSAlert\0"));
        let alert = rt::msg_id(cls, rt::sel(#str_ptr("new\0")));
        return Alert { _obj: alert };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn set_message(this, text: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setMessageText:\0")), bridge::cplus_str_to_nsstring(text));
    }

    fn set_informative(this, text: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setInformativeText:\0")), bridge::cplus_str_to_nsstring(text));
    }

    fn add_button(this, title: str) -> *u8 {
        return rt::msg_id_id(this._obj, rt::sel(#str_ptr("addButtonWithTitle:\0")), bridge::cplus_str_to_nsstring(title));
    }

    fn run_modal(this) -> i64 {
        return rt::msg_i64(this._obj, rt::sel(#str_ptr("runModal\0")));
    }
}
