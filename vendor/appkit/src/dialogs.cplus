import "./runtime" as rt;

pub struct Alert {
    pub obj: *u8,
}

impl Alert {
    pub fn new() -> Alert {
        let cls = rt::get_class(str_ptr("NSAlert\0"));
        let alert = rt::msg_id(cls, rt::sel(str_ptr("new\0")));
        return Alert { obj: alert };
    }

    pub fn set_message_text(self, text: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setMessageText:\0")), rt::ns_string(text));
    }

    pub fn set_informative_text(self, text: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setInformativeText:\0")), rt::ns_string(text));
    }

    pub fn add_button(self, title: *u8) -> *u8 {
        return rt::msg_id_id(self.obj, rt::sel(str_ptr("addButtonWithTitle:\0")), rt::ns_string(title));
    }

    pub fn run_modal(self) -> i64 {
        return rt::msg_i64(self.obj, rt::sel(str_ptr("runModal\0")));
    }
}
