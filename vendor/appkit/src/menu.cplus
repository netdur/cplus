import "./runtime" as rt;

// Owned (+1 via alloc/initWithTitle:); the app (setMainMenu:) or a parent menu
// item (setSubmenu:) retains it. `drop` releases this wrapper's +1
// (plan.appkit.md §2).
pub struct Menu {
    pub obj: *u8,
}

impl Menu {
    pub fn new(title: *u8) -> Menu {
        let ns_title = rt::ns_string(title);
        let cls = rt::get_class(str_ptr("NSMenu\0"));
        let menu_alloc = rt::msg_id(cls, rt::sel(str_ptr("alloc\0")));
        let menu = rt::msg_id_id(menu_alloc, rt::sel(str_ptr("initWithTitle:\0")), ns_title);
        return Menu { obj: menu };
    }

    fn drop(mut self) {
        rt::release(self.obj);
    }

    pub fn add_item(self, item: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("addItem:\0")), item);
    }

    pub fn remove_all_items(self) {
        rt::msg_void(self.obj, rt::sel(str_ptr("removeAllItems\0")));
    }

    pub fn set_autoenables_items(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(str_ptr("setAutoenablesItems:\0")), flag);
    }
}

// Owned (+1 via alloc/initWithTitle:action:keyEquivalent:); the menu retains it
// on `addItem:`. `drop` releases this wrapper's +1 (plan.appkit.md §2). Note
// `separator()` is a separate +0 autoreleased factory that returns a raw `*u8`,
// not a `MenuItem` — so it is not affected.
pub struct MenuItem {
    pub obj: *u8,
}

impl MenuItem {
    fn drop(mut self) {
        rt::release(self.obj);
    }

    pub fn new(title: *u8, action: *u8, key_equiv: *u8) -> MenuItem {
        let ns_title = rt::ns_string(title);
        let mut act_sel: *u8 = unsafe { 0 as *u8 };
        if action != unsafe { 0 as *u8 } {
            act_sel = rt::sel(action);
        }
        let ns_key = rt::ns_string(key_equiv);
        let cls = rt::get_class(str_ptr("NSMenuItem\0"));
        let item_alloc = rt::msg_id(cls, rt::sel(str_ptr("alloc\0")));
        let item = rt::msg_init_menu_item(item_alloc, rt::sel(str_ptr("initWithTitle:action:keyEquivalent:\0")), ns_title, act_sel, ns_key);
        return MenuItem { obj: item };
    }

    pub fn separator() -> *u8 {
        let cls = rt::get_class(str_ptr("NSMenuItem\0"));
        return rt::msg_id(cls, rt::sel(str_ptr("separatorItem\0")));
    }

    pub fn set_submenu(self, submenu: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setSubmenu:\0")), submenu);
    }

    pub fn set_enabled(self, flag: i8) {
        rt::msg_void_i8(self.obj, rt::sel(str_ptr("setEnabled:\0")), flag);
    }

    pub fn set_target(self, target: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setTarget:\0")), target);
    }

    pub fn set_action(self, action: *u8) {
        rt::msg_void_id(self.obj, rt::sel(str_ptr("setAction:\0")), action);
    }

    pub fn set_key_equivalent_modifier_mask(self, mask: u64) {
        rt::msg_void_u64(self.obj, rt::sel(str_ptr("setKeyEquivalentModifierMask:\0")), mask);
    }
}
