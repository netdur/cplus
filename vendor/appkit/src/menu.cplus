import "./runtime" as rt;
import "./convert" as bridge;

// Owned (+1 via alloc/initWithTitle:); the app (setMainMenu:) or a parent menu
// item (setSubmenu:) retains it. `drop` releases this wrapper's +1
// (plan.appkit.md §2).
struct Menu {
    _obj: *u8,
}

impl Menu {
    fn raw(this) -> *u8 { return this._obj; }

    fn new(title: str) -> Menu {
        let ns_title = bridge::cplus_str_to_nsstring(title);
        let cls = rt::get_class(#str_ptr("NSMenu\0"));
        let menu_alloc = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let menu = rt::msg_id_id(menu_alloc, rt::sel(#str_ptr("initWithTitle:\0")), ns_title);
        return Menu { _obj: menu };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn add_item(this, item: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("addItem:\0")), item);
    }

    fn remove_all_items(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("removeAllItems\0")));
    }

    fn set_autoenables_items(this, autoenables: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setAutoenablesItems:\0")), autoenables as i8);
    }
}

// Owned (+1 via alloc/initWithTitle:action:keyEquivalent:); the menu retains it
// on `addItem:`. `drop` releases this wrapper's +1 (plan.appkit.md §2). Note
// `separator()` is a separate +0 autoreleased factory that returns a raw `*u8`,
// not a `MenuItem` — so it is not affected.
struct MenuItem {
    _obj: *u8,
}

impl MenuItem {
    fn raw(this) -> *u8 { return this._obj; }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    // `action` is a raw Objective-C selector name (a C string, e.g.
    // `#str_ptr("doFoo:\0")`), or `0 as *u8` for no action — it is fed straight
    // to `sel`, so it stays a raw interop handle rather than a `str`.
    fn new(title: str, action: *u8, key_equiv: str) -> MenuItem {
        let ns_title = bridge::cplus_str_to_nsstring(title);
        var act_sel: *u8 = { 0 as *u8 };
        if action != { 0 as *u8 } {
            act_sel = rt::sel(action);
        }
        let ns_key = bridge::cplus_str_to_nsstring(key_equiv);
        let cls = rt::get_class(#str_ptr("NSMenuItem\0"));
        let item_alloc = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let item = rt::msg_init_menu_item(item_alloc, rt::sel(#str_ptr("initWithTitle:action:keyEquivalent:\0")), ns_title, act_sel, ns_key);
        return MenuItem { _obj: item };
    }

    fn separator() -> *u8 {
        let cls = rt::get_class(#str_ptr("NSMenuItem\0"));
        return rt::msg_id(cls, rt::sel(#str_ptr("separatorItem\0")));
    }

    fn set_submenu(this, submenu: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setSubmenu:\0")), submenu);
    }

    fn set_enabled(this, enabled: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setEnabled:\0")), enabled as i8);
    }

    fn set_target(this, target: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setTarget:\0")), target);
    }

    fn set_action(this, action: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setAction:\0")), action);
    }

    fn set_key_equivalent_modifier_mask(this, mask: u64) {
        rt::msg_void_u64(this._obj, rt::sel(#str_ptr("setKeyEquivalentModifierMask:\0")), mask);
    }
}
