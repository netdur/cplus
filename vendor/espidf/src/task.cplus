// Task sleep. `usleep` is newlib's real function under ESP-IDF (it
// delegates to `vTaskDelay` for whole ticks), so sleeping is independent
// of the FreeRTOS tick-rate configuration — unlike the `pdMS_TO_TICKS`
// C macro, which cannot be bound.

extern fn usleep(us: u32) -> i32;

fn delay_ms(ms: u32) {
    let _r: i32 = { usleep(ms * 1000) };
    return;
}

fn delay_us(us: u32) {
    let _r: i32 = { usleep(us) };
    return;
}
