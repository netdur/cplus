// UIView, UILabel, UIColor, UIStackView, UIScrollView.

import "./runtime" as rt;
import "./convert" as convert;

fn create_custom_view(frame: rt::Rect, draw_imp: fn(*u8, *u8, rt::Rect)) -> View {
    let existing: *u8 = rt::get_class(#str_ptr("CUIKitCustomView\0"));
    var cls: *u8 = existing;
    if existing == { 0 as *u8 } {
        let uiview: *u8 = rt::get_class(#str_ptr("UIView\0"));
        cls = rt::allocate_class_pair(uiview, #str_ptr("CUIKitCustomView\0"), 0 as usize);
        let _added: i8 = rt::add_method_draw_rect(
            cls,
            rt::sel(#str_ptr("drawRect:\0")),
            draw_imp,
            #str_ptr("v@:{CGRect={CGPoint=dd}{CGSize=dd}}\0"),
        );
        rt::register_class_pair(cls);
    }
    let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
    let v: *u8 = rt::msg_id_rect(alloced, rt::sel(#str_ptr("initWithFrame:\0")), frame);
    return View { _obj: v };
}

struct View {
    opaque _obj: *u8,
}

impl View {
    fn raw(this) -> *u8 { return this._obj; }

    fn new(frame: rt::Rect) -> View {
        return View { _obj: rt::alloc_init_with_frame(#str_ptr("UIView\0"), frame) };
    }

    fn from_raw(obj: *u8) -> View {
        return View { _obj: obj };
    }

    fn as_view_obj(this) -> *u8 {
        return this._obj;
    }

    fn add_subview(this, child: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("addSubview:\0")), child);
    }

    fn remove_from_superview(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("removeFromSuperview\0")));
    }

    fn set_background_color(this, color: Color) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setBackgroundColor:\0")), color.raw());
    }

    fn frame(this) -> rt::Rect {
        return rt::msg_rect(this._obj, rt::sel(#str_ptr("frame\0")));
    }

    fn set_frame(this, frame: rt::Rect) {
        rt::msg_void_rect(this._obj, rt::sel(#str_ptr("setFrame:\0")), frame);
    }

    fn bounds(this) -> rt::Rect {
        return rt::msg_rect(this._obj, rt::sel(#str_ptr("bounds\0")));
    }

    fn set_bounds(this, bounds: rt::Rect) {
        rt::msg_void_rect(this._obj, rt::sel(#str_ptr("setBounds:\0")), bounds);
    }

    fn set_hidden(this, flag: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setHidden:\0")), flag as i8);
    }

    fn is_hidden(this) -> bool {
        return rt::msg_i8(this._obj, rt::sel(#str_ptr("isHidden\0"))) != (0 as i8);
    }

    fn set_alpha(this, alpha: f64) {
        rt::msg_void_f64(this._obj, rt::sel(#str_ptr("setAlpha:\0")), alpha);
    }

    fn set_user_interaction_enabled(this, flag: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setUserInteractionEnabled:\0")), flag as i8);
    }

    fn set_content_mode(this, mode: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setContentMode:\0")), mode);
    }

    fn set_needs_display(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("setNeedsDisplay\0")));
    }

    fn layout_if_needed(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("layoutIfNeeded\0")));
    }

    fn layer(this) -> *u8 {
        return rt::msg_id(this._obj, rt::sel(#str_ptr("layer\0")));
    }

    fn safe_area_layout_guide(this) -> *u8 {
        return rt::msg_id(this._obj, rt::sel(#str_ptr("safeAreaLayoutGuide\0")));
    }
}

struct Label {
    opaque _obj: *u8,
}

// NSTextAlignment values (UIKit's NSTextAlignmentCenter is 1 on iOS).
fn text_alignment_left() -> i64 { return 0; }
fn text_alignment_center() -> i64 { return 1; }
fn text_alignment_right() -> i64 { return 2; }

impl Label {
    fn raw(this) -> *u8 { return this._obj; }

    fn new(frame: rt::Rect) -> Label {
        let cls: *u8 = rt::get_class(#str_ptr("UILabel\0"));
        let alloc: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let label: *u8 = rt::msg_id_rect(alloc, rt::sel(#str_ptr("initWithFrame:\0")), frame);
        return Label { _obj: label };
    }

    fn set_text(this, s: str) {
        let ns: *u8 = convert::cplus_str_to_nsstring(s);
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setText:\0")), ns);
    }

    fn set_text_alignment(this, alignment: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setTextAlignment:\0")), alignment);
    }

    fn set_text_color(this, color: Color) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setTextColor:\0")), color.raw());
    }

    fn set_font(this, font: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setFont:\0")), font);
    }

    fn set_number_of_lines(this, lines: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setNumberOfLines:\0")), lines);
    }

    fn set_line_break_mode(this, mode: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setLineBreakMode:\0")), mode);
    }

    fn set_background_color(this, color: Color) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setBackgroundColor:\0")), color.raw());
    }

    fn as_view_obj(this) -> *u8 {
        return this._obj;
    }
}

struct Color {
    opaque _obj: *u8,
}

impl Color {
    fn raw(this) -> *u8 { return this._obj; }

    fn white() -> Color {
        let cls: *u8 = rt::get_class(#str_ptr("UIColor\0"));
        return Color { _obj: rt::msg_id(cls, rt::sel(#str_ptr("whiteColor\0"))) };
    }

    fn black() -> Color {
        let cls: *u8 = rt::get_class(#str_ptr("UIColor\0"));
        return Color { _obj: rt::msg_id(cls, rt::sel(#str_ptr("blackColor\0"))) };
    }

    fn clear() -> Color {
        let cls: *u8 = rt::get_class(#str_ptr("UIColor\0"));
        return Color { _obj: rt::msg_id(cls, rt::sel(#str_ptr("clearColor\0"))) };
    }

    fn red() -> Color {
        let cls: *u8 = rt::get_class(#str_ptr("UIColor\0"));
        return Color { _obj: rt::msg_id(cls, rt::sel(#str_ptr("redColor\0"))) };
    }

    fn green() -> Color {
        let cls: *u8 = rt::get_class(#str_ptr("UIColor\0"));
        return Color { _obj: rt::msg_id(cls, rt::sel(#str_ptr("greenColor\0"))) };
    }

    fn blue() -> Color {
        let cls: *u8 = rt::get_class(#str_ptr("UIColor\0"));
        return Color { _obj: rt::msg_id(cls, rt::sel(#str_ptr("blueColor\0"))) };
    }

    fn system_blue() -> Color {
        let cls: *u8 = rt::get_class(#str_ptr("UIColor\0"));
        return Color { _obj: rt::msg_id(cls, rt::sel(#str_ptr("systemBlueColor\0"))) };
    }

    fn label() -> Color {
        let cls: *u8 = rt::get_class(#str_ptr("UIColor\0"));
        return Color { _obj: rt::msg_id(cls, rt::sel(#str_ptr("labelColor\0"))) };
    }

    fn secondary_label() -> Color {
        let cls: *u8 = rt::get_class(#str_ptr("UIColor\0"));
        return Color { _obj: rt::msg_id(cls, rt::sel(#str_ptr("secondaryLabelColor\0"))) };
    }

    fn system_background() -> Color {
        let cls: *u8 = rt::get_class(#str_ptr("UIColor\0"));
        return Color { _obj: rt::msg_id(cls, rt::sel(#str_ptr("systemBackgroundColor\0"))) };
    }

    fn rgba(r: f64, g: f64, b: f64, a: f64) -> Color {
        let cls: *u8 = rt::get_class(#str_ptr("UIColor\0"));
        let selector: *u8 = rt::sel(#str_ptr("colorWithRed:green:blue:alpha:\0"));
        return Color { _obj: rt::msg_id_rgba(cls, selector, r, g, b, a) };
    }

    fn cg_color(this) -> *u8 {
        return rt::msg_id(this._obj, rt::sel(#str_ptr("CGColor\0")));
    }
}

struct StackView {
    _obj: *u8,
}

impl StackView {
    fn raw(this) -> *u8 { return this._obj; }

    fn new(frame: rt::Rect) -> StackView {
        return StackView { _obj: rt::alloc_init_with_frame(#str_ptr("UIStackView\0"), frame) };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn add_view(this, view: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("addArrangedSubview:\0")), view);
    }

    fn remove_view(this, view: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("removeArrangedSubview:\0")), view);
    }

    fn set_axis(this, axis: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setAxis:\0")), axis);
    }

    fn set_spacing(this, spacing: f64) {
        rt::msg_void_f64(this._obj, rt::sel(#str_ptr("setSpacing:\0")), spacing);
    }

    fn set_alignment(this, alignment: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setAlignment:\0")), alignment);
    }

    fn set_distribution(this, distribution: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setDistribution:\0")), distribution);
    }

    fn as_view_obj(this) -> *u8 {
        return this._obj;
    }
}

struct ScrollView {
    _obj: *u8,
}

impl ScrollView {
    fn raw(this) -> *u8 { return this._obj; }

    fn new(frame: rt::Rect) -> ScrollView {
        return ScrollView { _obj: rt::alloc_init_with_frame(#str_ptr("UIScrollView\0"), frame) };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn add_subview(this, view: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("addSubview:\0")), view);
    }

    fn set_content_size(this, size: rt::Size) {
        rt::msg_void_size(this._obj, rt::sel(#str_ptr("setContentSize:\0")), size);
    }

    fn set_content_offset(this, point: rt::Point) {
        rt::msg_void_point(this._obj, rt::sel(#str_ptr("setContentOffset:\0")), point);
    }

    fn set_content_inset(this, top: f64, left: f64, bottom: f64, right: f64) {
        let insets: rt::EdgeInsets = rt::EdgeInsets { top: top, left: left, bottom: bottom, right: right };
        rt::msg_void_edge_insets(this._obj, rt::sel(#str_ptr("setContentInset:\0")), insets);
    }

    fn set_scroll_enabled(this, flag: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setScrollEnabled:\0")), flag as i8);
    }

    fn set_shows_vertical_scroll_indicator(this, flag: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setShowsVerticalScrollIndicator:\0")), flag as i8);
    }

    fn set_shows_horizontal_scroll_indicator(this, flag: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setShowsHorizontalScrollIndicator:\0")), flag as i8);
    }

    fn as_view_obj(this) -> *u8 {
        return this._obj;
    }
}
