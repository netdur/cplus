    }

    fn exclusion_paths(this) -> vec::Vec[BezierPath] {
        let arr: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("exclusionPaths\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[BezierPath] = vec::Vec[BezierPath]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(BezierPath::from_raw(rt::retain(rt::msg_id_u64(arr, at_sel, i))));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn set_exclusion_paths(this, exclusion_paths: vec::Vec[BezierPath]) {
        let arr_exclusion_paths: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableArray\0")), rt::sel(#str_ptr("array\0")));
        let add_sel_exclusion_paths: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let n_exclusion_paths: usize = exclusion_paths.count();
        var i_exclusion_paths: usize = 0 as usize;
        while i_exclusion_paths < n_exclusion_paths {
            match exclusion_paths.at_ptr(i_exclusion_paths) {
                option::Option[*BezierPath]::Some(e_exclusion_paths) => { rt::msg_void_id(arr_exclusion_paths, add_sel_exclusion_paths, (*e_exclusion_paths).raw()); }
                option::Option[*BezierPath]::None => {}
            }
            i_exclusion_paths = i_exclusion_paths +% (1 as usize);
        }
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setExclusionPaths:\0")), arr_exclusion_paths);
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }
}

