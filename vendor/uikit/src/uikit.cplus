// `NSFileWrapper` (Foundation/ObjC). Non-owning handle (factory/singleton); `opaque`, no drop.
struct NSFileWrapper {
    opaque _obj: *u8,
}

impl NSFileWrapper {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> NSFileWrapper { return NSFileWrapper { _obj: ptr }; }

}

// `NSTextAttachmentViewProvider` (Foundation/ObjC). Owned via alloc/init; `drop` releases the +1.
struct NSTextAttachmentViewProvider {
    _obj: *u8,
}

impl NSTextAttachmentViewProvider {
