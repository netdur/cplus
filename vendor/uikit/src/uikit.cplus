        let sadd_mandatory_keys: *u8 = rt::sel(#str_ptr("addObject:\0"));
        let scap_mandatory_keys: usize = mandatory_keys.slot_capacity();
        var ssi_mandatory_keys: usize = 0 as usize;
        while ssi_mandatory_keys < scap_mandatory_keys {
            match mandatory_keys.element_ptr_at_slot(ssi_mandatory_keys) {
                option::Option[*text::Text]::Some(sep_mandatory_keys) => { rt::msg_void_id(arr_mandatory_keys, sadd_mandatory_keys, bridge::nsstring((*sep_mandatory_keys).view())); }
                option::Option[*text::Text]::None => {}
