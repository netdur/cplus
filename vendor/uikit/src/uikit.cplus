}

impl Screen {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> Screen { return Screen { _obj: ptr }; }

    fn display_link_with_target(this, target: *u8, selector: *u8) -> option::Option[CADisplayLink] {
        let obj: *u8 = rt::msg_id_id_id(this._obj, rt::sel(#str_ptr("displayLinkWithTarget:selector:\0")), target, selector);
        if obj == { 0 as *u8 } {
            return option::Option[CADisplayLink]::None;
        }
        return option::some(CADisplayLink::from_raw(obj));
    }

    fn screens() -> vec::Vec[Screen] {
        let arr: *u8 = rt::msg_id(rt::get_class(#str_ptr("UIScreen\0")), rt::sel(#str_ptr("screens\0")));
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[Screen] = vec::Vec[Screen]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            out.append(Screen::from_raw(rt::msg_id_u64(arr, at_sel, i)));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn main_screen() -> Screen {
        return Screen { _obj: rt::msg_id(rt::get_class(#str_ptr("UIScreen\0")), rt::sel(#str_ptr("mainScreen\0"))) };
