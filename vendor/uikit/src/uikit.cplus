    }

    fn options(this) -> string_map::StringMap[AnyObject] {
        let dict: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("options\0")));
        let keys: *u8 = rt::msg_id(dict, rt::sel(#str_ptr("allKeys\0")));
        let n: u64 = rt::msg_u64(keys, rt::sel(#str_ptr("count\0")));
        var out: string_map::StringMap[AnyObject] = string_map::new::[AnyObject]();
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        let obj_sel: *u8 = rt::sel(#str_ptr("objectForKey:\0"));
        var i: u64 = 0 as u64;
        while i < n {
            let nskey: *u8 = rt::msg_id_u64(keys, at_sel, i);
            let nsval: *u8 = rt::msg_id_id(dict, obj_sel, nskey);
            out.insert(bridge::to_text(nskey), AnyObject::from_raw(nsval));
            i = i +% (1 as u64);
        }
        return out;
    }

    fn new(alignment: NSTextAlignment, loc: f64, options: string_map::StringMap[AnyObject]) -> NSTextTab {
        let cls: *u8 = rt::get_class(#str_ptr("NSTextTab\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let dict_options: *u8 = rt::msg_id(rt::get_class(#str_ptr("NSMutableDictionary\0")), rt::sel(#str_ptr("dictionary\0")));
        let dset_options: *u8 = rt::sel(#str_ptr("setObject:forKey:\0"));
        let dcap_options: usize = options.slot_capacity();
        var dsi_options: usize = 0 as usize;
        while dsi_options < dcap_options {
            match options.value_ptr_at_slot(dsi_options) {
                option::Option[*AnyObject]::Some(dvp_options) => {
                    match options.key_ptr_at_slot(dsi_options) {
                        option::Option[*text::Text]::Some(dkp_options) => {
                    let dval_options: *u8 = (*dvp_options).raw();
                            rt::msg_void_id_id(dict_options, dset_options, dval_options, bridge::nsstring((*dkp_options).view()));
                        }
                        option::Option[*text::Text]::None => {}
                    }
                }
                option::Option[*AnyObject]::None => {}
            }
            dsi_options = dsi_options +% (1 as usize);
        }
        return NSTextTab { _obj: objc_msg_id_i64_f64_id(alloced, rt::sel(#str_ptr("initWithTextAlignment:location:options:\0")), n_s_text_alignment_raw(alignment), loc, dict_options) };
    }

