// `NSShadow` (Foundation/ObjC). Owned via alloc/init; `drop` releases the +1.
struct NSShadow {
    _obj: *u8,
}

impl NSShadow {
    fn raw(this) -> *u8 { return this._obj; }

    fn from_raw(ptr: *u8) -> NSShadow { return NSShadow { _obj: ptr }; }

    fn new() -> NSShadow {
        let cls: *u8 = rt::get_class(#str_ptr("NSShadow\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        return NSShadow { _obj: rt::msg_id(alloced, rt::sel(#str_ptr("init\0"))) };
    }

    fn new_with_coder(coder: NSCoder) -> NSShadow {
        let cls: *u8 = rt::get_class(#str_ptr("NSShadow\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        return NSShadow { _obj: rt::msg_id_id(alloced, rt::sel(#str_ptr("initWithCoder:\0")), coder.raw()) };
    }

    fn shadow_offset(this) -> rt::Size {
        return rt::msg_size(this._obj, rt::sel(#str_ptr("shadowOffset\0")));
    }

    fn set_shadow_offset(this, shadow_offset: rt::Size) {
        rt::msg_void_size(this._obj, rt::sel(#str_ptr("setShadowOffset:\0")), shadow_offset);
    }

    fn shadow_blur_radius(this) -> f64 {
        return rt::msg_f64(this._obj, rt::sel(#str_ptr("shadowBlurRadius\0")));
    }

    fn set_shadow_blur_radius(this, shadow_blur_radius: f64) {
        rt::msg_void_f64(this._obj, rt::sel(#str_ptr("setShadowBlurRadius:\0")), shadow_blur_radius);
    }

    fn shadow_color(this) -> option::Option[*u8] {
        let obj: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("shadowColor\0")));
        return bridge::obj_option(obj);
    }

    fn set_shadow_color(this, shadow_color: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setShadowColor:\0")), shadow_color);
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }
}

