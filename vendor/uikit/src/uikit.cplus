            ssi_mandatory_keys = ssi_mandatory_keys +% (1 as usize);
        }
        let set_mandatory_keys: *u8 = rt::msg_id_id(rt::get_class(#str_ptr("NSSet\0")), rt::sel(#str_ptr("setWithArray:\0")), arr_mandatory_keys);
        let arr: *u8 = rt::msg_id_id(this._obj, rt::sel(#str_ptr("matchingFontDescriptorsWithMandatoryKeys:\0")), set_mandatory_keys);
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
