// Umbrella module: one import surfaces the whole binding set, mirroring
// `vendor/appkit/src/appkit.cplus`.

import "./runtime" as runtime;
import "./convert" as convert;
import "./application" as application;
import "./screen" as screen;
import "./window" as window;
import "./controllers" as controllers;
import "./view" as view;
import "./controls" as controls;
import "./text" as text;
import "./containers" as containers;
import "./data" as data;
import "./graphics" as graphics;
import "./dialogs" as dialogs;
import "./toolbar" as toolbar;
import "./pasteboard" as pasteboard;
import "./notifications" as notifications;

type Point = runtime::Point;
type Size = runtime::Size;
type Rect = runtime::Rect;
type EdgeInsets = runtime::EdgeInsets;

type Screen = screen::Screen;
type Window = window::Window;
type ViewController = controllers::ViewController;
type NavigationController = controllers::NavigationController;
type TabBarController = controllers::TabBarController;
type SplitViewController = controllers::SplitViewController;
type PageViewController = controllers::PageViewController;

type View = view::View;
type Label = view::Label;
type StackView = view::StackView;
type ScrollView = view::ScrollView;
type Color = view::Color;

type Button = controls::Button;
type Slider = controls::Slider;
type Switch = controls::Switch;
type SegmentedControl = controls::SegmentedControl;
type ProgressView = controls::ProgressView;
type ProgressIndicator = controls::ActivityIndicator;
type ActivityIndicator = controls::ActivityIndicator;
type PageControl = controls::PageControl;
type DatePicker = controls::DatePicker;

type TextField = text::TextField;
type TextView = text::TextView;
type SearchBar = text::SearchBar;
type SecureTextField = text::SecureTextField;

type VisualEffectView = containers::VisualEffectView;
type BlurEffect = containers::BlurEffect;
type TableViewCell = containers::TableViewCell;

type TableView = data::TableView;
type CollectionView = data::CollectionView;
type CollectionViewCell = data::CollectionViewCell;
type CollectionViewFlowLayout = data::CollectionViewFlowLayout;
type PickerView = data::PickerView;

type ImageView = graphics::ImageView;
type Image = graphics::Image;
type Font = graphics::Font;
type BezierPath = graphics::BezierPath;

type AlertController = dialogs::AlertController;
type AlertAction = dialogs::AlertAction;
type Alert = dialogs::Alert;

type Toolbar = toolbar::Toolbar;
type NavigationBar = toolbar::NavigationBar;
type BarButtonItem = toolbar::BarButtonItem;
type TabBar = toolbar::TabBar;
type TabBarItem = toolbar::TabBarItem;

type Pasteboard = pasteboard::Pasteboard;
type NotificationCenter = notifications::NotificationCenter;
type Observer = notifications::Observer;

fn ns_string(utf8: *u8) -> *u8 {
    return runtime::ns_string(utf8);
}

fn make_rect(x: f64, y: f64, w: f64, h: f64) -> runtime::Rect {
    return runtime::make_rect(x, y, w, h);
}

fn run(argc: i32, argv: *u8, did_finish_imp: fn(*u8, *u8, *u8, *u8) -> i8) -> i32 {
    return application::run(argc, argv, did_finish_imp);
}
