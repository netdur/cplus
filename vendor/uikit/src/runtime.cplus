// CoreGraphics geometry, `#[repr(C)]` so it crosses the C ABI verbatim.
// CGFloat is f64 on every 64-bit Apple target.
#[repr(C)]
struct Point {
    x: f64,
    y: f64,
}

#[repr(C)]
struct Size {
    width: f64,
    height: f64,
}

#[repr(C)]
struct Rect {
    origin: Point,
    size: Size,
}

#[repr(C)]
struct EdgeInsets {
    top: f64,
    left: f64,
    bottom: f64,
    right: f64,
}

fn make_rect(x: f64, y: f64, w: f64, h: f64) -> Rect {
    return Rect {
        origin: Point { x: x, y: y },
        size: Size { width: w, height: h },
    };
}

fn get_class(name: *u8) -> *u8 {
    return { objc_getClass(name) };
}

fn sel(name: *u8) -> *u8 {
    return { sel_registerName(name) };
}

fn allocate_class_pair(superclass: *u8, name: *u8, extra_bytes: usize) -> *u8 {
    return { objc_allocateClassPair(superclass, name, extra_bytes) };
}

fn register_class_pair(cls: *u8) {
    { objc_registerClassPair(cls); };
}

fn class_name(obj: *u8) -> *u8 {
    return { object_getClassName(obj) };
}

// Add `application:didFinishLaunchingWithOptions:` (`(self, _cmd, app,
// options) -> BOOL`) to a synthesized delegate class. `types` is "c@:@@".
fn add_did_finish_method(cls: *u8, selector: *u8, imp: fn(*u8, *u8, *u8, *u8) -> i8, types: *u8) -> i8 {
    return { class_addMethod_did_finish(cls, selector, imp, types) };
}

// Add a `(self, _cmd, sender) -> void` method (target-action). `types` is "v@:@".
fn add_action_method(cls: *u8, selector: *u8, imp: fn(*u8, *u8, *u8), types: *u8) -> i8 {
    return { class_addMethod_action(cls, selector, imp, types) };
}

fn add_method_draw_rect(cls: *u8, selector: *u8, imp: fn(*u8, *u8, Rect), types: *u8) -> i8 {
    return { class_addMethod_draw_rect(cls, selector, imp, types) };
}

