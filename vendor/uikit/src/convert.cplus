// C+ str → NSString. Mirrors `vendor/appkit/src/convert.cplus`'s
// `stringWithBytes:length:encoding:` path: NSString copies the buffer
// internally, so the caller's `str` (a borrow) can drop freely after.

import "./runtime" as rt;

// NSUTF8StringEncoding.
fn ns_utf8() -> u64 {
    return 4 as u64;
}

fn cplus_str_to_nsstring(s: str) -> *u8 {
    let cls: *u8 = rt::get_class(#str_ptr("NSString\0"));
    let selector: *u8 = rt::sel(#str_ptr("stringWithBytes:length:encoding:\0"));
    return rt::msg_id_ptr_len_enc(cls, selector, #str_ptr(s), #str_len(s), ns_utf8());
}
