import "./runtime" as rt;
import "./convert" as convert;
import "./view" as view;

fn control_event_touch_up_inside() -> u64 { return rt::control_event_touch_up_inside(); }
fn control_event_value_changed() -> u64 { return rt::control_event_value_changed(); }

struct Button {
    _obj: *u8,
}

impl Button {
    fn raw(this) -> *u8 { return this._obj; }

    fn new(frame: rt::Rect) -> Button {
        return Button { _obj: rt::alloc_init_with_frame(#str_ptr("UIButton\0"), frame) };
    }

    fn system(frame: rt::Rect) -> Button {
        let cls: *u8 = rt::get_class(#str_ptr("UIButton\0"));
        let raw: *u8 = rt::msg_id_u64(cls, rt::sel(#str_ptr("buttonWithType:\0")), 1 as u64);
        rt::msg_void_rect(raw, rt::sel(#str_ptr("setFrame:\0")), frame);
        return Button { _obj: rt::retain(raw) };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn into_raw(ref this) -> *u8 {
        let p: *u8 = this._obj;
        this._obj = { 0 as *u8 };
        return p;
    }

    fn from_raw(obj: *u8) -> Button {
        return Button { _obj: obj };
    }

    fn set_title(this, title: str) {
        rt::msg_void_id_i64(
            this._obj,
            rt::sel(#str_ptr("setTitle:forState:\0")),
            convert::cplus_str_to_nsstring(title),
            0 as i64,
        );
    }

    fn set_title_color(this, color: view::Color) {
        rt::msg_void_id_i64(
            this._obj,
            rt::sel(#str_ptr("setTitleColor:forState:\0")),
            color.raw(),
            0 as i64,
        );
    }

    fn set_enabled(this, flag: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setEnabled:\0")), flag as i8);
    }

    fn is_enabled(this) -> bool {
        return rt::msg_i8(this._obj, rt::sel(#str_ptr("isEnabled\0"))) != (0 as i8);
    }

    fn set_selected(this, flag: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setSelected:\0")), flag as i8);
    }

    fn is_selected(this) -> bool {
        return rt::msg_i8(this._obj, rt::sel(#str_ptr("isSelected\0"))) != (0 as i8);
    }

    fn set_on_click(this, cb: fn(*u8)) {
        rt::attach_control_callback(this._obj, cb, rt::control_event_touch_up_inside());
    }

    fn as_view_obj(this) -> *u8 {
        return this._obj;
    }
}

