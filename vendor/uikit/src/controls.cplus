    }

    fn value(this) -> f32 {
        return rt::msg_f32(this._obj, rt::sel(#str_ptr("value\0")));
    }

    fn set_minimum_value(this, value: f32) {
        rt::msg_void_f32(this._obj, rt::sel(#str_ptr("setMinimumValue:\0")), value);
    }

    fn set_maximum_value(this, value: f32) {
        rt::msg_void_f32(this._obj, rt::sel(#str_ptr("setMaximumValue:\0")), value);
    }

    fn set_on_change(this, cb: fn(*u8)) {
        rt::attach_control_callback(this._obj, cb, rt::control_event_value_changed());
    }

    fn as_view_obj(this) -> *u8 {
        return this._obj;
    }
}

