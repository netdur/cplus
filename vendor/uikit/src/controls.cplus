pub struct SegmentedControl {
    pub obj: *u8,
}

impl SegmentedControl {
    pub fn new(frame: rt::Rect) -> SegmentedControl {
        return SegmentedControl { obj: rt::alloc_init_with_frame(#str_ptr("UISegmentedControl\0"), frame) };
    }

    fn drop(mut self) {
        rt::release(self.obj);
    }

    pub fn insert_segment(self, title: str, index: i64, animated: i8) {
        rt::msg_void_id_i64_i8(
            self.obj,
            rt::sel(#str_ptr("insertSegmentWithTitle:atIndex:animated:\0")),
            convert::cplus_str_to_nsstring(title),
            index,
            animated,
        );
    }

    pub fn set_title_for_segment(self, title: str, index: i64) {
        rt::msg_void_id_i64(
            self.obj,
            rt::sel(#str_ptr("setTitle:forSegmentAtIndex:\0")),
            convert::cplus_str_to_nsstring(title),
            index,
        );
    }

    pub fn set_selected_segment_index(self, index: i64) {
        rt::msg_void_i64(self.obj, rt::sel(#str_ptr("setSelectedSegmentIndex:\0")), index);
    }

    pub fn selected_segment_index(self) -> i64 {
        return rt::msg_i64(self.obj, rt::sel(#str_ptr("selectedSegmentIndex\0")));
    }

    pub fn set_on_change(self, cb: fn(*u8)) {
        rt::attach_control_callback(self.obj, cb, rt::control_event_value_changed());
    }

    pub fn as_view_obj(self) -> *u8 {
        return self.obj;
    }
}

