import "./runtime" as rt;
import "./convert" as convert;
import "./view" as view;

pub fn control_event_touch_up_inside() -> u64 { return rt::control_event_touch_up_inside(); }
pub fn control_event_value_changed() -> u64 { return rt::control_event_value_changed(); }

pub struct Button {
    pub obj: *u8,
}

impl Button {
    pub fn new(frame: rt::Rect) -> Button {
        return Button { obj: rt::alloc_init_with_frame(#str_ptr("UIButton\0"), frame) };
    }

    pub fn system(frame: rt::Rect) -> Button {
        let cls: *u8 = rt::get_class(#str_ptr("UIButton\0"));
        let raw: *u8 = rt::msg_id_u64(cls, rt::sel(#str_ptr("buttonWithType:\0")), 1 as u64);
        rt::msg_void_rect(raw, rt::sel(#str_ptr("setFrame:\0")), frame);
        return Button { obj: rt::retain(raw) };
    }

    fn drop(ref this) {
        rt::release(this.obj);
    }

    pub fn into_raw(ref this) -> *u8 {
        let p: *u8 = this.obj;
        this.obj = unsafe { 0 as *u8 };
        return p;
    }

    pub fn from_raw(obj: *u8) -> Button {
        return Button { obj: obj };
    }

    pub fn set_title(this, title: str) {
        rt::msg_void_id_i64(
            this.obj,
            rt::sel(#str_ptr("setTitle:forState:\0")),
            convert::cplus_str_to_nsstring(title),
            0 as i64,
        );
    }

    pub fn set_title_ns(this, title_ns: *u8) {
        rt::msg_void_id_i64(
            this.obj,
            rt::sel(#str_ptr("setTitle:forState:\0")),
            title_ns,
            0 as i64,
        );
    }

    pub fn set_title_color(this, color: view::Color) {
        rt::msg_void_id_i64(
            this.obj,
            rt::sel(#str_ptr("setTitleColor:forState:\0")),
            color.obj,
            0 as i64,
        );
    }

    pub fn set_enabled(this, flag: i8) {
        rt::msg_void_i8(this.obj, rt::sel(#str_ptr("setEnabled:\0")), flag);
    }

    pub fn is_enabled(this) -> i8 {
        return rt::msg_i8(this.obj, rt::sel(#str_ptr("isEnabled\0")));
    }

    pub fn set_selected(this, flag: i8) {
        rt::msg_void_i8(this.obj, rt::sel(#str_ptr("setSelected:\0")), flag);
    }

    pub fn is_selected(this) -> i8 {
        return rt::msg_i8(this.obj, rt::sel(#str_ptr("isSelected\0")));
    }

    pub fn set_on_click(this, cb: fn(*u8)) {
        rt::attach_control_callback(this.obj, cb, rt::control_event_touch_up_inside());
    }

    pub fn as_view_obj(this) -> *u8 {
        return this.obj;
    }
}

