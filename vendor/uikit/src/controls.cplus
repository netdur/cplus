pub struct SegmentedControl {
    pub obj: *u8,
}

impl SegmentedControl {
    pub fn new(frame: rt::Rect) -> SegmentedControl {
        return SegmentedControl { obj: rt::alloc_init_with_frame(#str_ptr("UISegmentedControl\0"), frame) };
    }

    fn drop(ref this) {
        rt::release(this.obj);
    }

    pub fn insert_segment(this, title: str, index: i64, animated: i8) {
        rt::msg_void_id_i64_i8(
            this.obj,
            rt::sel(#str_ptr("insertSegmentWithTitle:atIndex:animated:\0")),
            convert::cplus_str_to_nsstring(title),
            index,
            animated,
        );
    }

    pub fn set_title_for_segment(this, title: str, index: i64) {
        rt::msg_void_id_i64(
            this.obj,
            rt::sel(#str_ptr("setTitle:forSegmentAtIndex:\0")),
            convert::cplus_str_to_nsstring(title),
            index,
        );
    }

    pub fn set_selected_segment_index(this, index: i64) {
        rt::msg_void_i64(this.obj, rt::sel(#str_ptr("setSelectedSegmentIndex:\0")), index);
    }

    pub fn selected_segment_index(this) -> i64 {
        return rt::msg_i64(this.obj, rt::sel(#str_ptr("selectedSegmentIndex\0")));
    }

    pub fn set_on_change(this, cb: fn(*u8)) {
        rt::attach_control_callback(this.obj, cb, rt::control_event_value_changed());
    }

    pub fn as_view_obj(this) -> *u8 {
        return this.obj;
    }
}

