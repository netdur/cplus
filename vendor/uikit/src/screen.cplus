// UIScreen.

import "./runtime" as rt;

struct Screen {
    opaque obj: *u8,
}

impl Screen {
    fn main() -> Screen {
        let cls: *u8 = rt::get_class(#str_ptr("UIScreen\0"));
        let screen: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("mainScreen\0")));
        return Screen { obj: screen };
    }

    fn bounds(this) -> rt::Rect {
        return rt::msg_rect(this.obj, rt::sel(#str_ptr("bounds\0")));
    }

    fn scale(this) -> f64 {
        return rt::msg_f64(this.obj, rt::sel(#str_ptr("scale\0")));
    }
}
