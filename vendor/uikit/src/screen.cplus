// UIScreen.

import "./runtime" as rt;

pub struct Screen {
    pub opaque obj: *u8,
}

impl Screen {
    pub fn main() -> Screen {
        let cls: *u8 = rt::get_class(#str_ptr("UIScreen\0"));
        let screen: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("mainScreen\0")));
        return Screen { obj: screen };
    }

    pub fn bounds(self) -> rt::Rect {
        return rt::msg_rect(self.obj, rt::sel(#str_ptr("bounds\0")));
    }

    pub fn scale(self) -> f64 {
        return rt::msg_f64(self.obj, rt::sel(#str_ptr("scale\0")));
    }
}
