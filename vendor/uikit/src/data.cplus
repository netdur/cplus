import "./runtime" as rt;

struct TableView {
    obj: *u8,
}

impl TableView {
    fn new(frame: rt::Rect) -> TableView {
        return TableView { obj: rt::alloc_init_with_frame(#str_ptr("UITableView\0"), frame) };
    }

    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn set_data_source(this, data_source: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setDataSource:\0")), data_source);
    }

    fn set_delegate(this, delegate: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    }

    fn reload_data(this) {
        rt::msg_void(this.obj, rt::sel(#str_ptr("reloadData\0")));
    }

    fn dequeue_cell(this, identifier: *u8) -> *u8 {
        return rt::msg_id_id(this.obj, rt::sel(#str_ptr("dequeueReusableCellWithIdentifier:\0")), identifier);
    }

    fn register_cell_class(this, cls: *u8, identifier: *u8) {
        rt::msg_void_id_id(
            this.obj,
            rt::sel(#str_ptr("registerClass:forCellReuseIdentifier:\0")),
            cls,
            identifier,
        );
    }

    fn set_row_height(this, height: f64) {
        rt::msg_void_f64(this.obj, rt::sel(#str_ptr("setRowHeight:\0")), height);
    }

    fn as_view_obj(this) -> *u8 {
        return this.obj;
    }
}

struct CollectionView {
    obj: *u8,
}

impl CollectionView {
    fn new(frame: rt::Rect, layout: *u8) -> CollectionView {
        let cls: *u8 = rt::get_class(#str_ptr("UICollectionView\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let cv: *u8 = rt::msg_id_rect_id(
            alloced,
            rt::sel(#str_ptr("initWithFrame:collectionViewLayout:\0")),
            frame,
            layout,
        );
        return CollectionView { obj: cv };
    }

    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn set_data_source(this, data_source: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setDataSource:\0")), data_source);
    }

    fn set_delegate(this, delegate: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    }

    fn reload_data(this) {
        rt::msg_void(this.obj, rt::sel(#str_ptr("reloadData\0")));
    }

    fn register_cell_class(this, cls: *u8, identifier: *u8) {
        rt::msg_void_id_id(
            this.obj,
            rt::sel(#str_ptr("registerClass:forCellWithReuseIdentifier:\0")),
            cls,
            identifier,
        );
    }

    fn dequeue_cell(this, identifier: *u8, index_path: *u8) -> *u8 {
        return rt::msg_id_2id(
            this.obj,
            rt::sel(#str_ptr("dequeueReusableCellWithReuseIdentifier:forIndexPath:\0")),
            identifier,
            index_path,
        );
    }

    fn as_view_obj(this) -> *u8 {
        return this.obj;
    }
}

struct CollectionViewFlowLayout {
    obj: *u8,
}

impl CollectionViewFlowLayout {
    fn new() -> CollectionViewFlowLayout {
        return CollectionViewFlowLayout { obj: rt::alloc_init(#str_ptr("UICollectionViewFlowLayout\0")) };
    }

    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn set_minimum_line_spacing(this, spacing: f64) {
        rt::msg_void_f64(this.obj, rt::sel(#str_ptr("setMinimumLineSpacing:\0")), spacing);
    }

    fn set_minimum_interitem_spacing(this, spacing: f64) {
        rt::msg_void_f64(this.obj, rt::sel(#str_ptr("setMinimumInteritemSpacing:\0")), spacing);
    }

    fn set_item_size(this, size: rt::Size) {
        rt::msg_void_size(this.obj, rt::sel(#str_ptr("setItemSize:\0")), size);
    }
}

struct CollectionViewCell {
    obj: *u8,
}

impl CollectionViewCell {
    fn new(frame: rt::Rect) -> CollectionViewCell {
        return CollectionViewCell { obj: rt::alloc_init_with_frame(#str_ptr("UICollectionViewCell\0"), frame) };
    }

    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn content_view(this) -> *u8 {
        return rt::msg_id(this.obj, rt::sel(#str_ptr("contentView\0")));
    }
}

struct PickerView {
    obj: *u8,
}

impl PickerView {
    fn new(frame: rt::Rect) -> PickerView {
        return PickerView { obj: rt::alloc_init_with_frame(#str_ptr("UIPickerView\0"), frame) };
    }

    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn set_data_source(this, data_source: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setDataSource:\0")), data_source);
    }

    fn set_delegate(this, delegate: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setDelegate:\0")), delegate);
    }

    fn reload_all_components(this) {
        rt::msg_void(this.obj, rt::sel(#str_ptr("reloadAllComponents\0")));
    }

    fn selected_row(this, component: i64) -> i64 {
        return rt::msg_i64_i64(this.obj, rt::sel(#str_ptr("selectedRowInComponent:\0")), component);
    }

    fn as_view_obj(this) -> *u8 {
        return this.obj;
    }
}
