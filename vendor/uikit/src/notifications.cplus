import "./runtime" as rt;

fn handle_notification(self_obj: *u8, _cmd: *u8, notification: *u8) {
    let cb: fn(*u8) = rt::get_associated_callback(self_obj, #str_ptr("notify_cb_key\0"));
    cb(notification);
}

fn observer_class() -> *u8 {
    let existing: *u8 = rt::get_class(#str_ptr("CUIKitNotifyObserver\0"));
    if existing != { 0 as *u8 } {
        return existing;
    }
    let nsobject: *u8 = rt::get_class(#str_ptr("NSObject\0"));
    let cls: *u8 = rt::allocate_class_pair(nsobject, #str_ptr("CUIKitNotifyObserver\0"), 0 as usize);
    let _added: i8 = rt::add_action_method(
        cls,
        rt::sel(#str_ptr("handleNotification:\0")),
        handle_notification,
        #str_ptr("v@:@\0"),
    );
    rt::register_class_pair(cls);
    return cls;
}

fn default_center() -> *u8 {
    return rt::msg_id(
        rt::get_class(#str_ptr("NSNotificationCenter\0")),
        rt::sel(#str_ptr("defaultCenter\0")),
    );
}

struct Observer {
    _obj: *u8,
}

impl Observer {
    fn raw(this) -> *u8 { return this._obj; }

    fn drop(ref this) {
        rt::msg_void_id(default_center(), rt::sel(#str_ptr("removeObserver:\0")), this._obj);
        rt::release(this._obj);
    }
}

struct NotificationCenter {
    opaque _obj: *u8,
}

impl NotificationCenter {
    fn raw(this) -> *u8 { return this._obj; }

    fn default() -> NotificationCenter {
        return NotificationCenter { _obj: default_center() };
    }

    fn post(this, name: *u8) {
        rt::msg_void_id_id(
            this._obj,
            rt::sel(#str_ptr("postNotificationName:object:\0")),
            rt::ns_string(name),
            { 0 as *u8 },
        );
    }

    fn post_ns(this, name_ns: *u8) {
        rt::msg_void_id_id(
            this._obj,
            rt::sel(#str_ptr("postNotificationName:object:\0")),
            name_ns,
            { 0 as *u8 },
        );
    }

    fn add_observer(this, name: *u8, cb: fn(*u8)) -> Observer {
        let cls: *u8 = observer_class();
        let obs: *u8 = rt::alloc_init(#str_ptr("CUIKitNotifyObserver\0"));
        rt::set_associated_callback(obs, #str_ptr("notify_cb_key\0"), cb, 0 as usize);
        rt::msg_void_id_id_id_id(
            this._obj,
            rt::sel(#str_ptr("addObserver:selector:name:object:\0")),
            obs,
            rt::sel(#str_ptr("handleNotification:\0")),
            rt::ns_string(name),
            { 0 as *u8 },
        );
        return Observer { _obj: obs };
    }
}
