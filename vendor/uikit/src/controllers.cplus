// UIViewController.

import "./runtime" as rt;
import "./view" as view;
import "./convert" as convert;

struct ViewController {
    opaque _obj: *u8,
}

impl ViewController {
    fn raw(this) -> *u8 { return this._obj; }

    fn new() -> ViewController {
        let cls: *u8 = rt::get_class(#str_ptr("UIViewController\0"));
        let vc: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("new\0")));
        return ViewController { _obj: vc };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn into_raw(ref this) -> *u8 {
        let p: *u8 = this._obj;
        this._obj = { 0 as *u8 };
        return p;
    }

    fn from_raw(obj: *u8) -> ViewController {
        return ViewController { _obj: obj };
    }

    fn view(this) -> view::View {
        let v: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("view\0")));
        return view::View::from_raw(v);
    }

    fn set_view(this, v: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setView:\0")), v);
    }

    fn set_title(this, title: str) {
        let ns: *u8 = convert::cplus_str_to_nsstring(title);
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setTitle:\0")), ns);
    }

    fn add_child(this, child: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("addChildViewController:\0")), child);
    }

    fn did_move_to_parent(this, parent: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("didMoveToParentViewController:\0")), parent);
    }

    fn present(this, child: *u8, animated: i8) {
        rt::msg_void_id_i8_id(
            this._obj,
            rt::sel(#str_ptr("presentViewController:animated:completion:\0")),
            child,
            animated,
            { 0 as *u8 },
        );
    }

    fn dismiss(this, animated: i8) {
        rt::msg_void_i8_id(
            this._obj,
            rt::sel(#str_ptr("dismissViewControllerAnimated:completion:\0")),
            animated,
            { 0 as *u8 },
        );
    }
}

struct NavigationController {
    _obj: *u8,
}

impl NavigationController {
    fn raw(this) -> *u8 { return this._obj; }

    fn new(root: *u8) -> NavigationController {
        let cls: *u8 = rt::get_class(#str_ptr("UINavigationController\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let nav: *u8 = rt::msg_id_id(alloced, rt::sel(#str_ptr("initWithRootViewController:\0")), root);
        return NavigationController { _obj: nav };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn push(this, vc: *u8, animated: i8) {
        rt::msg_void_id_i8(this._obj, rt::sel(#str_ptr("pushViewController:animated:\0")), vc, animated);
    }

    fn pop(this, animated: i8) -> *u8 {
        return rt::msg_id_i8(this._obj, rt::sel(#str_ptr("popViewControllerAnimated:\0")), animated);
    }

    fn navigation_bar(this) -> *u8 {
        return rt::msg_id(this._obj, rt::sel(#str_ptr("navigationBar\0")));
    }
}

struct TabBarController {
    _obj: *u8,
}

impl TabBarController {
    fn raw(this) -> *u8 { return this._obj; }

    fn new() -> TabBarController {
        return TabBarController { _obj: rt::new_object(#str_ptr("UITabBarController\0")) };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn set_view_controllers(this, controllers: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setViewControllers:\0")), controllers);
    }

    fn tab_bar(this) -> *u8 {
        return rt::msg_id(this._obj, rt::sel(#str_ptr("tabBar\0")));
    }
}

struct SplitViewController {
    _obj: *u8,
}

impl SplitViewController {
    fn raw(this) -> *u8 { return this._obj; }

    fn new() -> SplitViewController {
        return SplitViewController { _obj: rt::new_object(#str_ptr("UISplitViewController\0")) };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn set_view_controllers(this, controllers: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setViewControllers:\0")), controllers);
    }
}

struct PageViewController {
    _obj: *u8,
}

impl PageViewController {
    fn raw(this) -> *u8 { return this._obj; }

    fn new() -> PageViewController {
        return PageViewController { _obj: rt::new_object(#str_ptr("UIPageViewController\0")) };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }
}
