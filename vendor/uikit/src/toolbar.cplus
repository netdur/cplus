import "./runtime" as rt;
import "./convert" as convert;

struct Toolbar {
    _obj: *u8,
}

impl Toolbar {
    fn raw(this) -> *u8 { return this._obj; }

    fn new(frame: rt::Rect) -> Toolbar {
        return Toolbar { _obj: rt::alloc_init_with_frame(#str_ptr("UIToolbar\0"), frame) };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn set_items(this, items: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setItems:\0")), items);
    }

    fn set_bar_style(this, style: i64) {
        rt::msg_void_i64(this._obj, rt::sel(#str_ptr("setBarStyle:\0")), style);
    }

    fn as_view_obj(this) -> *u8 {
        return this._obj;
    }
}

struct NavigationBar {
    _obj: *u8,
}

impl NavigationBar {
    fn raw(this) -> *u8 { return this._obj; }

    fn new(frame: rt::Rect) -> NavigationBar {
        return NavigationBar { _obj: rt::alloc_init_with_frame(#str_ptr("UINavigationBar\0"), frame) };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn set_items(this, items: *u8) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setItems:\0")), items);
    }

    fn as_view_obj(this) -> *u8 {
        return this._obj;
    }
}

struct BarButtonItem {
    _obj: *u8,
}

impl BarButtonItem {
    fn raw(this) -> *u8 { return this._obj; }

    fn new(title: str, style: i64, target: *u8, action: *u8) -> BarButtonItem {
        let cls: *u8 = rt::get_class(#str_ptr("UIBarButtonItem\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let item: *u8 = rt::msg_id_id_i64_id_id(
            alloced,
            rt::sel(#str_ptr("initWithTitle:style:target:action:\0")),
            convert::cplus_str_to_nsstring(title),
            style,
            target,
            action,
        );
        return BarButtonItem { _obj: item };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    fn set_enabled(this, flag: bool) {
        rt::msg_void_i8(this._obj, rt::sel(#str_ptr("setEnabled:\0")), flag as i8);
    }
}

