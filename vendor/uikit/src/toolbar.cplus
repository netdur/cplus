struct TabBarItem {
    _obj: *u8,
}

impl TabBarItem {
    fn raw(this) -> *u8 { return this._obj; }

    fn new(title: str, image: *u8, tag: i64) -> TabBarItem {
        let cls: *u8 = rt::get_class(#str_ptr("UITabBarItem\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let item: *u8 = rt::msg_id_id_id_i64(
            alloced,
            rt::sel(#str_ptr("initWithTitle:image:tag:\0")),
            convert::cplus_str_to_nsstring(title),
            image,
            tag,
        );
        return TabBarItem { _obj: item };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }
}
