import "./runtime" as rt;
import "./view" as view;
import "./controllers" as controllers;

type StackView = view::StackView;
type ScrollView = view::ScrollView;
type NavigationController = controllers::NavigationController;
type TabBarController = controllers::TabBarController;
type SplitViewController = controllers::SplitViewController;
type PageViewController = controllers::PageViewController;

struct VisualEffectView {
    obj: *u8,
}

impl VisualEffectView {
    fn raw(this) -> *u8 { return this.obj; }

    fn new(effect: *u8) -> VisualEffectView {
        let cls: *u8 = rt::get_class(#str_ptr("UIVisualEffectView\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let obj: *u8 = rt::msg_id_id(alloced, rt::sel(#str_ptr("initWithEffect:\0")), effect);
        return VisualEffectView { obj: obj };
    }

    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn content_view(this) -> view::View {
        return view::View { obj: rt::msg_id(this.obj, rt::sel(#str_ptr("contentView\0"))) };
    }

    fn set_effect(this, effect: *u8) {
        rt::msg_void_id(this.obj, rt::sel(#str_ptr("setEffect:\0")), effect);
    }

    fn as_view_obj(this) -> *u8 {
        return this.obj;
    }
}

struct BlurEffect {
    opaque obj: *u8,
}

impl BlurEffect {
    fn raw(this) -> *u8 { return this.obj; }

    fn style(style: i64) -> *u8 {
        let cls: *u8 = rt::get_class(#str_ptr("UIBlurEffect\0"));
        return rt::msg_id_u64(cls, rt::sel(#str_ptr("effectWithStyle:\0")), style as u64);
    }
}

struct TableViewCell {
    obj: *u8,
}

impl TableViewCell {
    fn raw(this) -> *u8 { return this.obj; }

    fn new(style: i64, reuse_identifier: *u8) -> TableViewCell {
        let cls: *u8 = rt::get_class(#str_ptr("UITableViewCell\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        let cell: *u8 = rt::msg_id_i64_id(
            alloced,
            rt::sel(#str_ptr("initWithStyle:reuseIdentifier:\0")),
            style,
            reuse_identifier,
        );
        return TableViewCell { obj: cell };
    }

    fn drop(ref this) {
        rt::release(this.obj);
    }

    fn content_view(this) -> view::View {
        return view::View { obj: rt::msg_id(this.obj, rt::sel(#str_ptr("contentView\0"))) };
    }

    fn text_label(this) -> *u8 {
        return rt::msg_id(this.obj, rt::sel(#str_ptr("textLabel\0")));
    }
}
