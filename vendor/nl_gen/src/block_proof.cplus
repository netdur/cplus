// Proof: invoke an Objective-C method that takes a `usingBlock:` block, with a
// C+ function as the block body — no C/ObjC shim, no build changes.
//
// An ObjC block is a struct starting with { isa, flags, reserved, invoke,
// descriptor }. For a synchronous NS_NOESCAPE block (like
// NLTokenizer.enumerateTokensInRange:usingBlock:) we build one on the stack,
// point `invoke` at a C+ fn, and pass it. `_NSConcreteStackBlock` (the isa for a
// stack block) is resolved with dlsym so no extern-global is needed. This reuses
// the same "C+ fn-pointer as an ObjC callback" capability appkit relies on.

import "objc/runtime" as rt;
import "./tokenizer" as tokenizer;

#[link_name = "dlsym"]
extern fn dlsym(handle: *u8, symbol: *u8) -> *u8;

#[repr(C)]
struct BlockDescriptor {
    reserved: u64,
    size: u64,
}

#[repr(C)]
struct BlockLiteral {
    opaque isa: *u8,
    flags: i32,
    reserved: i32,
    invoke: fn(*u8, rt::Range, u64, *u8),
    opaque descriptor: *u8,
}

// Block invocation counter (the enumerate is synchronous + non-reentrant, so a
// global is sufficient for the proof).
static BLOCK_HITS: i64 = 0;

// The block body: ObjC calls this once per token, as
// invoke(block, tokenRange, flags, stop).
fn token_block_invoke(block: *u8, range: rt::Range, flags: u64, stop: *u8) {
    { BLOCK_HITS = { BLOCK_HITS } +% (1 as i64); };
    return;
}

fn stack_block_isa() -> *u8 {
    // RTLD_DEFAULT = (void *)-2 on macOS.
    let rtld_default: *u8 = { ((0 as usize) -% (2 as usize)) as *u8 };
    return { dlsym(rtld_default, #str_ptr("_NSConcreteStackBlock\0")) };
}

fn enumerate_tokens(tok: *u8, range: rt::Range) {
    var desc: BlockDescriptor = BlockDescriptor { reserved: 0 as u64, size: 32 as u64 };
    var block: BlockLiteral = BlockLiteral {
        isa: stack_block_isa(),
        flags: 0 as i32,
        reserved: 0 as i32,
        invoke: token_block_invoke,
        descriptor: { #addr_of(desc) as *u8 },
    };
    let bp: *u8 = { #addr_of(block) as *u8 };
    rt::msg_void_range_id(tok, rt::sel(#str_ptr("enumerateTokensInRange:usingBlock:\0")), range, bp);
    return;
}

#[test]
fn generated_tokenizer_enumerate_block() {
    let tok: tokenizer::Tokenizer = tokenizer::Tokenizer::new(tokenizer::TokenUnit::Word);
    tok.set_text("the quick brown fox");          // 4 word tokens
    { BLOCK_HITS = 0 as i64; };
    let full: rt::Range = rt::Range { location: 0 as u64, length: 19 as u64 };
    enumerate_tokens(tok.raw(), full);
    assert { BLOCK_HITS } == (4 as i64);
    return;
}
