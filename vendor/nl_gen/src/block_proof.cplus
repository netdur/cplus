// Tests the cpc-bindgen-GENERATED block binding: NLTokenizer.enumerate_tokens
// (from enumerateTokensInRange:usingBlock:) drives a C+ callback once per token.
// The generator emits the Block_literal struct + invoke trampoline + wrapper;
// here we just supply the callback.

import "objc/runtime" as rt;
import "./tokenizer" as tokenizer;

// Block body: count tokens through a `*i64` context.
fn count_tokens(ctx: *u8, range: rt::Range, flags: i64, stop: *u8) {
    let counter: *i64 = { ctx as *i64 };
    { *counter = (*counter) +% (1 as i64); };
    return;
}

#[test]
fn generated_tokenizer_enumerate_block() {
    let tok: tokenizer::Tokenizer = tokenizer::Tokenizer::new(tokenizer::TokenUnit::Word);
    tok.set_text("the quick brown fox");                 // 4 word tokens
    var count: i64 = 0;
    let cp: *u8 = { #addr_of(count) as *u8 };
    let full: rt::Range = rt::Range { location: 0 as u64, length: 19 as u64 };
    tok.enumerate_tokens(full, count_tokens, cp);
    assert count == (4 as i64);
    return;
}
