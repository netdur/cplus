// Proof harness: tests the cpc-bindgen-GENERATED recognizer.cplus and
// tokenizer.cplus (generated WITH the overrides.json naming taste, so the API
// matches the hand-written golden) against the live framework.

import "./recognizer" as recognizer;
import "./tokenizer" as tokenizer;
import "./embedding" as embedding;
import "objc/runtime" as rt;
import "stdlib/text" as text;
import "stdlib/option" as option;
import "stdlib/vec" as vec;

type LanguageRecognizer = recognizer::LanguageRecognizer;
type Tokenizer = tokenizer::Tokenizer;
type TokenUnit = tokenizer::TokenUnit;

#[test]
fn generated_recognizer_detects_french() {
    match recognizer::LanguageRecognizer::detect("Bonjour le monde, comment allez-vous aujourd'hui?") {
        option::Option[text::Text]::Some(lang) => { assert lang.equals("fr"); }
        option::Option[text::Text]::None => { assert false; }
    }
    return;
}

#[test]
fn generated_recognizer_instance_detects_english() {
    let rec: recognizer::LanguageRecognizer = recognizer::LanguageRecognizer::new();
    rec.process("The quick brown fox jumps over the lazy dog every single morning.");
    match rec.dominant_language() {
        option::Option[text::Text]::Some(lang) => { assert lang.equals("en"); }
        option::Option[text::Text]::None => { assert false; }
    }
    return;
}

#[test]
fn generated_tokenizer_segments_words() {
    let tok: tokenizer::Tokenizer = tokenizer::Tokenizer::new(tokenizer::TokenUnit::Word);
    tok.set_text("the quick brown fox");                          // 19 ASCII chars
    let full: rt::Range = rt::Range { location: 0 as u64, length: 19 as u64 };
    let toks: vec::Vec[rt::Range] = tok.tokens(full);
    assert toks.count() == (4 as usize);
    return;
}

#[test]
fn generated_tokenizer_first_token_range() {
    let tok: tokenizer::Tokenizer = tokenizer::Tokenizer::new(tokenizer::TokenUnit::Word);
    tok.set_text("the quick brown fox");
    let r: rt::Range = tok.token_range(at: 0 as u64);
    assert r.location == (0 as u64);
    assert r.length == (3 as u64);                                // "the"
    return;
}

// ABI smoke for a generated MULTI-ARG class method
// (wordEmbeddingForLanguage:revision: -> word_embedding(for_language:, revision:)),
// proving 2-arg selector codegen + the msg_id_id_u64 dispatch. The call must run
// without crashing; it returns nil when the on-device model isn't installed, so
// we don't assert on the handle (a wrong ABI would corrupt the stack / crash).
#[test]
fn generated_embedding_multiarg_call() {
    let _e: *u8 = embedding::Embedding::word_embedding("en", revision: 0 as u64);
    return;
}
