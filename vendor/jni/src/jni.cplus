// jni-min: Core JNI interop types for C+
// Maps the JVM's jni.h to C+ types using #[repr(C)] and TypeKind::FnPtr.

type jint = i32;
type jlong = i64;
type jbyte = i8;
type jboolean = u8;
type jchar = u16;
type jshort = i16;
type jfloat = f32;
type jdouble = f64;
type jsize = i32;

// Opaque pointers to Java objects/classes
type jobject = *u8;
type jclass = *u8;
type jstring = *u8;
type jarray = *u8;
type jobjectArray = *u8;
type jbooleanArray = *u8;
type jbyteArray = *u8;
type jcharArray = *u8;
type jshortArray = *u8;
type jintArray = *u8;
type jlongArray = *u8;
type jfloatArray = *u8;
type jdoubleArray = *u8;
type jthrowable = *u8;
type jweak = *u8;

type jfieldID = *u8;
type jmethodID = *u8;

// In C, `JNIEnv` is `const JNINativeInterface*` and native methods receive
// `JNIEnv *env` — a pointer to the thread-local table pointer. JNI functions
// must be called with that double pointer (ART derives the thread state from
// it); passing the bare table pointer trips an ART CHECK and aborts.
type JNIEnv = *JNINativeInterface;
type JavaVM = *JNIInvokeInterface;

// JNI's `jvalue` is a C union. C+ does not expose C unions yet, so this
// binding models each argument slot as the union's ABI size: one 8-byte word.
// This is enough for object/int/boolean arguments used by the first Android
// View wrapper slice. Float/double helpers should be added with real bit casts
// when the package needs them.
#[repr(C)]
struct JValue {
    bits: jlong,
}

fn arg_object(obj: jobject) -> JValue {
    return JValue { bits: unsafe { obj as usize as jlong } };
}

fn arg_int(v: jint) -> JValue {
    return JValue { bits: v as jlong };
}

fn arg_bool(v: jboolean) -> JValue {
    return JValue { bits: v as jlong };
}

fn arg_long(v: jlong) -> JValue {
    return JValue { bits: v };
}

// The core JNI environment struct.
// Note: This struct must exactly match the memory layout of JNINativeInterface_ in jni.h.
// Since we only *read* from the JVM-provided pointer, we only need to define 
// the fields up to the methods we actually intend to call.
#[repr(C)]
struct JNINativeInterface {
    opaque reserved0: *u8,
    opaque reserved1: *u8,
    opaque reserved2: *u8,
    opaque reserved3: *u8,
    GetVersion: fn(*JNIEnv) -> jint,
    DefineClass: fn(*JNIEnv, *u8, jobject, *u8, jsize) -> jclass,
    FindClass: fn(*JNIEnv, *u8) -> jclass,
    FromReflectedMethod: fn(*JNIEnv, jobject) -> jmethodID,
    FromReflectedField: fn(*JNIEnv, jobject) -> jfieldID,
    ToReflectedMethod: fn(*JNIEnv, jclass, jmethodID, jboolean) -> jobject,
    GetSuperclass: fn(*JNIEnv, jclass) -> jclass,
    IsAssignableFrom: fn(*JNIEnv, jclass, jclass) -> jboolean,
    ToReflectedField: fn(*JNIEnv, jclass, jfieldID, jboolean) -> jobject,
    Throw: fn(*JNIEnv, jthrowable) -> jint,
    ThrowNew: fn(*JNIEnv, jclass, *u8) -> jint,
    ExceptionOccurred: fn(*JNIEnv) -> jthrowable,
    ExceptionDescribe: fn(*JNIEnv),
    ExceptionClear: fn(*JNIEnv),
    FatalError: fn(*JNIEnv, *u8),
    PushLocalFrame: fn(*JNIEnv, jint) -> jint,
    PopLocalFrame: fn(*JNIEnv, jobject) -> jobject,
    NewGlobalRef: fn(*JNIEnv, jobject) -> jobject,
    DeleteGlobalRef: fn(*JNIEnv, jobject),
    DeleteLocalRef: fn(*JNIEnv, jobject),
    IsSameObject: fn(*JNIEnv, jobject, jobject) -> jboolean,
    NewLocalRef: fn(*JNIEnv, jobject) -> jobject,
    EnsureLocalCapacity: fn(*JNIEnv, jint) -> jint,
    AllocObject: fn(*JNIEnv, jclass) -> jobject,
    NewObject: fn(*JNIEnv, jclass, jmethodID) -> jobject, // varargs conceptually
    NewObjectV: fn(*JNIEnv, jclass, jmethodID, *u8) -> jobject,
    NewObjectA: fn(*JNIEnv, jclass, jmethodID, *JValue) -> jobject,
    GetObjectClass: fn(*JNIEnv, jobject) -> jclass,
    IsInstanceOf: fn(*JNIEnv, jobject, jclass) -> jboolean,
    GetMethodID: fn(*JNIEnv, jclass, *u8, *u8) -> jmethodID,
    CallObjectMethod: fn(*JNIEnv, jobject, jmethodID) -> jobject,
    CallObjectMethodV: fn(*JNIEnv, jobject, jmethodID, *u8) -> jobject,
    CallObjectMethodA: fn(*JNIEnv, jobject, jmethodID, *u8) -> jobject,
    CallBooleanMethod: fn(*JNIEnv, jobject, jmethodID) -> jboolean,
    CallBooleanMethodV: fn(*JNIEnv, jobject, jmethodID, *u8) -> jboolean,
    CallBooleanMethodA: fn(*JNIEnv, jobject, jmethodID, *u8) -> jboolean,
    CallByteMethod: fn(*JNIEnv, jobject, jmethodID) -> jbyte,
    CallByteMethodV: fn(*JNIEnv, jobject, jmethodID, *u8) -> jbyte,
    CallByteMethodA: fn(*JNIEnv, jobject, jmethodID, *u8) -> jbyte,
    opaque reserved_call_char_method: *u8,
    opaque reserved_call_char_method_v: *u8,
    opaque reserved_call_char_method_a: *u8,
    opaque reserved_call_short_method: *u8,
    opaque reserved_call_short_method_v: *u8,
    opaque reserved_call_short_method_a: *u8,
    CallIntMethod: fn(*JNIEnv, jobject, jmethodID) -> jint,
    CallIntMethodV: fn(*JNIEnv, jobject, jmethodID, *u8) -> jint,
    CallIntMethodA: fn(*JNIEnv, jobject, jmethodID, *JValue) -> jint,
    opaque reserved_call_long_method: *u8,
    opaque reserved_call_long_method_v: *u8,
    opaque reserved_call_long_method_a: *u8,
    opaque reserved_call_float_method: *u8,
    opaque reserved_call_float_method_v: *u8,
    opaque reserved_call_float_method_a: *u8,
    opaque reserved_call_double_method: *u8,
    opaque reserved_call_double_method_v: *u8,
    opaque reserved_call_double_method_a: *u8,
    CallVoidMethod: fn(*JNIEnv, jobject, jmethodID),
    CallVoidMethodV: fn(*JNIEnv, jobject, jmethodID, *u8),
    CallVoidMethodA: fn(*JNIEnv, jobject, jmethodID, *JValue),
    opaque reserved_call_nonvirtual_object_method: *u8,
    opaque reserved_call_nonvirtual_object_method_v: *u8,
    opaque reserved_call_nonvirtual_object_method_a: *u8,
    opaque reserved_call_nonvirtual_boolean_method: *u8,
    opaque reserved_call_nonvirtual_boolean_method_v: *u8,
    opaque reserved_call_nonvirtual_boolean_method_a: *u8,
    opaque reserved_call_nonvirtual_byte_method: *u8,
    opaque reserved_call_nonvirtual_byte_method_v: *u8,
    opaque reserved_call_nonvirtual_byte_method_a: *u8,
    opaque reserved_call_nonvirtual_char_method: *u8,
    opaque reserved_call_nonvirtual_char_method_v: *u8,
    opaque reserved_call_nonvirtual_char_method_a: *u8,
    opaque reserved_call_nonvirtual_short_method: *u8,
    opaque reserved_call_nonvirtual_short_method_v: *u8,
    opaque reserved_call_nonvirtual_short_method_a: *u8,
    opaque reserved_call_nonvirtual_int_method: *u8,
    opaque reserved_call_nonvirtual_int_method_v: *u8,
    opaque reserved_call_nonvirtual_int_method_a: *u8,
    opaque reserved_call_nonvirtual_long_method: *u8,
    opaque reserved_call_nonvirtual_long_method_v: *u8,
    opaque reserved_call_nonvirtual_long_method_a: *u8,
    opaque reserved_call_nonvirtual_float_method: *u8,
    opaque reserved_call_nonvirtual_float_method_v: *u8,
    opaque reserved_call_nonvirtual_float_method_a: *u8,
    opaque reserved_call_nonvirtual_double_method: *u8,
    opaque reserved_call_nonvirtual_double_method_v: *u8,
    opaque reserved_call_nonvirtual_double_method_a: *u8,
    opaque reserved_call_nonvirtual_void_method: *u8,
    opaque reserved_call_nonvirtual_void_method_v: *u8,
    opaque reserved_call_nonvirtual_void_method_a: *u8,
    opaque reserved_get_field_id: *u8,
    opaque reserved_get_object_field: *u8,
    opaque reserved_get_boolean_field: *u8,
    opaque reserved_get_byte_field: *u8,
    opaque reserved_get_char_field: *u8,
    opaque reserved_get_short_field: *u8,
    opaque reserved_get_int_field: *u8,
    opaque reserved_get_long_field: *u8,
    opaque reserved_get_float_field: *u8,
    opaque reserved_get_double_field: *u8,
    opaque reserved_set_object_field: *u8,
    opaque reserved_set_boolean_field: *u8,
    opaque reserved_set_byte_field: *u8,
    opaque reserved_set_char_field: *u8,
    opaque reserved_set_short_field: *u8,
    opaque reserved_set_int_field: *u8,
    opaque reserved_set_long_field: *u8,
    opaque reserved_set_float_field: *u8,
    opaque reserved_set_double_field: *u8,
    opaque reserved_get_static_method_id: *u8,
    opaque reserved_call_static_object_method: *u8,
    opaque reserved_call_static_object_method_v: *u8,
    opaque reserved_call_static_object_method_a: *u8,
    opaque reserved_call_static_boolean_method: *u8,
    opaque reserved_call_static_boolean_method_v: *u8,
    opaque reserved_call_static_boolean_method_a: *u8,
    opaque reserved_call_static_byte_method: *u8,
    opaque reserved_call_static_byte_method_v: *u8,
    opaque reserved_call_static_byte_method_a: *u8,
    opaque reserved_call_static_char_method: *u8,
    opaque reserved_call_static_char_method_v: *u8,
    opaque reserved_call_static_char_method_a: *u8,
    opaque reserved_call_static_short_method: *u8,
    opaque reserved_call_static_short_method_v: *u8,
    opaque reserved_call_static_short_method_a: *u8,
    opaque reserved_call_static_int_method: *u8,
    opaque reserved_call_static_int_method_v: *u8,
    opaque reserved_call_static_int_method_a: *u8,
    opaque reserved_call_static_long_method: *u8,
    opaque reserved_call_static_long_method_v: *u8,
    opaque reserved_call_static_long_method_a: *u8,
    opaque reserved_call_static_float_method: *u8,
    opaque reserved_call_static_float_method_v: *u8,
    opaque reserved_call_static_float_method_a: *u8,
    opaque reserved_call_static_double_method: *u8,
    opaque reserved_call_static_double_method_v: *u8,
    opaque reserved_call_static_double_method_a: *u8,
    opaque reserved_call_static_void_method: *u8,
    opaque reserved_call_static_void_method_v: *u8,
    opaque reserved_call_static_void_method_a: *u8,
    opaque reserved_get_static_field_id: *u8,
    opaque reserved_get_static_object_field: *u8,
    opaque reserved_get_static_boolean_field: *u8,
    opaque reserved_get_static_byte_field: *u8,
    opaque reserved_get_static_char_field: *u8,
    opaque reserved_get_static_short_field: *u8,
    opaque reserved_get_static_int_field: *u8,
    opaque reserved_get_static_long_field: *u8,
    opaque reserved_get_static_float_field: *u8,
    opaque reserved_get_static_double_field: *u8,
    opaque reserved_set_static_object_field: *u8,
    opaque reserved_set_static_boolean_field: *u8,
    opaque reserved_set_static_byte_field: *u8,
    opaque reserved_set_static_char_field: *u8,
    opaque reserved_set_static_short_field: *u8,
    opaque reserved_set_static_int_field: *u8,
    opaque reserved_set_static_long_field: *u8,
    opaque reserved_set_static_float_field: *u8,
    opaque reserved_set_static_double_field: *u8,
    opaque reserved_new_string: *u8,
    opaque reserved_get_string_length: *u8,
    opaque reserved_get_string_chars: *u8,
    opaque reserved_release_string_chars: *u8,
    NewStringUTF: fn(*JNIEnv, *u8) -> jstring,
    GetStringUTFLength: fn(*JNIEnv, jstring) -> jsize,
    GetStringUTFChars: fn(*JNIEnv, jstring, *jboolean) -> *u8,
    ReleaseStringUTFChars: fn(*JNIEnv, jstring, *u8),
    // Object arrays (slots 171-174 in jni.h).
    GetArrayLength: fn(*JNIEnv, jarray) -> jsize,
    NewObjectArray: fn(*JNIEnv, jsize, jclass, jobject) -> jobjectArray,
    GetObjectArrayElement: fn(*JNIEnv, jobjectArray, jsize) -> jobject,
    SetObjectArrayElement: fn(*JNIEnv, jobjectArray, jsize, jobject),
    // Primitive arrays (175-214): 8 New<P>Array, 8 Get<P>ArrayElements,
    // 8 Release<P>ArrayElements, 8 Get<P>ArrayRegion, 8 Set<P>ArrayRegion.
    opaque reserved_new_prim_array_0: *u8,
    opaque reserved_new_prim_array_1: *u8,
    opaque reserved_new_prim_array_2: *u8,
    opaque reserved_new_prim_array_3: *u8,
    opaque reserved_new_prim_array_4: *u8,
    opaque reserved_new_prim_array_5: *u8,
    opaque reserved_new_prim_array_6: *u8,
    opaque reserved_new_prim_array_7: *u8,
    opaque reserved_get_prim_elems_0: *u8,
    opaque reserved_get_prim_elems_1: *u8,
    opaque reserved_get_prim_elems_2: *u8,
    opaque reserved_get_prim_elems_3: *u8,
    opaque reserved_get_prim_elems_4: *u8,
    opaque reserved_get_prim_elems_5: *u8,
    opaque reserved_get_prim_elems_6: *u8,
    opaque reserved_get_prim_elems_7: *u8,
    opaque reserved_release_prim_elems_0: *u8,
    opaque reserved_release_prim_elems_1: *u8,
    opaque reserved_release_prim_elems_2: *u8,
    opaque reserved_release_prim_elems_3: *u8,
    opaque reserved_release_prim_elems_4: *u8,
    opaque reserved_release_prim_elems_5: *u8,
    opaque reserved_release_prim_elems_6: *u8,
    opaque reserved_release_prim_elems_7: *u8,
    opaque reserved_get_prim_region_0: *u8,
    opaque reserved_get_prim_region_1: *u8,
    opaque reserved_get_prim_region_2: *u8,
    opaque reserved_get_prim_region_3: *u8,
    opaque reserved_get_prim_region_4: *u8,
    opaque reserved_get_prim_region_5: *u8,
    opaque reserved_get_prim_region_6: *u8,
    opaque reserved_get_prim_region_7: *u8,
    opaque reserved_set_prim_region_0: *u8,
    opaque reserved_set_prim_region_1: *u8,
    opaque reserved_set_prim_region_2: *u8,
    opaque reserved_set_prim_region_3: *u8,
    opaque reserved_set_prim_region_4: *u8,
    opaque reserved_set_prim_region_5: *u8,
    opaque reserved_set_prim_region_6: *u8,
    opaque reserved_set_prim_region_7: *u8,
    // 215: explicit native-method binding. `methods` is a pointer to
    // `count` packed records { name, signature, fnPtr } — callers define
    // the record with a concretely-typed fn field (see
    // android_view/listener). Required for classes from
    // InMemoryDexClassLoader: ART resolves `native` methods by symbol
    // only through a classloader's own native-lib namespace, which an
    // in-memory loader does not have.
    RegisterNatives: fn(*JNIEnv, jclass, *u8, jint) -> jint,
    opaque reserved_unregister_natives: *u8,
    opaque reserved_monitor_enter: *u8,
    opaque reserved_monitor_exit: *u8,
    opaque reserved_get_java_vm: *u8,
    opaque reserved_get_string_region: *u8,
    opaque reserved_get_string_utf_region: *u8,
    opaque reserved_get_prim_critical: *u8,
    opaque reserved_release_prim_critical: *u8,
    opaque reserved_get_string_critical: *u8,
    opaque reserved_release_string_critical: *u8,
    opaque reserved_new_weak_global_ref: *u8,
    opaque reserved_delete_weak_global_ref: *u8,
    // 228: pending-exception predicate (cheaper than ExceptionOccurred —
    // no local ref).
    ExceptionCheck: fn(*JNIEnv) -> jboolean,
    // 229: wrap native memory as a java.nio.ByteBuffer. The memory must
    // outlive the buffer; `#include_bytes` blobs (static lifetime) qualify.
    NewDirectByteBuffer: fn(*JNIEnv, *u8, jlong) -> jobject,
    opaque reserved_get_direct_buffer_address: *u8,
    opaque reserved_get_direct_buffer_capacity: *u8,
    opaque reserved_get_object_ref_type: *u8,
}

#[repr(C)]
struct JNIInvokeInterface {
    opaque reserved0: *u8,
    opaque reserved1: *u8,
    opaque reserved2: *u8,
    DestroyJavaVM: fn(*JavaVM) -> jint,
    AttachCurrentThread: fn(*JavaVM, *u8, *u8) -> jint,
    DetachCurrentThread: fn(*JavaVM) -> jint,
    GetEnv: fn(*JavaVM, *u8, jint) -> jint,
    AttachCurrentThreadAsDaemon: fn(*JavaVM, *u8, *u8) -> jint,
}

// Layout sanity: the binding's correctness rests entirely on every function
// pointer sitting at its `jni.h` offset, so pin the total size. A dropped,
// added, or mistyped field shifts every later offset and changes the size.
// 64-bit: the full JNI 1.6 table is 233 slots (GetVersion at index 4
// through GetObjectRefType at 232, verified against the NDK r29 jni.h),
// 233 * 8 = 1864. JNIInvokeInterface = 3 reserved + 5 fn-ptrs = 64.
#[test]
fn jni_interface_layout_sizes() {
    assert #size_of::[JNINativeInterface]() == (1864 as usize);
    assert #size_of::[JNIInvokeInterface]() == (64 as usize);
    assert #align_of::[JNINativeInterface]() == (8 as usize);
}
