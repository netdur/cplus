import "./glue" as glue;

// AdwApplication — a GtkApplication that also initializes libadwaita (loads the
// Adwaita stylesheet, sets up the style manager). Use it instead of
// `gtk::Application` for an Adwaita app; everything else (signals, the main
// loop) is inherited from GtkApplication, so we delegate `run` to the gtk
// wrapper via the shared raw pointer.
//
//   fn on_activate(app: *u8, _d: *u8) {
//       let win = window::Window::for_application(app);
//       win.set_content(/* … */);
//       win.present();
//   }
//   fn main() -> i32 {
//       let app = application::Application::new(#str_ptr("org.example.Adw\0"));
//       app.connect_activate(on_activate);
//       let status = app.run();
//       app.unref();
//       return status;
//   }

#[link_name = "adw_application_new"]
extern fn adw_application_new(app_id: *u8, flags: u32) -> *u8;

struct Application {
    opaque _obj: *u8,
}

impl Application {
    fn raw(this) -> *u8 { return this._obj; }
    fn from_raw(obj: *u8) -> Application { return Application { _obj: obj }; }

    fn new(app_id: *u8) -> Application {
        return Application { _obj: { adw_application_new(app_id, glue::application_default_flags()) } };
    }

    // "activate" — build the first window here (same as gtk::Application).
    fn connect_activate(this, handler: fn(*u8, *u8)) {
        let _id: u64 = glue::signal_connect(this._obj, #str_ptr("activate\0"), handler, 0 as *u8);
    }

    // Run the main loop (delegated to the GtkApplication base via the raw ptr).
    fn run(this) -> i32 {
        return glue::application_run(this._obj);
    }

    fn quit(this) {
        glue::application_quit(this._obj);
    }

    fn add_action(this, action: *u8) {
        glue::application_add_action(this._obj, action);
    }

    fn set_menubar(this, menu_model: *u8) {
        glue::application_set_menubar(this._obj, menu_model);
    }

    fn unref(this) {
        glue::unref(this._obj);
    }
}
