import "gtk/glib" as g;

// AdwStyleManager — runtime control over the Adwaita color scheme (light/dark
// preference) and read-only access to whether dark is currently in effect.
// The default manager governs the whole application.
//
//   let mgr = style::StyleManager::default_manager();
//   mgr.set_color_scheme(style::color_scheme_prefer_dark());

#[link_name = "adw_style_manager_get_default"]
extern fn adw_style_manager_get_default() -> *u8;

#[link_name = "adw_style_manager_set_color_scheme"]
extern fn adw_style_manager_set_color_scheme(manager: *u8, color_scheme: i32);

#[link_name = "adw_style_manager_get_dark"]
extern fn adw_style_manager_get_dark(manager: *u8) -> i32;

// AdwColorScheme values.
fn color_scheme_default() -> i32 { return 0; }
fn color_scheme_force_light() -> i32 { return 1; }
fn color_scheme_prefer_light() -> i32 { return 2; }
fn color_scheme_prefer_dark() -> i32 { return 3; }
fn color_scheme_force_dark() -> i32 { return 4; }

struct StyleManager {
    opaque obj: *u8,
}

impl StyleManager {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> StyleManager { return StyleManager { obj: obj }; }

    // The application-wide style manager (a borrowed singleton — no unref).
    fn default_manager() -> StyleManager {
        return StyleManager { obj: { adw_style_manager_get_default() } };
    }

    // Set the preference (a `color_scheme_*` value). Note `force_*` overrides
    // the system setting; `prefer_*` follows it when possible.
    fn set_color_scheme(this, color_scheme: i32) {
        { adw_style_manager_set_color_scheme(this.obj, color_scheme); };
    }

    // 1 if dark styling is currently applied.
    fn is_dark(this) -> i32 {
        return { adw_style_manager_get_dark(this.obj) };
    }

    // Dark-state changes fire "notify::dark".
    fn connect_dark_changed(this, handler: fn(*u8, *u8)) {
        let _id: u64 = g::signal_connect(this.obj, #str_ptr("notify::dark\0"), handler, 0 as *u8);
    }
}
