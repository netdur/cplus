import "./glue" as glue;

// AdwStyleManager — runtime control over the Adwaita color scheme (light/dark
// preference) and read-only access to whether dark is currently in effect.
// The default manager governs the whole application.
//
//   let mgr = style::StyleManager::default_manager();
//   mgr.set_color_scheme(style::color_scheme_prefer_dark());

#[link_name = "adw_style_manager_get_default"]
extern fn adw_style_manager_get_default() -> *u8;

#[link_name = "adw_style_manager_set_color_scheme"]
extern fn adw_style_manager_set_color_scheme(manager: *u8, color_scheme: i32);

#[link_name = "adw_style_manager_get_dark"]
extern fn adw_style_manager_get_dark(manager: *u8) -> i32;

// AdwColorScheme values.
fn color_scheme_default() -> i32 { return 0; }
fn color_scheme_force_light() -> i32 { return 1; }
fn color_scheme_prefer_light() -> i32 { return 2; }
fn color_scheme_prefer_dark() -> i32 { return 3; }
fn color_scheme_force_dark() -> i32 { return 4; }

struct StyleManager {
    opaque _obj: *u8,
}

impl StyleManager {
    fn raw(this) -> *u8 { return this._obj; }
    fn from_raw(obj: *u8) -> StyleManager { return StyleManager { _obj: obj }; }

    // The application-wide style manager (a borrowed singleton — no unref).
    fn default_manager() -> StyleManager {
        return StyleManager { _obj: { adw_style_manager_get_default() } };
    }

    // Set the preference (a `color_scheme_*` value). Note `force_*` overrides
    // the system setting; `prefer_*` follows it when possible.
    fn set_color_scheme(this, color_scheme: i32) {
        { adw_style_manager_set_color_scheme(this._obj, color_scheme); };
    }

    // 1 if dark styling is currently applied.
    fn is_dark(this) -> i32 {
        return { adw_style_manager_get_dark(this._obj) };
    }

    // Dark-state changes fire "notify::dark".
    fn connect_dark_changed(this, handler: fn(*u8, *u8)) {
        let _id: u64 = glue::signal_connect(this._obj, #str_ptr("notify::dark\0"), handler, 0 as *u8);
    }
}

// ---- tests ----
//
// The widget surface is direct libadwaita FFI and needs a live display to
// exercise; only the pure `AdwColorScheme` enum mapping is host-runnable, so
// that is what these tests pin. The numeric values are part of libadwaita's
// stable ABI (AdwColorScheme): DEFAULT=0, FORCE_LIGHT=1, PREFER_LIGHT=2,
// PREFER_DARK=3, FORCE_DARK=4. Pinning them guards against silent drift.

#[test]
fn test_color_scheme_values_match_abi() {
    assert color_scheme_default() == 0;
    assert color_scheme_force_light() == 1;
    assert color_scheme_prefer_light() == 2;
    assert color_scheme_prefer_dark() == 3;
    assert color_scheme_force_dark() == 4;
}

#[test]
fn test_color_schemes_are_distinct() {
    assert color_scheme_default() != color_scheme_force_light();
    assert color_scheme_prefer_light() != color_scheme_prefer_dark();
    assert color_scheme_force_light() != color_scheme_force_dark();
}

#[test]
fn test_color_scheme_ordering() {
    // Preferences sit between the matching force overrides in the enum.
    assert color_scheme_force_light() < color_scheme_prefer_light();
    assert color_scheme_prefer_light() < color_scheme_prefer_dark();
    assert color_scheme_prefer_dark() < color_scheme_force_dark();
}
