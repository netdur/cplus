#[link_name = "adw_preferences_window_new"]
extern fn adw_preferences_window_new() -> *u8;

#[link_name = "adw_preferences_window_add"]
extern fn adw_preferences_window_add(window: *u8, page: *u8);

struct PreferencesWindow {
    opaque _obj: *u8,
}

impl PreferencesWindow {
    fn raw(this) -> *u8 { return this._obj; }
    fn from_raw(obj: *u8) -> PreferencesWindow { return PreferencesWindow { _obj: obj }; }

    fn new() -> PreferencesWindow {
        return PreferencesWindow { _obj: { adw_preferences_window_new() } };
    }

    fn add(this, page: *u8) {
        { adw_preferences_window_add(this._obj, page); };
    }
}
