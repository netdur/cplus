// Umbrella facade for the libadwaita bindings — import this for the flat Adw
// type surface (`adwaita::Application`, `adwaita::ToolbarView`, …), or import
// the narrower modules directly. Adwaita builds on GTK: import `gtk/gtk`
// alongside this for the base widgets (Box, Button, Label, ListBox, …) that
// Adwaita containers hold.

import "./application" as application;
import "./window" as window;
import "./header" as header;
import "./view" as view;
import "./toast" as toast;
import "./rows" as rows;
import "./viewstack" as viewstack;
import "./style" as style;
import "./widgets" as widgets;

type Application = application::Application;

type Window = window::Window;
type PlainWindow = window::PlainWindow;

type HeaderBar = header::HeaderBar;
type WindowTitle = header::WindowTitle;
type ToolbarView = header::ToolbarView;

type Clamp = view::Clamp;
type Bin = view::Bin;
type StatusPage = view::StatusPage;

type Toast = toast::Toast;
type ToastOverlay = toast::ToastOverlay;

type ActionRow = rows::ActionRow;
type EntryRow = rows::EntryRow;
type SwitchRow = rows::SwitchRow;
type ComboRow = rows::ComboRow;
type ExpanderRow = rows::ExpanderRow;
type PreferencesGroup = rows::PreferencesGroup;
type PreferencesPage = rows::PreferencesPage;
type PreferencesWindow = rows::PreferencesWindow;

type ViewStack = viewstack::ViewStack;
type ViewSwitcher = viewstack::ViewSwitcher;

type StyleManager = style::StyleManager;

type Avatar = widgets::Avatar;
type ButtonContent = widgets::ButtonContent;
type SplitButton = widgets::SplitButton;

// ---- re-exported AdwColorScheme constants ----

fn color_scheme_default() -> i32 { return style::color_scheme_default(); }
fn color_scheme_prefer_light() -> i32 { return style::color_scheme_prefer_light(); }
fn color_scheme_prefer_dark() -> i32 { return style::color_scheme_prefer_dark(); }
fn color_scheme_force_dark() -> i32 { return style::color_scheme_force_dark(); }
