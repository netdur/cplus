    fn splat(value: i16) -> Int16x8 { return Int16x8 { _v: i16x8::splat(value) }; }
    fn from_raw(v: i16x8) -> Int16x8 { return Int16x8 { _v: v }; }
    fn raw(this) -> i16x8 { return this._v; }
    fn count() -> usize { return 8 as usize; }

    fn to_array(this) -> [i16; 8] {
        return [this._v.lane(0 as u32), this._v.lane(1 as u32),
                this._v.lane(2 as u32), this._v.lane(3 as u32),
                this._v.lane(4 as u32), this._v.lane(5 as u32),
                this._v.lane(6 as u32), this._v.lane(7 as u32)];
    }
    fn lane(this, at: u32) -> option::Option[i16] {
        if at >= (8 as u32) { return option::Option[i16]::None; }
        let a: [i16; 8] = this.to_array();
