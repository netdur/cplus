    fn add(this, o: Int16x8) -> Int16x8 { return Int16x8 { _v: this._v.add(o._v) }; }
    fn sub(this, o: Int16x8) -> Int16x8 { return Int16x8 { _v: this._v.sub(o._v) }; }
