// simd/lanes.cplus — integer / unsigned SIMD *lane* vectors.
//
// The geometry modules (vec3/vec4/mat4x4) wrap `f32x4` as a 3D-math type
// (x/y/z/w, dot, length, normalize). These are a different thing: a
// fixed-width vector of N independent integer lanes for SIMD compute —
// the shape Accelerate's vDSP/vImage kernels return. Each type is a thin,
// safe newtype over the v0.0.7 SIMD built-in (`i32x4`, `u8x16`, …), so an
// FFI return value flows in via `from_raw`, is read/operated on through a
// guideline-shaped API, and flows back out via `raw`.
//
// Naming-guideline notes (naming_guideline.md):
//   - the raw lane vector is hidden behind `_v`; `raw()` reads it,
//     `from_raw(_)` builds from one (the FFI interop seam).
//   - `lane(at:)` returns `Option` — an out-of-range index is absence,
//     not a trap. `to_array()` extracts every lane at once.
//   - arithmetic reads as a phrase: `a.add(b)`, `a.min(b)`.

import "stdlib/option" as option;

// ── Int32x4 — 4 lanes of i32 ────────────────────────────────────────
struct Int32x4 {
    _v: i32x4,
}

impl Int32x4 {
    fn splat(value: i32) -> Int32x4 { return Int32x4 { _v: i32x4::splat(value) }; }
    fn new(a: i32, b: i32, c: i32, d: i32) -> Int32x4 {
        return Int32x4 { _v: i32x4::new(a, b, c, d) };
    }
    fn from_raw(v: i32x4) -> Int32x4 { return Int32x4 { _v: v }; }
    fn raw(this) -> i32x4 { return this._v; }
    fn count() -> usize { return 4 as usize; }

    fn to_array(this) -> [i32; 4] {
        return [this._v.lane(0 as u32), this._v.lane(1 as u32),
                this._v.lane(2 as u32), this._v.lane(3 as u32)];
    }
    fn lane(this, at: u32) -> option::Option[i32] {
        if at >= (4 as u32) { return option::Option[i32]::None; }
        let a: [i32; 4] = this.to_array();
        return option::some(a[at as usize]);
    }

    fn add(this, o: Int32x4) -> Int32x4 { return Int32x4 { _v: this._v.add(o._v) }; }
    fn sub(this, o: Int32x4) -> Int32x4 { return Int32x4 { _v: this._v.sub(o._v) }; }
    fn mul(this, o: Int32x4) -> Int32x4 { return Int32x4 { _v: this._v.mul(o._v) }; }
    fn min(this, o: Int32x4) -> Int32x4 { return Int32x4 { _v: this._v.min(o._v) }; }
    fn max(this, o: Int32x4) -> Int32x4 { return Int32x4 { _v: this._v.max(o._v) }; }
    fn sum(this) -> i32 { return this._v.sum(); }
}

// ── UInt32x4 — 4 lanes of u32 ───────────────────────────────────────
struct UInt32x4 {
    _v: u32x4,
}

impl UInt32x4 {
    fn splat(value: u32) -> UInt32x4 { return UInt32x4 { _v: u32x4::splat(value) }; }
    fn new(a: u32, b: u32, c: u32, d: u32) -> UInt32x4 {
        return UInt32x4 { _v: u32x4::new(a, b, c, d) };
    }
    fn from_raw(v: u32x4) -> UInt32x4 { return UInt32x4 { _v: v }; }
    fn raw(this) -> u32x4 { return this._v; }
    fn count() -> usize { return 4 as usize; }

    fn to_array(this) -> [u32; 4] {
        return [this._v.lane(0 as u32), this._v.lane(1 as u32),
                this._v.lane(2 as u32), this._v.lane(3 as u32)];
    }
    fn lane(this, at: u32) -> option::Option[u32] {
        if at >= (4 as u32) { return option::Option[u32]::None; }
        let a: [u32; 4] = this.to_array();
        return option::some(a[at as usize]);
    }

    fn add(this, o: UInt32x4) -> UInt32x4 { return UInt32x4 { _v: this._v.add(o._v) }; }
    fn sub(this, o: UInt32x4) -> UInt32x4 { return UInt32x4 { _v: this._v.sub(o._v) }; }
    fn mul(this, o: UInt32x4) -> UInt32x4 { return UInt32x4 { _v: this._v.mul(o._v) }; }
    fn min(this, o: UInt32x4) -> UInt32x4 { return UInt32x4 { _v: this._v.min(o._v) }; }
    fn max(this, o: UInt32x4) -> UInt32x4 { return UInt32x4 { _v: this._v.max(o._v) }; }
    fn sum(this) -> u32 { return this._v.sum(); }
}

// ── Int16x8 — 8 lanes of i16 ────────────────────────────────────────
struct Int16x8 {
