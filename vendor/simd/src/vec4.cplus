// simd/vec4.cplus — 4D float vector backed by `f32x4`.
//
// Unlike `Vec3`, `Vec4` uses every lane — no invariant. Convenient
// for homogeneous coordinates (x, y, z, w) and as the row/column type
// of `Mat4x4`. Dot product is straight `mul.sum()` over all 4 lanes;
// no swizzle gymnastics needed.

pub struct Vec4 {
    v: f32x4,
}

impl Vec4 {
    // Construction --------------------------------------------------

    pub fn new(x: f32, y: f32, z: f32, w: f32) -> Vec4 {
        return Vec4 { v: f32x4::new(x, y, z, w) };
    }

    pub fn splat(s: f32) -> Vec4 {
        return Vec4 { v: f32x4::splat(s) };
    }

    pub fn zero() -> Vec4 {
        return Vec4 { v: f32x4::splat(0.0f32) };
    }

    // Lane accessors ------------------------------------------------

    pub fn x(this) -> f32 { return this.v.lane(0 as u32); }
    pub fn y(this) -> f32 { return this.v.lane(1 as u32); }
    pub fn z(this) -> f32 { return this.v.lane(2 as u32); }
    pub fn w(this) -> f32 { return this.v.lane(3 as u32); }

    // Arithmetic ----------------------------------------------------

    pub fn add(this, o: Vec4) -> Vec4 {
        return Vec4 { v: this.v.add(o.v) };
    }

    pub fn sub(this, o: Vec4) -> Vec4 {
        return Vec4 { v: this.v.sub(o.v) };
    }

    pub fn mul(this, o: Vec4) -> Vec4 {
        return Vec4 { v: this.v.mul(o.v) };
    }

    pub fn scale(this, s: f32) -> Vec4 {
        return Vec4 { v: this.v.mul(f32x4::splat(s)) };
    }

    pub fn neg(this) -> Vec4 {
        return Vec4 { v: this.v.mul(f32x4::splat(0.0f32 - 1.0f32)) };
    }

    // Geometric ops -------------------------------------------------

    pub fn dot(this, o: Vec4) -> f32 {
        return this.v.mul(o.v).sum();
    }

    pub fn len2(this) -> f32 {
        return this.dot(this);
    }

    pub fn length(this) -> f32 {
        return f_sqrt(this.dot(this));
    }

    pub fn normalize(this) -> Vec4 {
        let inv: f32 = 1.0f32 / this.length();
        return this.scale(inv);
    }

    // Lane-wise helpers ---------------------------------------------

    pub fn min(this, o: Vec4) -> Vec4 {
        return Vec4 { v: this.v.min(o.v) };
    }

    pub fn max(this, o: Vec4) -> Vec4 {
        return Vec4 { v: this.v.max(o.v) };
    }

    pub fn clamp(this, lo: Vec4, hi: Vec4) -> Vec4 {
        return this.max(lo).min(hi);
    }

    pub fn lerp(this, o: Vec4, t: f32) -> Vec4 {
        let diff: f32x4 = o.v.sub(this.v);
        let tv: f32x4 = f32x4::splat(t);
        return Vec4 { v: diff.fma(tv, this.v) };
    }

    // Inner accessor for `mat4x4` cross-module use ------------------

    pub fn raw(this) -> f32x4 {
        return this.v;
    }

    pub fn from_raw(v: f32x4) -> Vec4 {
        return Vec4 { v: v };
    }
}

extern fn sqrtf(x: f32) -> f32;
fn f_sqrt(x: f32) -> f32 {
    return unsafe { sqrtf(x) };
}
