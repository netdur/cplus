// simd/integer.cplus — integer widening lane helpers (SIMD Tier-2).
//
// The geometry modules (vec3/vec4/mat4x4) cover float math. This module
// covers the *integer-widening* lane ops that quantized kernels lean on,
// composed entirely from the v0.0.12 Tier-1 SIMD primitives the compiler
// ships — `widen` / `narrow` / `low` / `high` / `combine` / `swizzle` —
// so there is no dedicated compiler builtin for any of them.
//
// The headline is `dot_i32`: a 16-lane signed-byte dot product that
// accumulates in i32. It is the composable answer to the "widening
// integer dot product" (NEON `vdotq_s32`) that `i8x16.mul().sum()`
// silently miscomputes (i8 lane wrap). `mull_*` / `mlal_*` are the
// building blocks; `paddl_i8` is the widening pairwise add.
//
// Signed `i8` today (the q8_0 quant case). Unsigned and 16-bit variants
// follow the same shape and can be added when a consumer needs them.

// --- widening multiply -----------------------------------------------

// Widening multiply of two 8-lane signed-byte vectors: each i8*i8
// product is kept at full i16 precision (NEON `vmull_s8`). No lane wrap.
fn mull_i8(a: i8x8, b: i8x8) -> i16x8 {
    return a.widen().mul(b.widen());
}

// Widening multiply of the low / high 8 lanes of two i8x16 vectors,
// producing the 8 i16 products (NEON `vmull_s8` after `vget_low/high`).
fn mull_lo_i8(a: i8x16, b: i8x16) -> i16x8 {
    return mull_i8(a.low(), b.low());
}

fn mull_hi_i8(a: i8x16, b: i8x16) -> i16x8 {
    return mull_i8(a.high(), b.high());
}

// Widening multiply-accumulate: `acc + (a * b)` at i16 precision (NEON
// `vmlal_s8`). The caller is responsible for keeping the i16 accumulator
// from overflowing; for long reductions accumulate in i32 via `dot_i32`.
fn mlal_i8(acc: i16x8, a: i8x8, b: i8x8) -> i16x8 {
    return acc.add(mull_i8(a, b));
}

// --- pairwise widening add -------------------------------------------

// Widening pairwise add (NEON `vpaddlq_s8`): sum adjacent i8 lanes,
// widening to i16. `out[k] = widen(v[2k]) + widen(v[2k+1])`. Implemented
// by deinterleaving even / odd lanes (swizzle + low) then widen-adding.
fn paddl_i8(v: i8x16) -> i16x8 {
    let evens: i8x8 = v.swizzle([
        0 as u32, 2 as u32, 4 as u32, 6 as u32,
        8 as u32, 10 as u32, 12 as u32, 14 as u32,
        0 as u32, 2 as u32, 4 as u32, 6 as u32,
        8 as u32, 10 as u32, 12 as u32, 14 as u32,
    ]).low();
    let odds: i8x8 = v.swizzle([
        1 as u32, 3 as u32, 5 as u32, 7 as u32,
        9 as u32, 11 as u32, 13 as u32, 15 as u32,
        1 as u32, 3 as u32, 5 as u32, 7 as u32,
        9 as u32, 11 as u32, 13 as u32, 15 as u32,
    ]).low();
    return evens.widen().add(odds.widen());
}

// --- the keystone: widening dot product ------------------------------

// Signed dot product of two 16-lane byte vectors, accumulated in i32
// (NEON `vdotq_s32` shape). Widens each i8 product to i16, then widens
// the i16 partial sums to i32 before reducing, so the result is exact
// for any i8 inputs (no i8 or i16 lane wrap).
fn dot_i32(a: i8x16, b: i8x16) -> i32 {
    let plo: i16x8 = mull_lo_i8(a, b);   // 8 products from the low lanes
    let phi: i16x8 = mull_hi_i8(a, b);   // 8 products from the high lanes
    // Widen each i16x8 of products to i32 (split into i16x4 halves) and
    // accumulate, so 256-ish-magnitude products never overflow.
    let acc_lo: i32x4 = plo.low().widen().add(plo.high().widen());
    let acc_hi: i32x4 = phi.low().widen().add(phi.high().widen());
    return acc_lo.add(acc_hi).sum();
}

// ---------------- in-package tests (cpc test) ------------------------

#[test]
fn test_mull_i8_widens_products() {
    let a: i8x8 = i8x8::splat(3i8);
    let b: i8x8 = i8x8::splat(4i8);
    let p: i16x8 = mull_i8(a, b);
    assert p.lane(0 as u32) == 12i16;
    assert p.lane(7 as u32) == 12i16;
}

#[test]
fn test_mull_i8_no_wrap_past_i8() {
    // 50 * 3 = 150 overflows i8 (would wrap to -106 in a same-width mul);
    // the widening product keeps it correct at i16.
    let p: i16x8 = mull_i8(i8x8::splat(50i8), i8x8::splat(3i8));
    assert p.lane(0 as u32) == 150i16;
}

#[test]
fn test_mull_lo_hi_split() {
    let a: i8x16 = i8x16::new(1i8,2i8,3i8,4i8,5i8,6i8,7i8,8i8,
                             9i8,10i8,11i8,12i8,13i8,14i8,15i8,16i8);
    let b: i8x16 = i8x16::splat(2i8);
    let lo: i16x8 = mull_lo_i8(a, b);
    let hi: i16x8 = mull_hi_i8(a, b);
    assert lo.lane(0 as u32) == 2i16;    // 1 * 2
    assert lo.lane(7 as u32) == 16i16;   // 8 * 2
    assert hi.lane(0 as u32) == 18i16;   // 9 * 2
    assert hi.lane(7 as u32) == 32i16;   // 16 * 2
}

#[test]
fn test_mlal_i8_accumulates() {
    let acc: i16x8 = i16x8::splat(1i16);
    let r: i16x8 = mlal_i8(acc, i8x8::splat(2i8), i8x8::splat(3i8));
    assert r.lane(0 as u32) == 7i16;     // 1 + 2*3
}

#[test]
fn test_paddl_i8_pairwise() {
    let v: i8x16 = i8x16::new(1i8,2i8,3i8,4i8,5i8,6i8,7i8,8i8,
                             9i8,10i8,11i8,12i8,13i8,14i8,15i8,16i8);
    let r: i16x8 = paddl_i8(v);
    assert r.lane(0 as u32) == 3i16;     // 1 + 2
    assert r.lane(1 as u32) == 7i16;     // 3 + 4
    assert r.lane(7 as u32) == 31i16;    // 15 + 16
}

#[test]
fn test_dot_i32_small() {
    // 16 lanes * (2 * 3 = 6) = 96.
    let r: i32 = dot_i32(i8x16::splat(2i8), i8x16::splat(3i8));
    assert r == 96;
}

#[test]
fn test_dot_i32_exceeds_i16() {
    // 16 lanes * (50 * 50 = 2500) = 40000, which exceeds i16::MAX (32767).
    // The i32 accumulation keeps it exact — proving no i16 lane wrap.
    let r: i32 = dot_i32(i8x16::splat(50i8), i8x16::splat(50i8));
    assert r == 40000;
}

#[test]
fn test_dot_i32_mixed_signs() {
    // alternating +1 / -1 dotted with all 1s = 0 (eight +1, eight -1).
    let a: i8x16 = i8x16::new(1i8,(0i8 - 1i8),1i8,(0i8 - 1i8),
                             1i8,(0i8 - 1i8),1i8,(0i8 - 1i8),
                             1i8,(0i8 - 1i8),1i8,(0i8 - 1i8),
                             1i8,(0i8 - 1i8),1i8,(0i8 - 1i8));
    let r: i32 = dot_i32(a, i8x16::splat(1i8));
    assert r == 0;
}
