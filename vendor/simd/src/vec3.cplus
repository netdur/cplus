// simd/vec3.cplus — 3D float vector backed by `f32x4`.
//
// `Vec3` is a single-field newtype around `f32x4` with the invariant
// that lane 3 is always zero. The invariant makes:
//   - dot product correct: `a._v.mul(b._v).sum()` includes `a.w * b.w = 0`.
//   - per-lane min/max safe at the 4th lane: `0 min anything <= 0`.
//   - reductions ignore the padding lane (it contributes 0 to fadd /
//     1 to fmul — `product()` callers should slice through `.x/.y/.z`).
//
// All ops preserve the lane-3-zero invariant. New Vec3 values come
// from `Vec3::new(x, y, z)` (which zeros lane 3), arithmetic on Vec3
// (lane 3 stays 0), or `cross` (lane 3 stays 0 because both inputs
// have 0 in lane 3).
//
// Naming-guideline notes (naming_guideline.md):
//   - The raw `f32x4` handle is hidden behind `_v`; read it through the
//     role-named `raw()` accessor, build from one with `from_raw(_)`.
//   - Interpolation and refraction take labeled parameters that read as
//     a phrase: `a.lerp(b, at: t)`, `v.refract(across: n, eta: r)`.
//   - Absence is a value: `normalize()` returns `None` for a zero-length
//     vector (its true direction is undefined), and `refract` returns
//     `None` on total internal reflection rather than the old zero
//     sentinel.

import "stdlib/option" as option;

struct Vec3 {
    _v: f32x4,
}

impl Vec3 {
    // Construction --------------------------------------------------

    fn new(x: f32, y: f32, z: f32) -> Vec3 {
        return Vec3 { _v: f32x4::new(x, y, z, 0.0f32) };
    }

    fn splat(s: f32) -> Vec3 {
        // Lane 3 must be zero to preserve the invariant.
        return Vec3 { _v: f32x4::new(s, s, s, 0.0f32) };
    }

    fn zero() -> Vec3 {
        return Vec3 { _v: f32x4::splat(0.0f32) };
    }

    // Inner accessor — the role-named bridge to the raw register, used
    // by `mat4x4` and any kernel that wants the underlying lanes. The
    // `_v` field stays private; this is the read path.
    fn raw(this) -> f32x4 {
        return this._v;
    }

    // Build a Vec3 from a raw register. The caller is responsible for
    // lane 3 being zero (the constructors and arithmetic guarantee it).
    fn from_raw(v: f32x4) -> Vec3 {
        return Vec3 { _v: v };
    }

    // Lane accessors ------------------------------------------------

    fn x(this) -> f32 { return this._v.lane(0 as u32); }
    fn y(this) -> f32 { return this._v.lane(1 as u32); }
    fn z(this) -> f32 { return this._v.lane(2 as u32); }

    // Arithmetic (lane 3 stays 0 because both operands have 0 there) -

    fn add(this, o: Vec3) -> Vec3 {
        return Vec3 { _v: this._v.add(o._v) };
    }

    fn sub(this, o: Vec3) -> Vec3 {
        return Vec3 { _v: this._v.sub(o._v) };
    }

    fn mul(this, o: Vec3) -> Vec3 {
        // Hadamard (per-lane) product. Lane 3 = 0 * 0 = 0. ✓
        return Vec3 { _v: this._v.mul(o._v) };
    }

    fn scale(this, s: f32) -> Vec3 {
        // Multiply every lane by scalar. Lane 3 = 0 * s = 0. ✓
        return Vec3 { _v: this._v.mul(f32x4::splat(s)) };
    }

    fn neg(this) -> Vec3 {
        return Vec3 { _v: this._v.mul(f32x4::splat(0.0f32 - 1.0f32)) };
    }

    // Geometric ops -------------------------------------------------

    fn dot(this, o: Vec3) -> f32 {
        // Lane-3 contribution is `0 * 0 = 0`, so summing all 4 lanes
        // is the 3D dot product. One `fmul <4 x float>` plus one
        // `llvm.vector.reduce.fadd.v4f32`.
        return this._v.mul(o._v).sum();
    }

    fn cross(this, o: Vec3) -> Vec3 {
        // Classic 3D cross product via shuffles:
        //   c.x = a.y*b.z - a.z*b.y
        //   c.y = a.z*b.x - a.x*b.z
        //   c.z = a.x*b.y - a.y*b.x
        // a_yzx0 = (a.y, a.z, a.x, 0); b_zxy0 = (b.z, b.x, b.y, 0)
        // a_zxy0 = (a.z, a.x, a.y, 0); b_yzx0 = (b.y, b.z, b.x, 0)
        // result = a_yzx0 * b_zxy0 - a_zxy0 * b_yzx0
        // Lane 3 of result = 0*0 - 0*0 = 0. Invariant preserved.
        let a_yzx0: f32x4 = this._v.swizzle([1 as u32, 2 as u32, 0 as u32, 3 as u32]);
        let b_zxy0: f32x4 = o._v.swizzle([2 as u32, 0 as u32, 1 as u32, 3 as u32]);
        let a_zxy0: f32x4 = this._v.swizzle([2 as u32, 0 as u32, 1 as u32, 3 as u32]);
        let b_yzx0: f32x4 = o._v.swizzle([1 as u32, 2 as u32, 0 as u32, 3 as u32]);
        return Vec3 { _v: a_yzx0.mul(b_zxy0).sub(a_zxy0.mul(b_yzx0)) };
    }

    fn len2(this) -> f32 {
        // Squared length — avoids the sqrt when callers only need to
        // compare magnitudes.
        return this.dot(this);
    }

    fn length(this) -> f32 {
        // Scalar sqrt of the dot product. Vector sqrt over the whole
        // SIMD register isn't useful here — we want just one scalar.
        return f_sqrt(this.dot(this));
    }

    // Unit vector in the same direction, or `None` for a zero-length
    // vector (whose direction is undefined — dividing by 0 would give
    // NaN lanes). Absence is reported as a value, per the guideline.
    fn normalize(this) -> option::Option[Vec3] {
        let len: f32 = this.length();
        if len == 0.0f32 {
            return option::Option[Vec3]::None;
        }
        let inv: f32 = 1.0f32 / len;
        return option::some::[Vec3](this.scale(inv));
    }

    fn reflect(this, across: Vec3) -> Vec3 {
        // r = v - 2 * dot(v, n) * n  — incident-to-reflected vector
        // about the surface normal `across`. It should be normalized.
        let t: f32 = 2.0f32 * this.dot(across);
        return this.sub(across.scale(t));
    }

    // Snell's-law refraction. `across` is the surface normal, `eta` the
    // ratio of indices (incident / transmitted). Both `this` and
    // `across` should be normalized. Returns the refracted direction,
    // or `None` on total internal reflection.
    fn refract(this, across: Vec3, eta: f32) -> option::Option[Vec3] {
        let cos_i: f32 = 0.0f32 - this.dot(across);
        let k: f32 = 1.0f32 - eta * eta * (1.0f32 - cos_i * cos_i);
        if k < 0.0f32 {
            return option::Option[Vec3]::None;
        }
        let scale_self: f32 = eta;
        let scale_n: f32 = eta * cos_i - f_sqrt(k);
        return option::some::[Vec3](this.scale(scale_self).add(across.scale(scale_n)));
    }

    // Lane-wise helpers ---------------------------------------------

    fn min(this, o: Vec3) -> Vec3 {
        // Lane-3: min(0, 0) = 0. Invariant safe.
        return Vec3 { _v: this._v.min(o._v) };
    }

    fn max(this, o: Vec3) -> Vec3 {
        return Vec3 { _v: this._v.max(o._v) };
    }

    // Clamp each lane into [min, max]. Labeled so the call reads
    // `v.clamp(min: lo, max: hi)`.
    fn clamp(this, min: Vec3, max: Vec3) -> Vec3 {
        return this.max(min).min(max);
    }

    // Linear interpolation: `this + t * (o - this)`. Labeled so the
    // call reads `a.lerp(b, at: t)`. Uses f32x4 FMA for the inner
    // `t * (o - this) + this` step: `fma((o - this), splat(t), this)`.
    fn lerp(this, o: Vec3, at: f32) -> Vec3 {
        let diff: f32x4 = o._v.sub(this._v);
        let tv: f32x4 = f32x4::splat(at);
        return Vec3 { _v: diff.fma(tv, this._v) };
    }
}

// Internal — wraps the f32 sqrt intrinsic so we don't need to import
// it from the stdlib. cpc inlines this; LLVM emits `llvm.sqrt.f32`.
extern fn sqrtf(x: f32) -> f32;

fn f_sqrt(x: f32) -> f32 {
    return { sqrtf(x) };
}

// ---------------- in-package tests (cpc test) ------------------------

fn approx(a: f32, b: f32) -> bool {
    let d: f32 = a - b;
    if d < 0.0f32 { return (0.0f32 - d) < 0.0001f32; }
    return d < 0.0001f32;
}

#[test]
fn test_new_sets_lanes_and_zeros_w() {
    let v: Vec3 = Vec3::new(1.0f32, 2.0f32, 3.0f32);
    assert v.x() == 1.0f32;
    assert v.y() == 2.0f32;
    assert v.z() == 3.0f32;
    // The lane-3-zero invariant: read it through the raw register.
    assert v.raw().lane(3 as u32) == 0.0f32;
}

#[test]
fn test_splat_and_zero() {
    let s: Vec3 = Vec3::splat(5.0f32);
    assert s.x() == 5.0f32 && s.y() == 5.0f32 && s.z() == 5.0f32;
    assert s.raw().lane(3 as u32) == 0.0f32;
    let z: Vec3 = Vec3::zero();
    assert z.x() == 0.0f32 && z.y() == 0.0f32 && z.z() == 0.0f32;
}

#[test]
fn test_raw_roundtrip() {
    let v: Vec3 = Vec3::new(7.0f32, 8.0f32, 9.0f32);
    let r: Vec3 = Vec3::from_raw(v.raw());
    assert r.x() == 7.0f32 && r.y() == 8.0f32 && r.z() == 9.0f32;
}

#[test]
fn test_add_sub() {
    let a: Vec3 = Vec3::new(1.0f32, 2.0f32, 3.0f32);
    let b: Vec3 = Vec3::new(4.0f32, 5.0f32, 6.0f32);
    let s: Vec3 = a.add(b);
    assert s.x() == 5.0f32 && s.y() == 7.0f32 && s.z() == 9.0f32;
    let d: Vec3 = b.sub(a);
    assert d.x() == 3.0f32 && d.y() == 3.0f32 && d.z() == 3.0f32;
}

#[test]
fn test_mul_scale_neg() {
    let a: Vec3 = Vec3::new(2.0f32, 3.0f32, 4.0f32);
    let b: Vec3 = Vec3::new(5.0f32, 6.0f32, 7.0f32);
    let h: Vec3 = a.mul(b);
    assert h.x() == 10.0f32 && h.y() == 18.0f32 && h.z() == 28.0f32;
    let sc: Vec3 = a.scale(2.0f32);
    assert sc.x() == 4.0f32 && sc.y() == 6.0f32 && sc.z() == 8.0f32;
    let n: Vec3 = a.neg();
    assert n.x() == (0.0f32 - 2.0f32) && n.z() == (0.0f32 - 4.0f32);
}

#[test]
fn test_dot() {
    let a: Vec3 = Vec3::new(1.0f32, 2.0f32, 3.0f32);
    let b: Vec3 = Vec3::new(4.0f32, 5.0f32, 6.0f32);
    // 1*4 + 2*5 + 3*6 = 32. The padding lane contributes 0.
    assert a.dot(b) == 32.0f32;
}

#[test]
fn test_cross_basis() {
    // x × y = z
    let x: Vec3 = Vec3::new(1.0f32, 0.0f32, 0.0f32);
    let y: Vec3 = Vec3::new(0.0f32, 1.0f32, 0.0f32);
    let c: Vec3 = x.cross(y);
    assert c.x() == 0.0f32 && c.y() == 0.0f32 && c.z() == 1.0f32;
    // Result preserves the lane-3-zero invariant.
    assert c.raw().lane(3 as u32) == 0.0f32;
}

#[test]
fn test_cross_anticommutes() {
    let a: Vec3 = Vec3::new(1.0f32, 2.0f32, 3.0f32);
    let b: Vec3 = Vec3::new(4.0f32, 5.0f32, 6.0f32);
    let ab: Vec3 = a.cross(b);
    let ba: Vec3 = b.cross(a);
    assert approx(ab.x(), 0.0f32 - ba.x());
    assert approx(ab.y(), 0.0f32 - ba.y());
    assert approx(ab.z(), 0.0f32 - ba.z());
}

#[test]
fn test_len2_and_length() {
    let v: Vec3 = Vec3::new(3.0f32, 4.0f32, 0.0f32);
    assert v.len2() == 25.0f32;
    assert v.length() == 5.0f32;
}

#[test]
fn test_normalize_unit_length() {
    let v: Vec3 = Vec3::new(0.0f32, 3.0f32, 4.0f32);
    guard let option::Option[Vec3]::Some(u) = v.normalize() else {
        assert false;
        return;
    };
    assert approx(u.length(), 1.0f32);
    assert approx(u.y(), 0.6f32);
    assert approx(u.z(), 0.8f32);
}

#[test]
fn test_normalize_zero_is_none() {
    // Negative case: the zero vector has no direction.
    match Vec3::zero().normalize() {
        option::Option[Vec3]::Some(_) => { assert false; }
        option::Option[Vec3]::None => { assert true; }
    };
}

#[test]
fn test_reflect_off_axis() {
    // A vector going down-right, reflected about the up normal, flips y.
    let v: Vec3 = Vec3::new(1.0f32, 0.0f32 - 1.0f32, 0.0f32);
    let n: Vec3 = Vec3::new(0.0f32, 1.0f32, 0.0f32);
    let r: Vec3 = v.reflect(across: n);
    assert approx(r.x(), 1.0f32);
    assert approx(r.y(), 1.0f32);
    assert approx(r.z(), 0.0f32);
}

#[test]
fn test_refract_straight_through() {
    // eta = 1 (no index change): the ray passes straight through.
    let v: Vec3 = Vec3::new(0.0f32, 0.0f32 - 1.0f32, 0.0f32);
    let n: Vec3 = Vec3::new(0.0f32, 1.0f32, 0.0f32);
    guard let option::Option[Vec3]::Some(r) = v.refract(across: n, eta: 1.0f32) else {
        assert false;
        return;
    };
    assert approx(r.x(), 0.0f32);
    assert approx(r.y(), 0.0f32 - 1.0f32);
}

#[test]
fn test_refract_total_internal_reflection_is_none() {
    // Negative case: a grazing ray into a denser-to-rarer medium with a
    // large eta exceeds the critical angle — total internal reflection.
    let v: Vec3 = Vec3::new(0.99f32, 0.0f32 - 0.141f32, 0.0f32);
    let n: Vec3 = Vec3::new(0.0f32, 1.0f32, 0.0f32);
    match v.refract(across: n, eta: 2.0f32) {
        option::Option[Vec3]::Some(_) => { assert false; }
        option::Option[Vec3]::None => { assert true; }
    };
}

#[test]
fn test_min_max_clamp() {
    let a: Vec3 = Vec3::new(1.0f32, 5.0f32, 3.0f32);
    let b: Vec3 = Vec3::new(4.0f32, 2.0f32, 6.0f32);
    let mn: Vec3 = a.min(b);
    assert mn.x() == 1.0f32 && mn.y() == 2.0f32 && mn.z() == 3.0f32;
    let mx: Vec3 = a.max(b);
    assert mx.x() == 4.0f32 && mx.y() == 5.0f32 && mx.z() == 6.0f32;
    let lo: Vec3 = Vec3::splat(2.0f32);
    let hi: Vec3 = Vec3::splat(4.0f32);
    let c: Vec3 = a.clamp(min: lo, max: hi);
    assert c.x() == 2.0f32 && c.y() == 4.0f32 && c.z() == 3.0f32;
}

#[test]
fn test_lerp_endpoints_and_mid() {
    let a: Vec3 = Vec3::new(0.0f32, 0.0f32, 0.0f32);
    let b: Vec3 = Vec3::new(10.0f32, 20.0f32, 30.0f32);
    let at0: Vec3 = a.lerp(b, at: 0.0f32);
    assert approx(at0.x(), 0.0f32) && approx(at0.z(), 0.0f32);
    let at1: Vec3 = a.lerp(b, at: 1.0f32);
    assert approx(at1.x(), 10.0f32) && approx(at1.z(), 30.0f32);
    let mid: Vec3 = a.lerp(b, at: 0.5f32);
    assert approx(mid.x(), 5.0f32) && approx(mid.y(), 10.0f32) && approx(mid.z(), 15.0f32);
}
