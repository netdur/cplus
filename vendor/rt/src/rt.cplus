// vendor/rt/src/spsc_ring.cplus — fixed-capacity single-producer /
// single-consumer ring buffer.
//
// A bounded, wait-free, allocation-free queue. The whole buffer lives
// inline in the struct (stack or `static mut` storage) — no `malloc`,
// no `realloc`, no `free` — so `push` / `pop` satisfy the v0.0.12
// real-time contracts (`#[no_alloc]` + `#[no_block]`). Full and empty
// are reported as values (`bool` / `Option`), never by blocking.
//
// Why a fixed concrete capacity? C+ doesn't yet have const-generic
// struct params (`struct SpscRing[const N: usize]`), so this first cut
// ships one shape: 1024 `u64` slots. A `u64` slot carries a control
// word, an index, a tagged handle, or a bit-cast `f64` — enough for the
// UI/control-message channel a real-time hot path needs. For a different
// capacity, copy this struct and change the three `1024` constants (the
// `buf` length, and the two capacity checks).
//
// **Concurrency model (SPSC).** Exactly one producer thread calls
// `push`, exactly one consumer thread calls `pop`, both through the same
// ring in shared stable storage. `head` (consumer-owned) and `tail`
// (producer-owned) are monotonically increasing u64 indices; the slot is
// `index % capacity`. The release store of `tail` after writing a slot
// publishes the element; the acquire load of `tail` in `pop` seals the
// happens-before edge. Capacity is never exceeded, so the producer never
// overwrites an unread slot.

import "stdlib/atomic" as atomic;
import "stdlib/option" as option;
// Sibling module: the fixed-capacity object pool. Pulled in so the package
// build/test graph includes it (and its `#[test]` functions).
import "./pool" as pool;

pub struct SpscRingU64 {
    pub buf: [u64; 1024],
    // Consumer index — only `pop` advances it. Read by `push` to detect full.
    pub head: u64,
    // Producer index — only `push` advances it. Read by `pop` to detect empty.
    pub tail: u64,
}

impl SpscRingU64 {
    // Construct an empty ring. The `[0u64; 1024]` fill is a stack/static
    // memset — no heap allocation — so this is itself `#[no_alloc]`.
    #[no_alloc] #[no_block]
    pub fn new() -> SpscRingU64 {
        return SpscRingU64 { buf: [0u64; 1024], head: 0 as u64, tail: 0 as u64 };
    }

    pub fn capacity(self) -> usize { return 1024 as usize; }

    // Approximate occupancy. Exact when observed by one of the two
    // participants; a snapshot otherwise. Acquire loads so a caller that
    // also reads published slots sees a consistent view.
    #[no_alloc] #[no_block]
    pub fn len(self) -> usize {
        let head: u64 = unsafe { atomic::atomic_load_u64(#addr_of(self.head), atomic::Ordering::Acquire) };
        let tail: u64 = unsafe { atomic::atomic_load_u64(#addr_of(self.tail), atomic::Ordering::Acquire) };
        return (tail -% head) as usize;
    }

    #[no_alloc] #[no_block]
    pub fn is_empty(self) -> bool { return self.len() == (0 as usize); }

    #[no_alloc] #[no_block]
    pub fn is_full(self) -> bool { return self.len() >= (1024 as usize); }

    // Producer side. Returns `false` (without blocking) when the ring is
    // full; the caller decides whether to drop, overwrite, or retry later.
    #[no_alloc] #[no_block]
    pub fn push(mut self, v: u64) -> bool {
        // Acquire on `head` so a slot freed by the consumer is visible.
        let head: u64 = unsafe { atomic::atomic_load_u64(#addr_of(self.head), atomic::Ordering::Acquire) };
        // Relaxed on `tail` — this thread is its sole writer.
        let tail: u64 = unsafe { atomic::atomic_load_u64(#addr_of(self.tail), atomic::Ordering::Relaxed) };
        if (tail -% head) >= (1024 as u64) {
            return false;
        }
        let idx: usize = (tail % (1024 as u64)) as usize;
        self.buf[idx] = v;
        // Release publishes the slot write before the index advance.
        unsafe { atomic::atomic_store_u64(#addr_of(self.tail), tail +% (1 as u64), atomic::Ordering::Release); }
        return true;
    }

    // Consumer side. Returns `None` (without blocking) when the ring is
    // empty.
    #[no_alloc] #[no_block]
    pub fn pop(mut self) -> option::Option[u64] {
        // Acquire on `tail` so the producer's slot write is visible.
        let tail: u64 = unsafe { atomic::atomic_load_u64(#addr_of(self.tail), atomic::Ordering::Acquire) };
        // Relaxed on `head` — this thread is its sole writer.
        let head: u64 = unsafe { atomic::atomic_load_u64(#addr_of(self.head), atomic::Ordering::Relaxed) };
        if head == tail {
            return option::Option[u64]::None;
        }
        let idx: usize = (head % (1024 as u64)) as usize;
        let v: u64 = self.buf[idx];
        // Release frees the slot before the consumer index advance.
        unsafe { atomic::atomic_store_u64(#addr_of(self.head), head +% (1 as u64), atomic::Ordering::Release); }
        return option::Option[u64]::Some(v);
    }
}

// ---------------- Unit tests ----------------

#[test]
fn test_new_is_empty() {
    let r: SpscRingU64 = SpscRingU64::new();
    assert r.is_empty();
    assert r.len() == (0 as usize);
    assert r.capacity() == (1024 as usize);
}

#[test]
fn test_pop_empty_returns_none() {
    let mut r: SpscRingU64 = SpscRingU64::new();
    match r.pop() {
        option::Option[u64]::Some(_) => { assert false; }
        option::Option[u64]::None => { assert true; }
    };
}

#[test]
fn test_push_then_pop_round_trips() {
    let mut r: SpscRingU64 = SpscRingU64::new();
    assert r.push(42 as u64);
    assert r.len() == (1 as usize);
    guard let option::Option[u64]::Some(v) = r.pop() else {
        assert false;
        return;
    };
    assert v == (42 as u64);
    assert r.is_empty();
}

#[test]
fn test_fifo_order_preserved() {
    let mut r: SpscRingU64 = SpscRingU64::new();
    assert r.push(1 as u64);
    assert r.push(2 as u64);
    assert r.push(3 as u64);
    guard let option::Option[u64]::Some(a) = r.pop() else { assert false; return; };
    guard let option::Option[u64]::Some(b) = r.pop() else { assert false; return; };
    guard let option::Option[u64]::Some(c) = r.pop() else { assert false; return; };
    assert a == (1 as u64);
    assert b == (2 as u64);
    assert c == (3 as u64);
}

#[test]
fn test_full_ring_rejects_push() {
    let mut r: SpscRingU64 = SpscRingU64::new();
    for i in 0..1024 {
        assert r.push(i as u64);
    }
    assert r.is_full();
    // The 1025th push must fail without blocking.
    assert (r.push(9999 as u64)) == false;
    assert r.len() == (1024 as usize);
}

#[test]
fn test_wraparound_many_cycles() {
    // Single-slot in/out far past the 1024 boundary exercises index
    // wraparound (`% capacity`) without ever filling the ring.
    let mut r: SpscRingU64 = SpscRingU64::new();
    for i in 0..3000 {
        assert r.push(i as u64);
        guard let option::Option[u64]::Some(v) = r.pop() else { assert false; return; };
        assert v == (i as u64);
    }
    assert r.is_empty();
}

#[test]
fn test_fill_drain_fill_again() {
    let mut r: SpscRingU64 = SpscRingU64::new();
    for i in 0..1024 { assert r.push(i as u64); }
    for i in 0..1024 {
        guard let option::Option[u64]::Some(v) = r.pop() else { assert false; return; };
        assert v == (i as u64);
    }
    assert r.is_empty();
    // Refilling after a full drain must succeed (indices are monotonic,
    // slots reused via modulo).
    assert r.push(7 as u64);
    guard let option::Option[u64]::Some(v) = r.pop() else { assert false; return; };
    assert v == (7 as u64);
}
