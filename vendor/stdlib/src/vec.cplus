// stdlib/vec.cplus -- ownership-safe growable vector.
//
// The core API rule is: a generic Vec[T] never bitwise-copies a T out of
// storage. Operations that yield an owned element either remove it first
// (`pop`, `swap_remove`), or require `T: Copy` at the boundary (`get`,
// `at_copy`, `extend_from_slice`). To READ a non-Copy element in place, use
// `at(i) -> Option[*T]` (a bounds-checked pointer; deref is `unsafe` because
// the language has no element borrowing yet). `iter` is a gen method intended
// for Copy `T` (it copies each element out); iterate non-Copy vectors by index
// via `at`. Allocation sizing is overflow-checked and every malloc/realloc is
// null-checked.

import "./option" as option;
import "./iterator" as iterator;

extern fn malloc(n: usize) -> *u8;
extern fn realloc(p: *u8, n: usize) -> *u8;
extern fn free(p: *u8);
extern fn memcpy(dest: *u8, src: *u8, n: usize) -> *u8;

pub struct Vec[T] {
    ptr: *T,
    len: usize,
    cap: usize,
}

fn max_usize() -> usize {
    return (0 as usize) -% (1 as usize);
}

fn checked_bytes[T](count: usize) -> usize {
    if count == (0 as usize) {
        return 0 as usize;
    }
    let elem: usize = #size_of::[T]();
    assert elem != (0 as usize);
    assert count <= (max_usize() / elem);
    return count *% elem;
}

fn required_len(len: usize, additional: usize) -> usize {
    assert additional <= (max_usize() -% len);
    return len +% additional;
}

fn next_capacity(current: usize, required: usize) -> usize {
    assert required > current;
    let mut out: usize = current;
    if out == (0 as usize) {
        out = 1 as usize;
    }
    while out < required {
        if out > (max_usize() / (2 as usize)) {
            out = required;
        } else {
            out = out *% (2 as usize);
        }
    }
    return out;
}

pub fn new[T]() -> Vec[T] {
    return Vec[T] {
        ptr: unsafe { 0 as *T },
        len: 0 as usize,
        cap: 0 as usize,
    };
}

pub fn with_capacity[T](n: usize) -> Vec[T] {
    if n == (0 as usize) {
        return new::[T]();
    }
    let bytes: usize = checked_bytes::[T](n);
    let raw: *u8 = unsafe { malloc(bytes) };
    assert raw.is_not_null();
    return Vec[T] {
        ptr: unsafe { raw as *T },
        len: 0 as usize,
        cap: n,
    };
}

impl Vec[T] {
    fn grow_to(mut this, new_cap: usize) {
        assert new_cap > this.cap;
        let bytes: usize = checked_bytes::[T](new_cap);
        let raw: *u8 = unsafe { realloc(this.ptr as *u8, bytes) };
        assert raw.is_not_null();
        this.ptr = unsafe { raw as *T };
        this.cap = new_cap;
        return;
    }

    pub fn len(this) -> usize {
        return this.len;
    }

    pub fn capacity(this) -> usize {
        return this.cap;
    }

    pub fn is_empty(this) -> bool {
        return this.len == (0 as usize);
    }

    pub fn reserve(mut this, additional: usize) {
        let required: usize = required_len(this.len, additional);
        if required <= this.cap {
            return;
        }
        this.grow_to(next_capacity(this.cap, required));
        return;
    }

    pub fn push(mut this, value: T) {
        let required: usize = required_len(this.len, 1 as usize);
        if required > this.cap {
            this.grow_to(next_capacity(this.cap, required));
        }
        let slot: *T = unsafe { this.ptr + this.len };
        unsafe { *slot = value; }
        this.len = required;
        return;
    }

    pub fn pop(mut this) -> option::Option[T] {
        if this.len == (0 as usize) {
            return option::Option[T]::None;
        }
        let new_len: usize = this.len -% (1 as usize);
        let slot: *T = unsafe { this.ptr + new_len };
        let value: T = unsafe { *slot };
        this.len = new_len;
        return option::Option[T]::Some(value);
    }

    pub fn swap_remove(mut this, i: usize) -> option::Option[T] {
        if i >= this.len {
            return option::Option[T]::None;
        }
        let last: usize = this.len -% (1 as usize);
        let slot: *T = unsafe { this.ptr + i };
        let value: T = unsafe { *slot };
        if i != last {
            let last_slot: *T = unsafe { this.ptr + last };
            unsafe { *slot = *last_slot; }
        }
        this.len = last;
        return option::Option[T]::Some(value);
    }

    pub fn clear(mut this) {
        let mut i: usize = 0 as usize;
        while i < this.len {
            let elem: *T = unsafe { this.ptr + i };
            unsafe { #drop_in_place::[T](elem); }
            i = i +% (1 as usize);
        }
        this.len = 0 as usize;
        return;
    }

    pub fn truncate(mut this, new_len: usize) {
        if new_len >= this.len {
            return;
        }
        let mut i: usize = new_len;
        while i < this.len {
            let elem: *T = unsafe { this.ptr + i };
            unsafe { #drop_in_place::[T](elem); }
            i = i +% (1 as usize);
        }
        this.len = new_len;
        return;
    }

    pub fn shrink_to_fit(mut this) {
        if this.len == this.cap {
            return;
        }
        if this.len == (0 as usize) {
            if this.ptr.is_not_null() {
                unsafe { free(this.ptr as *u8); }
            }
            this.ptr = unsafe { 0 as *T };
            this.cap = 0 as usize;
            return;
        }
        let bytes: usize = checked_bytes::[T](this.len);
        let raw: *u8 = unsafe { realloc(this.ptr as *u8, bytes) };
        assert raw.is_not_null();
        this.ptr = unsafe { raw as *T };
        this.cap = this.len;
        return;
    }

    pub fn as_slice(this) -> T[] {
        return unsafe { #slice_from_raw_parts(this.ptr, this.len) };
    }

    // Pointer to element `i`, bounds-checked (None past the end).
    //
    // This is the read path for NON-Copy elements, where `get`'s `T: Copy`
    // bound does not apply. It hands back a raw `*T` into live storage, not an
    // owned `T`, so there is no copy-out and no drop-flag hazard: the Vec keeps
    // sole ownership, and a `*T` is never dropped. Reading through the pointer
    // is `unsafe` only because, with no language-level element borrowing, the
    // deref is unchecked:
    //
    //     match v.at(i) {
    //         option::Option[*T]::Some(p) => { let n = unsafe { (*p).field }; ... }
    //         option::Option[*T]::None    => { ... }
    //     }
    pub fn at(this, i: usize) -> option::Option[*T] {
        if i >= this.len {
            return option::Option[*T]::None;
        }
        return option::Option[*T]::Some(unsafe { this.ptr + i });
    }

    // Replace element `i` with `value`, dropping the element previously there.
    // Asserts the index is in bounds. Works for any `T`: the old element's Drop
    // runs (freeing e.g. a `string`'s buffer) before the new value is moved in,
    // so there is no leak and no double free.
    pub fn set(mut this, i: usize, value: T) {
        assert i < this.len;
        let slot: *T = unsafe { this.ptr + i };
        unsafe { #drop_in_place::[T](slot); }
        unsafe { *slot = value; }
        return;
    }

    // Yield each element by value, in order, as an `Iterator[T]` (drives for-in
    // and the iterator adapters). Intended for Copy `T`: iteration copies each
    // element out, so for a non-Copy `T` the yielded value would alias storage —
    // read those by index through `at` instead. This is a gen *method* (receiver
    // by value), not a `[T: Copy]` free fn, because the coroutine must own the
    // receiver across yields; a borrowed param does not survive suspension.
    pub gen fn iter(this) -> T {
        let mut i: usize = 0 as usize;
        while i < this.len {
            match this.at(i) {
                option::Option[*T]::Some(p) => { yield unsafe { *p }; }
                option::Option[*T]::None => { return; }
            }
            i = i +% (1 as usize);
        }
        return;
    }

    // Bulk-copy `count` elements from a raw pointer (bitwise). The caller is
    // responsible for `T` being bit-copyable, or for the source relinquishing
    // ownership; this runs no element clone or drop. Mirrors the old vec.cplus
    // method so byte-stream consumers (fs, appkit/convert) port unchanged.
    pub fn extend_from_raw(mut this, src: *T, count: usize) {
        if count == (0 as usize) {
            return;
        }
        let required: usize = required_len(this.len, count);
        if required > this.cap {
            this.grow_to(next_capacity(this.cap, required));
        }
        let dest: *T = unsafe { this.ptr + this.len };
        let bytes: usize = checked_bytes::[T](count);
        unsafe { memcpy(dest as *u8, src as *u8, bytes); }
        this.len = required;
        return;
    }

    fn drop(mut this) {
        let mut i: usize = 0 as usize;
        while i < this.len {
            let elem: *T = unsafe { this.ptr + i };
            unsafe { #drop_in_place::[T](elem); }
            i = i +% (1 as usize);
        }
        if this.ptr.is_not_null() {
            unsafe { free(this.ptr as *u8); }
        }
        return;
    }
}

pub fn get[T: Copy](borrow v: Vec[T], i: usize) -> option::Option[T] {
    if i >= v.len {
        return option::Option[T]::None;
    }
    let slot: *T = unsafe { v.ptr + i };
    return option::Option[T]::Some(unsafe { *slot });
}

// Like `get`, but asserts the index is in bounds and returns the element
// directly (no Option) — the safe, ergonomic "I know this index is valid" read,
// analogous to indexing. Copy-only (so the returned value is an independent copy,
// never an alias into storage) and bounds-checked (aborts on out-of-bounds).
pub fn at_copy[T: Copy](borrow v: Vec[T], i: usize) -> T {
    assert i < v.len;
    let slot: *T = unsafe { v.ptr + i };
    return unsafe { *slot };
}

pub fn extend_from_slice[T: Copy](mut v: Vec[T], s: T[]) {
    let count: usize = #slice_len(s);
    if count == (0 as usize) {
        return;
    }
    let required: usize = required_len(v.len, count);
    if required > v.cap {
        v.grow_to(next_capacity(v.cap, required));
    }
    let dest: *T = unsafe { v.ptr + v.len };
    let src: *T = unsafe { #slice_ptr(s) };
    let bytes: usize = checked_bytes::[T](count);
    unsafe { memcpy(dest as *u8, src as *u8, bytes); }
    v.len = required;
    return;
}

pub fn collect[T](move source: iterator::Iterator[T]) -> Vec[T] {
    let mut out: Vec[T] = new::[T]();
    loop {
        match source.next() {
            option::Option[T]::Some(value) => { out.push(value); }
            option::Option[T]::None => { return out; }
        }
    }
    return out;
}
