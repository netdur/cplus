// stdlib/vec.cplus — growable, heap-backed buffer.
//
// `Vec[T]` owns its allocation; Drop frees it. `push` doubles capacity on
// overflow (1 → 2 → 4 → ...). `as_slice` borrows the live region as a `T[]`.
//
// API note: the v0.0.3 stdlib exposes constructors as **free functions**
// (`vec::new[T]()`, `vec::with_capacity[T](n)`) rather than associated
// functions (`Vec[T]::new()`). The latter is blocked on a Phase-7 polish
// item — module-qualified generic associated-fn calls (`mod::Type[args]::method()`)
// don't yet resolve. Free functions avoid the limitation cleanly and
// match Zig/Go conventions. The associated-fn shape lands when the
// resolver-side support is wired.

// v0.0.5 Phase 3 Slice 3A: gen-method `iter` returns `Iterator[T]`;
// importing `iterator` brings the template into scope so the wrap
// resolves at sig-collection time.
import "./iterator" as iterator;
// v0.0.5 Phase 3 Slice 3C follow-on: `collect` consumes an Iterator[T]
// into a fresh Vec[T]. Lives in vec.cplus (not iterator.cplus) to
// avoid the iterator↔vec circular import that an `impl Iterator[T]`
// method would force.
import "./option" as option;

extern fn malloc(n: usize) -> *u8;
extern fn realloc(p: *u8, n: usize) -> *u8;
extern fn free(p: *u8);
extern fn memcpy(dest: *u8, src: *u8, n: usize) -> *u8;

pub struct Vec[T] {
    ptr: *T,
    len: usize,
    cap: usize,
}

// Empty Vec, no allocation. Drop's free is a no-op when `cap == 0`.
pub fn new[T]() -> Vec[T] {
    return Vec[T] { ptr: unsafe { 0 as *T }, len: 0 as usize, cap: 0 as usize };
}

// v0.0.5 Phase 3 Slice 3C follow-on: drain an Iterator[T] into a
// fresh Vec[T]. Consumes the iterator (`move source`). The natural
// home would be `impl Iterator[T]::collect_to_vec(move self) -> Vec[T]`
// but iterator.cplus can't `import "./vec"` without a circular dep,
// so we expose it as a free fn here. Call: `vec::collect::[i32](v.iter())`.
pub fn collect[T](move source: iterator::Iterator[T]) -> Vec[T] {
    let mut out: Vec[T] = new::[T]();
    loop {
        match source.next() {
            option::Option[T]::Some(x) => { out.push(x); }
            option::Option[T]::None => { return out; }
        }
    }
    return out;
}

// Pre-allocate room for `n` elements (len stays 0).
pub fn with_capacity[T](n: usize) -> Vec[T] {
    let bytes: usize = n *% #size_of::[T]();
    let raw: *u8 = unsafe { malloc(bytes) };
    return Vec[T] { ptr: unsafe { raw as *T }, len: 0 as usize, cap: n };
}

impl Vec[T] {
    // Append one element. Doubles capacity when full (0 → 1 → 2 → 4 → ...).
    pub fn push(mut self, x: T) {
        if self.len == self.cap {
            let mut new_cap: usize = self.cap *% (2 as usize);
            if new_cap == (0 as usize) {
                new_cap = 1 as usize;
            }
            let new_bytes: usize = new_cap *% #size_of::[T]();
            let raw: *u8 = unsafe { realloc(self.ptr as *u8, new_bytes) };
            self.ptr = unsafe { raw as *T };
            self.cap = new_cap;
        }
        let slot: *T = unsafe { self.ptr + self.len };
        unsafe { *slot = x; }
        self.len = self.len +% (1 as usize);
        return;
    }

    // Ensure capacity for at least `additional` more elements beyond
    // `len`. If the current capacity already suffices, this is a no-op.
    // Otherwise grows the buffer to fit `len + additional` exactly —
    // no extra slack. Use `reserve(n)` upfront when you know you'll
    // push `n` elements to skip the log2(n) realloc cascade `push`
    // would otherwise pay (v0.0.4 Phase 3 Slice 3B.2).
    pub fn reserve(mut self, additional: usize) {
        let required: usize = self.len +% additional;
        if required <= self.cap {
            return;
        }
        let new_bytes: usize = required *% #size_of::[T]();
        let raw: *u8 = unsafe { realloc(self.ptr as *u8, new_bytes) };
        self.ptr = unsafe { raw as *T };
        self.cap = required;
        return;
    }

    // Drop the last element (no return). Use `get(len - 1)` first if needed.
    // Returns true iff something was popped.
    pub fn pop(mut self) -> bool {
        if self.len == (0 as usize) {
            return false;
        }
        self.len = self.len -% (1 as usize);
        return true;
    }

    // Bulk-copy elements from a raw pointer.
    pub fn extend_from_raw(mut self, src: *T, count: usize) {
        if count == (0 as usize) {
            return;
        }
        let required: usize = self.len +% count;
        if required > self.cap {
            let mut new_cap: usize = self.cap *% (2 as usize);
            if new_cap < required {
                new_cap = required;
            }
            if new_cap == (0 as usize) {
                new_cap = required;
            }
            let new_bytes: usize = new_cap *% #size_of::[T]();
            let raw: *u8 = unsafe { realloc(self.ptr as *u8, new_bytes) };
            self.ptr = unsafe { raw as *T };
            self.cap = new_cap;
        }
        let dest: *T = unsafe { self.ptr + self.len };
        let bytes_to_copy: usize = count *% #size_of::[T]();
        unsafe { memcpy(dest as *u8, src as *u8, bytes_to_copy); }
        self.len = required;
        return;
    }

    // v0.0.4 Phase 3 Slice 3B.3: slice-typed wrapper over `extend_from_raw`.
    // Same single-realloc + single-memcpy lowering, but the caller passes a
    // slice (fat pointer with bounds-known length) instead of a raw pointer
    // + count. Safer in practice — slice length comes from the producer, not
    // from a user-side `count` that can drift.
    pub fn extend_from_slice(mut self, s: T[]) {
        let p: *T = unsafe { #slice_ptr(s) };
        let n: usize = #slice_len(s);
        self.extend_from_raw(p, n);
        return;
    }

    // Drop all elements (running inner-T Drop on each) and reset `len`
    // to 0. Allocation is retained — the buffer keeps its capacity so
    // subsequent pushes don't re-malloc. Useful as a per-iteration
    // reset in chunked readers (File::lines's carry-over, etc.).
    pub fn clear(mut self) {
        let mut i: usize = 0 as usize;
        while i < self.len {
            let elem_ptr: *T = unsafe { self.ptr + i };
            unsafe { __cplus_drop_in_place::[T](elem_ptr); }
            i = i +% (1 as usize);
        }
        self.len = 0 as usize;
        return;
    }

    pub fn len(self) -> usize {
        return self.len;
    }

    pub fn capacity(self) -> usize {
        return self.cap;
    }

    // Read element `i`. Bounds check is the caller's job for now.
    pub fn get(self, i: usize) -> T {
        let p: *T = unsafe { self.ptr + i };
        return unsafe { *p };
    }

    // Borrow the live region as a slice.
    pub fn as_slice(self) -> T[] {
        return unsafe { #slice_from_raw_parts(self.ptr, self.len) };
    }

    // v0.0.5 Phase 3 Slice 3A: iterator-style traversal. Yields each
    // live element by value; for non-Copy T the receiver's storage
    // stays intact (`get` reads through the raw pointer, not move out).
    pub gen fn iter(self) -> T {
        let mut i: usize = 0 as usize;
        while i < self.len {
            yield self.get(i);
            i = i +% (1 as usize);
        }
        return;
    }

    // Destructor: walk live elements invoking inner-T Drop, then free
    // the heap buffer. v0.0.5 Phase 1C closes the v0.0.4 leak where
    // `Vec[string]` / `Vec[Vec[U]]` / `Vec[MyStructWithDrop]` leaked
    // every element's resources.
    fn drop(mut self) {
        if self.cap == (0 as usize) { return; }
        let mut i: usize = 0 as usize;
        while i < self.len {
            let elem_ptr: *T = unsafe { self.ptr + i };
            unsafe { __cplus_drop_in_place::[T](elem_ptr); }
            i = i +% (1 as usize);
        }
        unsafe { free(self.ptr as *u8); }
        return;
    }
}
