// stdlib/vec.cplus -- ownership-safe growable vector.
//
// The core API rule is: a generic Vec[T] never bitwise-copies a T out of
// storage. Operations that yield an owned element either remove it first
// (`pop`, `swap_remove`), or require `T: Copy` at the boundary (`get`,
// `at_copy`, `extend_from_slice`). To READ a non-Copy element in place, use
// `at(i) -> Option[*T]` (a bounds-checked pointer; deref is `unsafe` because
// the language has no element borrowing yet). `iter` is a gen method intended
// for Copy `T` (it copies each element out); iterate non-Copy vectors by index
// via `at`. Allocation sizing is overflow-checked and every malloc/realloc is
// null-checked.

import "./option" as option;
import "./iterator" as iterator;
import "./status" as status;

extern fn malloc(n: usize) -> *u8;
extern fn realloc(p: *u8, n: usize) -> *u8;
extern fn free(p: *u8);
extern fn memcpy(dest: *u8, src: *u8, n: usize) -> *u8;

struct Vec[T] {
    ptr: *T,
    len: usize,
    cap: usize,
}

fn max_usize() -> usize {
    return (0 as usize) -% (1 as usize);
}

// Bytes needed for `count` elements of `T`, or None if the multiplication would
// overflow `usize` — a request too large to ever satisfy. A zero count or a
// zero-size element needs zero bytes. Callers treat None as "out of memory" and
// recover, rather than trapping on the overflow.
fn checked_bytes[T](count: usize) -> option::Option[usize] {
    if count == (0 as usize) {
        return option::Option[usize]::Some(0 as usize);
    }
    let elem: usize = #size_of::[T]();
    if elem == (0 as usize) {
        return option::Option[usize]::Some(0 as usize);
    }
    if count > (max_usize() / elem) {
        return option::Option[usize]::None;
    }
    return option::Option[usize]::Some(count *% elem);
}

// `len + additional`, or None if it would overflow `usize`.
fn required_len(len: usize, additional: usize) -> option::Option[usize] {
    if additional > (max_usize() -% len) {
        return option::Option[usize]::None;
    }
    return option::Option[usize]::Some(len +% additional);
}

// Next capacity at least `required`, doubling from `current`. If `required` is
// already within `current` there is nothing to grow, so `current` is returned.
fn next_capacity(current: usize, required: usize) -> usize {
    if required <= current {
        return current;
    }
    var out: usize = current;
    if out == (0 as usize) {
        out = 1 as usize;
    }
    while out < required {
        if out > (max_usize() / (2 as usize)) {
            out = required;
        } else {
            out = out *% (2 as usize);
        }
    }
    return out;
}

fn new[T]() -> Vec[T] {
    return Vec[T] {
        ptr: { 0 as *T },
        len: 0 as usize,
        cap: 0 as usize,
    };
}

// Pre-allocate room for `n` elements. A value producer, so it recovers rather
// than reports: if the request overflows or the allocation fails, it returns a
// valid empty vec (capacity 0) instead of trapping. A later `push` will try to
// allocate again and surface the failure as a `Status` then.
fn with_capacity[T](n: usize) -> Vec[T] {
    if n == (0 as usize) {
        return new::[T]();
    }
    var bytes: usize = 0 as usize;
    match checked_bytes::[T](n) {
        option::Option[usize]::Some(b) => { bytes = b; }
        option::Option[usize]::None => { return new::[T](); }
    }
    let raw: *u8 = { malloc(bytes) };
    if raw.is_not_null() {
        return Vec[T] {
            ptr: { raw as *T },
            len: 0 as usize,
            cap: n,
        };
    }
    return new::[T]();
}

impl Vec[T] {
    // Grow the backing allocation to hold at least `new_cap` elements. Returns
    // `OutOfMemory` (leaving the vec unchanged and valid) if the size overflows
    // or `realloc` fails; `Ok` otherwise. A `new_cap` already within capacity is
    // a no-op `Ok`.
    fn grow_to(ref this, new_cap: usize) -> status::Status {
        if new_cap <= this.cap {
            return status::Status::Ok;
        }
        var bytes: usize = 0 as usize;
        match checked_bytes::[T](new_cap) {
            option::Option[usize]::Some(b) => { bytes = b; }
            option::Option[usize]::None => { return status::Status::OutOfMemory; }
        }
        let raw: *u8 = { realloc(this.ptr as *u8, bytes) };
        if raw.is_not_null() {
            this.ptr = { raw as *T };
            this.cap = new_cap;
            return status::Status::Ok;
        }
        return status::Status::OutOfMemory;
    }

    fn len(this) -> usize {
        return this.len;
    }

    fn capacity(this) -> usize {
        return this.cap;
    }

    fn is_empty(this) -> bool {
        return this.len == (0 as usize);
    }

    // Ensure room for `additional` more elements. Returns `OutOfMemory` (vec
    // unchanged) if the new length overflows or the allocation fails.
    fn reserve(ref this, additional: usize) -> status::Status {
        var required: usize = 0 as usize;
        match required_len(this.len, additional) {
            option::Option[usize]::Some(r) => { required = r; }
            option::Option[usize]::None => { return status::Status::OutOfMemory; }
        }
        if required <= this.cap {
            return status::Status::Ok;
        }
        return this.grow_to(next_capacity(this.cap, required));
    }

    // Append `value`. On success returns `Ok`. If the vec cannot grow (length
    // overflow or allocation failure) it returns `OutOfMemory`, leaving the vec
    // unchanged; `value` is dropped as the function returns, so nothing leaks
    // and there is no partial state. The caller may check the status or ignore
    // it — either way the vec stays valid.
    fn push(ref this, take value: T) -> status::Status {
        var required: usize = 0 as usize;
        match required_len(this.len, 1 as usize) {
            option::Option[usize]::Some(r) => { required = r; }
            option::Option[usize]::None => { return status::Status::OutOfMemory; }
        }
        if required > this.cap {
            let st: status::Status = this.grow_to(next_capacity(this.cap, required));
            if st != status::Status::Ok {
                return st;
            }
        }
        let slot: *T = { this.ptr + this.len };
        { *slot = value; }
        this.len = required;
        return status::Status::Ok;
    }

    fn pop(ref this) -> option::Option[T] {
        if this.len == (0 as usize) {
            return option::Option[T]::None;
        }
        let new_len: usize = this.len -% (1 as usize);
        let slot: *T = { this.ptr + new_len };
        let value: T = { *slot };
        this.len = new_len;
        return option::Option[T]::Some(value);
    }

    fn swap_remove(ref this, i: usize) -> option::Option[T] {
        if i >= this.len {
            return option::Option[T]::None;
        }
        let last: usize = this.len -% (1 as usize);
        let slot: *T = { this.ptr + i };
        let value: T = { *slot };
        if i != last {
            let last_slot: *T = { this.ptr + last };
            { *slot = *last_slot; }
        }
        this.len = last;
        return option::Option[T]::Some(value);
    }

    fn clear(ref this) {
        var i: usize = 0 as usize;
        while i < this.len {
            let elem: *T = { this.ptr + i };
            { #drop_in_place::[T](elem); }
            i = i +% (1 as usize);
        }
        this.len = 0 as usize;
        return;
    }

    fn truncate(ref this, new_len: usize) {
        if new_len >= this.len {
            return;
        }
        var i: usize = new_len;
        while i < this.len {
            let elem: *T = { this.ptr + i };
            { #drop_in_place::[T](elem); }
            i = i +% (1 as usize);
        }
        this.len = new_len;
        return;
    }

    // Release unused capacity. If the shrinking `realloc` fails, the larger
    // buffer is kept (the data is intact) and `OutOfMemory` is returned; `Ok`
    // otherwise. Never traps.
    fn shrink_to_fit(ref this) -> status::Status {
        if this.len == this.cap {
            return status::Status::Ok;
        }
        if this.len == (0 as usize) {
            if this.ptr.is_not_null() {
                { free(this.ptr as *u8); }
            }
            this.ptr = { 0 as *T };
            this.cap = 0 as usize;
            return status::Status::Ok;
        }
        var bytes: usize = 0 as usize;
        match checked_bytes::[T](this.len) {
            option::Option[usize]::Some(b) => { bytes = b; }
            option::Option[usize]::None => { return status::Status::OutOfMemory; }
        }
        let raw: *u8 = { realloc(this.ptr as *u8, bytes) };
        if raw.is_not_null() {
            this.ptr = { raw as *T };
            this.cap = this.len;
            return status::Status::Ok;
        }
        return status::Status::OutOfMemory;
    }

    fn as_slice(this) -> T[] {
        return { #slice_from_raw_parts(this.ptr, this.len) };
    }

    // Pointer to element `i`, bounds-checked (None past the end).
    //
    // This is the read path for NON-Copy elements, where `get`'s `T: Copy`
    // bound does not apply. It hands back a raw `*T` into live storage, not an
    // owned `T`, so there is no copy-out and no drop-flag hazard: the Vec keeps
    // sole ownership, and a `*T` is never dropped. Reading through the pointer
    // is `unsafe` only because, with no language-level element borrowing, the
    // deref is unchecked:
    //
    //     match v.at(i) {
    //         option::Option[*T]::Some(p) => { let n = { (*p).field }; ... }
    //         option::Option[*T]::None    => { ... }
    //     }
    fn at(this, i: usize) -> option::Option[*T] {
        if i >= this.len {
            return option::Option[*T]::None;
        }
        return option::Option[*T]::Some({ this.ptr + i });
    }

    // Replace element `i` with `value`. Out of bounds is reported, not trapped:
    // returns `OutOfBounds` when `i >= len` — `value` is dropped as the function
    // returns, the vec is left unchanged, nothing leaks — and `Ok` on success.
    // On success the previous element's Drop runs before the new value is moved
    // in, so there is no leak and no double free. The caller may check the
    // status or ignore it; the vec stays valid either way.
    fn set(ref this, i: usize, take value: T) -> status::Status {
        if i >= this.len {
            return status::Status::OutOfBounds;
        }
        let slot: *T = { this.ptr + i };
        { #drop_in_place::[T](slot); }
        { *slot = value; }
        return status::Status::Ok;
    }

    // Yield each element by value, in order, as an `Iterator[T]` (drives for-in
    // and the iterator adapters). Intended for Copy `T`: iteration copies each
    // element out, so for a non-Copy `T` the yielded value would alias storage —
    // read those by index through `at` instead. This is a gen *method* (receiver
    // by value), not a `[T: Copy]` free fn, because the coroutine must own the
    // receiver across yields; a borrowed param does not survive suspension.
    gen fn iter(this) -> T {
        var i: usize = 0 as usize;
        while i < this.len {
            match this.at(i) {
                option::Option[*T]::Some(p) => { yield { *p }; }
                option::Option[*T]::None => { return; }
            }
            i = i +% (1 as usize);
        }
        return;
    }

    // Bulk-copy `count` elements from a raw pointer (bitwise). The caller is
    // responsible for `T` being bit-copyable, or for the source relinquishing
    // ownership; this runs no element clone or drop. Mirrors the old vec.cplus
    // method so byte-stream consumers (fs, appkit/convert) port unchanged.
    fn extend_from_raw(ref this, src: *T, count: usize) -> status::Status {
        if count == (0 as usize) {
            return status::Status::Ok;
        }
        var required: usize = 0 as usize;
        match required_len(this.len, count) {
            option::Option[usize]::Some(r) => { required = r; }
            option::Option[usize]::None => { return status::Status::OutOfMemory; }
        }
        if required > this.cap {
            let st: status::Status = this.grow_to(next_capacity(this.cap, required));
            if st != status::Status::Ok {
                return st;
            }
        }
        let dest: *T = { this.ptr + this.len };
        var bytes: usize = 0 as usize;
        match checked_bytes::[T](count) {
            option::Option[usize]::Some(b) => { bytes = b; }
            option::Option[usize]::None => { return status::Status::OutOfMemory; }
        }
        { memcpy(dest as *u8, src as *u8, bytes); }
        this.len = required;
        return status::Status::Ok;
    }

    fn drop(ref this) {
        var i: usize = 0 as usize;
        while i < this.len {
            let elem: *T = { this.ptr + i };
            { #drop_in_place::[T](elem); }
            i = i +% (1 as usize);
        }
        if this.ptr.is_not_null() {
            { free(this.ptr as *u8); }
        }
        return;
    }
}

fn get[T: Copy](v: Vec[T], i: usize) -> option::Option[T] {
    if i >= v.len {
        return option::Option[T]::None;
    }
    let slot: *T = { v.ptr + i };
    return option::Option[T]::Some({ *slot });
}

// Like `get`, but asserts the index is in bounds and returns the element
// directly (no Option) — the safe, ergonomic "I know this index is valid" read,
// analogous to indexing. Copy-only (so the returned value is an independent copy,
// never an alias into storage) and bounds-checked (aborts on out-of-bounds).
fn at_copy[T: Copy](v: Vec[T], i: usize) -> T {
    assert i < v.len;
    let slot: *T = { v.ptr + i };
    return { *slot };
}

fn extend_from_slice[T: Copy](ref v: Vec[T], s: T[]) -> status::Status {
    let count: usize = #slice_len(s);
    if count == (0 as usize) {
        return status::Status::Ok;
    }
    var required: usize = 0 as usize;
    match required_len(v.len, count) {
        option::Option[usize]::Some(r) => { required = r; }
        option::Option[usize]::None => { return status::Status::OutOfMemory; }
    }
    if required > v.cap {
        let st: status::Status = v.grow_to(next_capacity(v.cap, required));
        if st != status::Status::Ok {
            return st;
        }
    }
    let dest: *T = { v.ptr + v.len };
    let src: *T = { #slice_ptr(s) };
    var bytes: usize = 0 as usize;
    match checked_bytes::[T](count) {
        option::Option[usize]::Some(b) => { bytes = b; }
        option::Option[usize]::None => { return status::Status::OutOfMemory; }
    }
    { memcpy(dest as *u8, src as *u8, bytes); }
    v.len = required;
    return status::Status::Ok;
}

fn collect[T](take source: iterator::Iterator[T]) -> Vec[T] {
    var out: Vec[T] = new::[T]();
    loop {
        match source.next() {
            option::Option[T]::Some(value) => { out.push(value); }
            option::Option[T]::None => { return out; }
        }
    }
    return out;
}
