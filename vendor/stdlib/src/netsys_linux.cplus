// stdlib/netsys_linux.cplus — Linux variant of netsys.cplus (loaded in
// place of it by the resolver's `_linux` platform-override). Exports the
// identical public surface with Linux/glibc values.

// Linux errno location: `int *__errno_location(void)`.
extern fn __errno_location() -> *i32;

// Current thread's errno value.
fn errno() -> i32 {
    let p: *i32 = { __errno_location() };
    return { *p };
}

// O_NONBLOCK for fcntl(F_SETFL). Linux: 04000 octal = 0x800.
fn o_nonblock() -> i32 { return 0x800 as i32; }

// EAGAIN (== EWOULDBLOCK on Linux): 11.
fn eagain() -> i32 { return 11 as i32; }

// setsockopt level / optname for SO_REUSEADDR. Linux (asm-generic):
// SOL_SOCKET=1, SO_REUSEADDR=2.
fn sol_socket() -> i32 { return 1 as i32; }
fn so_reuseaddr() -> i32 { return 2 as i32; }

// First two bytes of `sockaddr_in`. Linux has no `sin_len`: the struct
// starts with `sa_family_t sin_family` (a 2-byte field), so for AF_INET=2
// the little-endian bytes are [2, 0].
fn sa_family_byte0() -> u8 { return 2 as u8; }
fn sa_family_byte1() -> u8 { return 0 as u8; }

// POSIX raw-syscall shims used by net.cplus. Splitting these behind netsys
// keeps net.cplus platform-neutral: the Windows variant routes them to
// Winsock (recv/send/closesocket/ioctlsocket) instead.
extern fn read(fd: i32, buf: *u8, count: usize) -> isize;
extern fn write(fd: i32, buf: *u8, count: usize) -> isize;
extern fn close(fd: i32) -> i32;
// fcntl is variadic in libc — the third arg is read from the variadic area,
// not a fixed register. Declaring it fixed-arity silently breaks `F_SETFL`
// on AArch64-darwin where varargs come from the stack.
extern fn fcntl(fd: i32, cmd: i32, ...) -> i32;

fn recv_fd(fd: i32, buf: *u8, count: usize) -> isize {
    return { read(fd, buf, count) };
}

fn send_fd(fd: i32, buf: *u8, count: usize) -> isize {
    return { write(fd, buf, count) };
}

fn close_fd(fd: i32) -> i32 {
    return { close(fd) };
}

// F_GETFL / F_SETFL are 3 / 4 on both macOS and Linux.
fn f_getfl() -> i32 { return 3 as i32; }
fn f_setfl() -> i32 { return 4 as i32; }

// Flip O_NONBLOCK on fd via fcntl. Returns 0 on success, -1 on error.
// Idempotent — safe to call repeatedly on the same fd.
fn set_nonblocking(fd: i32) -> i32 {
    let flags: i32 = { fcntl(fd, f_getfl(), 0 as i32) };
    if flags < (0 as i32) {
        return 0 -% 1 as i32;
    }
    let new_flags: i32 = flags|o_nonblock();
    if new_flags == flags {
        return 0 as i32;
    }
    let rc: i32 = { fcntl(fd, f_setfl(), new_flags) };
    if rc < (0 as i32) {
        return 0 -% 1 as i32;
    }
    return 0 as i32;
}

// Socket subsystem init — a no-op on POSIX (matches Winsock's WSAStartup).
fn startup() -> i32 { return 0 as i32; }
