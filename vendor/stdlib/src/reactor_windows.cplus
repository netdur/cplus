// stdlib/reactor_windows.cplus — async event loop, Windows backend.
//
// Windows counterpart to reactor.cplus (kqueue/macOS) and
// reactor_linux.cplus (epoll/Linux). The resolver loads this file in place
// of reactor.cplus when the compiler targets Windows (the `_windows`
// platform-override convention — see resolver::platform_override). It exports
// the identical public surface:
//
//   - the `stdlib_reactor_*_v1` C-ABI symbols codegen emits calls to, and
//   - `pub fn poll_one_event` / `waiter_count`, which executor.cplus uses.
//
// so async lowering, executor::block_on, time::sleep and the cooperative
// primitives (yield_now / spawn_local / await chains) all work unchanged.
//
// **Readiness source: WSAPoll.** Socket/file readiness is wired through
// Winsock's `WSAPoll` — the level-triggered, *readiness* analogue of epoll
// (it reports a socket readable/writable without consuming any bytes, which
// is exactly what read_fd_async / write_fd_async need: they do their own
// recv/send after being woken). IOCP, by contrast, is a *completion* model
// and would consume the data the caller expects to read itself, so WSAPoll
// is the right fit for this reactor's contract. Timers and fd readiness
// share a single `WSAPoll` wait the same way the Linux backend unifies them
// under `epoll_wait`: the poll timeout is bounded by the earliest pending
// timer deadline, so a `time::sleep` and a pending socket read in one
// `block_on` both fire correctly.
//
// **Scope.** The pending-task queue and the awaiter table are pure
// bookkeeping (malloc/realloc + parallel arrays) and are copied from the
// other backends verbatim — they drive yield_now, spawn_local and await.
// Timers use the Win32 clock (`GetTickCount64`); when no fd is parked they
// fall back to a plain `Sleep` to the earliest deadline.
//
// **Socket handles.** Win32 `SOCKET` is a 64-bit `UINT_PTR`; the reactor
// stores fds as i32 to match the rest of stdlib, zero-extending into the
// 8-byte WSAPOLLFD slot. Valid for the small handles a normal process is
// handed (same assumption as netsys_windows / net.cplus).

extern fn malloc(n: usize) -> *u8;
extern fn realloc(p: *u8, n: usize) -> *u8;
extern fn free(p: *u8);

// Win32 timing primitives (kernel32, linked by default on windows-msvc).
extern fn Sleep(ms: u32);
extern fn GetTickCount64() -> u64;

// Winsock readiness wait + init (ws2_32). WSAPoll takes an array of
// WSAPOLLFD { SOCKET fd@0; SHORT events@8; SHORT revents@10; } (16 bytes
// each, 8-byte aligned), a count, and a millisecond timeout (-1 = infinite).
extern fn WSAPoll(fdarray: *u8, nfds: u32, timeout: i32) -> i32;
extern fn WSAStartup(version: u16, data: *u8) -> i32;

// LLVM coroutine intrinsics — surfaced via stable wrapper symbols emitted
// by codegen, so stdlib can call them as plain extern fns.
extern fn __cplus_coro_resume(hdl: *u8);
extern fn __cplus_coro_done(hdl: *u8) -> i32;

// Reactor-state-slot accessors emitted in the codegen preamble.
extern fn __cplus_reactor_get_state() -> *u8;
extern fn __cplus_reactor_set_state(p: *u8);

// WSAPOLLFD event bits. POLLRDNORM (read-ready) = 0x0100, POLLWRNORM
// (write-ready) = 0x0010. Stored per waiter and written into the events
// field; on return any non-zero revents (incl. POLLHUP/POLLERR) wakes it.
fn pollrdnorm() -> i16 { return 0x0100 as i16; }
fn pollwrnorm() -> i16 { return 0x0010 as i16; }

// Heap-block layout (Windows-private; only this module reads these offsets).
// Eight i32 counters, then eight pointers to the parallel arrays.
fn header_bytes() -> usize { return 96 as usize; }

fn off_n_waiters() -> usize { return 0 as usize; }
fn off_cap_waiters() -> usize { return 4 as usize; }
fn off_n_pending() -> usize { return 8 as usize; }
fn off_cap_pending() -> usize { return 12 as usize; }
fn off_n_timers() -> usize { return 16 as usize; }
fn off_cap_timers() -> usize { return 20 as usize; }
fn off_n_awaiters() -> usize { return 24 as usize; }
fn off_cap_awaiters() -> usize { return 28 as usize; }
fn off_waiter_fds() -> usize { return 32 as usize; }
fn off_waiter_hdls() -> usize { return 40 as usize; }
fn off_pending_hdls() -> usize { return 48 as usize; }
fn off_timer_deadlines() -> usize { return 56 as usize; }
fn off_timer_hdls() -> usize { return 64 as usize; }
fn off_awaitee_hdls() -> usize { return 72 as usize; }
fn off_awaiter_hdls() -> usize { return 80 as usize; }
// Per-waiter WSAPOLLFD events mask (i16), parallel to waiter_fds/_hdls.
fn off_waiter_evmask() -> usize { return 88 as usize; }

fn ptr_is_null(p: *u8) -> bool {
    let null_p: *u8 = { 0 as *u8 };
    return p == null_p;
}

// Lazily allocate + init the reactor on first use. Idempotent.
fn ensure() -> *u8 {
    let cur: *u8 = { #reactor_get_state() };
    if !ptr_is_null(cur) { return cur; }
    let state: *u8 = { malloc(header_bytes()) };
    let nw_slot: *i32 = { (state + off_n_waiters()) as *i32 };
    { *nw_slot = 0 as i32; }
    let cw_slot: *i32 = { (state + off_cap_waiters()) as *i32 };
    { *cw_slot = 8 as i32; }
    let np_slot: *i32 = { (state + off_n_pending()) as *i32 };
    { *np_slot = 0 as i32; }
    let cp_slot: *i32 = { (state + off_cap_pending()) as *i32 };
    { *cp_slot = 8 as i32; }
    let nt_slot: *i32 = { (state + off_n_timers()) as *i32 };
    { *nt_slot = 0 as i32; }
    let ct_slot: *i32 = { (state + off_cap_timers()) as *i32 };
    { *ct_slot = 8 as i32; }
    let na_slot: *i32 = { (state + off_n_awaiters()) as *i32 };
    { *na_slot = 0 as i32; }
    let ca_slot: *i32 = { (state + off_cap_awaiters()) as *i32 };
    { *ca_slot = 8 as i32; }
    let wf_slot: **u8 = { (state + off_waiter_fds()) as **u8 };
    { *wf_slot = malloc((8 *% 4) as usize); }
    let wh_slot: **u8 = { (state + off_waiter_hdls()) as **u8 };
    { *wh_slot = malloc((8 *% 8) as usize); }
    let wm_slot: **u8 = { (state + off_waiter_evmask()) as **u8 };
    { *wm_slot = malloc((8 *% 2) as usize); }
    let ph_slot: **u8 = { (state + off_pending_hdls()) as **u8 };
    { *ph_slot = malloc((8 *% 8) as usize); }
    let td_slot: **u8 = { (state + off_timer_deadlines()) as **u8 };
    { *td_slot = malloc((8 *% 8) as usize); }
    let th_slot: **u8 = { (state + off_timer_hdls()) as **u8 };
    { *th_slot = malloc((8 *% 8) as usize); }
    let ae_slot: **u8 = { (state + off_awaitee_hdls()) as **u8 };
    { *ae_slot = malloc((8 *% 8) as usize); }
    let ar_slot: **u8 = { (state + off_awaiter_hdls()) as **u8 };
    { *ar_slot = malloc((8 *% 8) as usize); }
    // Bring Winsock up so WSAPoll is usable even if the reactor is driven
    // before net's own WSAStartup. Refcounted by the OS; safe to repeat.
    let wsad: *u8 = { malloc(512 as usize) };
    { WSAStartup(0x0202 as u16, wsad); }
    { free(wsad); }
    { #reactor_set_state(state); }
    return state;
}

export extern fn stdlib_reactor_register_read_v1(fd: i32, hdl: *u8) {
    register_read(fd, hdl);
    return;
}

export extern fn stdlib_reactor_register_write_v1(fd: i32, hdl: *u8) {
    register_write(fd, hdl);
    return;
}

export extern fn stdlib_reactor_register_timer_v1(ms: u64, hdl: *u8) {
    register_timer(ms, hdl);
    return;
}

export extern fn stdlib_reactor_register_awaiter_v1(awaitee: *u8, awaiter: *u8) {
    register_awaiter(awaitee, awaiter);
    return;
}

export extern fn stdlib_reactor_notify_completed_v1(awaitee: *u8) {
    notify_completed(awaitee);
    return;
}

export extern fn stdlib_reactor_enqueue_pending_v1(hdl: *u8) {
    enqueue_pending(hdl);
    return;
}

export extern fn stdlib_reactor_drain_pending_v1() -> i32 {
    return drain_pending();
}

export extern fn stdlib_reactor_waiter_count_v1() -> i32 {
    return waiter_count();
}

export extern fn stdlib_reactor_poll_one_event_v1() -> i32 {
    if poll_one_event() {
        return 1 as i32;
    }
    return 0 as i32;
}

// Register fd for read-readiness; record the coroutine handle to wake.
fn register_read(fd: i32, hdl: *u8) {
    register_fd(fd, hdl, pollrdnorm());
    return;
}

// Register fd for write-readiness.
fn register_write(fd: i32, hdl: *u8) {
    register_fd(fd, hdl, pollwrnorm());
    return;
}

// Append a (fd, hdl, events) triple to the waiter arrays. `poll_one_event`
// builds a WSAPOLLFD array from these and matches the firing fd back.
fn register_fd(fd: i32, hdl: *u8, evmask: i16) {
    let state: *u8 = ensure();
    let nw_slot: *i32 = { (state + off_n_waiters()) as *i32 };
    let cw_slot: *i32 = { (state + off_cap_waiters()) as *i32 };
    let wf_slot: **u8 = { (state + off_waiter_fds()) as **u8 };
    let wh_slot: **u8 = { (state + off_waiter_hdls()) as **u8 };
    let wm_slot: **u8 = { (state + off_waiter_evmask()) as **u8 };
    var n: i32 = { *nw_slot };
    var cap: i32 = { *cw_slot };
    if n == cap {
        cap = cap *% (2 as i32);
        let new_fds: *u8 = { realloc(*wf_slot, (cap *% 4) as usize) };
        let new_hdls: *u8 = { realloc(*wh_slot, (cap *% 8) as usize) };
        let new_masks: *u8 = { realloc(*wm_slot, (cap *% 2) as usize) };
        { *wf_slot = new_fds; }
        { *wh_slot = new_hdls; }
        { *wm_slot = new_masks; }
        { *cw_slot = cap; }
    }
    let fds: *i32 = { *wf_slot as *i32 };
    let hdls: **u8 = { *wh_slot as **u8 };
    let masks: *i16 = { *wm_slot as *i16 };
    { *(fds + (n as usize)) = fd; }
    { *(hdls + (n as usize)) = hdl; }
    { *(masks + (n as usize)) = evmask; }
    { *nw_slot = n +% (1 as i32); }
    return;
}

// Register a one-shot timer that fires `ms` milliseconds from now and
// resumes `hdl`. Stored as an absolute Win32 tick deadline; poll_one_event
// bounds its wait by the earliest deadline and resumes its handle.
fn register_timer(ms: u64, hdl: *u8) {
    let state: *u8 = ensure();
    let nt_slot: *i32 = { (state + off_n_timers()) as *i32 };
    let ct_slot: *i32 = { (state + off_cap_timers()) as *i32 };
    let td_slot: **u8 = { (state + off_timer_deadlines()) as **u8 };
    let th_slot: **u8 = { (state + off_timer_hdls()) as **u8 };
    var n: i32 = { *nt_slot };
    var cap: i32 = { *ct_slot };
    if n == cap {
        cap = cap *% (2 as i32);
        let new_d: *u8 = { realloc(*td_slot, (cap *% 8) as usize) };
        let new_h: *u8 = { realloc(*th_slot, (cap *% 8) as usize) };
        { *td_slot = new_d; }
        { *th_slot = new_h; }
        { *ct_slot = cap; }
    }
    let now: u64 = { GetTickCount64() };
    let deadline: u64 = now +% ms;
    let deadlines: *u64 = { *td_slot as *u64 };
    let hdls: **u8 = { *th_slot as **u8 };
    { *(deadlines + (n as usize)) = deadline; }
    { *(hdls + (n as usize)) = hdl; }
    { *nt_slot = n +% (1 as i32); }
    return;
}

// Index of the timer with the earliest deadline (caller guarantees n>0).
fn earliest_timer(state: *u8) -> i32 {
    let nt_slot: *i32 = { (state + off_n_timers()) as *i32 };
    let n: i32 = { *nt_slot };
    let td_slot: **u8 = { (state + off_timer_deadlines()) as **u8 };
    let deadlines: *u64 = { *td_slot as *u64 };
    var best: i32 = 0;
    var best_dl: u64 = { *(deadlines + (0 as usize)) };
    var i: i32 = 1;
    while i < n {
        let dl: u64 = { *(deadlines + (i as usize)) };
        if dl < best_dl {
            best_dl = dl;
            best = i;
        }
        i = i +% (1 as i32);
    }
    return best;
}

// Resume the earliest timer (sleeping to its deadline first if it has not
// yet elapsed) and swap-remove it. Caller guarantees n_timers > 0.
fn fire_earliest_timer(state: *u8) -> bool {
    let nt_slot: *i32 = { (state + off_n_timers()) as *i32 };
    let n: i32 = { *nt_slot };
    let td_slot: **u8 = { (state + off_timer_deadlines()) as **u8 };
    let th_slot: **u8 = { (state + off_timer_hdls()) as **u8 };
    let deadlines: *u64 = { *td_slot as *u64 };
    let hdls: **u8 = { *th_slot as **u8 };
    let best: i32 = earliest_timer(state);
    let best_dl: u64 = { *(deadlines + (best as usize)) };
    let now: u64 = { GetTickCount64() };
    if best_dl > now {
        { Sleep((best_dl -% now) as u32); }
    }
    let hdl: *u8 = { *(hdls + (best as usize)) };
    let last_i: i32 = n -% (1 as i32);
    if best != last_i {
        let last_dl: u64 = { *(deadlines + (last_i as usize)) };
        let last_hdl: *u8 = { *(hdls + (last_i as usize)) };
        { *(deadlines + (best as usize)) = last_dl; }
        { *(hdls + (best as usize)) = last_hdl; }
    }
    { *nt_slot = last_i; }
    { #coro_resume(hdl); }
    return true;
}

// Wait for one event — a ready fd or an elapsed timer — and resume its
// waiter. With fd waiters parked, blocks on WSAPoll bounded by the earliest
// timer deadline; with timers only, sleeps to the deadline. Returns true if
// a coroutine was resumed.
fn poll_one_event() -> bool {
    let state: *u8 = ensure();
    let nw_slot: *i32 = { (state + off_n_waiters()) as *i32 };
    let nt_slot: *i32 = { (state + off_n_timers()) as *i32 };
    let nw: i32 = { *nw_slot };
    let nt: i32 = { *nt_slot };
    if nw == (0 as i32) {
        if nt == (0 as i32) { return false; }
        return fire_earliest_timer(state);
    }
    // Bound the wait by the earliest timer (so timers + I/O share one wait);
    // -1 means block until an fd is ready when no timer is pending.
    var timeout: i32 = (0 as i32) -% (1 as i32);
    if nt > (0 as i32) {
        let best: i32 = earliest_timer(state);
        let td_slot: **u8 = { (state + off_timer_deadlines()) as **u8 };
        let deadlines: *u64 = { *td_slot as *u64 };
        let best_dl: u64 = { *(deadlines + (best as usize)) };
        let now: u64 = { GetTickCount64() };
        if best_dl <= now {
            timeout = 0 as i32;
        } else {
            timeout = (best_dl -% now) as i32;
        }
    }
    // Build the WSAPOLLFD array (16 bytes/entry: fd@0, events@8, revents@10).
    let wf_slot: **u8 = { (state + off_waiter_fds()) as **u8 };
    let wh_slot: **u8 = { (state + off_waiter_hdls()) as **u8 };
    let wm_slot: **u8 = { (state + off_waiter_evmask()) as **u8 };
    let fds: *i32 = { *wf_slot as *i32 };
    let hdls: **u8 = { *wh_slot as **u8 };
    let masks: *i16 = { *wm_slot as *i16 };
    let arr: *u8 = { malloc((nw as usize) *% (16 as usize)) };
    var i: i32 = 0;
    while i < nw {
        let base: *u8 = { arr + ((i as usize) *% (16 as usize)) };
        let fd_slot: *u64 = { base as *u64 };
        let fd_i32: i32 = { *(fds + (i as usize)) };
        { *fd_slot = (fd_i32 as u32) as u64; }
        let ev_slot: *i16 = { (base + (8 as usize)) as *i16 };
        { *ev_slot = *(masks + (i as usize)); }
        let rev_slot: *i16 = { (base + (10 as usize)) as *i16 };
        { *rev_slot = 0 as i16; }
        i = i +% (1 as i32);
    }
    let nready: i32 = { WSAPoll(arr, nw as u32, timeout) };
    if nready > (0 as i32) {
        // Resume the first waiter whose revents is set; one event per call.
        var j: i32 = 0;
        while j < nw {
            let base: *u8 = { arr + ((j as usize) *% (16 as usize)) };
            let rev: i16 = { *((base + (10 as usize)) as *i16) };
            if rev != (0 as i16) {
                let hdl: *u8 = { *(hdls + (j as usize)) };
                let last_i: i32 = nw -% (1 as i32);
                if j != last_i {
                    let last_fd: i32 = { *(fds + (last_i as usize)) };
                    let last_hdl: *u8 = { *(hdls + (last_i as usize)) };
                    let last_mask: i16 = { *(masks + (last_i as usize)) };
                    { *(fds + (j as usize)) = last_fd; }
                    { *(hdls + (j as usize)) = last_hdl; }
                    { *(masks + (j as usize)) = last_mask; }
                }
                { *nw_slot = last_i; }
                { free(arr); }
                { #coro_resume(hdl); }
                return true;
            }
            j = j +% (1 as i32);
        }
        { free(arr); }
        return false;
    }
    { free(arr); }
    if nready == (0 as i32) {
        // Timed out — the earliest timer is due.
        if nt > (0 as i32) {
            return fire_earliest_timer(state);
        }
        return false;
    }
    // WSAPoll error (nready < 0).
    return false;
}

// Drain the spawn_local / yield task queue: resume each handle once.
fn drain_pending() -> i32 {
    let state: *u8 = ensure();
    let np_slot: *i32 = { (state + off_n_pending()) as *i32 };
    let n: i32 = { *np_slot };
    if n == (0 as i32) { return 0; }
    let ph_slot: **u8 = { (state + off_pending_hdls()) as **u8 };
    let hdls: **u8 = { *ph_slot as **u8 };
    { *np_slot = 0 as i32; }
    var i: i32 = 0;
    while i < n {
        let hdl: *u8 = { *(hdls + (i as usize)) };
        let done: i32 = { #coro_done(hdl) };
        if done == (0 as i32) {
            { #coro_resume(hdl); }
        }
        i = i +% (1 as i32);
    }
    return n;
}

// Push a coroutine handle to the pending queue.
fn enqueue_pending(hdl: *u8) {
    let state: *u8 = ensure();
    let np_slot: *i32 = { (state + off_n_pending()) as *i32 };
    let cp_slot: *i32 = { (state + off_cap_pending()) as *i32 };
    let ph_slot: **u8 = { (state + off_pending_hdls()) as **u8 };
    var n: i32 = { *np_slot };
    var cap: i32 = { *cp_slot };
    if n == cap {
        cap = cap *% (2 as i32);
        let new_p: *u8 = { realloc(*ph_slot, (cap *% 8) as usize) };
        { *ph_slot = new_p; }
        { *cp_slot = cap; }
    }
    let hdls: **u8 = { *ph_slot as **u8 };
    { *(hdls + (n as usize)) = hdl; }
    { *np_slot = n +% (1 as i32); }
    return;
}

// Snapshot of pending event-side work — fd waiters plus active timers.
fn waiter_count() -> i32 {
    let state: *u8 = ensure();
    let nw_slot: *i32 = { (state + off_n_waiters()) as *i32 };
    let nt_slot: *i32 = { (state + off_n_timers()) as *i32 };
    return { *nw_slot } +% { *nt_slot };
}

fn pending_count() -> i32 {
    let state: *u8 = ensure();
    let np_slot: *i32 = { (state + off_n_pending()) as *i32 };
    return { *np_slot };
}

// Register `awaiter` as waiting on `awaitee`. Append-only; removed by
// `notify_completed` (swap-remove).
fn register_awaiter(awaitee: *u8, awaiter: *u8) {
    let state: *u8 = ensure();
    let na_slot: *i32 = { (state + off_n_awaiters()) as *i32 };
    let ca_slot: *i32 = { (state + off_cap_awaiters()) as *i32 };
    let ae_slot: **u8 = { (state + off_awaitee_hdls()) as **u8 };
    let ar_slot: **u8 = { (state + off_awaiter_hdls()) as **u8 };
    var n: i32 = { *na_slot };
    var cap: i32 = { *ca_slot };
    if n == cap {
        cap = cap *% (2 as i32);
        let new_ae: *u8 = { realloc(*ae_slot, (cap *% 8) as usize) };
        let new_ar: *u8 = { realloc(*ar_slot, (cap *% 8) as usize) };
        { *ae_slot = new_ae; }
        { *ar_slot = new_ar; }
        { *ca_slot = cap; }
    }
    let aes: **u8 = { *ae_slot as **u8 };
    let ars: **u8 = { *ar_slot as **u8 };
    { *(aes + (n as usize)) = awaitee; }
    { *(ars + (n as usize)) = awaiter; }
    { *na_slot = n +% (1 as i32); }
    return;
}

// Linear scan for an awaiter registered on `awaitee`; if found, swap-remove
// and enqueue the awaiter for resumption.
fn notify_completed(awaitee: *u8) {
    let state: *u8 = ensure();
    let na_slot: *i32 = { (state + off_n_awaiters()) as *i32 };
    let ae_slot: **u8 = { (state + off_awaitee_hdls()) as **u8 };
    let ar_slot: **u8 = { (state + off_awaiter_hdls()) as **u8 };
    let n: i32 = { *na_slot };
    if n == (0 as i32) { return; }
    let aes: **u8 = { *ae_slot as **u8 };
    let ars: **u8 = { *ar_slot as **u8 };
    var i: i32 = 0;
    while i < n {
        let cur_ae: *u8 = { *(aes + (i as usize)) };
        if cur_ae == awaitee {
            let awaiter: *u8 = { *(ars + (i as usize)) };
            let last_i: i32 = n -% (1 as i32);
            if i != last_i {
                let last_ae: *u8 = { *(aes + (last_i as usize)) };
                let last_ar: *u8 = { *(ars + (last_i as usize)) };
                { *(aes + (i as usize)) = last_ae; }
                { *(ars + (i as usize)) = last_ar; }
            }
            { *na_slot = last_i; }
            enqueue_pending(awaiter);
            return;
        }
        i = i +% (1 as i32);
    }
    return;
}
