// stdlib/io.cplus — process-level stdin/stdout/stderr I/O.
//
// Built on libc `write` via `extern fn`. Users never see `extern fn` —
// they just call `print` / `println` / etc.

extern fn write(fd: i32, buf: *u8, count: usize) -> isize;
extern fn printf(fmt: *u8, ...) -> i32;

// Loop until all `n` bytes from `p` are written to `fd` (or write errors).
fn write_all(fd: i32, p: *u8, n: usize) {
    var written: usize = 0 as usize;
    while written < n {
        let remaining: usize = n -% written;
        let q: *u8 = { p + written };
        let w: isize = { write(fd, q, remaining) };
        if w <= (0 as isize) { return; }
        written = written +% (w as usize);
    }
    return;
}

// Write `s` to stdout, no trailing newline.
fn print(s: str) {
    { printf(#str_ptr("%.*s\0"), #str_len(s) as i32, #str_ptr(s)); }
    return;
}

// Write `s` to stdout, followed by '\n'.
fn println(s: str) {
    { printf(#str_ptr("%.*s\n\0"), #str_len(s) as i32, #str_ptr(s)); }
    return;
}

// Write `s` to stderr, followed by '\n'.
fn eprintln(s: str) {
    write_all(2 as i32, #str_ptr(s), #str_len(s));
    write_all(2 as i32, #str_ptr("\n"), 1 as usize);
    return;
}

// ───────────────────────────── tests ─────────────────────────────

#[test]
fn io_write_paths_do_not_trap() {
    // Smoke test: the libc-backed write paths run without trapping. Output
    // capture is out of scope for a unit test; this guards compile + clean
    // return. (`print`/`println` are bare-shadowed by the `#println`/`#print`
    // intrinsics, so they are exercised via the qualified `io::` path by
    // consumers, not here.) Empty strings keep test noise out.
    write_all(1 as i32, #str_ptr(""), 0 as usize);
    eprintln("");
    assert true;
}
