// stdlib/reactor.cplus — async I/O event loop (v0.0.4 Phase 3 Slice 3A.1).
//
// Backed by kqueue on macOS; epoll-on-Linux lands separately. The reactor
// is a process-global resource lazily initialized on first use. Single-
// threaded for v0.0.4 — matches tokio's `current_thread` runtime, and
// sidesteps the Send/Sync design that the multi-threaded executor would
// need.
//
// **Architecture.**
//
//   - The reactor holds a kqueue fd + parallel arrays for `(waiter_fd,
//     waiter_filter, waiter_handle)` triples (one per pending fd
//     registration; storing the filter makes wait_read + wait_write on
//     the same fd resume the right coroutine) and a queue of pending
//     coroutine handles (spawned via `spawn_local`).
//
//   - Async I/O wrappers call `wait_fd_readable(fd)` (a compiler
//     intrinsic — see codegen.rs) to suspend the current coroutine
//     until the fd becomes read-ready. The intrinsic registers
//     `(fd, current_coro_handle)` with the reactor, then issues
//     `llvm.coro.suspend`.
//
//   - `executor::block_on(future)` drives the outer coroutine. When
//     `coro.resume(outer)` returns and `coro.done(outer)` is false,
//     block_on first drains any tasks `spawn_local` queued, then
//     calls `reactor::poll_one_event` which blocks on `kevent` until
//     one fd is ready, looks up the waiter, and `coro.resume`s it.
//     Loop until outer is done.
//
//   - `spawn_local(future)` pushes the future's handle onto the
//     reactor's task queue; block_on's loop resumes each queued task
//     to its next suspend point.
//
//   - `yield_now()` is `spawn_local(this)` essentially — re-enqueue
//     this and suspend, giving the scheduler a chance to run other
//     queued tasks.
//
// **Layout of the reactor state heap block:**
//   0..4    kqfd             i32
//   4..8    n_waiters        i32   (current waiter count)
//   8..12   cap_waiters      i32
//   12..16  n_pending        i32   (queued spawn_local handles)
//   16..20  cap_pending      i32
//   20..24  (pad)
//   24..32  waiter_fds       *i32  (separately malloc'd)
//   32..40  waiter_hdls      **u8
//   40..48  pending_hdls     **u8
//   48..56  kevent_buf       *u8  (32-byte kevent struct slot, reused)
//   56..64  waiter_filters   *i16  (parallel to waiter_fds: EVFILT_READ=-1, EVFILT_WRITE=-2)
//   64..68  n_timers         i32   (pending one-shot timer count; v0.0.5 Slice 4A)
//   68..72  (pad)
//   72..76  n_awaiters       i32   (live awaitee→awaiter mappings; v0.0.5 Slice 4F)
//   76..80  cap_awaiters     i32
//   80..88  awaitee_hdls     **u8  (parallel to awaiter_hdls; v0.0.5 Slice 4F)
//   88..96  awaiter_hdls     **u8
//   total: 96 bytes header + 6 growable buffers.
//
// **Timers (v0.0.5 Slice 4A).** A `sleep(ms)` await registers a kqueue
// EVFILT_TIMER (filter = -7) using the coroutine handle as the kevent
// `ident` (uintptr_t). On fire, `poll_one_event` reads ident back and
// resumes that handle directly — no separate waiter table needed, since
// the resume target is encoded in the ident. `n_timers` participates in
// `waiter_count()` so `block_on` knows to keep polling.
//
// **Awaiter notification (v0.0.5 Slice 4F).** Each `await EXPR` site
// registers `(awaitee_hdl, %.coro.hdl)` in the awaiter table before
// suspending the awaiter coroutine. When the awaitee reaches its
// `final_suspend` epilogue, codegen emits a `notify_completed(self_hdl)`
// call — the reactor looks up the matching entry, swap-removes it, and
// enqueues the awaiter on the pending queue. Next `drain_pending` round
// resumes the awaiter, which re-checks `coro.done(awaitee)` (now true)
// and extracts the value. Without this notification, awaiters of inner
// coroutines that suspend on fd/timer events stall forever — `block_on`
// only re-resumes the *outermost* future on each loop pass.

extern fn malloc(n: usize) -> *u8;
extern fn realloc(p: *u8, n: usize) -> *u8;
extern fn free(p: *u8);

// kqueue / kevent (macOS).
extern fn kqueue() -> i32;
extern fn kevent(
    kq: i32,
    changelist: *u8,
    nchanges: i32,
    eventlist: *u8,
    nevents: i32,
    timeout: *u8,
) -> i32;

// LLVM coroutine intrinsics — surfaced via stable wrapper symbols
// emitted by codegen, so stdlib can call them as plain extern fns.
// `#coro_resume(hdl)` lowers to `call void @llvm.coro.resume(ptr %hdl)`.
extern fn __cplus_coro_resume(hdl: *u8);
extern fn __cplus_coro_done(hdl: *u8) -> i32;

// Reactor-state-slot accessors emitted in the codegen preamble.
extern fn __cplus_reactor_get_state() -> *u8;
extern fn __cplus_reactor_set_state(p: *u8);

// kevent struct field constants (macOS):
//   ident   uintptr_t  @ 0    (fd for EVFILT_READ)
//   filter  int16_t    @ 8    (EVFILT_READ = -1)
//   flags   uint16_t   @ 10   (EV_ADD | EV_ONESHOT = 0x11)
//   fflags  uint32_t   @ 12
//   data    intptr_t   @ 16
//   udata   void*      @ 24
// total size: 32 bytes.

fn header_bytes() -> usize { return 96 as usize; }
fn kevent_bytes() -> usize { return 32 as usize; }

fn off_kqfd() -> usize { return 0 as usize; }
fn off_n_waiters() -> usize { return 4 as usize; }
fn off_cap_waiters() -> usize { return 8 as usize; }
fn off_n_pending() -> usize { return 12 as usize; }
fn off_cap_pending() -> usize { return 16 as usize; }
fn off_waiter_fds() -> usize { return 24 as usize; }
fn off_waiter_hdls() -> usize { return 32 as usize; }
fn off_pending_hdls() -> usize { return 40 as usize; }
fn off_kevent_buf() -> usize { return 48 as usize; }
fn off_waiter_filters() -> usize { return 56 as usize; }
fn off_n_timers() -> usize { return 64 as usize; }
fn off_n_awaiters() -> usize { return 72 as usize; }
fn off_cap_awaiters() -> usize { return 76 as usize; }
fn off_awaitee_hdls() -> usize { return 80 as usize; }
fn off_awaiter_hdls() -> usize { return 88 as usize; }

// EVFILT_READ = -1, EVFILT_WRITE = -2, EVFILT_TIMER = -7 (macOS sys/event.h).
fn evfilt_read() -> i16 { return (0 as i16) -% (1 as i16); }
fn evfilt_write() -> i16 { return (0 as i16) -% (2 as i16); }
fn evfilt_timer() -> i16 { return (0 as i16) -% (7 as i16); }

// Lazily allocate + init the reactor on first use. Idempotent: returns
// the same state pointer on every call within a process.
pub fn ensure() -> *u8 {
    let cur: *u8 = unsafe { #reactor_get_state() };
    let null_p: *u8 = unsafe { 0 as *u8 };
    if !ptr_is_null(cur) { return cur; }
    let state: *u8 = unsafe { malloc(header_bytes()) };
    let kqfd: i32 = unsafe { kqueue() };
    let kqfd_slot: *i32 = unsafe { (state + off_kqfd()) as *i32 };
    unsafe { *kqfd_slot = kqfd; }
    let nw_slot: *i32 = unsafe { (state + off_n_waiters()) as *i32 };
    unsafe { *nw_slot = 0 as i32; }
    let cw_slot: *i32 = unsafe { (state + off_cap_waiters()) as *i32 };
    unsafe { *cw_slot = 8 as i32; }
    let np_slot: *i32 = unsafe { (state + off_n_pending()) as *i32 };
    unsafe { *np_slot = 0 as i32; }
    let cp_slot: *i32 = unsafe { (state + off_cap_pending()) as *i32 };
    unsafe { *cp_slot = 8 as i32; }
    let wf_slot: **u8 = unsafe { (state + off_waiter_fds()) as **u8 };
    unsafe { *wf_slot = malloc((8 *% 4) as usize); }
    let wh_slot: **u8 = unsafe { (state + off_waiter_hdls()) as **u8 };
    unsafe { *wh_slot = malloc((8 *% 8) as usize); }
    let ph_slot: **u8 = unsafe { (state + off_pending_hdls()) as **u8 };
    unsafe { *ph_slot = malloc((8 *% 8) as usize); }
    let kb_slot: **u8 = unsafe { (state + off_kevent_buf()) as **u8 };
    unsafe { *kb_slot = malloc(kevent_bytes()); }
    let wflt_slot: **u8 = unsafe { (state + off_waiter_filters()) as **u8 };
    unsafe { *wflt_slot = malloc((8 *% 2) as usize); }
    // v0.0.5 Slice 4A: timer count starts at zero. Timers don't need a
    // parallel waiter table — the kevent ident *is* the resume target.
    let nt_slot: *i32 = unsafe { (state + off_n_timers()) as *i32 };
    unsafe { *nt_slot = 0 as i32; }
    // v0.0.5 Slice 4F: awaiter table. Two parallel arrays of `*u8`.
    let na_slot: *i32 = unsafe { (state + off_n_awaiters()) as *i32 };
    unsafe { *na_slot = 0 as i32; }
    let ca_slot: *i32 = unsafe { (state + off_cap_awaiters()) as *i32 };
    unsafe { *ca_slot = 8 as i32; }
    let ae_slot: **u8 = unsafe { (state + off_awaitee_hdls()) as **u8 };
    unsafe { *ae_slot = malloc((8 *% 8) as usize); }
    let ar_slot: **u8 = unsafe { (state + off_awaiter_hdls()) as **u8 };
    unsafe { *ar_slot = malloc((8 *% 8) as usize); }
    unsafe { #reactor_set_state(state); }
    let _x: *u8 = null_p;
    return state;
}

// Internal helper: null check on a raw pointer via direct comparison
// against the canonical null spelling.
fn ptr_is_null(p: *u8) -> bool {
    let null_p: *u8 = unsafe { 0 as *u8 };
    return p == null_p;
}

// Stable-symbol wrappers exposed under canonical C-ABI names so the
// codegen intrinsics for `__cplus_reactor_wait_read` and
// `block_on`'s reactor-integrated drive loop can call them directly.
// Named at the source level rather than via `#[link_name]` because the
// link_name attribute is currently honored only on `extern fn`
// declarations, not on `export extern fn` export definitions (v0.0.5
// polish — at which point these can rename via link_name).
export extern fn stdlib_reactor_register_read_v1(fd: i32, hdl: *u8) {
    register_read(fd, hdl);
    return;
}

export extern fn stdlib_reactor_register_write_v1(fd: i32, hdl: *u8) {
    register_write(fd, hdl);
    return;
}

// v0.0.5 Slice 4A: register a one-shot timer that fires after `ms`
// milliseconds and resumes `hdl`. Uses kqueue EVFILT_TIMER with
// ident = handle pointer (uintptr_t). On fire, `poll_one_event` reads
// ident back from the kevent and resumes directly — no waiter table
// lookup, no separate timer-id allocation.
export extern fn stdlib_reactor_register_timer_v1(ms: u64, hdl: *u8) {
    register_timer(ms, hdl);
    return;
}

// v0.0.5 Slice 4F: awaiter-of-completed-coroutine notification.
// Codegen emits `register_awaiter_v1(awaitee, this)` at await sites
// before suspending; `notify_completed_v1(this)` runs in every async
// fn's final_suspend epilogue. See the architecture comment at the
// top of this file for the full flow.
export extern fn stdlib_reactor_register_awaiter_v1(awaitee: *u8, awaiter: *u8) {
    register_awaiter(awaitee, awaiter);
    return;
}

export extern fn stdlib_reactor_notify_completed_v1(awaitee: *u8) {
    notify_completed(awaitee);
    return;
}

export extern fn stdlib_reactor_enqueue_pending_v1(hdl: *u8) {
    enqueue_pending(hdl);
    return;
}

export extern fn stdlib_reactor_drain_pending_v1() -> i32 {
    return drain_pending();
}

export extern fn stdlib_reactor_waiter_count_v1() -> i32 {
    return waiter_count();
}

export extern fn stdlib_reactor_poll_one_event_v1() -> i32 {
    if poll_one_event() {
        return 1 as i32;
    }
    return 0 as i32;
}

// Register fd for read-readiness; record the coroutine handle to wake.
pub fn register_read(fd: i32, hdl: *u8) {
    register_filter(fd, hdl, evfilt_read());
    return;
}

// Register fd for write-readiness (kqueue EVFILT_WRITE).
pub fn register_write(fd: i32, hdl: *u8) {
    register_filter(fd, hdl, evfilt_write());
    return;
}

// v0.0.5 Slice 4A: register a one-shot timer. Submits EVFILT_TIMER with
// ident = (u64)hdl, data = ms (default unit on macOS is milliseconds).
// `poll_one_event` recognizes the timer filter and resumes via ident
// directly, so we just bump the `n_timers` counter so `block_on`'s
// "anything pending?" check sees us.
pub fn register_timer(ms: u64, hdl: *u8) {
    let state: *u8 = ensure();
    let nt_slot: *i32 = unsafe { (state + off_n_timers()) as *i32 };
    let n: i32 = unsafe { *nt_slot };
    unsafe { *nt_slot = n +% (1 as i32); }
    let kqfd: i32 = unsafe { *((state + off_kqfd()) as *i32) };
    let kb: *u8 = unsafe { *((state + off_kevent_buf()) as **u8) };
    // ident @0 (uintptr_t = 8 bytes on 64-bit): the coroutine handle
    // pointer doubles as a unique timer ident. Write through a `**u8`
    // view so we don't need a pointer→integer cast (not yet legal in
    // surface C+ — pointers live in their own type space here).
    let ident_slot: **u8 = unsafe { kb as **u8 };
    unsafe { *ident_slot = hdl; }
    // filter @8 (i16): EVFILT_TIMER = -7
    let filter_slot: *i16 = unsafe { (kb + (8 as usize)) as *i16 };
    unsafe { *filter_slot = evfilt_timer(); }
    // flags @10 (u16): EV_ADD | EV_ONESHOT
    let flags_slot: *u16 = unsafe { (kb + (10 as usize)) as *u16 };
    unsafe { *flags_slot = 0x0011 as u16; }
    // fflags @12 (u32): 0 → data is interpreted as milliseconds.
    let fflags_slot: *u32 = unsafe { (kb + (12 as usize)) as *u32 };
    unsafe { *fflags_slot = 0 as u32; }
    // data @16 (i64): the timeout in milliseconds.
    let data_slot: *i64 = unsafe { (kb + (16 as usize)) as *i64 };
    unsafe { *data_slot = ms as i64; }
    // udata @24 (ptr): null
    let udata_slot: **u8 = unsafe { (kb + (24 as usize)) as **u8 };
    unsafe { *udata_slot = 0 as *u8; }
    let _r: i32 = unsafe { kevent(kqfd, kb, 1 as i32, 0 as *u8, 0 as i32, 0 as *u8) };
    return;
}

// Append a (fd, filter, hdl) triple to the waiter arrays and submit a
// one-shot kqueue filter. `poll_one_event` matches by (fd, filter) so
// read- and write-waiters on the same fd don't collide.
fn register_filter(fd: i32, hdl: *u8, filter: i16) {
    let state: *u8 = ensure();
    let nw_slot: *i32 = unsafe { (state + off_n_waiters()) as *i32 };
    let cw_slot: *i32 = unsafe { (state + off_cap_waiters()) as *i32 };
    let wf_slot: **u8 = unsafe { (state + off_waiter_fds()) as **u8 };
    let wh_slot: **u8 = unsafe { (state + off_waiter_hdls()) as **u8 };
    let wflt_slot: **u8 = unsafe { (state + off_waiter_filters()) as **u8 };
    var n: i32 = unsafe { *nw_slot };
    var cap: i32 = unsafe { *cw_slot };
    if n == cap {
        cap = cap *% (2 as i32);
        let new_fds: *u8 = unsafe { realloc(*wf_slot, (cap *% 4) as usize) };
        let new_hdls: *u8 = unsafe { realloc(*wh_slot, (cap *% 8) as usize) };
        let new_flts: *u8 = unsafe { realloc(*wflt_slot, (cap *% 2) as usize) };
        unsafe { *wf_slot = new_fds; }
        unsafe { *wh_slot = new_hdls; }
        unsafe { *wflt_slot = new_flts; }
        unsafe { *cw_slot = cap; }
    }
    let fds: *i32 = unsafe { *wf_slot as *i32 };
    let hdls: **u8 = unsafe { *wh_slot as **u8 };
    let flts: *i16 = unsafe { *wflt_slot as *i16 };
    let fd_slot: *i32 = unsafe { fds + (n as usize) };
    unsafe { *fd_slot = fd; }
    let hdl_slot: **u8 = unsafe { hdls + (n as usize) };
    unsafe { *hdl_slot = hdl; }
    let flt_slot: *i16 = unsafe { flts + (n as usize) };
    unsafe { *flt_slot = filter; }
    unsafe { *nw_slot = n +% (1 as i32); }
    // Submit a one-shot filter to kqueue.
    let kqfd: i32 = unsafe { *((state + off_kqfd()) as *i32) };
    let kb: *u8 = unsafe { *((state + off_kevent_buf()) as **u8) };
    // ident @0 (uintptr_t = u64): fd
    let ident_slot: *u64 = unsafe { kb as *u64 };
    unsafe { *ident_slot = fd as u64; }
    // filter @8 (i16)
    let filter_slot: *i16 = unsafe { (kb + (8 as usize)) as *i16 };
    unsafe { *filter_slot = filter; }
    // flags @10 (u16): EV_ADD (0x0001) | EV_ONESHOT (0x0010) = 0x0011
    let flags_slot: *u16 = unsafe { (kb + (10 as usize)) as *u16 };
    unsafe { *flags_slot = 0x0011 as u16; }
    // fflags @12 (u32): 0
    let fflags_slot: *u32 = unsafe { (kb + (12 as usize)) as *u32 };
    unsafe { *fflags_slot = 0 as u32; }
    // data @16 (i64): 0
    let data_slot: *i64 = unsafe { (kb + (16 as usize)) as *i64 };
    unsafe { *data_slot = 0 as i64; }
    // udata @24 (ptr): null
    let udata_slot: **u8 = unsafe { (kb + (24 as usize)) as **u8 };
    unsafe { *udata_slot = 0 as *u8; }
    let _r: i32 = unsafe { kevent(kqfd, kb, 1 as i32, 0 as *u8, 0 as i32, 0 as *u8) };
    return;
}

// Wait for one fd to become ready, then resume its waiter. Blocks the
// calling thread on kevent. Returns true if a coroutine was resumed.
pub fn poll_one_event() -> bool {
    let state: *u8 = ensure();
    let nw_slot: *i32 = unsafe { (state + off_n_waiters()) as *i32 };
    let nt_slot: *i32 = unsafe { (state + off_n_timers()) as *i32 };
    let n: i32 = unsafe { *nw_slot };
    let nt: i32 = unsafe { *nt_slot };
    if n == (0 as i32) {
        if nt == (0 as i32) { return false; }
    }
    let kqfd: i32 = unsafe { *((state + off_kqfd()) as *i32) };
    let kb: *u8 = unsafe { *((state + off_kevent_buf()) as **u8) };
    let nev: i32 = unsafe { kevent(kqfd, 0 as *u8, 0 as i32, kb, 1 as i32, 0 as *u8) };
    if nev <= (0 as i32) { return false; }
    let ident: u64 = unsafe { *(kb as *u64) };
    let filter_ready: i16 = unsafe { *((kb + (8 as usize)) as *i16) };
    // v0.0.5 Slice 4A: timer fires use ident as the coroutine handle
    // directly (we set it that way in register_timer). No waiter-table
    // lookup needed — just resume and decrement the timer count.
    if filter_ready == evfilt_timer() {
        // The kevent ident slot stored a coroutine-handle pointer (see
        // register_timer). Read it back as `*u8` via the existing
        // `*ident_slot` value we already loaded — `ident` is a u64
        // but we need it as a pointer, so re-load through a `**u8`
        // view at the same offset.
        let phdl: **u8 = unsafe { kb as **u8 };
        let hdl: *u8 = unsafe { *phdl };
        unsafe { *nt_slot = nt -% (1 as i32); }
        unsafe { #coro_resume(hdl); }
        return true;
    }
    let fd_ready: i32 = ident as i32;
    // Find the matching (fd, filter) waiter; swap-remove from the parallel arrays.
    let wf_slot: **u8 = unsafe { (state + off_waiter_fds()) as **u8 };
    let wh_slot: **u8 = unsafe { (state + off_waiter_hdls()) as **u8 };
    let wflt_slot: **u8 = unsafe { (state + off_waiter_filters()) as **u8 };
    let fds: *i32 = unsafe { *wf_slot as *i32 };
    let hdls: **u8 = unsafe { *wh_slot as **u8 };
    let flts: *i16 = unsafe { *wflt_slot as *i16 };
    var i: i32 = 0;
    while i < n {
        let cur_fd: i32 = unsafe { *(fds + (i as usize)) };
        let cur_flt: i16 = unsafe { *(flts + (i as usize)) };
        if cur_fd == fd_ready {
            if cur_flt == filter_ready {
                let hdl: *u8 = unsafe { *(hdls + (i as usize)) };
                // Swap-remove: move last to slot i, dec count.
                let last_i: i32 = n -% (1 as i32);
                if i != last_i {
                    let last_fd: i32 = unsafe { *(fds + (last_i as usize)) };
                    let last_hdl: *u8 = unsafe { *(hdls + (last_i as usize)) };
                    let last_flt: i16 = unsafe { *(flts + (last_i as usize)) };
                    unsafe { *(fds + (i as usize)) = last_fd; }
                    unsafe { *(hdls + (i as usize)) = last_hdl; }
                    unsafe { *(flts + (i as usize)) = last_flt; }
                }
                unsafe { *nw_slot = last_i; }
                unsafe { #coro_resume(hdl); }
                return true;
            }
        }
        i = i +% (1 as i32);
    }
    return false;
}

// Drain the spawn_local task queue: resume each handle once. Returns
// the number of tasks resumed.
pub fn drain_pending() -> i32 {
    let state: *u8 = ensure();
    let np_slot: *i32 = unsafe { (state + off_n_pending()) as *i32 };
    let n: i32 = unsafe { *np_slot };
    if n == (0 as i32) { return 0; }
    let ph_slot: **u8 = unsafe { (state + off_pending_hdls()) as **u8 };
    let hdls: **u8 = unsafe { *ph_slot as **u8 };
    unsafe { *np_slot = 0 as i32; }
    var i: i32 = 0;
    while i < n {
        let hdl: *u8 = unsafe { *(hdls + (i as usize)) };
        let done: i32 = unsafe { #coro_done(hdl) };
        if done == (0 as i32) {
            unsafe { #coro_resume(hdl); }
        }
        i = i +% (1 as i32);
    }
    return n;
}

// Push a coroutine handle to the spawn_local queue.
pub fn enqueue_pending(hdl: *u8) {
    let state: *u8 = ensure();
    let np_slot: *i32 = unsafe { (state + off_n_pending()) as *i32 };
    let cp_slot: *i32 = unsafe { (state + off_cap_pending()) as *i32 };
    let ph_slot: **u8 = unsafe { (state + off_pending_hdls()) as **u8 };
    var n: i32 = unsafe { *np_slot };
    var cap: i32 = unsafe { *cp_slot };
    if n == cap {
        cap = cap *% (2 as i32);
        let new_p: *u8 = unsafe { realloc(*ph_slot, (cap *% 8) as usize) };
        unsafe { *ph_slot = new_p; }
        unsafe { *cp_slot = cap; }
    }
    let hdls: **u8 = unsafe { *ph_slot as **u8 };
    let slot: **u8 = unsafe { hdls + (n as usize) };
    unsafe { *slot = hdl; }
    unsafe { *np_slot = n +% (1 as i32); }
    return;
}

// Snapshot of "pending kevent-side work" — fd waiters plus active
// timers. `block_on` uses it to decide whether to kevent_wait or
// terminate the loop.
//
// v0.0.5 Slice 4F: the awaiter table doesn't drive kevent (its
// resumes are triggered by `notify_completed`, which routes through
// `enqueue_pending`), so it doesn't participate here. The drain step
// in `block_on` picks up notified awaiters via the pending queue.
pub fn waiter_count() -> i32 {
    let state: *u8 = ensure();
    let nw_slot: *i32 = unsafe { (state + off_n_waiters()) as *i32 };
    let nt_slot: *i32 = unsafe { (state + off_n_timers()) as *i32 };
    return unsafe { *nw_slot } +% unsafe { *nt_slot };
}

pub fn pending_count() -> i32 {
    let state: *u8 = ensure();
    let np_slot: *i32 = unsafe { (state + off_n_pending()) as *i32 };
    return unsafe { *np_slot };
}

// v0.0.5 Slice 4F: register `awaiter` as waiting on `awaitee`. Codegen
// emits a call here from inside each `await` site's resume_bb, just
// before the awaiter suspends itself. The table grows by doubling.
// Append-only; entries are removed by `notify_completed` (swap-remove).
pub fn register_awaiter(awaitee: *u8, awaiter: *u8) {
    let state: *u8 = ensure();
    let na_slot: *i32 = unsafe { (state + off_n_awaiters()) as *i32 };
    let ca_slot: *i32 = unsafe { (state + off_cap_awaiters()) as *i32 };
    let ae_slot: **u8 = unsafe { (state + off_awaitee_hdls()) as **u8 };
    let ar_slot: **u8 = unsafe { (state + off_awaiter_hdls()) as **u8 };
    var n: i32 = unsafe { *na_slot };
    var cap: i32 = unsafe { *ca_slot };
    if n == cap {
        cap = cap *% (2 as i32);
        let new_ae: *u8 = unsafe { realloc(*ae_slot, (cap *% 8) as usize) };
        let new_ar: *u8 = unsafe { realloc(*ar_slot, (cap *% 8) as usize) };
        unsafe { *ae_slot = new_ae; }
        unsafe { *ar_slot = new_ar; }
        unsafe { *ca_slot = cap; }
    }
    let aes: **u8 = unsafe { *ae_slot as **u8 };
    let ars: **u8 = unsafe { *ar_slot as **u8 };
    let aes_dst: **u8 = unsafe { aes + (n as usize) };
    unsafe { *aes_dst = awaitee; }
    let ars_dst: **u8 = unsafe { ars + (n as usize) };
    unsafe { *ars_dst = awaiter; }
    unsafe { *na_slot = n +% (1 as i32); }
    return;
}

// v0.0.5 Slice 4F: linear scan for an awaiter registered on `awaitee`.
// If found, swap-remove and enqueue the awaiter for resumption. No-op
// when nobody is awaiting (block_on'd outer futures don't register,
// orphan spawned tasks don't register).
//
// An awaitee can in principle be awaited by multiple awaiters. The
// codegen path only generates a single `await X` per source-level
// `await`, so the scenario is: same future-value passed to two
// different awaiters via Copy semantics. Treating the table as a
// multimap is overkill for v0.0.5; instead this fn pops *one* matching
// entry per call. If two awaiters were registered, the second is left
// behind in the table — leak, not crash. (Realistic? Same Future
// shouldn't be awaited twice anyway; the gen_await_expr destroy path
// already breaks that pattern.)
pub fn notify_completed(awaitee: *u8) {
    let state: *u8 = ensure();
    let na_slot: *i32 = unsafe { (state + off_n_awaiters()) as *i32 };
    let ae_slot: **u8 = unsafe { (state + off_awaitee_hdls()) as **u8 };
    let ar_slot: **u8 = unsafe { (state + off_awaiter_hdls()) as **u8 };
    let n: i32 = unsafe { *na_slot };
    if n == (0 as i32) { return; }
    let aes: **u8 = unsafe { *ae_slot as **u8 };
    let ars: **u8 = unsafe { *ar_slot as **u8 };
    var i: i32 = 0;
    while i < n {
        let cur_ae: *u8 = unsafe { *(aes + (i as usize)) };
        if cur_ae == awaitee {
            let awaiter: *u8 = unsafe { *(ars + (i as usize)) };
            // Swap-remove.
            let last_i: i32 = n -% (1 as i32);
            if i != last_i {
                let last_ae: *u8 = unsafe { *(aes + (last_i as usize)) };
                let last_ar: *u8 = unsafe { *(ars + (last_i as usize)) };
                unsafe { *(aes + (i as usize)) = last_ae; }
                unsafe { *(ars + (i as usize)) = last_ar; }
            }
            unsafe { *na_slot = last_i; }
            enqueue_pending(awaiter);
            return;
        }
        i = i +% (1 as i32);
    }
    return;
}
