// stdlib/reactor_linux.cplus — async I/O event loop, Linux/epoll backend.
//
// Linux counterpart to reactor.cplus (which uses kqueue on macOS). The
// resolver loads this file in place of reactor.cplus when the compiler
// targets Linux (the `_linux` platform-override convention — see
// resolver::platform_override). It exports the identical public surface:
//
//   - the `stdlib_reactor_*_v1` C-ABI symbols codegen emits calls to, and
//   - `pub fn poll_one_event` / `waiter_count`, which executor.cplus uses.
//
// so async lowering, executor::block_on, time::sleep and net all work
// unchanged. Only the event-source primitives differ:
//
//   kqueue()                     -> epoll_create1(0)
//   kevent(EVFILT_READ/WRITE)    -> epoll_ctl(ADD, EPOLLIN/EPOLLOUT|ONESHOT)
//   kevent(EVFILT_TIMER)         -> timerfd_create + timerfd_settime, then
//                                   epoll_ctl(ADD) the timerfd
//   kevent(wait)                 -> epoll_wait
//
// **Timers.** epoll has no timer filter, so each one-shot timer gets its
// own timerfd armed via timerfd_settime. The timerfd is registered in the
// SAME waiter table as fd waiters, tagged with the `evfilt_timer()`
// sentinel filter (a table marker here, not a kernel value). When it
// fires, poll_one_event drains the 8-byte expiration count, closes the
// timerfd, and resumes the handle. This keeps `n_timers` at zero on Linux
// and lets `waiter_count` (= n_waiters + n_timers) stay correct while
// counting timers through `n_waiters`.
//
// **epoll_event layout.** This targets x86_64-linux, where
// `struct epoll_event` is `__attribute__((packed))`:
//     events  u32  @0
//     data    u64  @4   (union; we stash the ready fd here)
//   total 12 bytes. (aarch64-linux would be naturally aligned at @8 —
//   a future arch split if/when that target is added.)
//
// See reactor.cplus's header for the full architecture notes; the state
// heap-block layout and every table-management routine below are copied
// from it verbatim so the two backends stay byte-compatible.

extern fn malloc(n: usize) -> *u8;
extern fn realloc(p: *u8, n: usize) -> *u8;
extern fn free(p: *u8);

// epoll + timerfd (Linux).
extern fn epoll_create1(flags: i32) -> i32;
extern fn epoll_ctl(epfd: i32, op: i32, fd: i32, event: *u8) -> i32;
extern fn epoll_wait(epfd: i32, events: *u8, maxevents: i32, timeout: i32) -> i32;
extern fn timerfd_create(clockid: i32, flags: i32) -> i32;
extern fn timerfd_settime(fd: i32, flags: i32, new_value: *u8, old_value: *u8) -> i32;
extern fn close(fd: i32) -> i32;
extern fn read(fd: i32, buf: *u8, n: usize) -> isize;

// LLVM coroutine intrinsics — surfaced via stable wrapper symbols
// emitted by codegen, so stdlib can call them as plain extern fns.
extern fn __cplus_coro_resume(hdl: *u8);
extern fn __cplus_coro_done(hdl: *u8) -> i32;

// Reactor-state-slot accessors emitted in the codegen preamble.
extern fn __cplus_reactor_get_state() -> *u8;
extern fn __cplus_reactor_set_state(p: *u8);

// epoll constants (Linux, asm-generic).
fn epoll_ctl_add() -> i32 { return 1 as i32; }
fn epoll_ctl_del() -> i32 { return 2 as i32; }
fn epoll_ctl_mod() -> i32 { return 3 as i32; }
// EPOLLIN (0x1) / EPOLLOUT (0x4) | EPOLLONESHOT (0x40000000), as u32.
fn epollin_oneshot() -> u32 { return 0x40000001 as u32; }
fn epollout_oneshot() -> u32 { return 0x40000004 as u32; }
fn clock_monotonic() -> i32 { return 1 as i32; }

fn header_bytes() -> usize { return 96 as usize; }
// Scratch slot reused for the 12-byte epoll_event (register + wait). The
// 32-byte allocation from the kqueue layout is kept so the state-block
// offsets are byte-identical to reactor.cplus.
fn evbuf_bytes() -> usize { return 32 as usize; }

fn off_kqfd() -> usize { return 0 as usize; }
fn off_n_waiters() -> usize { return 4 as usize; }
fn off_cap_waiters() -> usize { return 8 as usize; }
fn off_n_pending() -> usize { return 12 as usize; }
fn off_cap_pending() -> usize { return 16 as usize; }
fn off_waiter_fds() -> usize { return 24 as usize; }
fn off_waiter_hdls() -> usize { return 32 as usize; }
fn off_pending_hdls() -> usize { return 40 as usize; }
fn off_evbuf() -> usize { return 48 as usize; }
fn off_waiter_filters() -> usize { return 56 as usize; }
fn off_n_timers() -> usize { return 64 as usize; }
fn off_n_awaiters() -> usize { return 72 as usize; }
fn off_cap_awaiters() -> usize { return 76 as usize; }
fn off_awaitee_hdls() -> usize { return 80 as usize; }
fn off_awaiter_hdls() -> usize { return 88 as usize; }

// Waiter-table filter tags. Internal markers only (NOT kernel values on
// Linux): they let poll_one_event tell a read waiter from a write waiter
// from a timerfd. Values match the macOS EVFILT_* constants for parity.
fn evfilt_read() -> i16 { return (0 as i16) -% (1 as i16); }
fn evfilt_write() -> i16 { return (0 as i16) -% (2 as i16); }
fn evfilt_timer() -> i16 { return (0 as i16) -% (7 as i16); }

// Lazily allocate + init the reactor on first use. Idempotent.
fn ensure() -> *u8 {
    let cur: *u8 = { #reactor_get_state() };
    let null_p: *u8 = { 0 as *u8 };
    if !ptr_is_null(cur) { return cur; }
    // NOTE — error-handling convention (docs/design/error-handling.md): the
    // reactor's allocations (this state block and the realloc-grown waiter
    // tables below) are NOT yet null-checked, so OOM crashes instead of
    // recovering. Linux-only async plumbing, not exercised by the macOS test
    // suite; converting it per the convention is a tracked follow-up.
    let state: *u8 = { malloc(header_bytes()) };
    let epfd: i32 = { epoll_create1(0 as i32) };
    let kqfd_slot: *i32 = { (state + off_kqfd()) as *i32 };
    { *kqfd_slot = epfd; }
    let nw_slot: *i32 = { (state + off_n_waiters()) as *i32 };
    { *nw_slot = 0 as i32; }
    let cw_slot: *i32 = { (state + off_cap_waiters()) as *i32 };
    { *cw_slot = 8 as i32; }
    let np_slot: *i32 = { (state + off_n_pending()) as *i32 };
    { *np_slot = 0 as i32; }
    let cp_slot: *i32 = { (state + off_cap_pending()) as *i32 };
    { *cp_slot = 8 as i32; }
    let wf_slot: **u8 = { (state + off_waiter_fds()) as **u8 };
    { *wf_slot = malloc((8 *% 4) as usize); }
    let wh_slot: **u8 = { (state + off_waiter_hdls()) as **u8 };
    { *wh_slot = malloc((8 *% 8) as usize); }
    let ph_slot: **u8 = { (state + off_pending_hdls()) as **u8 };
    { *ph_slot = malloc((8 *% 8) as usize); }
    let eb_slot: **u8 = { (state + off_evbuf()) as **u8 };
    { *eb_slot = malloc(evbuf_bytes()); }
    let wflt_slot: **u8 = { (state + off_waiter_filters()) as **u8 };
    { *wflt_slot = malloc((8 *% 2) as usize); }
    let nt_slot: *i32 = { (state + off_n_timers()) as *i32 };
    { *nt_slot = 0 as i32; }
    let na_slot: *i32 = { (state + off_n_awaiters()) as *i32 };
    { *na_slot = 0 as i32; }
    let ca_slot: *i32 = { (state + off_cap_awaiters()) as *i32 };
    { *ca_slot = 8 as i32; }
    let ae_slot: **u8 = { (state + off_awaitee_hdls()) as **u8 };
    { *ae_slot = malloc((8 *% 8) as usize); }
    let ar_slot: **u8 = { (state + off_awaiter_hdls()) as **u8 };
    { *ar_slot = malloc((8 *% 8) as usize); }
    { #reactor_set_state(state); }
    let _x: *u8 = null_p;
    return state;
}

fn ptr_is_null(p: *u8) -> bool {
    let null_p: *u8 = { 0 as *u8 };
    return p == null_p;
}

export extern fn stdlib_reactor_register_read_v1(fd: i32, hdl: *u8) {
    register_read(fd, hdl);
    return;
}

export extern fn stdlib_reactor_register_write_v1(fd: i32, hdl: *u8) {
    register_write(fd, hdl);
    return;
}

export extern fn stdlib_reactor_register_timer_v1(ms: u64, hdl: *u8) {
    register_timer(ms, hdl);
    return;
}

export extern fn stdlib_reactor_register_awaiter_v1(awaitee: *u8, awaiter: *u8) {
    register_awaiter(awaitee, awaiter);
    return;
}

export extern fn stdlib_reactor_notify_completed_v1(awaitee: *u8) {
    notify_completed(awaitee);
    return;
}

export extern fn stdlib_reactor_enqueue_pending_v1(hdl: *u8) {
    enqueue_pending(hdl);
    return;
}

export extern fn stdlib_reactor_drain_pending_v1() -> i32 {
    return drain_pending();
}

export extern fn stdlib_reactor_waiter_count_v1() -> i32 {
    return waiter_count();
}

export extern fn stdlib_reactor_poll_one_event_v1() -> i32 {
    if poll_one_event() {
        return 1 as i32;
    }
    return 0 as i32;
}

// Register fd for read-readiness; record the coroutine handle to wake.
fn register_read(fd: i32, hdl: *u8) {
    register_filter(fd, hdl, evfilt_read());
    return;
}

// Register fd for write-readiness.
fn register_write(fd: i32, hdl: *u8) {
    register_filter(fd, hdl, evfilt_write());
    return;
}

// Register a one-shot timer that fires after `ms` milliseconds and
// resumes `hdl`. Arms a fresh timerfd and parks it in the waiter table
// under the timer sentinel; poll_one_event reaps + closes it on fire.
fn register_timer(ms: u64, hdl: *u8) {
    let tfd: i32 = { timerfd_create(clock_monotonic(), 0 as i32) };
    // itimerspec is two timespec { i64 sec; i64 nsec } pairs (32 bytes):
    //   it_interval @0  (0 → one-shot), it_value @16 (sec @16, nsec @24).
    let its: *u8 = { malloc(32 as usize) };
    let i0: *i64 = { its as *i64 };
    { *i0 = 0 as i64; }
    let i1: *i64 = { (its + (8 as usize)) as *i64 };
    { *i1 = 0 as i64; }
    let secs: i64 = (ms / (1000 as u64)) as i64;
    let nsecs: i64 = ((ms % (1000 as u64)) *% (1000000 as u64)) as i64;
    let v_sec: *i64 = { (its + (16 as usize)) as *i64 };
    { *v_sec = secs; }
    let v_nsec: *i64 = { (its + (24 as usize)) as *i64 };
    { *v_nsec = nsecs; }
    let _r: i32 = { timerfd_settime(tfd, 0 as i32, its, 0 as *u8) };
    { free(its); }
    register_filter(tfd, hdl, evfilt_timer());
    return;
}

// Append a (fd, filter, hdl) triple to the waiter arrays and arm the fd
// with epoll. `poll_one_event` matches the firing fd back to its waiter.
fn register_filter(fd: i32, hdl: *u8, filter: i16) {
    let state: *u8 = ensure();
    let nw_slot: *i32 = { (state + off_n_waiters()) as *i32 };
    let cw_slot: *i32 = { (state + off_cap_waiters()) as *i32 };
    let wf_slot: **u8 = { (state + off_waiter_fds()) as **u8 };
    let wh_slot: **u8 = { (state + off_waiter_hdls()) as **u8 };
    let wflt_slot: **u8 = { (state + off_waiter_filters()) as **u8 };
    var n: i32 = { *nw_slot };
    var cap: i32 = { *cw_slot };
    if n == cap {
        cap = cap *% (2 as i32);
        let new_fds: *u8 = { realloc(*wf_slot, (cap *% 4) as usize) };
        let new_hdls: *u8 = { realloc(*wh_slot, (cap *% 8) as usize) };
        let new_flts: *u8 = { realloc(*wflt_slot, (cap *% 2) as usize) };
        { *wf_slot = new_fds; }
        { *wh_slot = new_hdls; }
        { *wflt_slot = new_flts; }
        { *cw_slot = cap; }
    }
    let fds: *i32 = { *wf_slot as *i32 };
    let hdls: **u8 = { *wh_slot as **u8 };
    let flts: *i16 = { *wflt_slot as *i16 };
    let fd_slot: *i32 = { fds + (n as usize) };
    { *fd_slot = fd; }
    let hdl_slot: **u8 = { hdls + (n as usize) };
    { *hdl_slot = hdl; }
    let flt_slot: *i16 = { flts + (n as usize) };
    { *flt_slot = filter; }
    { *nw_slot = n +% (1 as i32); }
    // Arm with epoll. events = (write? EPOLLOUT : EPOLLIN) | EPOLLONESHOT;
    // data stashes the fd so the wake-side can match it back.
    let epfd: i32 = { *((state + off_kqfd()) as *i32) };
    let eb: *u8 = { *((state + off_evbuf()) as **u8) };
    let ev_slot: *u32 = { eb as *u32 };
    if filter == evfilt_write() {
        { *ev_slot = epollout_oneshot(); }
    } else {
        { *ev_slot = epollin_oneshot(); }
    }
    let data_slot: *i64 = { (eb + (4 as usize)) as *i64 };
    { *data_slot = fd as i64; }
    let r: i32 = { epoll_ctl(epfd, epoll_ctl_add(), fd, eb) };
    // EEXIST (fd already armed — e.g. read+write on one fd): switch to MOD.
    if r != (0 as i32) {
        let _m: i32 = { epoll_ctl(epfd, epoll_ctl_mod(), fd, eb) };
    }
    return;
}

// Wait for one fd to become ready, then resume its waiter. Blocks the
// calling thread on epoll_wait. Returns true if a coroutine was resumed.
fn poll_one_event() -> bool {
    let state: *u8 = ensure();
    let nw_slot: *i32 = { (state + off_n_waiters()) as *i32 };
    let nt_slot: *i32 = { (state + off_n_timers()) as *i32 };
    let n: i32 = { *nw_slot };
    let nt: i32 = { *nt_slot };
    if n == (0 as i32) {
        if nt == (0 as i32) { return false; }
    }
    let epfd: i32 = { *((state + off_kqfd()) as *i32) };
    let eb: *u8 = { *((state + off_evbuf()) as **u8) };
    let nev: i32 = { epoll_wait(epfd, eb, 1 as i32, (0 as i32) -% (1 as i32)) };
    if nev <= (0 as i32) { return false; }
    // data @4 holds the fd we stored at register time.
    let fd_ready: i32 = { *((eb + (4 as usize)) as *i32) };
    let wf_slot: **u8 = { (state + off_waiter_fds()) as **u8 };
    let wh_slot: **u8 = { (state + off_waiter_hdls()) as **u8 };
    let wflt_slot: **u8 = { (state + off_waiter_filters()) as **u8 };
    let fds: *i32 = { *wf_slot as *i32 };
    let hdls: **u8 = { *wh_slot as **u8 };
    let flts: *i16 = { *wflt_slot as *i16 };
    var i: i32 = 0;
    while i < n {
        let cur_fd: i32 = { *(fds + (i as usize)) };
        if cur_fd == fd_ready {
            let hdl: *u8 = { *(hdls + (i as usize)) };
            let cur_flt: i16 = { *(flts + (i as usize)) };
            // Disarm in epoll (one event per registration).
            let _d: i32 = { epoll_ctl(epfd, epoll_ctl_del(), fd_ready, eb) };
            // A timerfd: drain its 8-byte expiration count and close it.
            if cur_flt == evfilt_timer() {
                let scratch: *u8 = { malloc(8 as usize) };
                let _rd: isize = { read(fd_ready, scratch, 8 as usize) };
                { free(scratch); }
                let _c: i32 = { close(fd_ready) };
            }
            // Swap-remove from the parallel arrays.
            let last_i: i32 = n -% (1 as i32);
            if i != last_i {
                let last_fd: i32 = { *(fds + (last_i as usize)) };
                let last_hdl: *u8 = { *(hdls + (last_i as usize)) };
                let last_flt: i16 = { *(flts + (last_i as usize)) };
                { *(fds + (i as usize)) = last_fd; }
                { *(hdls + (i as usize)) = last_hdl; }
                { *(flts + (i as usize)) = last_flt; }
            }
            { *nw_slot = last_i; }
            { #coro_resume(hdl); }
            return true;
        }
        i = i +% (1 as i32);
    }
    return false;
}

// Drain the spawn_local task queue: resume each handle once.
fn drain_pending() -> i32 {
    let state: *u8 = ensure();
    let np_slot: *i32 = { (state + off_n_pending()) as *i32 };
    let n: i32 = { *np_slot };
    if n == (0 as i32) { return 0; }
    let ph_slot: **u8 = { (state + off_pending_hdls()) as **u8 };
    let hdls: **u8 = { *ph_slot as **u8 };
    { *np_slot = 0 as i32; }
    var i: i32 = 0;
    while i < n {
        let hdl: *u8 = { *(hdls + (i as usize)) };
        let done: i32 = { #coro_done(hdl) };
        if done == (0 as i32) {
            { #coro_resume(hdl); }
        }
        i = i +% (1 as i32);
    }
    return n;
}

// Push a coroutine handle to the spawn_local queue.
fn enqueue_pending(hdl: *u8) {
    let state: *u8 = ensure();
    let np_slot: *i32 = { (state + off_n_pending()) as *i32 };
    let cp_slot: *i32 = { (state + off_cap_pending()) as *i32 };
    let ph_slot: **u8 = { (state + off_pending_hdls()) as **u8 };
    var n: i32 = { *np_slot };
    var cap: i32 = { *cp_slot };
    if n == cap {
        cap = cap *% (2 as i32);
        let new_p: *u8 = { realloc(*ph_slot, (cap *% 8) as usize) };
        { *ph_slot = new_p; }
        { *cp_slot = cap; }
    }
    let hdls: **u8 = { *ph_slot as **u8 };
    let slot: **u8 = { hdls + (n as usize) };
    { *slot = hdl; }
    { *np_slot = n +% (1 as i32); }
    return;
}

// Snapshot of "pending event-side work" — fd waiters plus active timers.
// On Linux, timers live in the waiter table (n_waiters), so n_timers stays
// zero; the sum keeps the same meaning as the kqueue backend.
fn waiter_count() -> i32 {
    let state: *u8 = ensure();
    let nw_slot: *i32 = { (state + off_n_waiters()) as *i32 };
    let nt_slot: *i32 = { (state + off_n_timers()) as *i32 };
    return { *nw_slot } +% { *nt_slot };
}

fn pending_count() -> i32 {
    let state: *u8 = ensure();
    let np_slot: *i32 = { (state + off_n_pending()) as *i32 };
    return { *np_slot };
}

// Register `awaiter` as waiting on `awaitee`. Append-only; entries are
// removed by `notify_completed` (swap-remove).
fn register_awaiter(awaitee: *u8, awaiter: *u8) {
    let state: *u8 = ensure();
    let na_slot: *i32 = { (state + off_n_awaiters()) as *i32 };
    let ca_slot: *i32 = { (state + off_cap_awaiters()) as *i32 };
    let ae_slot: **u8 = { (state + off_awaitee_hdls()) as **u8 };
    let ar_slot: **u8 = { (state + off_awaiter_hdls()) as **u8 };
    var n: i32 = { *na_slot };
    var cap: i32 = { *ca_slot };
    if n == cap {
        cap = cap *% (2 as i32);
        let new_ae: *u8 = { realloc(*ae_slot, (cap *% 8) as usize) };
        let new_ar: *u8 = { realloc(*ar_slot, (cap *% 8) as usize) };
        { *ae_slot = new_ae; }
        { *ar_slot = new_ar; }
        { *ca_slot = cap; }
    }
    let aes: **u8 = { *ae_slot as **u8 };
    let ars: **u8 = { *ar_slot as **u8 };
    let aes_dst: **u8 = { aes + (n as usize) };
    { *aes_dst = awaitee; }
    let ars_dst: **u8 = { ars + (n as usize) };
    { *ars_dst = awaiter; }
    { *na_slot = n +% (1 as i32); }
    return;
}

// Linear scan for an awaiter registered on `awaitee`; if found,
// swap-remove and enqueue the awaiter for resumption.
fn notify_completed(awaitee: *u8) {
    let state: *u8 = ensure();
    let na_slot: *i32 = { (state + off_n_awaiters()) as *i32 };
    let ae_slot: **u8 = { (state + off_awaitee_hdls()) as **u8 };
    let ar_slot: **u8 = { (state + off_awaiter_hdls()) as **u8 };
    let n: i32 = { *na_slot };
    if n == (0 as i32) { return; }
    let aes: **u8 = { *ae_slot as **u8 };
    let ars: **u8 = { *ar_slot as **u8 };
    var i: i32 = 0;
    while i < n {
        let cur_ae: *u8 = { *(aes + (i as usize)) };
        if cur_ae == awaitee {
            let awaiter: *u8 = { *(ars + (i as usize)) };
            let last_i: i32 = n -% (1 as i32);
            if i != last_i {
                let last_ae: *u8 = { *(aes + (last_i as usize)) };
                let last_ar: *u8 = { *(ars + (last_i as usize)) };
                { *(aes + (i as usize)) = last_ae; }
                { *(ars + (i as usize)) = last_ar; }
            }
            { *na_slot = last_i; }
            enqueue_pending(awaiter);
            return;
        }
        i = i +% (1 as i32);
    }
    return;
}
