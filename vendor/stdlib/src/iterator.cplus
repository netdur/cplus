// stdlib/iterator.cplus — `Iterator[T]`, the compiler-known shape
// returned by every `gen fn`.
//
// v0.0.4 Phase 4 Slice 4A/4B. Users never construct an `Iterator[T]`
// directly — the only way to produce one is to call a `gen fn`. The
// compiler synthesises the value at codegen time; the struct definition
// here just gives the type a stable shape so `gen fn` signatures
// resolve and `for x in iter { ... }` lowering type-checks.
//
// **Field shape (compiler-internal):** a single opaque `*u8` pointing
// at the LLVM coroutine frame (`llvm.coro.begin`'s return value).
// Codegen treats `handle == 0` as "exhausted and destroyed" to avoid
// double-resume.
//
// **`it.next()` is a blessed compiler method.** Sema recognizes the
// call shape `<Iterator[T]>.next()` and returns `Option[T]`; codegen
// lowers it inline to: check coro.done → if done return Option::None;
// else read promise → resume coroutine → return Option::Some(v). The
// method has no source-level body because the operation can't be
// expressed in surface C+ (it needs raw access to LLVM coro intrinsics).

import "./option" as option;

struct Iterator[T] {
    opaque _handle: *u8,
}

// v0.0.5 Phase 3 Slice 3C: iterator adapters. Each adapter is a
// `gen fn` that pulls from its source iterator and re-yields. The
// `match this.next() { Option[T]::Some(v) => ..., Option[T]::None => return }`
// shape is enabled by sema's `propagate_pattern_instantiations` pass
// (walks variant patterns inside generic-impl-method bodies and
// generic free fn bodies, substitutes through the outer subst, and
// registers the discovered enum instantiations).
//
// `map` is a free function rather than a method because methods can't
// declare an *additional* type parameter on top of the impl's `T`
// without a parser change for method-level generics; the free-fn form
// sidesteps that.

impl Iterator[T] {
    // Keep only elements where `pred` returns true.
    gen fn filter(this, pred: fn(T) -> bool) -> T {
        loop {
            match this.next() {
                option::Option[T]::Some(v) => {
                    if pred(v) { yield v; }
                }
                option::Option[T]::None => { return; }
            }
        }
    }

    // Yield at most the first `count` elements, then stop (Swift's
    // `prefix(_:)`).
    gen fn prefix(this, count: usize) -> T {
        var k: usize = 0 as usize;
        while k < count {
            match this.next() {
                option::Option[T]::Some(v) => { yield v; }
                option::Option[T]::None => { return; }
            }
            k = k +% (1 as usize);
        }
        return;
    }
}

// Transform each element via `f`. Free function because methods can't
// declare an extra type parameter on top of the impl's `T` today.
gen fn map[T, U](source: Iterator[T], f: fn(T) -> U) -> U {
    loop {
        match source.next() {
            option::Option[T]::Some(v) => { yield f(v); }
            option::Option[T]::None => { return; }
        }
    }
}

// ───────────────────────────── tests ─────────────────────────────
// A source `Iterator[i32]` for the adapter tests. Local to avoid importing
// `range` (which imports this module — that would be a cycle).
gen fn _ints_below(n: i32) -> i32 {
    var i: i32 = 0;
    while i < n {
        yield i;
        i = i +% (1 as i32);
    }
    return;
}

fn _is_even(x: i32) -> bool {
    return (x % (2 as i32)) == (0 as i32);
}

fn _double(x: i32) -> i32 {
    return x *% (2 as i32);
}

#[test]
fn iterator_next_yields_in_order() {
    var it: Iterator[i32] = _ints_below(2);
    match it.next() {
        option::Option[i32]::Some(x) => { assert x == 0; }
        option::Option[i32]::None => { assert false; }
    }
    match it.next() {
        option::Option[i32]::Some(x) => { assert x == 1; }
        option::Option[i32]::None => { assert false; }
    }
    match it.next() {
        option::Option[i32]::Some(x) => { assert false; }
        option::Option[i32]::None => { assert true; }
    }
    return;
}

#[test]
fn iterator_filter_keeps_matching() {
    var sum: i32 = 0;
    for x in _ints_below(6).filter(_is_even) {
        sum = sum +% x;
    }
    assert sum == 6; // 0 + 2 + 4
}

#[test]
fn iterator_prefix_limits_count() {
    var n: i32 = 0;
    for x in _ints_below(100).prefix(3 as usize) {
        n = n +% (1 as i32);
    }
    assert n == 3;
}

#[test]
fn iterator_map_transforms() {
    var sum: i32 = 0;
    for x in map::[i32, i32](_ints_below(4), _double) {
        sum = sum +% x;
    }
    assert sum == 12; // 0 + 2 + 4 + 6
}
