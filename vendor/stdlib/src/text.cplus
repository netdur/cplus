// stdlib/text.cplus — owned, growable string.
//
// `Text` owns a heap buffer (malloc'd) and frees it on drop. It is the owned
// string type: build it incrementally with `push_str`, read it by lending a
// `str` view. A `Text` coerces to `str` (its `{ptr,len}` prefix) wherever a
// `str` is expected — an argument, a binding, a return. Reads that search the
// contents (`find`/`contains`/`starts_with`/`ends_with`) take a `str` needle
// so any source — a literal, a slice, or another Text's view — works without
// allocating.
//
// The coerced `str` is a view into this Text's buffer with no lifetime tie back
// to it. If the Text drops, or reallocates on a later `push_str`, the view
// dangles. Returning the view of a *local* Text is rejected (E0513); returning
// a view of a parameter is the caller's promise that the Text outlives it.
//
// Bytes are stored as-is (UTF-8 when the inputs are UTF-8). Indices returned by
// `find` are byte offsets. This is the owned half of the `Text` plan; the
// borrowed-static / literal-construction representation is a later slice.

import "./option" as option;
import "./vec" as vec;

extern fn malloc(n: usize) -> *u8;
extern fn realloc(p: *u8, n: usize) -> *u8;
extern fn free(p: *u8);
extern fn memcpy(dest: *u8, src: *u8, n: usize) -> *u8;
extern fn memcmp(a: *u8, b: *u8, n: usize) -> i32;

// `#[lang("string")]` designates this struct as the compiler's owned-string
// type: a string literal in a `Text`-typed context (e.g. `let s: Text = "x";`)
// is lowered to a heap copy constructed as this `{ ptr, len, cap }` layout.
// The field order/shape below is load-bearing for that lowering.
#[lang("string")]
struct Text {
    ptr: *u8,
    len: usize,
    cap: usize,
}

fn max_usize() -> usize {
    return (0 as usize) -% (1 as usize);
}

fn next_capacity(current: usize, required: usize) -> usize {
    assert required > current;
    var out: usize = current;
    if out == (0 as usize) {
        out = 1 as usize;
    }
    while out < required {
        if out > (max_usize() / (2 as usize)) {
            out = required;
        } else {
            out = out *% (2 as usize);
        }
    }
    return out;
}

// ASCII whitespace: space, tab, LF, CR. Used by the `trim*` helpers.
fn is_ascii_ws(b: u8) -> bool {
    return b == (32 as u8) || b == (9 as u8) || b == (10 as u8) || b == (13 as u8);
}

// True if the `n` bytes at `needle` equal the `n` bytes of `hay` starting at
// byte offset `off`. The caller guarantees `off +% n <= hay length`.
fn region_matches(hay: *u8, off: usize, needle: *u8, n: usize) -> bool {
    if n == (0 as usize) {
        return true;
    }
    let a: *u8 = { hay + off };
    return { memcmp(a, needle, n) } == (0 as i32);
}

fn new() -> Text {
    return Text {
        ptr: { 0 as *u8 },
        len: 0 as usize,
        cap: 0 as usize,
    };
}

fn with_capacity(n: usize) -> Text {
    if n == (0 as usize) {
        return new();
    }
    let raw: *u8 = { malloc(n) };
    assert raw.is_not_null();
    return Text {
        ptr: raw,
        len: 0 as usize,
        cap: n,
    };
}

fn from_str(s: str) -> Text {
    let n: usize = #str_len(s);
    var t: Text = with_capacity(n);
    t.push_str(s);
    return t;
}

impl Text {
    fn grow_to(ref this, new_cap: usize) {
        assert new_cap > this.cap;
        let raw: *u8 = { realloc(this.ptr, new_cap) };
        assert raw.is_not_null();
        this.ptr = raw;
        this.cap = new_cap;
        return;
    }

    fn len(this) -> usize {
        return this.len;
    }

    fn capacity(this) -> usize {
        return this.cap;
    }

    fn is_empty(this) -> bool {
        return this.len == (0 as usize);
    }

    fn reserve(ref this, additional: usize) {
        assert additional <= (max_usize() -% this.len);
        let required: usize = this.len +% additional;
        if required <= this.cap {
            return;
        }
        this.grow_to(next_capacity(this.cap, required));
        return;
    }

    fn push_str(ref this, s: str) {
        let n: usize = #str_len(s);
        if n == (0 as usize) {
            return;
        }
        this.reserve(n);
        let src: *u8 = #str_ptr(s);
        let dest: *u8 = { this.ptr + this.len };
        { memcpy(dest, src, n); }
        this.len = this.len +% n;
        return;
    }

    fn clear(ref this) {
        this.len = 0 as usize;
        return;
    }

    fn truncate(ref this, new_len: usize) {
        if new_len < this.len {
            this.len = new_len;
        }
        return;
    }

    fn clone(this) -> Text {
        var t: Text = with_capacity(this.len);
        if this.len != (0 as usize) {
            { memcpy(t.ptr, this.ptr, this.len); }
            t.len = this.len;
        }
        return t;
    }

    fn starts_with(this, prefix: str) -> bool {
        let n: usize = #str_len(prefix);
        if n > this.len {
            return false;
        }
        return region_matches(this.ptr, 0 as usize, #str_ptr(prefix), n);
    }

    fn ends_with(this, suffix: str) -> bool {
        let n: usize = #str_len(suffix);
        if n > this.len {
            return false;
        }
        return region_matches(this.ptr, this.len -% n, #str_ptr(suffix), n);
    }

    // Byte offset of the first occurrence of `needle`, or None. An empty
    // needle matches at 0.
    fn find(this, needle: str) -> option::Option[usize] {
        let n: usize = #str_len(needle);
        if n == (0 as usize) {
            return option::Option[usize]::Some(0 as usize);
        }
        if n > this.len {
            return option::Option[usize]::None;
        }
        let p: *u8 = #str_ptr(needle);
        let last: usize = this.len -% n; // inclusive last start index
        var i: usize = 0 as usize;
        while i <= last {
            if region_matches(this.ptr, i, p, n) {
                return option::Option[usize]::Some(i);
            }
            i = i +% (1 as usize);
        }
        return option::Option[usize]::None;
    }

    fn contains(this, needle: str) -> bool {
        var found: bool = false;
        match this.find(needle) {
            option::Option[usize]::Some(_idx) => { found = true; }
            option::Option[usize]::None => { found = false; }
        }
        return found;
    }

    // Byte offset of the *last* occurrence of `needle`, or None. An empty needle
    // matches at `len`.
    fn rfind(this, needle: str) -> option::Option[usize] {
        let n: usize = #str_len(needle);
        if n == (0 as usize) {
            return option::Option[usize]::Some(this.len);
        }
        if n > this.len {
            return option::Option[usize]::None;
        }
        let p: *u8 = #str_ptr(needle);
        var i: usize = this.len -% n; // inclusive last start index
        loop {
            if region_matches(this.ptr, i, p, n) {
                return option::Option[usize]::Some(i);
            }
            if i == (0 as usize) {
                return option::Option[usize]::None;
            }
            i = i -% (1 as usize);
        }
        return option::Option[usize]::None;
    }

    // Read the byte at `i` (caller guarantees `i < len`).
    fn byte_at_raw(this, i: usize) -> u8 {
        let p: *u8 = { this.ptr + i };
        return { *p };
    }

    // Owned copy of the byte range `[start, end)` (caller guarantees the range
    // is in bounds and `start <= end`).
    fn copy_range(this, start: usize, end: usize) -> Text {
        let n: usize = end -% start;
        var t: Text = with_capacity(n);
        if n != (0 as usize) {
            let src: *u8 = { this.ptr + start };
            { memcpy(t.ptr, src, n); }
            t.len = n;
        }
        return t;
    }

    // Owned copy of the byte range `[start, end)`, or None if out of bounds /
    // inverted. (Copies — the result owns its bytes.)
    fn slice(this, start: usize, end: usize) -> option::Option[Text] {
        if start > end {
            return option::Option[Text]::None;
        }
        if end > this.len {
            return option::Option[Text]::None;
        }
        return option::Option[Text]::Some(this.copy_range(start, end));
    }

    // Owned copy with leading ASCII whitespace removed.
    fn trim_start(this) -> Text {
        var start: usize = 0 as usize;
        while start < this.len {
            if is_ascii_ws(this.byte_at_raw(start)) == false {
                break;
            }
            start = start +% (1 as usize);
        }
        return this.copy_range(start, this.len);
    }

    // Owned copy with trailing ASCII whitespace removed.
    fn trim_end(this) -> Text {
        var end: usize = this.len;
        while end > (0 as usize) {
            if is_ascii_ws(this.byte_at_raw(end -% (1 as usize))) == false {
                break;
            }
            end = end -% (1 as usize);
        }
        return this.copy_range(0 as usize, end);
    }

    // Owned copy with leading and trailing ASCII whitespace removed.
    fn trim(this) -> Text {
        var start: usize = 0 as usize;
        while start < this.len {
            if is_ascii_ws(this.byte_at_raw(start)) == false {
                break;
            }
            start = start +% (1 as usize);
        }
        var end: usize = this.len;
        while end > start {
            if is_ascii_ws(this.byte_at_raw(end -% (1 as usize))) == false {
                break;
            }
            end = end -% (1 as usize);
        }
        return this.copy_range(start, end);
    }

    // Split on every (non-overlapping) occurrence of `sep`, returning the pieces
    // as owned `Text` values. An empty `sep` yields the whole string as one
    // piece. `"a,b,c".split(",")` → `["a", "b", "c"]`.
    fn split(this, sep: str) -> vec::Vec[Text] {
        var out: vec::Vec[Text] = vec::new::[Text]();
        let n: usize = #str_len(sep);
        if n == (0 as usize) {
            out.push(this.copy_range(0 as usize, this.len));
            return out;
        }
        let p: *u8 = #str_ptr(sep);
        var start: usize = 0 as usize;
        var i: usize = 0 as usize;
        while (i +% n) <= this.len {
            if region_matches(this.ptr, i, p, n) {
                out.push(this.copy_range(start, i));
                i = i +% n;
                start = i;
            } else {
                i = i +% (1 as usize);
            }
        }
        out.push(this.copy_range(start, this.len));
        return out;
    }

    // Build a C string (owned, NUL-terminated) for passing to a C function.
    // Returns None if the text contains an interior NUL byte (a C string can't
    // represent one). The returned `CString` owns its buffer and frees it on
    // drop; pass `cs.as_ptr()` to the `extern fn` and keep `cs` alive across the
    // call. Length-based C APIs don't need this — pass the `str` view's ptr+len.
    fn c_str(this) -> option::Option[CString] {
        var i: usize = 0 as usize;
        while i < this.len {
            if this.byte_at_raw(i) == (0 as u8) {
                return option::Option[CString]::None;
            }
            i = i +% (1 as usize);
        }
        let buf: *u8 = { malloc(this.len +% (1 as usize)) };
        assert buf.is_not_null();
        if this.len != (0 as usize) {
            { memcpy(buf, this.ptr, this.len); }
        }
        let term: *u8 = { buf + this.len };
        { *term = 0 as u8; }
        return option::Option[CString]::Some(CString { ptr: buf, len: this.len });
    }

    fn drop(ref this) {
        if this.ptr.is_not_null() {
            { free(this.ptr); }
        }
        return;
    }
}

// `Text` owns its heap buffer outright (no shared/aliased state, no interior
// mutability), so moving it to another thread (`Send`) and sharing `&Text`
// across threads (`Sync`) are both sound — like Rust's `String`. The
// raw-pointer field makes it `!Send`/`!Sync` by default; these markers opt in.
// `Send` is needed for `thread::spawn` payloads; `Send + Sync` for `Arc[Text]`.
impl Text: Send {}
impl Text: Sync {}

// An owned, NUL-terminated C string — the bridge to `extern fn`s that take a
// `const char*`. The buffer is `len + 1` bytes (the trailing NUL is not counted
// in `len`). Owns its buffer; frees it on drop. Build one with `Text::c_str`.
struct CString {
    ptr: *u8,
    len: usize,
}

impl CString {
    // The raw `*u8` the C ABI wants. Valid only while this `CString` is alive.
    fn as_ptr(this) -> *u8 {
        return this.ptr;
    }

    // Length in bytes, NOT counting the trailing NUL.
    fn len(this) -> usize {
        return this.len;
    }

    fn drop(ref this) {
        if this.ptr.is_not_null() {
            { free(this.ptr); }
        }
        return;
    }
}
