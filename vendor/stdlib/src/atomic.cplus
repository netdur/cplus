// u64
// ============================================================

#[no_alloc] #[no_block]
fn load_u64(p: *u64, ordering: Ordering) -> u64 {
    return match ordering {
        Ordering::Relaxed => { #atomic_load_u64_relaxed(p) },
        Ordering::Acquire => { #atomic_load_u64_acquire(p) },
        Ordering::Release => { #atomic_load_u64_seqcst(p) },
        Ordering::AcqRel => { #atomic_load_u64_seqcst(p) },
        Ordering::SeqCst => { #atomic_load_u64_seqcst(p) },
    };
}

#[no_alloc] #[no_block]
fn store_u64(p: *u64, val: u64, ordering: Ordering) {
    match ordering {
        Ordering::Relaxed => { #atomic_store_u64_relaxed(p, val); },
        Ordering::Acquire => { #atomic_store_u64_seqcst(p, val); },
        Ordering::Release => { #atomic_store_u64_release(p, val); },
        Ordering::AcqRel => { #atomic_store_u64_seqcst(p, val); },
        Ordering::SeqCst => { #atomic_store_u64_seqcst(p, val); },
    }
    return;
}

#[no_alloc] #[no_block]
fn fetch_add_u64(p: *u64, val: u64, ordering: Ordering) -> u64 {
    return match ordering {
        Ordering::Relaxed => { #atomic_fetch_add_u64_relaxed(p, val) },
        Ordering::Acquire => { #atomic_fetch_add_u64_acquire(p, val) },
        Ordering::Release => { #atomic_fetch_add_u64_release(p, val) },
        Ordering::AcqRel => { #atomic_fetch_add_u64_acqrel(p, val) },
        Ordering::SeqCst => { #atomic_fetch_add_u64_seqcst(p, val) },
