}

fn fetch_xor_i32(p: *i32, val: i32, ordering: Ordering) -> i32 {
    return match ordering {
        Ordering::Relaxed => { #atomic_fetch_xor_i32_relaxed(p, val) },
        Ordering::Acquire => { #atomic_fetch_xor_i32_acquire(p, val) },
        Ordering::Release => { #atomic_fetch_xor_i32_release(p, val) },
        Ordering::AcqRel => { #atomic_fetch_xor_i32_acqrel(p, val) },
        Ordering::SeqCst => { #atomic_fetch_xor_i32_seqcst(p, val) },
    };
}

// Returns the previous value at `*p`. Compare against `expected` to
// detect success. Uses a single ordering for both success and failure
// (the compiler lowers `release` → success=release, failure=monotonic,
// etc., to satisfy LLVM's "failure-ordering ≤ success-ordering" constraint).
fn compare_exchange_i32(p: *i32, expected: i32, desired: i32, ordering: Ordering) -> i32 {
    return match ordering {
        Ordering::Relaxed => { #atomic_cmpxchg_i32_relaxed(p, expected, desired) },
        Ordering::Acquire => { #atomic_cmpxchg_i32_acquire(p, expected, desired) },
        Ordering::Release => { #atomic_cmpxchg_i32_release(p, expected, desired) },
        Ordering::AcqRel => { #atomic_cmpxchg_i32_acqrel(p, expected, desired) },
        Ordering::SeqCst => { #atomic_cmpxchg_i32_seqcst(p, expected, desired) },
    };
}

