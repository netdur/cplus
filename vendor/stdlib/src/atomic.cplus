// stdlib/atomic.cplus — atomic memory operations on raw pointers.
//
// v0.0.3 Phase 5 Slice 5A. The compiler exposes per-(op, type, ordering)
// intrinsics named `__cplus_atomic_<op>_<ty>_<ordering>`; this module wraps
// them behind ergonomic free functions that take a runtime `Ordering`.
//
// **Why free fns on raw pointers, not an `Atomic[T]` struct.** A struct
// wrapper would require generics-with-width-dispatch (each width calls a
// different intrinsic), which compounds the v0.0.3 generic-method
// limitations. Shipping free fns now keeps the surface ~250 lines and
// covers every Phase 5B/5C threading use case (the parallel-sum recipe
// doesn't need shared state at all; the concurrent-counter recipe in 5D
// shares a `*u64` directly). A struct wrapper can layer on later.
//
// **Why `unsafe` is required.** Every atomic op reads/writes through a
// raw pointer whose validity the compiler can't prove (alignment,
// pointee lifetime, no concurrent non-atomic access). The wrappers
// here forward the `unsafe` requirement: callers must wrap atomic
// calls in `{ ... }` themselves.

enum Ordering {
    Relaxed,
    Acquire,
    Release,
    AcqRel,
    SeqCst,
}

// ============================================================
// i32
// ============================================================

fn load_i32(p: *i32, ordering: Ordering) -> i32 {
    // Release / AcqRel are invalid for loads in LLVM; upgrade to SeqCst.
    return match ordering {
        Ordering::Relaxed => { #atomic_load_i32_relaxed(p) },
        Ordering::Acquire => { #atomic_load_i32_acquire(p) },
        Ordering::Release => { #atomic_load_i32_seqcst(p) },
        Ordering::AcqRel => { #atomic_load_i32_seqcst(p) },
        Ordering::SeqCst => { #atomic_load_i32_seqcst(p) },
    };
}

fn store_i32(p: *i32, val: i32, ordering: Ordering) {
    // Acquire / AcqRel are invalid for stores in LLVM; upgrade to SeqCst.
    match ordering {
        Ordering::Relaxed => { #atomic_store_i32_relaxed(p, val); },
        Ordering::Acquire => { #atomic_store_i32_seqcst(p, val); },
        Ordering::Release => { #atomic_store_i32_release(p, val); },
        Ordering::AcqRel => { #atomic_store_i32_seqcst(p, val); },
        Ordering::SeqCst => { #atomic_store_i32_seqcst(p, val); },
    }
    return;
}

fn swap_i32(p: *i32, val: i32, ordering: Ordering) -> i32 {
    return match ordering {
        Ordering::Relaxed => { #atomic_xchg_i32_relaxed(p, val) },
        Ordering::Acquire => { #atomic_xchg_i32_acquire(p, val) },
        Ordering::Release => { #atomic_xchg_i32_release(p, val) },
        Ordering::AcqRel => { #atomic_xchg_i32_acqrel(p, val) },
        Ordering::SeqCst => { #atomic_xchg_i32_seqcst(p, val) },
    };
}

fn fetch_add_i32(p: *i32, val: i32, ordering: Ordering) -> i32 {
    return match ordering {
        Ordering::Relaxed => { #atomic_fetch_add_i32_relaxed(p, val) },
        Ordering::Acquire => { #atomic_fetch_add_i32_acquire(p, val) },
        Ordering::Release => { #atomic_fetch_add_i32_release(p, val) },
        Ordering::AcqRel => { #atomic_fetch_add_i32_acqrel(p, val) },
        Ordering::SeqCst => { #atomic_fetch_add_i32_seqcst(p, val) },
    };
}

fn fetch_sub_i32(p: *i32, val: i32, ordering: Ordering) -> i32 {
    return match ordering {
        Ordering::Relaxed => { #atomic_fetch_sub_i32_relaxed(p, val) },
        Ordering::Acquire => { #atomic_fetch_sub_i32_acquire(p, val) },
        Ordering::Release => { #atomic_fetch_sub_i32_release(p, val) },
        Ordering::AcqRel => { #atomic_fetch_sub_i32_acqrel(p, val) },
        Ordering::SeqCst => { #atomic_fetch_sub_i32_seqcst(p, val) },
    };
}

fn fetch_and_i32(p: *i32, val: i32, ordering: Ordering) -> i32 {
    return match ordering {
        Ordering::Relaxed => { #atomic_fetch_and_i32_relaxed(p, val) },
        Ordering::Acquire => { #atomic_fetch_and_i32_acquire(p, val) },
        Ordering::Release => { #atomic_fetch_and_i32_release(p, val) },
