#[no_alloc] #[no_block]
fn compare_exchange_u64(p: *u64, expected: u64, desired: u64, ordering: Ordering) -> u64 {
    return match ordering {
        Ordering::Relaxed => { #atomic_cmpxchg_u64_relaxed(p, expected, desired) },
        Ordering::Acquire => { #atomic_cmpxchg_u64_acquire(p, expected, desired) },
        Ordering::Release => { #atomic_cmpxchg_u64_release(p, expected, desired) },
        Ordering::AcqRel => { #atomic_cmpxchg_u64_acqrel(p, expected, desired) },
        Ordering::SeqCst => { #atomic_cmpxchg_u64_seqcst(p, expected, desired) },
    };
}

// v0.0.12 G-030 (llama.cplus G-029): standalone memory fence — no
// pointer, no value, just a barrier. Maps to LLVM's `fence` instruction
// with the matching ordering. `Relaxed` is a no-op per C and LLVM
// (LLVM rejects `fence monotonic`; codegen emits nothing). Required
// by `ggml_barrier`-style spin-wait publish patterns where the
// publishing store has already happened on another path and we need
// to seal the happens-before edge with a separate fence.
#[no_alloc] #[no_block]
fn fence(ordering: Ordering) {
    match ordering {
        Ordering::Relaxed => { { #atomic_fence_relaxed(); } }
        Ordering::Acquire => { { #atomic_fence_acquire(); } }
        Ordering::Release => { { #atomic_fence_release(); } }
        Ordering::AcqRel => { { #atomic_fence_acqrel(); } }
        Ordering::SeqCst => { { #atomic_fence_seqcst(); } }
    };
    return;
}

// ───────────────────────────── tests ─────────────────────────────

#[test]
fn load_store_u64() {
    var n: u64 = 0 as u64;
    let p: *u64 = #addr_of(n);
    { store_u64(p, 42 as u64, Ordering::SeqCst); }
    let v: u64 = { load_u64(p, Ordering::SeqCst) };
    assert v == (42 as u64);
}

#[test]
fn fetch_add_sub_u64() {
    var n: u64 = 10 as u64;
    let p: *u64 = #addr_of(n);
    let prev: u64 = { fetch_add_u64(p, 5 as u64, Ordering::SeqCst) };
    assert prev == (10 as u64);
    assert n == (15 as u64);
    let prev2: u64 = { fetch_sub_u64(p, 3 as u64, Ordering::SeqCst) };
    assert prev2 == (15 as u64);
    assert n == (12 as u64);
}
