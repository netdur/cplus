#[no_alloc] #[no_block]
fn fetch_sub_u64(p: *u64, val: u64, ordering: Ordering) -> u64 {
    return match ordering {
        Ordering::Relaxed => { #atomic_fetch_sub_u64_relaxed(p, val) },
        Ordering::Acquire => { #atomic_fetch_sub_u64_acquire(p, val) },
        Ordering::Release => { #atomic_fetch_sub_u64_release(p, val) },
        Ordering::AcqRel => { #atomic_fetch_sub_u64_acqrel(p, val) },
