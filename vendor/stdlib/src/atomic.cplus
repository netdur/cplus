fn fetch_or_i32(p: *i32, val: i32, ordering: Ordering) -> i32 {
    return match ordering {
        Ordering::Relaxed => { #atomic_fetch_or_i32_relaxed(p, val) },
        Ordering::Acquire => { #atomic_fetch_or_i32_acquire(p, val) },
        Ordering::Release => { #atomic_fetch_or_i32_release(p, val) },
        Ordering::AcqRel => { #atomic_fetch_or_i32_acqrel(p, val) },
        Ordering::SeqCst => { #atomic_fetch_or_i32_seqcst(p, val) },
