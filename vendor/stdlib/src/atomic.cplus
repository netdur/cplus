pub fn atomic_fetch_xor_i32(p: *i32, val: i32, ord: Ordering) -> i32 {
    return match ord {
        Ordering::Relaxed => unsafe { __cplus_atomic_fetch_xor_i32_relaxed(p, val) },
        Ordering::Acquire => unsafe { __cplus_atomic_fetch_xor_i32_acquire(p, val) },
        Ordering::Release => unsafe { __cplus_atomic_fetch_xor_i32_release(p, val) },
        Ordering::AcqRel => unsafe { __cplus_atomic_fetch_xor_i32_acqrel(p, val) },
        Ordering::SeqCst => unsafe { __cplus_atomic_fetch_xor_i32_seqcst(p, val) },
    };
}

// Returns the previous value at `*p`. Compare against `expected` to
// detect success. Uses a single ordering for both success and failure
// (the compiler lowers `release` → success=release, failure=monotonic,
// etc., to satisfy LLVM's "failure-ord ≤ success-ord" constraint).
pub fn atomic_compare_exchange_i32(p: *i32, expected: i32, desired: i32, ord: Ordering) -> i32 {
    return match ord {
        Ordering::Relaxed => unsafe { __cplus_atomic_cmpxchg_i32_relaxed(p, expected, desired) },
        Ordering::Acquire => unsafe { __cplus_atomic_cmpxchg_i32_acquire(p, expected, desired) },
        Ordering::Release => unsafe { __cplus_atomic_cmpxchg_i32_release(p, expected, desired) },
        Ordering::AcqRel => unsafe { __cplus_atomic_cmpxchg_i32_acqrel(p, expected, desired) },
        Ordering::SeqCst => unsafe { __cplus_atomic_cmpxchg_i32_seqcst(p, expected, desired) },
    };
}

