// stdlib/thread.cplus — 1:1 OS threads with value-returning `join`.
//
// v0.0.3 Phase 5 Slice 5B. The cornerstone API for safe split-work-join-
// results: `thread::spawn[O](f) -> JoinHandle[O]` runs `f` on a fresh
// pthread; `JoinHandle[O]::join(move self) -> O` waits for it and
// transfers ownership of the result back to the parent. No shared
// memory, no `unsafe` at the user surface, no raw pointers.
//
// **Scope (5B).** O must be a Copy type whose LLVM representation fits
// in 8 bytes — every integer width, bool, raw and function pointers,
// small Copy enums. Non-Copy O (string, Vec[T], owned aggregates) lands
// in 5C alongside the cross-thread `move` work; they require sret-aware
// trampoline emission, which doubles the codegen surface.
//
// **Layout.** `JoinHandle[O]` is `(tid: u64, ctx: *u8)`. The compiler
// intrinsic `__cplus_thread_spawn` mallocs an 8 + size_of(O) byte
// context, stores the user's fn pointer at offset 0, generates a
// per-O trampoline that calls f and writes the result at offset 8,
// then calls pthread_create. `__cplus_thread_join` runs pthread_join,
// loads the result from the context, frees the context, and returns
// the value. See [cplus-core/src/codegen.rs] for the lowering.
//
// **Panic semantics.** `JoinHandle::join` returns `T`, not
// `Result[T, ThreadPanic]`. C+ has no unwind story today — a worker
// that traps takes the whole process with it (llvm.trap-shaped panic).
// Agents arriving with Rust priors should not expect a Result here;
// the signature is honest and the docstring explains why.

// v0.0.4 Phase 2 Slice 2H: JoinHandle::drop switches from blocking
// pthread_join to true fire-and-forget pthread_detach. Safety is
// preserved by a refcounted ctx (codegen-side layout: u64 refcount @0,
// fn_ptr @8, result @16, [optional input @16+sizeof(O)]). Parent's
// drop atomically decrements; worker's trampoline also decrements
// after writing the result; whichever thread observes the prev==1
// transition frees the ctx. pthread_detach tells the OS to reclaim
// the thread's kernel resources whenever it exits.

import "stdlib/atomic" as atomic;

extern fn pthread_join(tid: u64, retval: *u8) -> i32;
extern fn pthread_detach(tid: u64) -> i32;
extern fn free(p: *u8);

pub struct JoinHandle[O] {
    tid: u64,
    ctx: *u8,
}

// Spawn a fresh OS thread that will run `f`. Returns a handle whose
// `join()` blocks until the thread finishes and returns the thread's
// value to the caller. The thread runs concurrently with the parent
// until joined.
//
// `O: Send` — the return value must be safely transferrable between
// threads. v0.0.4 Phase 2 Slice 2A baseline: every type is Send.
// Future tightening rejects `Rc[T]`, `MutexGuard[T]`, and structs
// with raw-pointer fields (unless explicitly opted-in).
pub fn spawn[O: Send](f: fn() -> O) -> JoinHandle[O] {
    return unsafe { #thread_spawn::[O](f) };
}

// Spawn a fresh OS thread that will run `f(input)`. The `input` value
// is moved into the worker's heap context — the parent can no longer
// access it after this call (the borrow checker rejects post-move
// use). The thread runs `f` with that input as its sole argument;
// `join()` returns the produced value of type `O`.
//
// **v0.0.3 Slice 5C scope:** `I` and `O` must be types whose LLVM
// representation passes by value in a single register (or struct
// splat) — every integer width, bool, f32/f64, and Copy structs
// (`Range { start: i64, end: i64 }` is the canonical example).
// Non-Copy ownership-transferring types like `string` and `Vec[T]`
// work for the input position (they're moved into ctx and the worker
// becomes the owner), but spawn_with's output-side O retains the
// scalar-only restriction from Slice 5B.
pub fn spawn_with[I: Send, O: Send](move input: I, f: fn(I) -> O) -> JoinHandle[O] {
    return unsafe { #thread_spawn_with::[I, O](input, f) };
}

impl JoinHandle[O] {
    // Block until the worker thread finishes and return its produced
    // value. Consumes `self` — a handle can only be joined once,
    // enforced by the move-semantics receiver. The borrow checker
    // catches double-join at compile time.
    pub fn join(move self) -> O {
        return unsafe { #thread_join::[O](self) };
    }

    // Drop an un-joined handle: detach the worker from the OS (so its
    // kernel resources get reaped when it eventually exits), then
    // atomically decrement the ctx refcount. If we were the last
    // reference (the worker already finished and decremented its
    // ref), free the ctx ourselves; otherwise the worker will free
    // when it exits. **No blocking** — true fire-and-forget.
    //
    // v0.0.4 Phase 2 Slice 2H: refcounted-ctx design closes the
    // v0.0.3 carryover. The pre-refcount drop blocked on
    // pthread_join because freeing the ctx underneath a still-running
    // worker would race the worker's result-store. With the refcount
    // both sides safely cooperate on lifetime.
    fn drop(mut self) {
        unsafe { pthread_detach(self.tid); }
        let refct: *u64 = unsafe { self.ctx as *u64 };
        let prev: u64 = unsafe {
            atomic::atomic_fetch_sub_u64(refct, 1 as u64, atomic::Ordering::AcqRel)
        };
        if prev == (1 as u64) {
            unsafe { free(self.ctx); }
        }
        return;
    }
}
