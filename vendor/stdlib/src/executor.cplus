// stdlib/executor.cplus — single-threaded driver for `Future[T]`.
//
// v0.0.3 Phase 5 Slice 5E.5. `block_on` is the canonical entry point
// for synchronous code that wants to consume an `async fn`'s result.
// It loops `Future::poll` (via the compiler's `coro.resume` /
// `coro.done` intrinsics) until the future produces `Ready(T)`,
// then returns T.
//
// **v0.0.3 scope:** synchronous drive only — the loop spins on the
// coroutine until completion. No reactor, no I/O suspension. The
// async-fetch recipe (with kqueue/epoll wake-on-readable) lands
// post-v0.0.3 when the reactor ships.
//
// **No multi-threaded executor.** Single-threaded driver only —
// matches tokio's `current_thread` runtime semantics and sidesteps
// the `Send`/`Sync` design that v0.0.4 will tackle.

import "./future" as future;
// v0.0.4 Phase 3 Slice 3A.1: pull in the reactor so block_on's
// reactor-integrated drive loop has its stable-symbol callees
// (`stdlib_reactor_*_v1`) available at link time. block_on itself
// is compiler-intrinsic, but it now calls into the reactor's drain /
// poll routines emitted by reactor.cplus.
import "./reactor" as reactor;

// Drive a `Future[T]` to completion and return its produced value.
// Blocks the calling thread (no other tasks run on it) until the
// future resolves. Drops the coroutine frame after extracting T.
fn block_on[T](f: future::Future[T]) -> T {
    return unsafe { #block_on::[T](f) };
}

// v0.0.4 Phase 3 Slice 3A.2: yield control back to the executor.
// Only meaningful inside an `async fn` body — pushes this onto the
// reactor's pending queue and suspends. On the next block_on
// iteration, the drain step resumes us; cooperative-multitasking
// primitive for "give other tasks a turn."
async fn yield_now() {
    unsafe { #reactor_yield_now(); }
    return;
}

// v0.0.4 Phase 3 Slice 3A.2: enqueue a future for the executor to
// drive in addition to the one passed to `block_on`. The spawned
// future runs to completion in the same thread, interleaved with
// the awaiter. Single-threaded only.
//
// `T` must be Send for forward compatibility, even though v0.0.4's
// Send is permissive (every type satisfies it).
fn spawn_local[T: Send](take f: future::Future[T]) {
    unsafe { #reactor_spawn_local(f); }
    return;
}

// Touch reactor module so the `import` isn't treated as unused. The
// reactor's stable-symbol exports are link-time-resolved; this read
// keeps the import elided-pass happy.
fn _touch_reactor() -> i32 {
    return reactor::waiter_count();
}
