// stdlib/option.cplus — `Option[T]` (v0.0.4 Phase 4).
//
// The canonical "value or nothing" type. Returned by `Iterator[T]::next()`
// to signal end-of-stream. Also useful anywhere a function might or
// might not produce a value.
//
// **Why not just use `Result[T, E]` with `E = ()`?** Option's `None`
// case is more idiomatic for "no value here, this isn't an error";
// Result's `Err` implies a fault path. Both shapes coexist — pick the
// one that matches caller intent.

enum Option[T] {
    Some(T),
    None,
}

// Generic constructor for `Some` — symmetric with `Result::ok`. The
// `None` variant is constructed directly as `Option[T]::None` with the
// turbofish (sema can't infer T from a payload-less variant).
fn some[T](take v: T) -> Option[T] {
    return Option[T]::Some(v);
}

// ───────────────────────────── tests ─────────────────────────────

#[test]
fn option_some_constructor() {
    let o: Option[i32] = some::[i32](42);
    match o {
        Option[i32]::Some(x) => { assert x == 42; }
        Option[i32]::None => { assert false; }
    }
    return;
}

#[test]
fn option_some_direct() {
    let o: Option[i32] = Option[i32]::Some(7);
    match o {
        Option[i32]::Some(x) => { assert x == 7; }
        Option[i32]::None => { assert false; }
    }
    return;
}

#[test]
fn option_none() {
    let o: Option[i32] = Option[i32]::None;
    match o {
        Option[i32]::Some(x) => { assert false; }
        Option[i32]::None => { assert true; }
    }
    return;
}
