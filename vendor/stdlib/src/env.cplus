// stdlib/env.cplus — environment variables and argv.
//
// Built on libc `getenv` + macOS `_NSGetArgc`/`_NSGetArgv`. Returns
// byte counts and writes into caller-owned `Vec[u8]` buffers (rather
// than returning owned `string`) because v0.0.3 codegen doesn't yet
// track drop ownership through cross-module returns of heap-owning
// aggregates. See [stdlib/fs.cplus](./fs.cplus) for the same pattern.

import "./vec" as vec;

extern fn getenv(name: *u8) -> *u8;
extern fn _NSGetArgc() -> *i32;
extern fn _NSGetArgv() -> ***u8;
extern fn strlen(s: *u8) -> usize;

// Read env var `name` and append its bytes to `out`. Returns true on
// success (variable set), false on absent. Empty values append 0 bytes
// and still return true; check `out.len()` if you need to distinguish.
fn var_into(name: str, ref out: vec::Vec[u8]) -> bool {
    let raw: *u8 = unsafe { getenv(#str_ptr(name)) };
    let null: *u8 = unsafe { 0 as *u8 };
    if raw == null {
        return false;
    }
    let len: usize = unsafe { strlen(raw) };
    var i: usize = 0 as usize;
    while i < len {
        let bp: *u8 = unsafe { raw + i };
        out.push(unsafe { *bp });
        i = i +% (1 as usize);
    }
    return true;
}

// Convenience: true iff `name` is set in the environment.
fn has_var(name: str) -> bool {
    let raw: *u8 = unsafe { getenv(#str_ptr(name)) };
    let null: *u8 = unsafe { 0 as *u8 };
    return raw != null;
}

// Process argv count. Includes argv[0] (the program name).
fn argc() -> usize {
    let c: i32 = unsafe { *_NSGetArgc() };
    return c as usize;
}

// Append the bytes of argv[i] to `out`. Returns true on success, false
// if i >= argc.
fn arg_into(i: usize, ref out: vec::Vec[u8]) -> bool {
    let n: i32 = unsafe { *_NSGetArgc() };
    if i >= (n as usize) {
        return false;
    }
    let argv: **u8 = unsafe { *_NSGetArgv() };
    let pp: **u8 = unsafe { argv + i };
    let arg: *u8 = unsafe { *pp };
    let len: usize = unsafe { strlen(arg) };
    var k: usize = 0 as usize;
    while k < len {
        let bp: *u8 = unsafe { arg + k };
        out.push(unsafe { *bp });
        k = k +% (1 as usize);
    }
    return true;
}
