// stdlib/env.cplus — environment variables and argv.
//
// Built on libc `getenv` + macOS `_NSGetArgc`/`_NSGetArgv`. The reads return an
// owned `Text` wrapped in `Option` — `Some(value)` when set, `None` when absent
// — so a caller never has to pre-allocate a buffer and the missing case is
// impossible to ignore by accident. (The older `*_into(ref out)` buffer pattern
// predated cross-module owned-`Text` returns; those now work.)

import "./option" as option;
import "./text" as text;

extern fn getenv(name: *u8) -> *u8;
extern fn _NSGetArgc() -> *i32;
extern fn _NSGetArgv() -> ***u8;
extern fn strlen(s: *u8) -> usize;

// The value of env var `name` as an owned `Text`, or `None` if it is not set.
// An empty-but-set variable returns `Some` of an empty `Text` (distinct from
// `None`).
fn var(name: str) -> option::Option[text::Text] {
    let raw: *u8 = { getenv(#str_ptr(name)) };
    let null: *u8 = { 0 as *u8 };
    if raw == null {
        return option::Option[text::Text]::None;
    }
    let len: usize = { strlen(raw) };
    let view: str = { #str_from_raw_parts(raw, len) };
    return option::Option[text::Text]::Some(view.to_text());
}

// True iff `name` is set in the environment.
fn has_var(name: str) -> bool {
    let raw: *u8 = { getenv(#str_ptr(name)) };
    let null: *u8 = { 0 as *u8 };
    return raw != null;
}

// Process argv count. Includes argv[0] (the program name).
fn argc() -> usize {
    let c: i32 = { *_NSGetArgc() };
    return c as usize;
}

// argv[`i`] as an owned `Text`, or `None` if `i >= argc`.
fn arg(i: usize) -> option::Option[text::Text] {
    let n: i32 = { *_NSGetArgc() };
    if i >= (n as usize) {
        return option::Option[text::Text]::None;
    }
    let argv: **u8 = { *_NSGetArgv() };
    let pp: **u8 = { argv + i };
    let a: *u8 = { *pp };
    let len: usize = { strlen(a) };
    let view: str = { #str_from_raw_parts(a, len) };
    return option::Option[text::Text]::Some(view.to_text());
}

// ───────────────────────────── tests ─────────────────────────────

#[test]
fn env_has_var() {
    assert has_var("PATH"); // set on macOS + Linux
    assert has_var("CPLUS_NOT_A_REAL_VAR_XYZ") == false;
}

#[test]
fn env_var_returns_value() {
    match var("PATH") {
        option::Option[text::Text]::Some(v) => { assert v.is_empty() == false; }
        option::Option[text::Text]::None => { assert false; }
    }
    return;
}

#[test]
fn env_var_absent_is_none() {
    match var("CPLUS_NOT_A_REAL_VAR_XYZ") {
        option::Option[text::Text]::Some(v) => { assert false; }
        option::Option[text::Text]::None => { assert true; }
    }
    return;
}

#[test]
fn env_argc_at_least_one() {
    assert argc() >= (1 as usize); // argv[0] is the program name
}

#[test]
fn env_arg_zero_present() {
    match arg(0 as usize) {
        option::Option[text::Text]::Some(a) => { assert a.is_empty() == false; }
        option::Option[text::Text]::None => { assert false; }
    }
    return;
}
