// stdlib/env.cplus — environment variables and argv.
//
// Skeleton: API only. Bodies fill in during Phase 3.
//
// `var` wraps libc `getenv`; `args` walks the C runtime's argv array.
// Both return owned `string` so callers don't have to track libc's
// internal storage lifetime.

import "./result.cplus" as result;
import "./vec.cplus" as vec;

// Read an env variable by name. None when unset.
//
// Phase 3 may swap `Result` for a dedicated `Option`-like type — keeping
// `Result` here for now since the skeleton's Result enum is the only
// option-shaped type available.
pub fn var(name: str) -> result::Result[string, result::IoError] {
    // TODO: Phase 3 — extern fn getenv(name: *u8) -> *u8;
    // null → Err(NotFound); else copy bytes into owned string.
    return result::Result::Err(result::IoError::NotFound);
}

// Process argv as owned strings. argv[0] is conventionally the binary
// name. Order matches the C runtime's argv.
pub fn args() -> vec::Vec[string] {
    // TODO: Phase 3 — walk argv until null; copy each into owned string;
    // push into a Vec[string].
    return vec::Vec[string]::new();
}
