// stdlib/result.cplus

pub enum Result[T, E] {
    Ok(T),
    Err(E),
}

pub enum IoError {
    NotFound,
    PermissionDenied,
    AlreadyExists,
    Interrupted,
    UnexpectedEof,
    InvalidInput,
    InvalidData,
    WouldBlock,
    ConnectionRefused,
    ConnectionReset,
    AddrInUse,
    BrokenPipe,
    TimedOut,
    Other,
}

// Generic constructors. T and E must be supplied via turbofish at the call
// site (sema can't infer E from the arg alone when E doesn't appear in the
// arg position).
pub fn ok[T, E](move v: T) -> Result[T, E] {
    return Result[T, E]::Ok(v);
}

pub fn err[T, E](move e: E) -> Result[T, E] {
    return Result[T, E]::Err(e);
}

// Convenience constructors for the common `Result[T, IoError]` shape.
pub fn io_ok[T](move v: T) -> Result[T, IoError] {
    return Result[T, IoError]::Ok(v);
}

pub fn io_err[T](e: IoError) -> Result[T, IoError] {
    return Result[T, IoError]::Err(e);
}
