// stdlib/net.cplus ŌĆö TCP networking.
//
// Built on libc socket/connect/bind/listen/accept/read/write/close via
// `extern fn`. `TcpStream` and `TcpListener` are owned fd handles; Drop
// closes them on scope exit.
//
// v0.0.3 scope: IPv4 + numeric IP addresses only. DNS resolution (via
// `gethostbyname` or `getaddrinfo`) is a follow-up ŌĆö for now, callers
// pass an IP string like "127.0.0.1". The `gethostbyname` recipe lives
// at [docs/examples/recipes/http_get/](../../../docs/examples/recipes/http_get/)
// for programs that need DNS today.

import "./result" as result;
import "./vec" as vec;
import "./reactor" as reactor;
import "./future" as future;
// Platform syscall constants + errno accessor. macOS values live in
// netsys.cplus; Linux ones in netsys_linux.cplus (selected by the
// resolver's `_linux` override). Keeps this file platform-neutral.
import "./netsys" as netsys;

extern fn socket(domain: i32, ty: i32, protocol: i32) -> i32;
extern fn connect(fd: i32, addr: *u8, len: u32) -> i32;
extern fn bind(fd: i32, addr: *u8, len: u32) -> i32;
extern fn listen(fd: i32, backlog: i32) -> i32;
extern fn accept(fd: i32, addr: *u8, len: *u32) -> i32;
extern fn setsockopt(fd: i32, level: i32, optname: i32, optval: *u8, optlen: u32) -> i32;
extern fn shutdown(fd: i32, how: i32) -> i32;
// read / write / close on a socket fd differ by platform (POSIX read/write/
// close vs Winsock recv/send/closesocket), so they route through netsys.
extern fn inet_addr(s: *u8) -> u32;
extern fn malloc(n: usize) -> *u8;
extern fn memset(p: *u8, c: i32, n: usize) -> *u8;
extern fn free(p: *u8);

struct TcpStream {
    _fd: i32,
}

struct TcpListener {
    _fd: i32,
}

// Build a `sockaddr_in` for IPv4 in a fresh malloc'd buffer (16 bytes).
// The first two bytes are platform-specific (macOS has a `sin_len` byte
// ahead of the family; Linux starts with a 2-byte family) ŌĆö netsys
// supplies them. Caller owns the buffer.
fn build_sockaddr(ip_dotted: str, port: u16) -> *u8 {
    let addr: u32 = { inet_addr(#str_ptr(ip_dotted)) };
    let sa: *u8 = { malloc(16 as usize) };
    if sa.is_null() {
        return { 0 as *u8 };   // allocation failed; callers check for null
    }
    {
        memset(sa, 0 as i32, 16 as usize);
        sa[0 as usize] = netsys::sa_family_byte0();
        sa[1 as usize] = netsys::sa_family_byte1();
        // sin_port in network byte order (high byte first).
        sa[2 as usize] = ((port >> (8 as u32)) & (0xff as u16)) as u8;
        sa[3 as usize] = (port & (0xff as u16)) as u8;
        sa[4 as usize] = (addr & (0xff as u32)) as u8;
        sa[5 as usize] = ((addr >> (8 as u32)) & (0xff as u32)) as u8;
        sa[6 as usize] = ((addr >> (16 as u32)) & (0xff as u32)) as u8;
        sa[7 as usize] = ((addr >> (24 as u32)) & (0xff as u32)) as u8;
    }
    return sa;
}

// Connect to `ip:port` over TCP. `ip` is a dotted-quad string ("127.0.0.1");
// DNS resolution is out of scope for v0.0.3.
fn connect_tcp(ip: str, port: u16) -> result::Result[TcpStream, result::IoError] {
    // Initialize the socket subsystem (Winsock on Windows; no-op on POSIX)
    // before the first socket call.
    { netsys::startup(); }
    // AF_INET=2, SOCK_STREAM=1.
    let fd: i32 = { socket(2 as i32, 1 as i32, 0 as i32) };
    if fd < (0 as i32) {
        return result::io_err::[TcpStream](result::IoError::Other);
    }
    let sa: *u8 = build_sockaddr(ip, port);
    if sa.is_null() {
        { netsys::close_fd(fd); }
        return result::io_err::[TcpStream](result::IoError::Other);
    }
    let crc: i32 = { connect(fd, sa, 16 as u32) };
    { free(sa); }
    if crc != (0 as i32) {
        { netsys::close_fd(fd); }
        return result::io_err::[TcpStream](result::IoError::ConnectionRefused);
    }
    return result::io_ok::[TcpStream](TcpStream { _fd: fd });
}

// Bind a listener to 127.0.0.1:port and start listening. Sets SO_REUSEADDR
// so quick test restarts don't hit EADDRINUSE.
fn listen_tcp(port: u16) -> result::Result[TcpListener, result::IoError] {
    // Initialize the socket subsystem (Winsock on Windows; no-op on POSIX)
    // before the first socket call.
    { netsys::startup(); }
    let fd: i32 = { socket(2 as i32, 1 as i32, 0 as i32) };
    if fd < (0 as i32) {
        return result::io_err::[TcpListener](result::IoError::Other);
    }
    // SO_REUSEADDR ŌĆö level + optname are platform-specific (netsys). If the
    // tiny option buffer can't be allocated, skip the hint (non-fatal) rather
    // than trap.
    let one: *u8 = { malloc(4 as usize) };
    if one.is_not_null() {
        {
            one[0 as usize] = 1 as u8; one[1 as usize] = 0 as u8;
            one[2 as usize] = 0 as u8; one[3 as usize] = 0 as u8;
        }
        { setsockopt(fd, netsys::sol_socket(), netsys::so_reuseaddr(), one, 4 as u32); }
        { free(one); }
    }

    let sa: *u8 = build_sockaddr("127.0.0.1", port);
    if sa.is_null() {
        { netsys::close_fd(fd); }
        return result::io_err::[TcpListener](result::IoError::Other);
    }
    let brc: i32 = { bind(fd, sa, 16 as u32) };
    { free(sa); }
    if brc != (0 as i32) {
        { netsys::close_fd(fd); }
        return result::io_err::[TcpListener](result::IoError::AddrInUse);
    }
    let lrc: i32 = { listen(fd, 16 as i32) };
    if lrc != (0 as i32) {
        { netsys::close_fd(fd); }
        return result::io_err::[TcpListener](result::IoError::Other);
    }
    return result::io_ok::[TcpListener](TcpListener { _fd: fd });
}

impl TcpStream {
    // Drain all remaining bytes from the peer (until EOF or error).
    fn read_to_end(ref this) -> result::Result[vec::Vec[u8], result::IoError] {
        var buf: vec::Vec[u8] = vec::new::[u8]();
        if this._fd < (0 as i32) {
            return result::io_err::[vec::Vec[u8]](result::IoError::InvalidInput);
        }
        let chunk_size: usize = 4096 as usize;
        let chunk: *u8 = { malloc(chunk_size) };
        if chunk.is_null() {
            return result::io_err::[vec::Vec[u8]](result::IoError::Other);
        }
        loop {
            let n: isize = { netsys::recv_fd(this._fd, chunk, chunk_size) };
            if n < (0 as isize) {
                { free(chunk); }
                return result::io_err::[vec::Vec[u8]](result::IoError::ConnectionReset);
            }
            if n == (0 as isize) {
                { free(chunk); }
                return result::io_ok::[vec::Vec[u8]](buf);
            }
            let count: usize = n as usize;
            var k: usize = 0 as usize;
            while k < count {
                let byte_p: *u8 = { chunk + k };
                buf.append({ *byte_p });
                k = k +% (1 as usize);
            }
        }
        return result::io_err::[vec::Vec[u8]](result::IoError::Other);
    }

    // Write `data` to the peer. Loops on short writes.
    fn write_all(ref this, data: vec::Vec[u8]) -> result::Result[usize, result::IoError] {
        if this._fd < (0 as i32) {
            return result::io_err::[usize](result::IoError::InvalidInput);
        }
        let n: usize = data.count();
        let slice: u8[] = data.as_slice();
        let p: *u8 = { #slice_ptr(slice) };
        var written: usize = 0 as usize;
        while written < n {
            let remaining: usize = n -% written;
            let q: *u8 = { p + written };
            let w: isize = { netsys::send_fd(this._fd, q, remaining) };
            if w <= (0 as isize) {
                return result::io_err::[usize](result::IoError::BrokenPipe);
            }
            written = written +% (w as usize);
        }
        return result::io_ok::[usize](written);
    }

    // Half-close the write side so the peer sees EOF. Pairs with a remote
    // `read_to_end` that would otherwise block forever waiting for more.
    fn shutdown_write(this) {
        if this._fd >= (0 as i32) {
            { shutdown(this._fd, 1 as i32); }
        }
        return;
    }

    fn close(ref this) {
        if this._fd >= (0 as i32) {
            { netsys::close_fd(this._fd); }
            this._fd = 0 -% 1 as i32;
        }
        return;
    }

    fn drop(ref this) {
        if this._fd >= (0 as i32) {
            { netsys::close_fd(this._fd); }
        }
        return;
    }

    // v0.0.5 Phase 4 Slice 4B: async I/O method form. `mut this` is
    // pointer-passed (not consumed), so callers can chain ŌĆö a
    // `stream.read_async(...)` then `stream.write_async(...)` keeps
    // the same handle live and Drop still runs on scope exit.
    //
    // Slice 4F shipped the executor's awaiter-notification machinery
    // (register_awaiter at await sites + notify_completed in async
    // fn epilogues), so these can now be real `async fn` methods ŌĆö
    // multi-level await chains drive correctly.
    //
    // Prerequisite: the stream's fd must be non-blocking. Easiest path
    // is to call `this.make_nonblocking()` once after construction.

    // Mark the stream's fd O_NONBLOCK. Idempotent; safe to call
    // repeatedly. Returns 0 on success, -1 on fcntl error.
    fn make_nonblocking(ref this) -> i32 {
        return set_nonblocking(this._fd);
    }

    // Async read: same semantics as `read_fd_async(this._fd, buf, count)`.
    async fn read_async(ref this, buf: *u8, count: usize) -> isize {
        return await read_fd_async(this._fd, buf, count);
    }

    // Async best-effort write (may return < count).
    async fn write_async(ref this, buf: *u8, count: usize) -> isize {
        return await write_fd_async(this._fd, buf, count);
    }

    // Async full-buffer write ŌĆö loops on short writes / EAGAIN.
    async fn write_all_async(ref this, buf: *u8, count: usize) -> isize {
        return await write_all_fd_async(this._fd, buf, count);
    }
}

impl TcpListener {
    // Block until a client connects, return the accepted stream.
    fn accept(ref this) -> result::Result[TcpStream, result::IoError] {
        if this._fd < (0 as i32) {
            return result::io_err::[TcpStream](result::IoError::InvalidInput);
        }
        // We don't expose the peer's address (would need another allocation
        // + caller-side parsing). Pass NULL pointers so accept skips it.
        let null_ptr: *u8 = { 0 as *u8 };
        let null_len: *u32 = { 0 as *u32 };
        let cfd: i32 = { accept(this._fd, null_ptr, null_len) };
        if cfd < (0 as i32) {
            return result::io_err::[TcpStream](result::IoError::Other);
        }
        return result::io_ok::[TcpStream](TcpStream { _fd: cfd });
    }

    fn close(ref this) {
        if this._fd >= (0 as i32) {
            { netsys::close_fd(this._fd); }
            this._fd = 0 -% 1 as i32;
        }
        return;
    }

    fn drop(ref this) {
        if this._fd >= (0 as i32) {
            { netsys::close_fd(this._fd); }
        }
        return;
    }

    // v0.0.5 Phase 4 Slice 4B: async accept method form. Slice 4F's
    // awaiter-notification fix made real `async fn` shapes safe here.
    fn make_nonblocking(ref this) -> i32 {
        return set_nonblocking(this._fd);
    }

    // Async accept: returns the accepted client fd on success (>= 0),
    // -1 on error.
    async fn accept_async(ref this) -> i32 {
        return await accept_fd_async(this._fd);
    }
}

// -----------------------------------------------------------------------------
// v0.0.4 Phase 3 Slice 3A.3 ŌĆö async I/O wrappers.
//
// Pattern: every wrapper requires the fd to be set non-blocking (call
// `set_nonblocking(fd)` once before first use), then loops:
//   1. Try the sync syscall (read / write / accept).
//   2. If it returns 0 or > 0 (or a valid fd for accept), return.
//   3. If it returns -1 and errno == EAGAIN, await the reactor's
//      wait_read / wait_write ŌĆö this suspends the coroutine until the
//      kqueue/epoll reports the fd ready. Then retry.
//   4. Any other -1 returns an error sentinel.
//
// The wrappers are free fns taking a raw `fd: i32` rather than methods on
// TcpStream / TcpListener: those types are non-Copy (have Drop), and v0.0.4
// async-method `this` passing would consume the stream on first call. Free
// fns sidestep that ŌĆö pass `stream._fd` and keep your handle. A friendlier
// method API can re-export these once impl-on-non-Copy-this async lands.
//
// EAGAIN / O_NONBLOCK / errno and the read/write/close + non-blocking
// mechanics all differ across macOS, Linux and Windows ŌĆö netsys supplies
// the right ones for the target.

// Set fd to non-blocking mode. Idempotent ŌĆö safe to call repeatedly on the
// same fd. Returns 0 on success, -1 on error. Delegates to the platform
// netsys shim (fcntl(O_NONBLOCK) on POSIX, ioctlsocket(FIONBIO) on Windows).
fn set_nonblocking(fd: i32) -> i32 {
    return netsys::set_nonblocking(fd);
}

// Async read from `fd` into `buf` for up to `count` bytes. Returns:
//   > 0  ŌĆö number of bytes read.
//   = 0  ŌĆö EOF (peer closed).
//   < 0  ŌĆö error (-1 generic).
//
// Suspends the calling coroutine via the reactor until data is available;
// under `block_on`, other queued tasks make progress meanwhile.
async fn read_fd_async(fd: i32, buf: *u8, count: usize) -> isize {
    loop {
        let n: isize = { netsys::recv_fd(fd, buf, count) };
        if n >= (0 as isize) {
            return n;
        }
        let e: i32 = netsys::errno();
        if e != netsys::eagain() {
            return (0 -% 1) as isize;
        }
        { #reactor_wait_read(fd); }
    }
    return (0 -% 1) as isize;
}

// Async write to `fd` from `buf` for up to `count` bytes. Returns:
//   > 0  ŌĆö bytes written this call (may be < count; caller loops or uses
//          `write_all_fd_async` for a full-write wrapper).
//   < 0  ŌĆö error (-1 generic).
async fn write_fd_async(fd: i32, buf: *u8, count: usize) -> isize {
    loop {
        let n: isize = { netsys::send_fd(fd, buf, count) };
        if n >= (0 as isize) {
            return n;
        }
        let e: i32 = netsys::errno();
        if e != netsys::eagain() {
            return (0 -% 1) as isize;
        }
        { #reactor_wait_write(fd); }
    }
    return (0 -% 1) as isize;
}

// Write every byte in [buf, buf+count). Loops on short writes, awaiting
// the reactor on EAGAIN. Returns 0 on full success, -1 on any error.
async fn write_all_fd_async(fd: i32, buf: *u8, count: usize) -> isize {
    var written: usize = 0 as usize;
    while written < count {
        let remaining: usize = count -% written;
        let q: *u8 = { buf + written };
        let m: isize = await write_fd_async(fd, q, remaining);
        if m <= (0 as isize) {
            return (0 -% 1) as isize;
        }
        written = written +% (m as usize);
    }
    return 0 as isize;
}

// Async accept on a listening socket. Returns:
//   >= 0  ŌĆö accepted client fd.
//   <  0  ŌĆö error.
async fn accept_fd_async(listener_fd: i32) -> i32 {
    let null_ptr: *u8 = { 0 as *u8 };
    let null_len: *u32 = { 0 as *u32 };
    loop {
        let cfd: i32 = { accept(listener_fd, null_ptr, null_len) };
        if cfd >= (0 as i32) {
            return cfd;
        }
        let e: i32 = netsys::errno();
        if e != netsys::eagain() {
            return 0 -% 1 as i32;
        }
        { #reactor_wait_read(listener_fd); }
    }
    return 0 -% 1 as i32;
}

// ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ tests ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ

#[test]
fn net_listen_tcp_binds_on_ephemeral_port() {
    // Port 0 -> the OS assigns a free port, so bind+listen succeed without a
    // fixed-port conflict. Exercises the socket/bind/listen path.
    match listen_tcp(0 as u16) {
        result::Result[TcpListener, result::IoError]::Ok(l) => {
            var srv: TcpListener = l;
            srv.close();
        }
        result::Result[TcpListener, result::IoError]::Err(e) => { assert false; }
    }
    return;
}
