// stdlib/hash_map.cplus — Generic `HashMap[K, V]` (v0.0.4 Slice 3B.5).
//
// Open addressing with linear probing, doubling at 0.75 load factor.
//
// **Type parameters and bounds.**
//
//   - `K: Copy` — keys are bitwise-copied into the table on insert.
//     Primitive types (`i32`, `i64`, `u64`, `usize`, `str`, ...) are
//     Copy structurally. User struct types are Copy iff every field is
//     Copy. For `K = str`, the table stores the str's fat pointer
//     verbatim — **the caller is responsible for keeping the underlying
//     bytes alive for the map's lifetime**. Use static string literals
//     or pre-allocated buffers; never store a str backed by a heap
//     string that drops before the map.
//
//   - `V: Copy` — same bitwise-copy semantics on insert and `get`.
//     Non-Copy `V` (like `string` or `Vec[T]`) would need Drop hooks
//     on overwrite and on map-Drop; forward-pointed to a future slice.
//
// **Hashing and equality.**
//
//   - `K.hash() -> u64` and `K.eq(other) -> bool` are required. The
//     compiler ships blessed implementations for every integer
//     primitive plus `str` — those just work. User types provide their
//     own via `impl Hash for MyType { fn hash(self) -> u64 { ... } }`
//     and `impl Eq for MyType { fn eq(self, other: Self) -> bool { ... } }`.
//
//     The generic body in this module calls `k.hash()` and `k.eq(stored)`
//     directly; monomorphization picks the right lowering per
//     instantiation.
//
// **Layout** (parallel arrays — separate K, V, and occupancy buffers,
// avoids per-entry padding that a `{K, V, bool}` slot struct would pay):
//
//   keys:     *K       — cap slots
//   vals:     *V       — cap slots
//   occupied: *u8      — cap slots; 0 = empty, 1 = occupied
//   cap, len: usize
//
// **API.**
//
//   hash_map::new::[K, V]() -> HashMap[K, V]
//   HashMap[K, V]::len(self) -> usize
//   HashMap[K, V]::capacity(self) -> usize
//   HashMap[K, V]::insert(mut self, k: K, v: V)
//   HashMap[K, V]::get(self, k: K) -> result::Result[V, result::IoError]
//   HashMap[K, V]::contains_key(self, k: K) -> bool
//
// `StrIntMap` from v0.0.3 is retained as a thin alias: `pub fn
// new_str_int_map() -> HashMap[str, i32]` constructs the same shape.

import "./result" as result;

extern fn malloc(n: usize) -> *u8;
extern fn realloc(p: *u8, n: usize) -> *u8;
extern fn free(p: *u8);
extern fn memcpy(dest: *u8, src: *u8, n: usize) -> *u8;
extern fn memset(b: *u8, c: i32, len: usize) -> *u8;

pub struct HashMap[K, V] {
    keys: *K,
    vals: *V,
    occupied: *u8,
    cap: usize,
    len: usize,
}

// Empty map; first insert allocates. `K` and `V` must both satisfy the
// blessed bounds documented at the top of this file — sema enforces
// them at use-site monomorphization.
pub fn new[K, V]() -> HashMap[K, V] {
    return HashMap[K, V] {
        keys: unsafe { 0 as *K },
        vals: unsafe { 0 as *V },
        occupied: unsafe { 0 as *u8 },
        cap: 0 as usize,
        len: 0 as usize,
    };
}

impl HashMap[K, V] {
    pub fn len(self) -> usize {
        return self.len;
    }

    pub fn capacity(self) -> usize {
        return self.cap;
    }

    // Insert or overwrite `k -> v`. Key + value are bitwise-copied into
    // the table (their `Copy` bound makes this safe).
    pub fn insert(mut self, k: K, v: V) {
        if self.cap == (0 as usize) {
            self.grow_to(16 as usize);
        }
        // Grow at 0.75 load factor.
        if (self.len *% (4 as usize)) >= (self.cap *% (3 as usize)) {
            self.grow_to(self.cap *% (2 as usize));
        }
        let h: u64 = k.hash();
        let start: usize = (h as usize) % self.cap;
        let mut slot: usize = start;
        loop {
            let occ: u8 = unsafe { self.occupied[slot] };
            if occ == (0 as u8) {
                unsafe { self.keys[slot] = k; }
                unsafe { self.vals[slot] = v; }
                unsafe { self.occupied[slot] = 1 as u8; }
                self.len = self.len +% (1 as usize);
                return;
            }
            let existing: K = unsafe { self.keys[slot] };
            if existing.eq(k) {
                unsafe { self.vals[slot] = v; }
                return;
            }
            slot = (slot +% (1 as usize)) % self.cap;
            if slot == start { return; } // table full; cannot happen post-grow
        }
    }

    // Look up `k`. Returns Ok(v) on hit, Err(NotFound) on miss.
    pub fn get(self, k: K) -> result::Result[V, result::IoError] {
        if self.cap == (0 as usize) {
            return result::io_err::[V](result::IoError::NotFound);
        }
        let h: u64 = k.hash();
        let start: usize = (h as usize) % self.cap;
        let mut slot: usize = start;
        loop {
            let occ: u8 = unsafe { self.occupied[slot] };
            if occ == (0 as u8) {
                return result::io_err::[V](result::IoError::NotFound);
            }
            let existing: K = unsafe { self.keys[slot] };
            if existing.eq(k) {
                let v: V = unsafe { self.vals[slot] };
                return result::io_ok::[V](v);
            }
            slot = (slot +% (1 as usize)) % self.cap;
            if slot == start {
                return result::io_err::[V](result::IoError::NotFound);
            }
        }
        return result::io_err::[V](result::IoError::NotFound);  // unreachable
    }

    pub fn contains_key(self, k: K) -> bool {
        return match self.get(k) {
            result::Result[V, result::IoError]::Ok(_) => true,
            result::Result[V, result::IoError]::Err(_) => false,
        };
    }

    // Grow capacity to at least `new_cap`. Re-inserts every live entry
    // (open-addressing positions depend on cap, so a memcpy-resize won't
    // work). Internal helper; not in the public surface.
    fn grow_to(mut self, new_cap: usize) {
        let old_keys: *K = self.keys;
        let old_vals: *V = self.vals;
        let old_occ: *u8 = self.occupied;
        let old_cap: usize = self.cap;

        let keys_bytes: usize = new_cap *% #size_of::[K]();
        let vals_bytes: usize = new_cap *% #size_of::[V]();
        let occ_bytes: usize = new_cap;
        let nk_raw: *u8 = unsafe { malloc(keys_bytes) };
        let nv_raw: *u8 = unsafe { malloc(vals_bytes) };
        let no_raw: *u8 = unsafe { malloc(occ_bytes) };
        // Zero the occupied buffer so empty-slot detection is correct.
        unsafe { memset(no_raw, 0 as i32, occ_bytes); }
        self.keys = unsafe { nk_raw as *K };
        self.vals = unsafe { nv_raw as *V };
        self.occupied = unsafe { no_raw as *u8 };
        self.cap = new_cap;
        self.len = 0 as usize;

        // Re-insert every old live entry.
        let mut j: usize = 0 as usize;
        while j < old_cap {
            let occ_j: u8 = unsafe { old_occ[j] };
            if occ_j != (0 as u8) {
                let k: K = unsafe { old_keys[j] };
                let v: V = unsafe { old_vals[j] };
                let h: u64 = k.hash();
                let start: usize = (h as usize) % self.cap;
                let mut slot: usize = start;
                loop {
                    let cur: u8 = unsafe { self.occupied[slot] };
                    if cur == (0 as u8) {
                        unsafe { self.keys[slot] = k; }
                        unsafe { self.vals[slot] = v; }
                        unsafe { self.occupied[slot] = 1 as u8; }
                        self.len = self.len +% (1 as usize);
                        break;
                    }
                    slot = (slot +% (1 as usize)) % self.cap;
                    if slot == start { break; }
                }
            }
            j = j +% (1 as usize);
        }
        if old_cap > (0 as usize) {
            unsafe { free(old_keys as *u8); }
            unsafe { free(old_vals as *u8); }
            unsafe { free(old_occ); }
        }
        return;
    }

    fn drop(mut self) {
        if self.cap == (0 as usize) { return; }
        // v0.0.5 Phase 1C: invoke per-entry Drop for each live (K, V)
        // pair before freeing the parallel storage arrays. Closes the
        // v0.0.4 leak where `HashMap[str, string]` leaked every value
        // and (for non-static) every key.
        let mut i: usize = 0 as usize;
        while i < self.cap {
            let occ: u8 = unsafe { self.occupied[i] };
            if occ != (0 as u8) {
                let k_ptr: *K = unsafe { self.keys + i };
                let v_ptr: *V = unsafe { self.vals + i };
                unsafe { __cplus_drop_in_place::[K](k_ptr); }
                unsafe { __cplus_drop_in_place::[V](v_ptr); }
            }
            i = i +% (1 as usize);
        }
        unsafe { free(self.keys as *u8); }
        unsafe { free(self.vals as *u8); }
        unsafe { free(self.occupied); }
        return;
    }
}

// v0.0.3 alias retained so existing callers don't have to migrate
// immediately. The shape is identical to the generic form; users can
// switch to `hash_map::new::[str, i32]()` directly when convenient.
pub fn new_str_int_map() -> HashMap[str, i32] {
    return new::[str, i32]();
}
