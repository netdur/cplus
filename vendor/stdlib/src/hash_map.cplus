// stdlib/hash_map.cplus — concrete `StrIntMap` (str → i32) for v0.0.3.
//
// Generic `HashMap[K, V]` is deferred to v0.0.4: it needs a `Hash[K]`
// interface that monomorphizes correctly across module boundaries,
// which compounds the same cross-module-impl machinery shipped for
// generic-struct methods in v0.0.3 Slice 1P. For now, this concrete
// map covers the 80% case (text counter, header dictionary, simple
// caches). The shape mirrors the eventual generic API so consumer
// code reads the same after the migration.
//
// Open addressing with linear probing. Doubles capacity at 0.75 load
// factor. Keys are byte-copied into the table on insert; the caller's
// `str` borrow can drop without affecting the map.

import "./result" as result;

extern fn malloc(n: usize) -> *u8;
extern fn realloc(p: *u8, n: usize) -> *u8;
extern fn free(p: *u8);
extern fn memcpy(dest: *u8, src: *u8, n: usize) -> *u8;

pub struct StrIntMap {
    // Three parallel arrays sized at `cap` entries each.
    keys: **u8,        // *u8 per slot — heap-owned copy of the key bytes (null = empty)
    klens: *usize,     // byte length of slot i's key (0 = empty)
    vals: *i32,        // value associated with slot i
    cap: usize,
    len: usize,
}

// FNV-1a 64-bit. Stable, fast, no need for randomization in v0.0.3.
fn fnv1a(bytes: *u8, len: usize) -> u64 {
    let mut h: u64 = 0xcbf29ce484222325 as u64;
    let mut i: usize = 0 as usize;
    while i < len {
        let b: u8 = unsafe { bytes[i] };
        h = h ^ (b as u64);
        h = h *% (0x100000001b3 as u64);
        i = i +% (1 as usize);
    }
    return h;
}

fn keys_equal(a: *u8, alen: usize, b: *u8, blen: usize) -> bool {
    if alen != blen { return false; }
    let mut i: usize = 0 as usize;
    while i < alen {
        if unsafe { a[i] } != unsafe { b[i] } { return false; }
        i = i +% (1 as usize);
    }
    return true;
}

// Empty map; allocates on first insert. Drop releases all heap memory.
pub fn new_str_int_map() -> StrIntMap {
    return StrIntMap {
        keys: unsafe { 0 as **u8 },
        klens: unsafe { 0 as *usize },
        vals: unsafe { 0 as *i32 },
        cap: 0 as usize,
        len: 0 as usize,
    };
}

impl StrIntMap {
    pub fn len(self) -> usize {
        return self.len;
    }

    pub fn capacity(self) -> usize {
        return self.cap;
    }

    // Insert or overwrite `key → val`. The key bytes are copied into the
    // table's own allocation; the caller's `str` can drop afterward.
    pub fn insert(mut self, key: str, val: i32) {
        if self.cap == (0 as usize) {
            self.grow_to(16 as usize);
        }
        // Grow at 0.75 load factor.
        if (self.len *% (4 as usize)) >= (self.cap *% (3 as usize)) {
            self.grow_to(self.cap *% (2 as usize));
        }
        let kp: *u8 = str_ptr(key);
        let kl: usize = str_len(key);
        let h: u64 = fnv1a(kp, kl);
        let start: usize = (h as usize) % self.cap;
        let mut slot: usize = start;
        loop {
            let existing_len: usize = unsafe { self.klens[slot] };
            if existing_len == (0 as usize) {
                let owned: *u8 = unsafe { malloc(kl) };
                unsafe { memcpy(owned, kp, kl); }
                unsafe { self.keys[slot] = owned; }
                unsafe { self.klens[slot] = kl; }
                unsafe { self.vals[slot] = val; }
                self.len = self.len +% (1 as usize);
                return;
            }
            let existing_key: *u8 = unsafe { self.keys[slot] };
            if keys_equal(existing_key, existing_len, kp, kl) {
                unsafe { self.vals[slot] = val; }
                return;
            }
            slot = (slot +% (1 as usize)) % self.cap;
            if slot == start { return; } // table full; should never happen post-grow
        }
    }

    // Look up `key`. Returns Ok(value) on hit, Err(NotFound) on miss.
    pub fn get(self, key: str) -> result::Result[i32, result::IoError] {
        if self.cap == (0 as usize) {
            return result::io_err::[i32](result::IoError::NotFound);
        }
        let kp: *u8 = str_ptr(key);
        let kl: usize = str_len(key);
        let h: u64 = fnv1a(kp, kl);
        let start: usize = (h as usize) % self.cap;
        let mut slot: usize = start;
        loop {
            let existing_len: usize = unsafe { self.klens[slot] };
            if existing_len == (0 as usize) {
                return result::io_err::[i32](result::IoError::NotFound);
            }
            let existing_key: *u8 = unsafe { self.keys[slot] };
            if keys_equal(existing_key, existing_len, kp, kl) {
                return result::io_ok::[i32](unsafe { self.vals[slot] });
            }
            slot = (slot +% (1 as usize)) % self.cap;
            if slot == start { return result::io_err::[i32](result::IoError::NotFound); }
        }
        return result::io_err::[i32](result::IoError::NotFound);  // unreachable
    }

    pub fn contains_key(self, key: str) -> bool {
        return match self.get(key) {
            result::Result[i32, result::IoError]::Ok(_) => true,
            result::Result[i32, result::IoError]::Err(_) => false,
        };
    }

    // Grow capacity to at least `new_cap`. Re-inserts every live entry
    // (open-addressing positions depend on cap, so a memcpy-resize won't
    // work). Internal helper; not in the public surface.
    fn grow_to(mut self, new_cap: usize) {
        let old_keys: **u8 = self.keys;
        let old_klens: *usize = self.klens;
        let old_vals: *i32 = self.vals;
        let old_cap: usize = self.cap;
        // 8 bytes per pointer, 8 per usize, 4 per i32 on aarch64-darwin.
        let keys_bytes: usize = new_cap *% (8 as usize);
        let lens_bytes: usize = new_cap *% (8 as usize);
        let vals_bytes: usize = new_cap *% (4 as usize);
        let nk_raw: *u8 = unsafe { malloc(keys_bytes) };
        let nl_raw: *u8 = unsafe { malloc(lens_bytes) };
        let nv_raw: *u8 = unsafe { malloc(vals_bytes) };
        // Zero key + length regions so empty-slot detection works.
        let mut i: usize = 0 as usize;
        while i < keys_bytes { unsafe { nk_raw[i] = 0 as u8; } i = i +% (1 as usize); }
        i = 0 as usize;
        while i < lens_bytes { unsafe { nl_raw[i] = 0 as u8; } i = i +% (1 as usize); }
        self.keys = unsafe { nk_raw as **u8 };
        self.klens = unsafe { nl_raw as *usize };
        self.vals = unsafe { nv_raw as *i32 };
        self.cap = new_cap;
        self.len = 0 as usize;
        // Re-insert every live old entry. Each was heap-allocated; we
        // transfer the existing allocation rather than re-malloc + free.
        let mut j: usize = 0 as usize;
        while j < old_cap {
            let l: usize = unsafe { old_klens[j] };
            if l != (0 as usize) {
                let kp: *u8 = unsafe { old_keys[j] };
                let v: i32 = unsafe { old_vals[j] };
                let h: u64 = fnv1a(kp, l);
                let start: usize = (h as usize) % self.cap;
                let mut slot: usize = start;
                loop {
                    let exist_len: usize = unsafe { self.klens[slot] };
                    if exist_len == (0 as usize) {
                        unsafe { self.keys[slot] = kp; }
                        unsafe { self.klens[slot] = l; }
                        unsafe { self.vals[slot] = v; }
                        self.len = self.len +% (1 as usize);
                        break;
                    }
                    slot = (slot +% (1 as usize)) % self.cap;
                    if slot == start { break; }
                }
            }
            j = j +% (1 as usize);
        }
        if old_cap > (0 as usize) {
            unsafe { free(old_keys as *u8); }
            unsafe { free(old_klens as *u8); }
            unsafe { free(old_vals as *u8); }
        }
        return;
    }

    fn drop(mut self) {
        if self.cap == (0 as usize) { return; }
        let mut i: usize = 0 as usize;
        while i < self.cap {
            let l: usize = unsafe { self.klens[i] };
            if l != (0 as usize) {
                let kp: *u8 = unsafe { self.keys[i] };
                unsafe { free(kp); }
            }
            i = i +% (1 as usize);
        }
        unsafe { free(self.keys as *u8); }
        unsafe { free(self.klens as *u8); }
        unsafe { free(self.vals as *u8); }
        return;
    }
}
