// stdlib/hash_map.cplus — Generic `HashMap[K, V]` (v0.0.4 Slice 3B.5).
//
// Open addressing with linear probing, doubling at 0.75 load factor.
//
// **Type parameters and bounds.**
//
//   - `K: Copy` (enforced) — keys are bitwise-copied into the table on
//     insert. Primitive types (`i32`, `i64`, `u64`, `usize`, `str`, ...) are
//     Copy structurally. User struct types are Copy iff every field is
//     Copy. For `K = str`, the table stores the str's fat pointer
//     verbatim — **the caller is responsible for keeping the underlying
//     bytes alive for the map's lifetime**. Use static string literals
//     or pre-allocated buffers; never store a str backed by a heap
//     string that drops before the map.
//
//   - `V: Copy` (enforced) — same bitwise-copy semantics on insert and
//     `get`. The bound is declared on the `HashMap` struct and `new`, so a
//     non-Copy (owning / `drop`-carrying) `K` or `V` — `string`, `Vec[T]`,
//     any type with `fn drop` — is rejected at the use site with E0502.
//     Without it, insert/overwrite/get bit-copy or overwrite owned values
//     and double-free or leak. A Drop-aware map (drop-on-overwrite +
//     drop-all-on-map-drop, like `Vec`) is a separate feature, not yet built.
//
// **Hashing and equality.**
//
//   - `K.hash() -> u64` and `K.eq(other) -> bool` are required. The
//     compiler ships blessed implementations for every integer
//     primitive plus `str` — those just work. User types provide their
//     own via `impl MyType: Hash { fn hash(this) -> u64 { ... } }`
//     and `impl MyType: Eq { fn eq(this, other: This) -> bool { ... } }`.
//
//     The generic body in this module calls `k.hash()` and `k.eq(stored)`
//     directly; monomorphization picks the right lowering per
//     instantiation.
//
// **Layout** (parallel arrays — separate K, V, and occupancy buffers,
// avoids per-entry padding that a `{K, V, bool}` slot struct would pay):
//
//   _keys:     *K       — cap slots
//   _vals:     *V       — cap slots
//   _occupied: *u8      — cap slots; 0 = empty, 1 = occupied
//   _cap, _len: usize
//
// **API.**
//
//   hash_map::new::[K, V]() -> HashMap[K, V]
//   HashMap[K, V]::count(this) -> usize
//   HashMap[K, V]::capacity(this) -> usize
//   HashMap[K, V]::insert(ref this, k: K, v: V) -> status::Status
//   HashMap[K, V]::get(this, k: K) -> option::Option[V]
//   HashMap[K, V]::contains_key(this, k: K) -> bool
//
// `StrIntMap` from v0.0.3 is retained as a thin alias: `pub fn
// new_str_int_map() -> HashMap[str, i32]` constructs the same shape.

import "./option" as option;
import "./status" as status;

extern fn malloc(n: usize) -> *u8;
extern fn realloc(p: *u8, n: usize) -> *u8;
extern fn free(p: *u8);
extern fn memcpy(dest: *u8, src: *u8, n: usize) -> *u8;
extern fn memset(b: *u8, c: i32, len: usize) -> *u8;

struct HashMap[K: Copy, V: Copy] {
    _keys: *K,
    _vals: *V,
    _occupied: *u8,
    _cap: usize,
    _len: usize,
}

fn max_usize() -> usize {
    return (0 as usize) -% (1 as usize);
}

// Empty map; first insert allocates. The `K: Copy` / `V: Copy` bounds are
// load-bearing, not cosmetic: insert bit-copies keys/values into the table,
// overwrite stores over the old slot without running a destructor, and `get`
// bit-copies the value out. A non-Copy (owning / `drop`-carrying) `K` or `V`
// would therefore double-free or leak. The bound makes sema reject such an
// instantiation (E0502) at the use site instead of miscompiling it. Drop-aware
// keys/values are a separate feature, not a soundness patch.
fn new[K: Copy, V: Copy]() -> HashMap[K, V] {
    return HashMap[K, V] {
        _keys: { 0 as *K },
        _vals: { 0 as *V },
        _occupied: { 0 as *u8 },
        _cap: 0 as usize,
        _len: 0 as usize,
    };
}

impl HashMap[K, V] {
    fn count(this) -> usize {
        return this._len;
    }

    fn capacity(this) -> usize {
        return this._cap;
    }

    // Insert or overwrite `k -> v`. Key + value are bitwise-copied into
    // the table (their `Copy` bound makes this safe).
    fn insert(ref this, take k: K, take v: V) -> status::Status {
        if this._cap == (0 as usize) {
            let st: status::Status = this.grow_to(16 as usize);
            if st != status::Status::Ok {
                return st;          // could not allocate; map unchanged (k, v are Copy)
            }
        }
        // Grow at 0.75 load factor.
        if (this._len *% (4 as usize)) >= (this._cap *% (3 as usize)) {
            let st: status::Status = this.grow_to(this._cap *% (2 as usize));
            if st != status::Status::Ok {
                return st;          // grow failed; map still valid at old capacity
            }
        }
        let h: u64 = k.hash();
        let start: usize = (h as usize) % this._cap;
        var slot: usize = start;
        loop {
            let occ: u8 = { this._occupied[slot] };
            if occ == (0 as u8) {
                { this._keys[slot] = k; }
                { this._vals[slot] = v; }
                { this._occupied[slot] = 1 as u8; }
                this._len = this._len +% (1 as usize);
                return status::Status::Ok;
            }
            let existing: K = { this._keys[slot] };
            if existing.eq(k) {
                { this._vals[slot] = v; }
                return status::Status::Ok;
            }
            slot = (slot +% (1 as usize)) % this._cap;
            if slot == start { return status::Status::OutOfMemory; } // full; cannot happen post-grow
        }
    }

    // Look up `k`. Returns `Some(v)` on hit, `None` on miss — Swift's
    // `dict[key] -> V?`. A miss is the absence of a value, not an error.
    fn get(this, k: K) -> option::Option[V] {
        if this._cap == (0 as usize) {
            return option::Option[V]::None;
        }
        let h: u64 = k.hash();
        let start: usize = (h as usize) % this._cap;
        var slot: usize = start;
        loop {
            let occ: u8 = { this._occupied[slot] };
            if occ == (0 as u8) {
                return option::Option[V]::None;
            }
            let existing: K = { this._keys[slot] };
            if existing.eq(k) {
                let v: V = { this._vals[slot] };
                return option::Option[V]::Some(v);
            }
            slot = (slot +% (1 as usize)) % this._cap;
            if slot == start {
                return option::Option[V]::None;
            }
        }
        return option::Option[V]::None;  // unreachable
    }

    fn contains_key(this, k: K) -> bool {
        return match this.get(k) {
            option::Option[V]::Some(_) => true,
            option::Option[V]::None => false,
        };
    }

    // Grow capacity to at least `new_cap`. Re-inserts every live entry
    // (open-addressing positions depend on cap, so a memcpy-resize won't
    // work). Internal helper; not in the public surface.
    fn grow_to(ref this, new_cap: usize) -> status::Status {
        let old_keys: *K = this._keys;
        let old_vals: *V = this._vals;
        let old_occ: *u8 = this._occupied;
        let old_cap: usize = this._cap;

        // Overflow-checked byte sizes; on overflow leave the map unchanged.
        let kelem: usize = #size_of::[K]();
        let velem: usize = #size_of::[V]();
        if kelem != (0 as usize) && new_cap > (max_usize() / kelem) {
            return status::Status::OutOfMemory;
        }
        if velem != (0 as usize) && new_cap > (max_usize() / velem) {
            return status::Status::OutOfMemory;
        }
        let keys_bytes: usize = new_cap *% kelem;
        let vals_bytes: usize = new_cap *% velem;
        let occ_bytes: usize = new_cap;

        // Allocate all three arrays. If any fails, free what we already got and
        // leave the map exactly as it was — still valid at its old capacity.
        let nk_raw: *u8 = { malloc(keys_bytes) };
        if nk_raw.is_null() {
            return status::Status::OutOfMemory;
        }
        let nv_raw: *u8 = { malloc(vals_bytes) };
        if nv_raw.is_null() {
            { free(nk_raw); }
            return status::Status::OutOfMemory;
        }
        let no_raw: *u8 = { malloc(occ_bytes) };
        if no_raw.is_null() {
            { free(nk_raw); }
            { free(nv_raw); }
            return status::Status::OutOfMemory;
        }
        // Zero the occupied buffer so empty-slot detection is correct.
        { memset(no_raw, 0 as i32, occ_bytes); }
        this._keys = { nk_raw as *K };
        this._vals = { nv_raw as *V };
        this._occupied = { no_raw as *u8 };
        this._cap = new_cap;
        this._len = 0 as usize;

        // Re-insert every old live entry.
        var j: usize = 0 as usize;
        while j < old_cap {
            let occ_j: u8 = { old_occ[j] };
            if occ_j != (0 as u8) {
                let k: K = { old_keys[j] };
                let v: V = { old_vals[j] };
                let h: u64 = k.hash();
                let start: usize = (h as usize) % this._cap;
                var slot: usize = start;
                loop {
                    let cur: u8 = { this._occupied[slot] };
                    if cur == (0 as u8) {
                        { this._keys[slot] = k; }
                        { this._vals[slot] = v; }
                        { this._occupied[slot] = 1 as u8; }
                        this._len = this._len +% (1 as usize);
                        break;
                    }
                    slot = (slot +% (1 as usize)) % this._cap;
                    if slot == start { break; }
                }
            }
            j = j +% (1 as usize);
        }
        if old_cap > (0 as usize) {
            { free(old_keys as *u8); }
            { free(old_vals as *u8); }
            { free(old_occ); }
        }
        return status::Status::Ok;
    }

    fn drop(ref this) {
        if this._cap == (0 as usize) { return; }
        // v0.0.5 Phase 1C: invoke per-entry Drop for each live (K, V)
        // pair before freeing the parallel storage arrays. Closes the
        // v0.0.4 leak where `HashMap[str, string]` leaked every value
        // and (for non-static) every key.
        var i: usize = 0 as usize;
        while i < this._cap {
            let occ: u8 = { this._occupied[i] };
            if occ != (0 as u8) {
                let k_ptr: *K = { this._keys + i };
                let v_ptr: *V = { this._vals + i };
                { #drop_in_place::[K](k_ptr); }
                { #drop_in_place::[V](v_ptr); }
            }
            i = i +% (1 as usize);
        }
        { free(this._keys as *u8); }
        { free(this._vals as *u8); }
        { free(this._occupied); }
        return;
    }
}

// v0.0.3 alias retained so existing callers don't have to migrate
// immediately. The shape is identical to the generic form; users can
// switch to `hash_map::new::[str, i32]()` directly when convenient.
fn new_str_int_map() -> HashMap[str, i32] {
    return new::[str, i32]();
}

// ───────────────────────────── tests ─────────────────────────────

#[test]
fn hashmap_new_is_empty() {
    let m: HashMap[i32, i32] = new::[i32, i32]();
    assert m.count() == (0 as usize);
}

#[test]
fn hashmap_insert_and_get() {
    var m: HashMap[i32, i32] = new::[i32, i32]();
    assert m.insert(1, 100) == status::Status::Ok;
    assert m.insert(2, 200) == status::Status::Ok;
    assert m.count() == (2 as usize);
    match m.get(1) {
        option::Option[i32]::Some(v) => { assert v == 100; }
        option::Option[i32]::None => { assert false; }
    }
    return;
}

#[test]
fn hashmap_get_missing_is_none() {
    var m: HashMap[i32, i32] = new::[i32, i32]();
    m.insert(1, 100);
    match m.get(999) {
        option::Option[i32]::Some(v) => { assert false; }
        option::Option[i32]::None => { assert true; }
    }
    return;
}

#[test]
fn hashmap_overwrite_updates_value() {
    var m: HashMap[i32, i32] = new::[i32, i32]();
    m.insert(1, 100);
    m.insert(1, 999);
    assert m.count() == (1 as usize);
    match m.get(1) {
        option::Option[i32]::Some(v) => { assert v == 999; }
        option::Option[i32]::None => { assert false; }
    }
    return;
}

#[test]
fn hashmap_contains_key() {
    var m: HashMap[i32, i32] = new::[i32, i32]();
    m.insert(5, 50);
    assert m.contains_key(5);
    assert m.contains_key(6) == false;
}

#[test]
fn hashmap_grows_past_load_factor() {
    var m: HashMap[i32, i32] = new::[i32, i32]();
    var i: i32 = 0;
    while i < 100 {
        m.insert(i, i *% (10 as i32));
        i = i +% 1;
    }
    assert m.count() == (100 as usize);
    match m.get(50) {
        option::Option[i32]::Some(v) => { assert v == 500; }
        option::Option[i32]::None => { assert false; }
    }
    return;
}

#[test]
fn hashmap_str_keys() {
    var m: HashMap[str, i32] = new::[str, i32]();
    m.insert("apple", 1);
    m.insert("banana", 2);
    match m.get("banana") {
        option::Option[i32]::Some(v) => { assert v == 2; }
        option::Option[i32]::None => { assert false; }
    }
    return;
}
