// stdlib/fs.cplus — file system access.
//
// Built on libc open/read/write/close via `extern fn`. `File` is an owned
// handle; Drop closes the fd on scope exit, so opening without explicit
// close is safe.

import "./result" as result;
import "./vec" as vec;
// v0.0.5 Phase 4 Slice 4C: File::read_async needs the reactor's
// fd-readiness path. Phase 3 Slice 3D's File::lines is sync but
// the gen-method machinery needs Iterator[T] in scope.
import "./net" as net;
import "./iterator" as iterator;
import "./text" as text;

// `open` is variadic in libc — mode is only consumed when O_CREAT is in
// flags. The variadic decl matches the platform ABI exactly (on
// aarch64-darwin a fixed third arg lands in a register but libc's
// implementation reads it via `va_arg`, which expects stack passing).
extern fn open(path: *u8, flags: i32, ...) -> i32;
extern fn read(fd: i32, buf: *u8, count: usize) -> isize;
extern fn write(fd: i32, buf: *u8, count: usize) -> isize;
extern fn close(fd: i32) -> i32;
extern fn malloc(n: usize) -> *u8;
extern fn free(p: *u8);

// Owned file handle. `fd == -1` is the invalid / closed state (disarms Drop).
struct File {
    fd: i32,
}

// Open `path` for reading. macOS + Linux: O_RDONLY = 0.
fn open_read(path: str) -> result::Result[File, result::IoError] {
    let fd: i32 = { open(#str_ptr(path), 0 as i32, 0 as i32) };
    if fd < (0 as i32) {
        return result::io_err::[File](result::IoError::NotFound);
    }
    return result::io_ok::[File](File { fd: fd });
}

// Open `path` for writing, creating + truncating if missing. Mode 0o644.
//
// macOS flags: O_WRONLY = 0x001, O_CREAT = 0x200, O_TRUNC = 0x400.
// Combined: 0x601 = 1537. (Linux numbers differ — Linux build is a Phase 1
// stretch; see plan.md non-goals.)
fn create(path: str) -> result::Result[File, result::IoError] {
    let flags: i32 = 1537 as i32;
    let mode: i32 = 420 as i32;
    let fd: i32 = { open(#str_ptr(path), flags, mode) };
    if fd < (0 as i32) {
        return result::io_err::[File](result::IoError::PermissionDenied);
    }
    return result::io_ok::[File](File { fd: fd });
}

impl File {
    // Drain remaining bytes into a fresh heap-allocated buffer. Returns
    // the Vec inside Result::Ok on success, or an IoError on failure.
    fn read_to_end(ref this) -> result::Result[vec::Vec[u8], result::IoError] {
        var buf: vec::Vec[u8] = vec::new::[u8]();
        if this.fd < (0 as i32) {
            return result::io_err::[vec::Vec[u8]](result::IoError::InvalidInput);
        }
        let chunk_size: usize = 4096 as usize;
        let chunk: *u8 = { malloc(chunk_size) };
        loop {
            let n: isize = { read(this.fd, chunk, chunk_size) };
            if n < (0 as isize) {
                { free(chunk); }
                return result::io_err::[vec::Vec[u8]](result::IoError::Other);
            }
            if n == (0 as isize) {
                { free(chunk); }
                return result::io_ok::[vec::Vec[u8]](buf);
            }
            let count: usize = n as usize;
            buf.extend_from_raw(chunk, count);
        }
        return result::io_err::[vec::Vec[u8]](result::IoError::Other);
    }

    // Write `data`. Loops on short writes. On success returns bytes written
    // (always == data.len()); errors return Err.
    fn write_all(ref this, data: vec::Vec[u8]) -> result::Result[usize, result::IoError] {
        if this.fd < (0 as i32) {
            return result::io_err::[usize](result::IoError::InvalidInput);
        }
        let n: usize = data.len();
        let slice: u8[] = data.as_slice();
        let p: *u8 = { #slice_ptr(slice) };
        var written: usize = 0 as usize;
        while written < n {
            let remaining: usize = n -% written;
            let q: *u8 = { p + written };
            let w: isize = { write(this.fd, q, remaining) };
            if w <= (0 as isize) {
                return result::io_err::[usize](result::IoError::BrokenPipe);
            }
            written = written +% (w as usize);
        }
        return result::io_ok::[usize](written);
    }

    // Explicit close. Disarms Drop by setting fd to -1.
    fn close(ref this) {
        if this.fd >= (0 as i32) {
            { close(this.fd); }
            this.fd = 0 -% 1 as i32;
        }
        return;
    }

    // v0.0.5 Phase 4 Slice 4C: flip O_NONBLOCK on the underlying fd so
    // `read_async` can return EAGAIN-loops instead of blocking the
    // executor thread. Idempotent; safe to call repeatedly. Returns 0
    // on success, -1 on fcntl error.
    fn make_nonblocking(ref this) -> i32 {
        return net::set_nonblocking(this.fd);
    }

    // v0.0.5 Phase 4 Slice 4C: async read. Same semantics as
    // `net::read_fd_async(this.fd, buf, count)` — reactor handles
    // EAGAIN suspension via kqueue EVFILT_READ. Prerequisite: call
    // `make_nonblocking()` once before first use.
    async fn read_async(ref this, buf: *u8, count: usize) -> isize {
        return await net::read_fd_async(this.fd, buf, count);
    }

    // v0.0.5 Phase 3 Slice 3D: iterator over '\n'-separated lines.
    // Reads the file in 4 KiB chunks; each yielded `Text` is the
    // line *without* its trailing newline. The carry buffer holds the
    // partial line that spans a chunk boundary, copied into the next
    // chunk's scan. A final fragment without a trailing newline at EOF
    // is yielded as the last line.
    gen fn lines(this) -> text::Text {
        var carry: vec::Vec[u8] = vec::new::[u8]();
        let chunk_size: usize = 4096 as usize;
        let chunk: *u8 = { malloc(chunk_size) };
        loop {
            let n: isize = { read(this.fd, chunk, chunk_size) };
            if n <= (0 as isize) {
                // EOF (n == 0) or error (n < 0). Yield any pending
                // partial line, then stop. Read errors are silently
                // surfaced as "no more lines" — callers needing error
                // detail should use `read_to_end` + manual splitting.
                if carry.len() > (0 as usize) {
                    let cs: u8[] = carry.as_slice();
                    let cp: *u8 = { #slice_ptr(cs) };
                    let view: str = { #str_from_raw_parts(cp, carry.len()) };
                    yield view.to_text();
                }
                { free(chunk); }
                return;
            }
            let count: usize = n as usize;
            var start: usize = 0 as usize;
            var i: usize = 0 as usize;
            while i < count {
                let bp: *u8 = { chunk + i };
                let b: u8 = { *bp };
                if b == (10 as u8) {
                    let chunk_p: *u8 = { chunk + start };
                    let chunk_len: usize = i -% start;
                    if carry.len() == (0 as usize) {
                        let view: str = { #str_from_raw_parts(chunk_p, chunk_len) };
                        yield view.to_text();
                    } else {
                        carry.extend_from_raw(chunk_p, chunk_len);
                        let cs: u8[] = carry.as_slice();
                        let cp: *u8 = { #slice_ptr(cs) };
                        let view: str = { #str_from_raw_parts(cp, carry.len()) };
                        yield view.to_text();
                        carry.clear();
                    }
                    start = i +% (1 as usize);
                }
                i = i +% (1 as usize);
            }
            if start < count {
                let rest_p: *u8 = { chunk + start };
                carry.extend_from_raw(rest_p, count -% start);
            }
        }
        return;
    }

    // Destructor: close the fd if not already closed.
    fn drop(ref this) {
        if this.fd >= (0 as i32) {
            { close(this.fd); }
        }
        return;
    }
}
