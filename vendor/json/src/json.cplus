// vendor/json/src/json.cplus — typed JSON parser + serializer.
//
// `Value` is a recursive tagged enum; `Object` payload uses
// `Vec[Member]` instead of `HashMap[str, Value]` because HashMap
// requires `V: Copy` and `Value` is non-Copy (the `Text` / `Array` /
// `Object` variants own heap storage). Linear lookup for `v.value(for_key:)` —
// fine for typical JSON payloads, would need a different shape only for
// objects with hundreds of keys.
//
// **API** (value-centric; every accessor returns `Option`, so a missing
// key/index is `None` — never a trap, never confused with a present `null`):
//   - `Value::parse(source:) -> Result[Value, ParseError]`
//   - `v.to_text() -> Text`  (compact JSON; `%.17g` numbers round-trip)
//   - constructors: `Value::null()` / `boolean(value:)` / `number(value:)` /
//      `text(value:)`, `array(values:)`, `object(members:)`
//   - predicates: `v.is_null()` / `is_boolean` / `is_number` / `is_text`
//      / `is_array` / `is_object`
//   - accessors: `v.item_count()`, `v.item(at:)`, `v.value(for_key:)`,
//      `v.key(at:)`, `v.object_value(at:)`, `v.as_boolean()`, `v.as_number()`,
//      `v.as_text()`
//
// Cleanup is automatic via the enum's recursive Drop — no manual
// `value_free` required (that was the pointer-API workaround).

import "stdlib/vec" as vec;
import "stdlib/result" as result;
import "stdlib/option" as option;
import "stdlib/text" as text;

extern fn malloc(n: usize) -> *u8;
extern fn realloc(p: *u8, n: usize) -> *u8;
extern fn free(p: *u8);
extern fn memcpy(dst: *u8, src: *u8, n: usize) -> *u8;
extern fn strtod(s: *u8, endp: **u8) -> f64;
extern fn snprintf(s: *u8, n: usize, fmt: *u8, ...) -> i32;

enum Value {
    Null,
    Bool(bool),
    Number(f64),
    Text(text::Text),
    Array(vec::Vec[Value]),
    Object(vec::Vec[Member]),
}

struct Member {
    key: text::Text,
    value: Value,
}

struct ParseError {
    offset: usize,
}

// ---------------- Constructors / builders ---------------------------------

impl Value {
    fn null() -> Value { return Value::Null; }
    fn boolean(value: bool) -> Value { return Value::Bool(value); }
    fn number(value: f64) -> Value { return Value::Number(value); }
    fn text(value: str) -> Value { return Value::Text(value.to_text()); }
    fn array(take values: vec::Vec[Value]) -> Value { return Value::Array(values); }
    fn object(take members: vec::Vec[Member]) -> Value { return Value::Object(members); }

    // Predicates.
    fn is_null(this) -> bool {
        let yes: bool = match this {
            Value::Null => true,
            _ => false,
        };
        return yes;
    }
    fn is_boolean(this) -> bool {
        let yes: bool = match this {
            Value::Bool(_) => true,
            _ => false,
        };
        return yes;
    }
    fn is_number(this) -> bool {
        let yes: bool = match this {
            Value::Number(_) => true,
            _ => false,
        };
        return yes;
    }
    fn is_text(this) -> bool {
        let yes: bool = match this {
            Value::Text(_) => true,
            _ => false,
        };
        return yes;
    }
    fn is_array(this) -> bool {
        let yes: bool = match this {
            Value::Array(_) => true,
            _ => false,
        };
        return yes;
    }
    fn is_object(this) -> bool {
        let yes: bool = match this {
            Value::Object(_) => true,
            _ => false,
        };
        return yes;
    }

    // ---- accessors ----
    // All borrow `this` and report absence as `None` — never a trap, and never
    // conflating a missing key/index with a present JSON `null`.

    // Element count: array elements, object members, or 0 for a scalar.
    fn item_count(this) -> usize {
        return match this {
            Value::Array(arr) => arr.count(),
            Value::Object(arr) => arr.count(),
            _ => 0 as usize,
        };
    }

    // The payload if `this` is exactly that kind, else `None`.
    fn as_boolean(this) -> option::Option[bool] {
        return match this {
            Value::Bool(x) => option::Option[bool]::Some(x),
            _ => option::Option[bool]::None,
        };
    }
    fn as_number(this) -> option::Option[f64] {
        return match this {
            Value::Number(x) => option::Option[f64]::Some(x),
            _ => option::Option[f64]::None,
        };
    }
    fn as_text(this) -> option::Option[text::Text] {
        return match this {
            Value::Text(x) => option::Option[text::Text]::Some(x.clone()),
            _ => option::Option[text::Text]::None,
        };
    }

    // Array item at `at`, or `None` if not an array / out of range.
    fn item(this, at: usize) -> option::Option[Value] {
        return match this {
            Value::Array(arr) => match arr.at_ptr(at) {
                option::Option[*Value]::Some(p) => option::Option[Value]::Some(clone_value({ *p })),
                option::Option[*Value]::None => option::Option[Value]::None,
            },
            _ => option::Option[Value]::None,
        };
    }

    // Object value for `key`, or `None` if not an object / no such key. A present
    // `null` returns `Some(Value::Null)` — distinct from a missing key.
    fn value(this, for_key: str) -> option::Option[Value] {
        return match this {
            Value::Object(arr) => {
                let n: usize = arr.count();
                var i: usize = 0 as usize;
                var found: option::Option[Value] = option::Option[Value]::None;
                while i < n {
                    match arr.at_ptr(i) {
                        option::Option[*Member]::Some(p) => {
                            if { (*p).key } == for_key {
                                found = option::Option[Value]::Some(clone_value({ (*p).value }));
                                i = n;
                            } else {
                                i = i +% (1 as usize);
                            }
                        }
                        option::Option[*Member]::None => { i = n; }
                    }
                }
                found
            }
            _ => option::Option[Value]::None,
        };
    }

    // Object's `at`-th key / value in insertion order, or `None` if out of range.
    fn key(this, at: usize) -> option::Option[text::Text] {
        return match this {
            Value::Object(arr) => match arr.at_ptr(at) {
                option::Option[*Member]::Some(p) => option::Option[text::Text]::Some({ (*p).key.clone() }),
                option::Option[*Member]::None => option::Option[text::Text]::None,
            },
            _ => option::Option[text::Text]::None,
        };
    }
    fn object_value(this, at: usize) -> option::Option[Value] {
        return match this {
            Value::Object(arr) => match arr.at_ptr(at) {
                option::Option[*Member]::Some(p) => option::Option[Value]::Some(clone_value({ (*p).value })),
                option::Option[*Member]::None => option::Option[Value]::None,
            },
            _ => option::Option[Value]::None,
        };
    }
}

impl Member {
    fn new(key: str, take value: Value) -> Member {
        return Member { key: key.to_text(), value: value };
    }
}

// ---------------- Internal byte buffer ------------------------------------

// `ptr` is owned but released explicitly via `buf_free`, not a `drop` —
// `opaque` documents "not freed by this struct's drop" (see buf_free).
struct Buf { opaque _ptr: *u8, len: usize, cap: usize }

fn buf_new() -> Buf {
    return Buf { _ptr: { 0 as *u8 }, len: 0 as usize, cap: 0 as usize };
}

fn buf_push(b: Buf, byte: u8) -> Buf {
    var b: Buf = b;
    if b.len == b.cap {
        let nc: usize = if b.cap == (0 as usize) { 16 as usize } else { b.cap *% (2 as usize) };
        let raw: *u8 = { realloc(b._ptr, nc) };
        b._ptr = raw;
        b.cap = nc;
    }
    let slot: *u8 = { b._ptr + b.len };
    { *slot = byte; }
    b.len = b.len +% (1 as usize);
    return b;
}

fn buf_free(b: Buf) {
    if { #addr(b._ptr) } != (0 as usize) { { free(b._ptr); } }
    return;
}

fn buf_to_string(b: Buf) -> text::Text {
    let view: str = { #str_from_raw_parts(b._ptr, b.len) };
    let out: text::Text = view.to_text();
    buf_free(b);
    return out;
}

fn hex_digit(c: u8) -> i32 {
    if c >= ('0' as u8) && c <= ('9' as u8) { return (c -% ('0' as u8)) as i32; }
    if c >= ('a' as u8) && c <= ('f' as u8) { return ((c -% ('a' as u8)) +% (10 as u8)) as i32; }
    if c >= ('A' as u8) && c <= ('F' as u8) { return ((c -% ('A' as u8)) +% (10 as u8)) as i32; }
    return - 1 as i32;
}

fn buf_push_utf8(b: Buf, cp: i32) -> Buf {
    var b: Buf = b;
    if cp < 0x80 {
        return buf_push(b, cp as u8);
    }
    if cp < 0x800 {
        b = buf_push(b, (0xC0 +% ((cp >> 6) & 0x1F)) as u8);
        b = buf_push(b, (0x80 +% (cp & 0x3F)) as u8);
        return b;
    }
    if cp < 0x10000 {
        b = buf_push(b, (0xE0 +% ((cp >> 12) & 0x0F)) as u8);
        b = buf_push(b, (0x80 +% ((cp >> 6) & 0x3F)) as u8);
        b = buf_push(b, (0x80 +% (cp & 0x3F)) as u8);
        return b;
    }
    // 4-byte form covers U+10000..U+10FFFF (surrogate-pair codepoints).
    b = buf_push(b, (0xF0 +% ((cp >> 18) & 0x07)) as u8);
    b = buf_push(b, (0x80 +% ((cp >> 12) & 0x3F)) as u8);
    b = buf_push(b, (0x80 +% ((cp >> 6) & 0x3F)) as u8);
    b = buf_push(b, (0x80 +% (cp & 0x3F)) as u8);
    return b;
}

// ---------------- Parser --------------------------------------------------

struct Parser {
    opaque _src: *u8,
    len: usize,
    pos: usize,
}

fn parser_new(s: str) -> Parser {
    return Parser {
        _src: #str_ptr(s),
        len: #str_len(s),
        pos: 0 as usize,
    };
}

fn peek(p: Parser) -> i32 {
    if p.pos >= p.len { return - 1 as i32; }
    let q: *u8 = { p._src + p.pos };
    return { *q } as i32;
}

fn skip_ws(p: Parser) -> Parser {
    var p: Parser = p;
    while p.pos < p.len {
        let q: *u8 = { p._src + p.pos };
        let c: u8 = { *q };
        if c == (32 as u8) || c == (9 as u8) || c == (10 as u8) || c == (13 as u8) {
            p.pos = p.pos +% (1 as usize);
        } else {
            return p;
        }
    }
    return p;
}

fn match_keyword(p: Parser, kw: str) -> bool {
    let n: usize = #str_len(kw);
    if p.pos +% n > p.len { return false; }
    var i: usize = 0 as usize;
    while i < n {
        let kq: *u8 = { #str_ptr(kw) + i };
        let sq: *u8 = { p._src + (p.pos +% i) };
        if { *kq } != { *sq } { return false; }
        i = i +% (1 as usize);
    }
    return true;
}

struct StrParse { p: Parser, ok: bool, buf: Buf }

fn parse_string_bytes(p: Parser) -> StrParse {
    var p: Parser = p;
    // Caller has verified the opening `"`. Consume it.
    p.pos = p.pos +% (1 as usize);
    var b: Buf = buf_new();
    while p.pos < p.len {
        let q: *u8 = { p._src + p.pos };
        let c: u8 = { *q };
        if c == ('"' as u8) {
            p.pos = p.pos +% (1 as usize);
            return StrParse { p: p, ok: true, buf: b };
        }
        if c == ('\\' as u8) {
            p.pos = p.pos +% (1 as usize);
            if p.pos >= p.len {
                buf_free(b);
                return StrParse { p: p, ok: false, buf: buf_new() };
            }
            let eq: *u8 = { p._src + p.pos };
            let esc: u8 = { *eq };
            p.pos = p.pos +% (1 as usize);
            if esc == ('"' as u8) { b = buf_push(b, '"' as u8); }
            else if esc == ('\\' as u8) { b = buf_push(b, '\\' as u8); }
            else if esc == ('/' as u8) { b = buf_push(b, '/' as u8); }
            else if esc == ('b' as u8) { b = buf_push(b, 8 as u8); }
            else if esc == ('f' as u8) { b = buf_push(b, 12 as u8); }
            else if esc == ('n' as u8) { b = buf_push(b, 10 as u8); }
            else if esc == ('r' as u8) { b = buf_push(b, 13 as u8); }
            else if esc == ('t' as u8) { b = buf_push(b, 9 as u8); }
            else if esc == ('u' as u8) {
                if p.pos +% (4 as usize) > p.len {
                    buf_free(b);
                    return StrParse { p: p, ok: false, buf: buf_new() };
                }
                let h1q: *u8 = { p._src + p.pos };
                let h2q: *u8 = { p._src + (p.pos +% (1 as usize)) };
                let h3q: *u8 = { p._src + (p.pos +% (2 as usize)) };
                let h4q: *u8 = { p._src + (p.pos +% (3 as usize)) };
                let h1: i32 = hex_digit({ *h1q });
                let h2: i32 = hex_digit({ *h2q });
                let h3: i32 = hex_digit({ *h3q });
                let h4: i32 = hex_digit({ *h4q });
                if h1 < 0 || h2 < 0 || h3 < 0 || h4 < 0 {
                    buf_free(b);
                    return StrParse { p: p, ok: false, buf: buf_new() };
                }
                var cp: i32 = (h1 << 12)| (h2 << 8)| (h3 << 4)|h4;
                p.pos = p.pos +% (4 as usize);
                // RFC 8259 §7: a high-surrogate (D800-DBFF) MUST be
                // followed by `\uYYYY` where Y is a low-surrogate
                // (DC00-DFFF). Combine the pair into a single codepoint
                // outside the BMP. Lone surrogates are tolerated by
                // pushing them as 3-byte UTF-8 to match the JSON spec's
                // "replace with U+FFFD" recommendation loosely; we keep
                // the bits intact so callers can round-trip them.
                if cp >= 0xD800 && cp <= 0xDBFF {
                    if p.pos +% (6 as usize) <= p.len {
                        let s0: *u8 = { p._src + p.pos };
                        let s1: *u8 = { p._src + (p.pos +% (1 as usize)) };
                        if { *s0 } == ('\\' as u8) && { *s1 } == ('u' as u8) {
                            let l1q: *u8 = { p._src + (p.pos +% (2 as usize)) };
                            let l2q: *u8 = { p._src + (p.pos +% (3 as usize)) };
                            let l3q: *u8 = { p._src + (p.pos +% (4 as usize)) };
                            let l4q: *u8 = { p._src + (p.pos +% (5 as usize)) };
                            let l1: i32 = hex_digit({ *l1q });
                            let l2: i32 = hex_digit({ *l2q });
                            let l3: i32 = hex_digit({ *l3q });
                            let l4: i32 = hex_digit({ *l4q });
                            if l1 >= 0 && l2 >= 0 && l3 >= 0 && l4 >= 0 {
                                let low: i32 = (l1 << 12)| (l2 << 8)| (l3 << 4)|l4;
                                if low >= 0xDC00 && low <= 0xDFFF {
                                    cp = 0x10000
                                        +% ((cp -% 0xD800) << 10)
                                        +% (low -% 0xDC00);
                                    p.pos = p.pos +% (6 as usize);
                                }
                            }
                        }
                    }
                }
                b = buf_push_utf8(b, cp);
            }
            else {
                buf_free(b);
                return StrParse { p: p, ok: false, buf: buf_new() };
            }
        } else {
            b = buf_push(b, c);
            p.pos = p.pos +% (1 as usize);
        }
    }
    buf_free(b);
    return StrParse { p: p, ok: false, buf: buf_new() };
}

// v0.0.14: a match-consumable result, not a struct. A struct can't release its
// owning `Value` field (no partial moves out of a Drop aggregate, E0509); an
// enum payload is extracted whole by `match` (which consumes the result). The
// `Parser` (Copy) rides in both variants so callers recover the position.
enum ValParse { Ok(Value, Parser), Fail(Parser) }

fn fail(p: Parser) -> ValParse {
    return ValParse::Fail(p);
}

fn is_number_byte(c: u8) -> bool {
    if c >= ('0' as u8) && c <= ('9' as u8) { return true; }
    if c == ('-' as u8) || c == ('+' as u8) { return true; }
    if c == ('.' as u8) { return true; }
    if c == ('e' as u8) || c == ('E' as u8) { return true; }
    return false;
}

fn parse_number(p: Parser) -> ValParse {
    var p: Parser = p;
    let start: usize = p.pos;
    // Scan the number token, tracking whether it is integer-shaped (no
    // fraction or exponent). The boundary rule (is_number_byte) is
    // unchanged, so acceptance is identical to before.
    var is_int: bool = true;
    while p.pos < p.len {
        let q: *u8 = { p._src + p.pos };
        let c: u8 = { *q };
        if !is_number_byte(c) { break; }
        if c == ('.' as u8) || c == ('e' as u8) || c == ('E' as u8) { is_int = false; }
        p.pos = p.pos +% (1 as usize);
    }
    let n: usize = p.pos -% start;
    if n == (0 as usize) { return fail(p); }
    let src_q: *u8 = { p._src + start };

    // Integer fast-path. A canonical `-?[0-9]+` of at most 15 digits fits
    // exactly in an f64 (|v| < 10^15 < 2^53), so accumulating in i64 and
    // converting is bit-identical to strtod — with no malloc, no memcpy,
    // and no strtod call. The benchmark workload is number-heavy, and this
    // is where the two malloc/free pairs per number were going. Anything
    // non-canonical (`+5`, leading `.`/`e`, `-0`, >15 digits, big ints)
    // falls through to the strtod path below, so rounding stays correct.
    if is_int {
        let f0: u8 = { *src_q };
        var i: usize = 0 as usize;
        var neg: bool = false;
        if f0 == ('-' as u8) { neg = true; i = 1 as usize; }
        let digits: usize = n -% i;
        if digits >= (1 as usize) && digits <= (15 as usize) {
            var acc: i64 = 0 as i64;
            var all_digits: bool = true;
            var j: usize = i;
            while j < n {
                let d: u8 = { *(p._src + (start +% j)) };
                if d < ('0' as u8) || d > ('9' as u8) { all_digits = false; break; }
                acc = acc *% (10 as i64) +% ((d -% ('0' as u8)) as i64);
                j = j +% (1 as usize);
            }
            // Skip `-0` so the strtod path keeps the signed-zero result.
            if all_digits && !(neg && acc == (0 as i64)) {
                if neg { acc = (0 as i64) -% acc; }
                let val: f64 = acc as f64;
                return ValParse::Ok(Value::Number(val), p);
            }
        }
    }

    // Float / big-integer / non-canonical fallback: strtod for correct
    // decimal rounding. The digit copy lands in a stack buffer for the
    // common case (numbers shorter than 63 bytes), so only pathologically
    // long literals still touch the heap; the strtod end-pointer slot is a
    // stack local addressed via `#addr_of` instead of a second malloc.
    var stackbuf: [u8; 64] = [0u8; 64];
    let usestack: bool = n < (63 as usize);
    let buf: *u8 = if usestack {
        { #addr_of(stackbuf) as *u8 }
    } else {
        { malloc(n +% (1 as usize)) }
    };
    if { #addr(buf) } == (0 as usize) { return fail(p); }
    { memcpy(buf, src_q, n); }
    let nulslot: *u8 = { buf + n };
    { *nulslot = 0 as u8; }
    var endp_stack: *u8 = { 0 as *u8 };
    let endp: **u8 = { #addr_of(endp_stack) };
    let val: f64 = { strtod(buf, endp) };
    let consumed_end: *u8 = { *endp };
    let consumed: usize = { #addr(consumed_end) -% #addr(buf) };
    if !usestack { { free(buf); } }
    if consumed == (0 as usize) || consumed != n { return fail(p); }
    return ValParse::Ok(Value::Number(val), p);
}

fn parse_value(p: Parser) -> ValParse {
    var p: Parser = p;
    p = skip_ws(p);
    let c: i32 = peek(p);
    if c < 0 { return fail(p); }
    let cb: u8 = c as u8;
    if cb == ('n' as u8) {
        if match_keyword(p, "null") { p.pos = p.pos +% (4 as usize); return ValParse::Ok(Value::Null, p); }
        return fail(p);
    }
    if cb == ('t' as u8) {
        if match_keyword(p, "true") { p.pos = p.pos +% (4 as usize); return ValParse::Ok(Value::Bool(true), p); }
        return fail(p);
    }
    if cb == ('f' as u8) {
        if match_keyword(p, "false") { p.pos = p.pos +% (5 as usize); return ValParse::Ok(Value::Bool(false), p); }
        return fail(p);
    }
    if cb == ('"' as u8) {
        let sp: StrParse = parse_string_bytes(p);
        if !sp.ok { return fail(sp.p); }
        let s: text::Text = buf_to_string(sp.buf);
        return ValParse::Ok(Value::Text(s), sp.p);
    }
    if cb == ('[' as u8) { return parse_array(p); }
    if cb == ('{' as u8) { return parse_object(p); }
    if cb == ('-' as u8) || (cb >= ('0' as u8) && cb <= ('9' as u8)) { return parse_number(p); }
    return fail(p);
}

fn parse_array(p: Parser) -> ValParse {
    var p: Parser = p;
    p.pos = p.pos +% (1 as usize);     // consume '['
    var elems: vec::Vec[Value] = vec::new::[Value]();
    p = skip_ws(p);
    if peek(p) == (']' as i32) {
        p.pos = p.pos +% (1 as usize);
        return ValParse::Ok(Value::Array(elems), p);
    }
    loop {
        let r: ValParse = parse_value(p);
        match r {
            ValParse::Ok(v, rp) => { p = rp; elems.append(v); }
            ValParse::Fail(rp) => { return fail(rp); }
        }
        p = skip_ws(p);
        let nc: i32 = peek(p);
        if nc == (',' as i32) {
            p.pos = p.pos +% (1 as usize);
            p = skip_ws(p);
            continue;
        }
        if nc == (']' as i32) {
            p.pos = p.pos +% (1 as usize);
            return ValParse::Ok(Value::Array(elems), p);
        }
        return fail(p);
    }
    return fail(p);
}

fn parse_object(p: Parser) -> ValParse {
    var p: Parser = p;
    p.pos = p.pos +% (1 as usize);     // consume '{'
    var members: vec::Vec[Member] = vec::new::[Member]();
    p = skip_ws(p);
    if peek(p) == ('}' as i32) {
        p.pos = p.pos +% (1 as usize);
        return ValParse::Ok(Value::Object(members), p);
    }
    loop {
        p = skip_ws(p);
        if peek(p) != ('"' as i32) { return fail(p); }
        let ks: StrParse = parse_string_bytes(p);
        p = ks.p;
        if !ks.ok { return fail(p); }
        let key: text::Text = buf_to_string(ks.buf);

        p = skip_ws(p);
        if peek(p) != (':' as i32) { return fail(p); }
        p.pos = p.pos +% (1 as usize);

        let r: ValParse = parse_value(p);
        match r {
            ValParse::Ok(v, rp) => { p = rp; members.append(Member { key: key, value: v }); }
            ValParse::Fail(rp) => { return fail(rp); }
        }

        p = skip_ws(p);
        let nc: i32 = peek(p);
        if nc == (',' as i32) {
            p.pos = p.pos +% (1 as usize);
            continue;
        }
        if nc == ('}' as i32) {
            p.pos = p.pos +% (1 as usize);
            return ValParse::Ok(Value::Object(members), p);
        }
        return fail(p);
    }
    return fail(p);
}

impl Value {
    // Parse `s` as JSON: `Ok(value)` on success, or `Err(ParseError)` carrying
    // the byte offset of the failure. Never traps.
    fn parse(source: str) -> result::Result[Value, ParseError] {
        let p0: Parser = parser_new(source);
        let r: ValParse = parse_value(p0);
        let res: result::Result[Value, ParseError] = match r {
            ValParse::Ok(v, rp) => {
                let p_end: Parser = skip_ws(rp);
                if p_end.pos != p_end.len {
                    result::Result[Value, ParseError]::Err(ParseError { offset: p_end.pos })
                } else {
                    result::Result[Value, ParseError]::Ok(v)
                }
            }
            ValParse::Fail(rp) => {
                result::Result[Value, ParseError]::Err(ParseError { offset: rp.pos })
            }
        };
        return res;
    }
}

// ---------------- Deep clone (used by the accessor methods) ---------------

// v0.0.14: deep-clone a Value into an independent owned value. Accessors that
// return owning data (an inner Value or a string) clone it so the result is
// owned outright and the borrowed source is left intact. Non-Copy Vec elements
// (Value / Member) are read in place through `vec::at(i) -> Option[*T]`: bind the
// pointer, then pass `{ *p }` / `{ (*p).value }` to the `borrow`
// params, which borrow without consuming — never copy a non-Copy element out of
// storage.
fn clone_value(v: Value) -> Value {
    return match v {
        Value::Null => Value::Null,
        Value::Bool(b) => Value::Bool(b),
        Value::Number(n) => Value::Number(n),
        Value::Text(s) => Value::Text(s.clone()),
        Value::Array(arr) => {
            let n: usize = arr.count();
            var out: vec::Vec[Value] = vec::new::[Value]();
            var i: usize = 0 as usize;
            while i < n {
                match arr.at_ptr(i) {
                    option::Option[*Value]::Some(p) => { out.append(clone_value({ *p })); }
                    option::Option[*Value]::None => {}
                }
                i = i +% (1 as usize);
            }
            Value::Array(out)
        }
        Value::Object(arr) => {
            let n: usize = arr.count();
            var out: vec::Vec[Member] = vec::new::[Member]();
            var i: usize = 0 as usize;
            while i < n {
                match arr.at_ptr(i) {
                    option::Option[*Member]::Some(p) => {
                        out.append(Member {
                            key: { (*p).key.clone() },
                            value: clone_value({ (*p).value }),
                        });
                    }
                    option::Option[*Member]::None => {}
                }
                i = i +% (1 as usize);
            }
            Value::Object(out)
        }
    };
}

// ---------------- Serializer ----------------------------------------------

fn buf_push_str(b: Buf, s: str) -> Buf {
    var b: Buf = b;
    let n: usize = #str_len(s);
    let p: *u8 = #str_ptr(s);
    var i: usize = 0 as usize;
    while i < n {
        let q: *u8 = { p + i };
        b = buf_push(b, { *q });
        i = i +% (1 as usize);
    }
    return b;
}

fn buf_push_bytes(b: Buf, p: *u8, n: usize) -> Buf {
    var b: Buf = b;
    var i: usize = 0 as usize;
    while i < n {
        let q: *u8 = { p + i };
        b = buf_push(b, { *q });
        i = i +% (1 as usize);
    }
    return b;
}

fn encode_string(b: Buf, s: str) -> Buf {
    var b: Buf = b;
    b = buf_push(b, '"' as u8);
    let p: *u8 = #str_ptr(s);
    let n: usize = #str_len(s);
    var i: usize = 0 as usize;
    while i < n {
        let q: *u8 = { p + i };
        let c: u8 = { *q };
        if c == ('"' as u8) { b = buf_push(b, '\\' as u8); b = buf_push(b, '"' as u8); }
        else if c == ('\\' as u8) { b = buf_push(b, '\\' as u8); b = buf_push(b, '\\' as u8); }
        else if c == (8 as u8) { b = buf_push(b, '\\' as u8); b = buf_push(b, 'b' as u8); }
        else if c == (12 as u8) { b = buf_push(b, '\\' as u8); b = buf_push(b, 'f' as u8); }
        else if c == (10 as u8) { b = buf_push(b, '\\' as u8); b = buf_push(b, 'n' as u8); }
        else if c == (13 as u8) { b = buf_push(b, '\\' as u8); b = buf_push(b, 'r' as u8); }
        else if c == (9 as u8) { b = buf_push(b, '\\' as u8); b = buf_push(b, 't' as u8); }
        else if c < (32 as u8) {
            let hex: *u8 = { malloc(7 as usize) };
            { snprintf(hex, 7 as usize, #str_ptr("\\u%04x\0"), c as i32); }
            b = buf_push_bytes(b, hex, 6 as usize);
            { free(hex); }
        }
        else { b = buf_push(b, c); }
        i = i +% (1 as usize);
    }
    b = buf_push(b, '"' as u8);
    return b;
}

fn encode_number(b: Buf, n: f64) -> Buf {
    var b: Buf = b;
    // Shortest round-trip: prefer fixed-point form (`%.*f` with the
    // smallest decimal-place count that round-trips), falling back to
    // `%.*g` for very large / very small magnitudes where fixed-point
    // would be longer than scientific. Integer-valued doubles in safe
    // int range print as plain integers ("30", not "3e+01"). This
    // replaces the v0.0.9 unconditional %.17g which always emitted 17
    // sig figs ("0.1" → "0.10000000000000001").
    // Integer fast-path. An integer-valued double in exact range
    // (|n| <= 9e15 < 2^53) formats with a manual base-10 conversion —
    // no malloc, no snprintf, and no strtod round-trip probing. This is
    // the same value the `%.0f` branch below would pick (it chooses the
    // smallest place count that round-trips, and p=0 round-trips for an
    // integer). `n == 0` falls through so signed zero ("-0") is left to
    // snprintf, preserving prior output exactly.
    let asi: i64 = n as i64;
    if asi != (0 as i64) && (asi as f64) == n && n <= 9.0e15 && n >= (0.0 - 9.0e15) {
        var x: i64 = asi;
        let neg: bool = x < (0 as i64);
        if neg { x = (0 as i64) -% x; }
        var digs: [u8; 24] = [0u8; 24];
        var len: usize = 0 as usize;
        while x > (0 as i64) {
            let d: i64 = x % (10 as i64);
            digs[len] = ('0' as u8) +% (d as u8);
            len = len +% (1 as usize);
            x = x / (10 as i64);
        }
        if neg { b = buf_push(b, '-' as u8); }
        var k: usize = len;
        while k > (0 as usize) {
            k = k -% (1 as usize);
            b = buf_push(b, digs[k]);
        }
        return b;
    }

    // Float / large-magnitude fallback. Stack buffers + `#addr_of` for
    // the strtod end-pointer keep the heap untouched here too.
    var out_arr: [u8; 64] = [0u8; 64];
    var fmt_arr: [u8; 8] = [0u8; 8];
    let buf: *u8 = { #addr_of(out_arr) as *u8 };
    let fmt_buf: *u8 = { #addr_of(fmt_arr) as *u8 };
    var endp_stack: *u8 = { 0 as *u8 };
    let endp: **u8 = { #addr_of(endp_stack) };

    var chosen_len: i32 = 0;

    // Phase 1: try %.0f .. %.17f (fixed point). Picks the smallest
    // decimal-place count that round-trips. Catches integers ("30"),
    // simple decimals ("0.1", "3.14"), etc.
    var p: i32 = 0;
    while p <= 17 {
        let fmt_n: i32 = { snprintf(fmt_buf, 8 as usize, #str_ptr("%%.%df\0"), p) };
        if fmt_n <= 0 { p = p +% 1; continue; }
        let w: i32 = { snprintf(buf, 64 as usize, fmt_buf, n) };
        if w > 0 && w < 64 {
            let round_trip: f64 = { strtod(buf, endp) };
            if round_trip == n {
                chosen_len = w;
                p = 100;
            }
        }
        p = p +% 1;
    }

    // Phase 2: if fixed point didn't work (very large or very small
    // magnitude), fall back to %.*g which can use scientific notation.
    if chosen_len == 0 {
        var q: i32 = 1;
        while q <= 17 {
            let fmt_n: i32 = { snprintf(fmt_buf, 8 as usize, #str_ptr("%%.%dg\0"), q) };
            if fmt_n <= 0 { q = q +% 1; continue; }
            let w: i32 = { snprintf(buf, 64 as usize, fmt_buf, n) };
            if w > 0 && w < 64 {
                let round_trip: f64 = { strtod(buf, endp) };
                if round_trip == n {
                    chosen_len = w;
                    q = 100;
                }
            }
            q = q +% 1;
        }
    }

    if chosen_len == 0 {
        chosen_len = { snprintf(buf, 64 as usize, #str_ptr("%.17g\0"), n) };
    }
    if chosen_len > 0 {
        b = buf_push_bytes(b, buf, chosen_len as usize);
    }
    return b;
}

fn encode_value(b: Buf, v: Value) -> Buf {
    var b: Buf = b;
    let out: Buf = match v {
        Value::Null => buf_push_str(b, "null"),
        Value::Bool(x) => if x { buf_push_str(b, "true") } else { buf_push_str(b, "false") },
        Value::Number(n) => encode_number(b, n),
        Value::Text(s) => encode_string(b, { s }),
        Value::Array(arr) => {
            var bb: Buf = buf_push(b, '[' as u8);
            let n: usize = arr.count();
            var i: usize = 0 as usize;
            while i < n {
                if i > (0 as usize) { bb = buf_push(bb, ',' as u8); }
                match arr.at_ptr(i) {
                    option::Option[*Value]::Some(p) => { bb = encode_value(bb, { *p }); }
                    option::Option[*Value]::None => {}
                }
                i = i +% (1 as usize);
            }
            bb = buf_push(bb, ']' as u8);
            bb
        }
        Value::Object(arr) => {
            var bb: Buf = buf_push(b, '{' as u8);
            let n: usize = arr.count();
            var i: usize = 0 as usize;
            while i < n {
                if i > (0 as usize) { bb = buf_push(bb, ',' as u8); }
                match arr.at_ptr(i) {
                    option::Option[*Member]::Some(p) => {
                        bb = encode_string(bb, { (*p).key });
                        bb = buf_push(bb, ':' as u8);
                        bb = encode_value(bb, { (*p).value });
                    }
                    option::Option[*Member]::None => {}
                }
                i = i +% (1 as usize);
            }
            bb = buf_push(bb, '}' as u8);
            bb
        }
    };
    return out;
}

impl Value {
    fn to_text(this) -> text::Text {
        let b: Buf = buf_new();
        let final_buf: Buf = encode_value(b, this);
        return buf_to_string(final_buf);
    }
}

// ---------------- Unit tests (run via `cpc test`) ----------------

fn parse_ok(source: str) -> Value {
    let r: result::Result[Value, ParseError] = Value::parse(source: source);
    guard let result::Result[Value, ParseError]::Ok(v) = r else {
        assert false;
        return Value::Null;
    };
    return v;
}

fn parse_fails(source: str) -> bool {
    let r: result::Result[Value, ParseError] = Value::parse(source: source);
    let failed: bool = match r {
        result::Result[Value, ParseError]::Ok(_) => false,
        result::Result[Value, ParseError]::Err(_) => true,
    };
    return failed;
}

// Unwrap helpers: assert the accessor returned `Some` and hand back the value.
// Keep the parse tests readable; the Option behavior itself is covered by the
// dedicated `*_none*` / `*_distinguishes_*` tests below.
fn _must_boolean(v: Value) -> bool {
    guard let option::Option[bool]::Some(b) = v.as_boolean() else { assert false; return false; };
    return b;
}
fn _must_number(v: Value) -> f64 {
    guard let option::Option[f64]::Some(n) = v.as_number() else { assert false; return 0.0f64; };
    return n;
}
fn _must_text(v: Value) -> text::Text {
    guard let option::Option[text::Text]::Some(t) = v.as_text() else { assert false; return "".to_text(); };
    return t;
}
fn _must_value(v: Value, key: str) -> Value {
    guard let option::Option[Value]::Some(x) = v.value(for_key: key) else { assert false; return Value::Null; };
    return x;
}

#[test]
fn test_parse_null() {
    let v: Value = parse_ok("null");
    assert v.is_null();
}

#[test]
fn test_parse_true() {
    let v: Value = parse_ok("true");
    assert v.is_boolean();
    assert _must_boolean(v);
}

#[test]
fn test_parse_false() {
    let v: Value = parse_ok("false");
    assert _must_boolean(v) == false;
}

#[test]
fn test_parse_number_integer() {
    let v: Value = parse_ok("42");
    assert v.is_number();
    let n: f64 = _must_number(v);
    assert n >= 41.5f64;
    assert n <= 42.5f64;
}

#[test]
fn test_parse_number_with_exponent() {
    let v: Value = parse_ok("-1.5e2");
    let n: f64 = _must_number(v);
    assert n >= - 150.5f64;
    assert n <= - 149.5f64;
}

#[test]
fn test_parse_number_rejects_double_dot() {
    assert parse_fails("1.2.3");
}

#[test]
fn test_parse_string_simple() {
    let v: Value = parse_ok("\"hello\"");
    assert v.is_text();
    let s: text::Text = _must_text(v);
    assert s.count() == (5 as usize);
}

#[test]
fn test_parse_string_with_escapes() {
    let v: Value = parse_ok("\"a\\nb\\t\\\\\"");
    let s: text::Text = _must_text(v);
    // decoded: 'a', '\n', 'b', '\t', '\\' = 5 bytes
    assert s.count() == (5 as usize);
}

#[test]
fn test_parse_empty_array() {
    let v: Value = parse_ok("[]");
    assert v.is_array();
    assert v.item_count() == (0 as usize);
}

#[test]
fn test_parse_array_of_numbers() {
    let v: Value = parse_ok("[1, 2, 3]");
    assert v.item_count() == (3 as usize);
}

#[test]
fn test_parse_empty_object() {
    let v: Value = parse_ok("{}");
    assert v.is_object();
    assert v.item_count() == (0 as usize);
}

#[test]
fn test_parse_object_get_by_key() {
    let v: Value = parse_ok("{\"a\":1,\"b\":2}");
    let va: Value = _must_value(v, "a");
    assert va.is_number();
    // missing key -> None (not a null Value)
    match parse_ok("{\"a\":1}").value(for_key: "missing") {
        option::Option[Value]::Some(x) => { assert false; }
        option::Option[Value]::None => { assert true; }
    }
    return;
}

#[test]
fn test_parse_nested() {
    let v: Value = parse_ok("{\"arr\":[true,false,null]}");
    let arr: Value = _must_value(v, "arr");
    assert arr.is_array();
    assert arr.item_count() == (3 as usize);
}

#[test]
fn test_parse_rejects_trailing_comma() {
    assert parse_fails("[1, 2,]");
}

#[test]
fn test_parse_rejects_unterminated_string() {
    assert parse_fails("\"hi");
}

#[test]
fn test_parse_rejects_empty() {
    assert parse_fails("");
}

#[test]
fn test_round_trip_array() {
    let src: str = "[true,false,null]";
    let v: Value = parse_ok(src);
    assert { v.to_text() } == src;
}

#[test]
fn test_round_trip_object() {
    let src: str = "{\"k\":\"v\"}";
    let v: Value = parse_ok(src);
    assert { v.to_text() } == src;
}

#[test]
fn test_builder_array_new_push() {
    var arr: Value = Value::array(vec::new::[Value]());
    var arr_inner: vec::Vec[Value] = match arr {
        Value::Array(a) => a,
        _ => vec::new::[Value](),
    };
    arr_inner.append(Value::Number(7.0f64));
    let final_v: Value = Value::Array(arr_inner);
    assert final_v.item_count() == (1 as usize);
}

#[test]
fn test_value_drop_does_not_double_free() {
    // The typed-enum Value carries Vec[Value] / Vec[Member] payloads;
    // dropping the outer Value recursively drops each Inner. This
    // test just exercises construction + scope-exit drop and relies
    // on ASan (if enabled) to catch double-free or leak.
    let v: Value = parse_ok("[\"a\",[\"b\",[\"c\"]]]");
    assert v.is_array();
    // no explicit free needed
}

#[test]
fn test_emit_number_short_form() {
    // Shortest round-trip: integers print without trailing decimal,
    // simple decimals print at their natural precision (not the old
    // %.17g "0.10000000000000001" noise).
    let v_int: Value = Value::Number(42.0f64);
    let s_int: text::Text = v_int.to_text();
    assert { s_int } == "42";

    let v_dec: Value = Value::Number(0.1f64);
    let s_dec: text::Text = v_dec.to_text();
    assert { s_dec } == "0.1";
}

#[test]
fn test_parse_surrogate_pair_decodes_to_4byte_utf8() {
    // 😀 = 😀 (U+1F600). Combined into a single codepoint,
    // emitted as 4 UTF-8 bytes: F0 9F 98 80.
    let v: Value = parse_ok("\"\\uD83D\\uDE00\"");
    let s: text::Text = _must_text(v);
    assert s.count() == (4 as usize);
    let p: *u8 = #str_ptr({ s });
    assert { *p } == (0xF0 as u8);
    assert { *(p + 1) } == (0x9F as u8);
    assert { *(p + 2) } == (0x98 as u8);
    assert { *(p + 3) } == (0x80 as u8);
}

#[test]
fn test_parse_bmp_unicode_escape_still_works() {
    // U+00E9 = é. Two-byte UTF-8 sequence: C3 A9.
    let v: Value = parse_ok("\"\\u00e9\"");
    let s: text::Text = _must_text(v);
    assert s.count() == (2 as usize);
    let p: *u8 = #str_ptr({ s });
    assert { *p } == (0xC3 as u8);
    assert { *(p + 1) } == (0xA9 as u8);
}

// ---- accessor safety + new method-API coverage ----

#[test]
fn test_value_distinguishes_null_from_missing() {
    let v: Value = parse_ok("{\"present\":null}");
    match v.value(for_key: "present") {   // present-but-null -> Some(Null)
        option::Option[Value]::Some(x) => { assert x.is_null(); }
        option::Option[Value]::None => { assert false; }
    }
    match v.value(for_key: "absent") {    // missing key -> None
        option::Option[Value]::Some(x) => { assert false; }
        option::Option[Value]::None => { assert true; }
    }
    return;
}

#[test]
fn test_accessors_none_on_type_mismatch() {
    let v: Value = parse_ok("42");        // a number
    match v.as_boolean() { option::Option[bool]::Some(b) => { assert false; } option::Option[bool]::None => { assert true; } }
    match v.as_text() { option::Option[text::Text]::Some(t) => { assert false; } option::Option[text::Text]::None => { assert true; } }
    return;
}

#[test]
fn test_item_with_label_and_bounds() {
    let v: Value = parse_ok("[10, 20, 30]");
    match v.item(at: 1 as usize) {
        option::Option[Value]::Some(x) => { assert _must_number(x) >= 19.5f64; }
        option::Option[Value]::None => { assert false; }
    }
    match v.item(at: 99 as usize) {       // out of bounds -> None
        option::Option[Value]::Some(x) => { assert false; }
        option::Option[Value]::None => { assert true; }
    }
    return;
}

#[test]
fn test_object_key_value_at() {
    let v: Value = parse_ok("{\"a\":1,\"b\":2}");
    assert v.item_count() == (2 as usize);
    match v.key(at: 0 as usize) {
        option::Option[text::Text]::Some(k) => { assert k.equals("a"); }
        option::Option[text::Text]::None => { assert false; }
    }
    match v.object_value(at: 1 as usize) {
        option::Option[Value]::Some(val) => { assert _must_number(val) >= 1.5f64; }
        option::Option[Value]::None => { assert false; }
    }
    return;
}

#[test]
fn test_named_constructors_build_values() {
    let text_value: Value = Value::text("ready");
    assert _must_text(text_value).equals("ready");

    var members: vec::Vec[Member] = vec::new::[Member]();
    members.append(Member::new("enabled", Value::boolean(true)));
    let object: Value = Value::object(members);
    let enabled: Value = _must_value(object, "enabled");
    assert _must_boolean(enabled);

    let number: Value = Value::number(12.0f64);
    assert _must_number(number) >= 11.5f64;
}
