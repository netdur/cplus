// Android View and ViewGroup wrappers.
//
// Naming guideline notes: the raw global ref is hidden behind `_obj` and the
// `Env` behind `_env`; booleans on the surface take `bool`. The adapter class
// name stays raw `*u8` (it names a JVM class with the JNI '/'-form descriptor,
// e.g. `com/example/app/NativeClickListener`, supplied as a `\0` literal).

import "jni/jni" as jni;
import "./runtime" as rt;

fn orientation_horizontal() -> i32 { return 0 as i32; }
fn orientation_vertical() -> i32 { return 1 as i32; }

// Host-runnable: the orientation constants match android.widget.LinearLayout
// (HORIZONTAL = 0, VERTICAL = 1); no JVM needed.
#[test]
fn orientation_constants_match_android() {
    assert orientation_horizontal() == 0 as i32;
    assert orientation_vertical() == 1 as i32;
    return;
}

// Wire a click handler through a JVM-side adapter class. Java interfaces
// cannot be implemented from native code, so the host app ships a tiny
// adapter (see the README's NativeClickListener) holding a `long` token;
// its onClick forwards to a `native` method the C+ app exports. The
// adapter class name is caller-provided because it lives in the app's own
// package (e.g. `com/example/app/NativeClickListener`).
fn set_on_click_raw(env: rt::Env, view: jni::jobject, adapter_class: *u8, token: i64) {
    let listener: jni::jobject = env.new_object_1(
        adapter_class,
        #str_ptr("(J)V\0"),
        rt::arg_long(token),
    );
    env.call_void_1(
        view,
        #str_ptr("android/view/View\0"),
        #str_ptr("setOnClickListener\0"),
        #str_ptr("(Landroid/view/View$OnClickListener;)V\0"),
        rt::arg_object(listener),
    );
    env.delete_local_ref(listener);
    return;
}

struct View {
    _env: rt::Env,
    _obj: jni::jobject,
}

impl View {
    fn drop(ref this) {
        // `into_raw` nulls `_obj` after transferring the global ref out;
        // JNI's DeleteGlobalRef contract does not admit NULL.
        if this._obj != { 0 as jni::jobject } {
            this._env.delete_global_ref(this._obj);
        }
        return;
    }

    fn from_global(env: rt::Env, obj: jni::jobject) -> View {
        return View { _env: env, _obj: obj };
    }

    fn from_local(env: rt::Env, obj: jni::jobject) -> View {
        return View { _env: env, _obj: env.retain_local_as_global(obj) };
    }

    fn as_obj(this) -> jni::jobject {
        return this._obj;
    }

    fn into_raw(ref this) -> jni::jobject {
        let p: jni::jobject = this._obj;
        this._obj = { 0 as jni::jobject };
        return p;
    }

    fn set_visibility(this, visibility: i32) {
        this._env.call_void_1(
            this._obj,
            #str_ptr("android/view/View\0"),
            #str_ptr("setVisibility\0"),
            #str_ptr("(I)V\0"),
            rt::arg_int(visibility),
        );
    }

    fn set_enabled(this, enabled: bool) {
        this._env.call_void_1(
            this._obj,
            #str_ptr("android/view/View\0"),
            #str_ptr("setEnabled\0"),
            #str_ptr("(Z)V\0"),
            rt::arg_bool(enabled),
        );
    }

    fn set_on_click(this, adapter_class: *u8, token: i64) {
        set_on_click_raw(this._env, this._obj, adapter_class, token);
        return;
    }
}

struct LinearLayout {
    _env: rt::Env,
    _obj: jni::jobject,
}

impl LinearLayout {
    fn drop(ref this) {
        // `into_raw` nulls `_obj` after transferring the global ref out;
        // JNI's DeleteGlobalRef contract does not admit NULL.
        if this._obj != { 0 as jni::jobject } {
            this._env.delete_global_ref(this._obj);
        }
        return;
    }

    fn new(env: rt::Env, ctx: rt::Context) -> LinearLayout {
        let local: jni::jobject = env.new_object_1(
            #str_ptr("android/widget/LinearLayout\0"),
            #str_ptr("(Landroid/content/Context;)V\0"),
            rt::arg_object(ctx),
        );
        return LinearLayout { _env: env, _obj: env.retain_local_as_global(local) };
    }

    fn as_view_obj(this) -> jni::jobject {
        return this._obj;
    }

    fn into_raw(ref this) -> jni::jobject {
        let p: jni::jobject = this._obj;
        this._obj = { 0 as jni::jobject };
        return p;
    }

    fn set_orientation(this, orientation: i32) {
        this._env.call_void_1(
            this._obj,
            #str_ptr("android/widget/LinearLayout\0"),
            #str_ptr("setOrientation\0"),
            #str_ptr("(I)V\0"),
            rt::arg_int(orientation),
        );
    }

    fn add_view(this, child: jni::jobject) {
        this._env.call_void_1(
            this._obj,
            #str_ptr("android/view/ViewGroup\0"),
            #str_ptr("addView\0"),
            #str_ptr("(Landroid/view/View;)V\0"),
            rt::arg_object(child),
        );
    }
}
