// android_view runtime: small JNI helpers used by the typed View wrappers.
//
// Native Android entrypoints receive `JNIEnv *` — a pointer to the
// thread-local JNI function-table pointer. JNI functions must be called
// with that same double pointer (ART recovers the thread from it), so
// `Env` stores it as-is and dereferences twice to reach the table.

import "jni/jni" as jni;

pub type Context = jni::jobject;
pub type Activity = jni::jobject;
pub type JavaObject = jni::jobject;

pub struct Env {
    pub opaque env: *jni::JNIEnv,
}

pub fn from_native(envp: *jni::JNIEnv) -> Env {
    return Env { env: envp };
}

impl Env {
    pub fn get_version(this) -> jni::jint {
        return unsafe { (*(*this.env)).GetVersion(this.env) };
    }

    pub fn find_class(this, name: *u8) -> jni::jclass {
        return unsafe { (*(*this.env)).FindClass(this.env, name) };
    }

    pub fn get_method_id(this, cls: jni::jclass, name: *u8, sig: *u8) -> jni::jmethodID {
        return unsafe { (*(*this.env)).GetMethodID(this.env, cls, name, sig) };
    }

    pub fn exception_occurred(this) -> jni::jthrowable {
        return unsafe { (*(*this.env)).ExceptionOccurred(this.env) };
    }

    pub fn exception_clear(this) {
        unsafe { (*(*this.env)).ExceptionClear(this.env); };
    }

    pub fn new_global_ref(this, obj: jni::jobject) -> jni::jobject {
        return unsafe { (*(*this.env)).NewGlobalRef(this.env, obj) };
    }

    pub fn delete_global_ref(this, obj: jni::jobject) {
        unsafe { (*(*this.env)).DeleteGlobalRef(this.env, obj); };
    }

    pub fn delete_local_ref(this, obj: jni::jobject) {
        unsafe { (*(*this.env)).DeleteLocalRef(this.env, obj); };
    }

    // `utf8` must be NUL-terminated modified UTF-8, matching JNI's
    // NewStringUTF contract. String-literal call sites should include `\0`.
    pub fn new_string_utf(this, utf8: *u8) -> jni::jstring {
        return unsafe { (*(*this.env)).NewStringUTF(this.env, utf8) };
    }

    pub fn method(this, class_name: *u8, name: *u8, sig: *u8) -> jni::jmethodID {
        let cls: jni::jclass = this.find_class(class_name);
        let mid: jni::jmethodID = this.get_method_id(cls, name, sig);
        this.delete_local_ref(cls);
        return mid;
    }

    pub fn new_object_0(this, class_name: *u8, ctor_sig: *u8) -> jni::jobject {
        let cls: jni::jclass = this.find_class(class_name);
        let ctor: jni::jmethodID = this.get_method_id(cls, #str_ptr("<init>\0"), ctor_sig);
        let obj: jni::jobject = unsafe {
            (*(*this.env)).NewObjectA(this.env, cls, ctor, 0 as *jni::JValue)
        };
        this.delete_local_ref(cls);
        return obj;
    }

    pub fn new_object_1(this, class_name: *u8, ctor_sig: *u8, arg0: jni::JValue) -> jni::jobject {
        let cls: jni::jclass = this.find_class(class_name);
        let ctor: jni::jmethodID = this.get_method_id(cls, #str_ptr("<init>\0"), ctor_sig);
        var args: [jni::JValue; 1] = [arg0];
        let obj: jni::jobject = unsafe {
            (*(*this.env)).NewObjectA(this.env, cls, ctor, #addr_of(args[0]))
        };
        this.delete_local_ref(cls);
        return obj;
    }

    pub fn call_void_0(this, obj: jni::jobject, class_name: *u8, name: *u8, sig: *u8) {
        let mid: jni::jmethodID = this.method(class_name, name, sig);
        unsafe { (*(*this.env)).CallVoidMethodA(this.env, obj, mid, 0 as *jni::JValue); };
    }

    pub fn call_void_1(this, obj: jni::jobject, class_name: *u8, name: *u8, sig: *u8, arg0: jni::JValue) {
        let mid: jni::jmethodID = this.method(class_name, name, sig);
        var args: [jni::JValue; 1] = [arg0];
        unsafe { (*(*this.env)).CallVoidMethodA(this.env, obj, mid, #addr_of(args[0])); };
    }

    pub fn call_void_2(
        this,
        obj: jni::jobject,
        class_name: *u8,
        name: *u8,
        sig: *u8,
        arg0: jni::JValue,
        arg1: jni::JValue,
    ) {
        let mid: jni::jmethodID = this.method(class_name, name, sig);
        var args: [jni::JValue; 2] = [arg0, arg1];
        unsafe { (*(*this.env)).CallVoidMethodA(this.env, obj, mid, #addr_of(args[0])); };
    }

    pub fn call_object_0(this, obj: jni::jobject, class_name: *u8, name: *u8, sig: *u8) -> jni::jobject {
        let mid: jni::jmethodID = this.method(class_name, name, sig);
        return unsafe { (*(*this.env)).CallObjectMethodA(this.env, obj, mid, 0 as *u8) };
    }

    pub fn call_object_1(this, obj: jni::jobject, class_name: *u8, name: *u8, sig: *u8, arg0: jni::JValue) -> jni::jobject {
        let mid: jni::jmethodID = this.method(class_name, name, sig);
        var args: [jni::JValue; 1] = [arg0];
        return unsafe {
            (*(*this.env)).CallObjectMethodA(this.env, obj, mid, #addr_of(args[0]) as *u8)
        };
    }

    pub fn exception_check(this) -> i8 {
        return unsafe { (*(*this.env)).ExceptionCheck(this.env) } as i8;
    }

    pub fn retain_local_as_global(this, local: jni::jobject) -> jni::jobject {
        let global: jni::jobject = this.new_global_ref(local);
        this.delete_local_ref(local);
        return global;
    }
}

pub fn arg_object(obj: jni::jobject) -> jni::JValue {
    return jni::arg_object(obj);
}

pub fn arg_int(v: i32) -> jni::JValue {
    return jni::arg_int(v as jni::jint);
}

pub fn arg_bool(v: i8) -> jni::JValue {
    return jni::arg_bool(v as jni::jboolean);
}

pub fn arg_long(v: i64) -> jni::JValue {
    return jni::arg_long(v as jni::jlong);
}

