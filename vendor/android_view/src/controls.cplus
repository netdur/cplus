// Basic android.widget controls backed by owned global JNI references.

import "jni/jni" as jni;
import "./runtime" as rt;
import "./view" as view;

pub struct TextView {
    pub env: rt::Env,
    pub obj: jni::jobject,
}

impl TextView {
    fn drop(mut self) {
        // `into_raw` nulls `obj` after transferring the global ref out;
        // JNI's DeleteGlobalRef contract does not admit NULL.
        if self.obj != unsafe { 0 as jni::jobject } {
            self.env.delete_global_ref(self.obj);
        }
        return;
    }

    pub fn new(env: rt::Env, ctx: rt::Context) -> TextView {
        let local: jni::jobject = env.new_object_1(
            #str_ptr("android/widget/TextView\0"),
            #str_ptr("(Landroid/content/Context;)V\0"),
            rt::arg_object(ctx),
        );
        return TextView { env: env, obj: env.retain_local_as_global(local) };
    }

    pub fn as_view_obj(self) -> jni::jobject {
        return self.obj;
    }

    pub fn into_raw(mut self) -> jni::jobject {
        let p: jni::jobject = self.obj;
        self.obj = unsafe { 0 as jni::jobject };
        return p;
    }

    pub fn set_text(self, utf8: *u8) {
        let s: jni::jstring = self.env.new_string_utf(utf8);
        self.env.call_void_1(
            self.obj,
            #str_ptr("android/widget/TextView\0"),
            #str_ptr("setText\0"),
            #str_ptr("(Ljava/lang/CharSequence;)V\0"),
            rt::arg_object(s),
        );
        self.env.delete_local_ref(s);
    }
}

pub struct Button {
    pub env: rt::Env,
    pub obj: jni::jobject,
}

impl Button {
    fn drop(mut self) {
        // `into_raw` nulls `obj` after transferring the global ref out;
        // JNI's DeleteGlobalRef contract does not admit NULL.
        if self.obj != unsafe { 0 as jni::jobject } {
            self.env.delete_global_ref(self.obj);
        }
        return;
    }

    pub fn new(env: rt::Env, ctx: rt::Context) -> Button {
        let local: jni::jobject = env.new_object_1(
            #str_ptr("android/widget/Button\0"),
            #str_ptr("(Landroid/content/Context;)V\0"),
            rt::arg_object(ctx),
        );
        return Button { env: env, obj: env.retain_local_as_global(local) };
    }

    pub fn as_view_obj(self) -> jni::jobject {
        return self.obj;
    }

    pub fn into_raw(mut self) -> jni::jobject {
        let p: jni::jobject = self.obj;
        self.obj = unsafe { 0 as jni::jobject };
        return p;
    }

    pub fn set_text(self, utf8: *u8) {
        let s: jni::jstring = self.env.new_string_utf(utf8);
        self.env.call_void_1(
            self.obj,
            #str_ptr("android/widget/TextView\0"),
            #str_ptr("setText\0"),
            #str_ptr("(Ljava/lang/CharSequence;)V\0"),
            rt::arg_object(s),
        );
        self.env.delete_local_ref(s);
    }

    pub fn set_on_click(self, adapter_class: *u8, token: i64) {
        view::set_on_click_raw(self.env, self.obj, adapter_class, token);
        return;
    }
    pub fn set_on_click_listener(self, listener: jni::jobject, listener_sig: *u8) {
        self.env.call_void_1(
            self.obj,
            #str_ptr("android/view/View\0"),
            #str_ptr("setOnClickListener\0"),
            listener_sig,
            rt::arg_object(listener),
        );
    }
}
