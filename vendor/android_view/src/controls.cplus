// Basic android.widget controls backed by owned global JNI references.

import "jni/jni" as jni;
import "./runtime" as rt;
import "./view" as view;

struct TextView {
    env: rt::Env,
    obj: jni::jobject,
}

impl TextView {
    fn drop(ref this) {
        // `into_raw` nulls `obj` after transferring the global ref out;
        // JNI's DeleteGlobalRef contract does not admit NULL.
        if this.obj != unsafe { 0 as jni::jobject } {
            this.env.delete_global_ref(this.obj);
        }
        return;
    }

    fn new(env: rt::Env, ctx: rt::Context) -> TextView {
        let local: jni::jobject = env.new_object_1(
            #str_ptr("android/widget/TextView\0"),
            #str_ptr("(Landroid/content/Context;)V\0"),
            rt::arg_object(ctx),
        );
        return TextView { env: env, obj: env.retain_local_as_global(local) };
    }

    fn as_view_obj(this) -> jni::jobject {
        return this.obj;
    }

    fn into_raw(ref this) -> jni::jobject {
        let p: jni::jobject = this.obj;
        this.obj = unsafe { 0 as jni::jobject };
        return p;
    }

    fn set_text(this, utf8: *u8) {
        let s: jni::jstring = this.env.new_string_utf(utf8);
        this.env.call_void_1(
            this.obj,
            #str_ptr("android/widget/TextView\0"),
            #str_ptr("setText\0"),
            #str_ptr("(Ljava/lang/CharSequence;)V\0"),
            rt::arg_object(s),
        );
        this.env.delete_local_ref(s);
    }
}

struct Button {
    env: rt::Env,
    obj: jni::jobject,
}

impl Button {
    fn drop(ref this) {
        // `into_raw` nulls `obj` after transferring the global ref out;
        // JNI's DeleteGlobalRef contract does not admit NULL.
        if this.obj != unsafe { 0 as jni::jobject } {
            this.env.delete_global_ref(this.obj);
        }
        return;
    }

    fn new(env: rt::Env, ctx: rt::Context) -> Button {
        let local: jni::jobject = env.new_object_1(
            #str_ptr("android/widget/Button\0"),
            #str_ptr("(Landroid/content/Context;)V\0"),
            rt::arg_object(ctx),
        );
        return Button { env: env, obj: env.retain_local_as_global(local) };
    }

    fn as_view_obj(this) -> jni::jobject {
        return this.obj;
    }

    fn into_raw(ref this) -> jni::jobject {
        let p: jni::jobject = this.obj;
        this.obj = unsafe { 0 as jni::jobject };
        return p;
    }

    fn set_text(this, utf8: *u8) {
        let s: jni::jstring = this.env.new_string_utf(utf8);
        this.env.call_void_1(
            this.obj,
            #str_ptr("android/widget/TextView\0"),
            #str_ptr("setText\0"),
            #str_ptr("(Ljava/lang/CharSequence;)V\0"),
            rt::arg_object(s),
        );
        this.env.delete_local_ref(s);
    }

    fn set_on_click(this, adapter_class: *u8, token: i64) {
        view::set_on_click_raw(this.env, this.obj, adapter_class, token);
        return;
    }
    fn set_on_click_listener(this, listener: jni::jobject, listener_sig: *u8) {
        this.env.call_void_1(
            this.obj,
            #str_ptr("android/view/View\0"),
            #str_ptr("setOnClickListener\0"),
            listener_sig,
            rt::arg_object(listener),
        );
    }
}
