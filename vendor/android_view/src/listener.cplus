// Self-contained click handling: no host-side Java beyond MainActivity.
//
// Java interfaces cannot be implemented from native code, so the adapter
// class (adapter/NativeClickListener.java) ships *inside this package* as
// a pre-compiled DEX, embedded in the binary via #include_bytes. On first
// use it is loaded with dalvik.system.InMemoryDexClassLoader (API 26+) and
// its `nativeOnClick` is bound with RegisterNatives — ART resolves native
// methods by symbol only through a classloader's own native-library
// namespace, which an in-memory loader does not have, so explicit binding
// is the only correct path.
//
// Contract: importing this module obligates the app to export the hook
//
//     export extern fn cplus_on_click(envp: *jni::JNIEnv, token: i64, view: jni::jobject)
//
// (bionic binds eagerly at System.loadLibrary, so a missing hook fails at
// library load). The `token` passed to `set_on_click` routes any number of
// controls through the single hook.

import "jni/jni" as jni;
import "./runtime" as rt;

extern fn cplus_on_click(envp: *jni::JNIEnv, token: i64, view: jni::jobject);

// The registered JNI target: `static native void nativeOnClick(long, View)`
// receives (env, class, token, view); forward to the app's hook.
export extern fn cplus_av_native_on_click(
    envp: *jni::JNIEnv,
    cls: jni::jobject,
    token: i64,
    view: jni::jobject,
) {
    unsafe { cplus_on_click(envp, token, view); }
    return;
}

// jni.h's JNINativeMethod, with the fn slot concretely typed for the
// click shape (the table call takes it as an untyped record pointer).
#[repr(C)]
struct ClickMethodRecord {
    // Both point at static string literals; nothing owns or frees them.
    pub opaque name: *u8,
    pub opaque signature: *u8,
    pub fn_ptr: fn(*jni::JNIEnv, jni::jobject, i64, jni::jobject),
}

// The adapter class, once loaded + bound: a jclass global ref (as usize —
// statics hold integers; the JVM owns the class object).
static LISTENER_CLASS: usize = 0;

// Load adapter.dex and bind nativeOnClick. Idempotent; runs on first
// `set_on_click`. The dex bytes live in the binary (static lifetime), so
// the direct ByteBuffer wrapping them stays valid for the loader's reads.
fn ensure_listener_class(env: rt::Env, any_view: jni::jobject) -> jni::jobject {
    let cached: usize = unsafe { LISTENER_CLASS };
    if cached != 0 {
        return unsafe { cached as *u8 };
    }
    let dex: *[u8; 976] = #include_bytes("../adapter/adapter.dex");
    let dex_ptr: *u8 = unsafe { dex as *u8 };
    let buffer: jni::jobject = unsafe {
        (*(*env.env)).NewDirectByteBuffer(env.env, dex_ptr, 976 as i64)
    };

    // The app's classloader, reached through any view's Context.
    let ctx: jni::jobject = env.call_object_0(
        any_view,
        #str_ptr("android/view/View\0"),
        #str_ptr("getContext\0"),
        #str_ptr("()Landroid/content/Context;\0"),
    );
    let app_loader: jni::jobject = env.call_object_0(
        ctx,
        #str_ptr("android/content/Context\0"),
        #str_ptr("getClassLoader\0"),
        #str_ptr("()Ljava/lang/ClassLoader;\0"),
    );

    // new InMemoryDexClassLoader(buffer, appLoader)
    let imdcl: jni::jclass = env.find_class(#str_ptr("dalvik/system/InMemoryDexClassLoader\0"));
    let ctor: jni::jmethodID = env.get_method_id(
        imdcl,
        #str_ptr("<init>\0"),
        #str_ptr("(Ljava/nio/ByteBuffer;Ljava/lang/ClassLoader;)V\0"),
    );
    var ctor_args: [jni::JValue; 2] = [jni::arg_object(buffer), jni::arg_object(app_loader)];
    let loader: jni::jobject = unsafe {
        (*(*env.env)).NewObjectA(env.env, imdcl, ctor, #addr_of(ctor_args[0]))
    };

    // loadClass uses the binary (dotted) name.
    let class_name: jni::jstring =
        env.new_string_utf(#str_ptr("cplus.androidview.NativeClickListener\0"));
    let cls_local: jni::jobject = env.call_object_1(
        loader,
        #str_ptr("java/lang/ClassLoader\0"),
        #str_ptr("loadClass\0"),
        #str_ptr("(Ljava/lang/String;)Ljava/lang/Class;\0"),
        jni::arg_object(class_name),
    );

    var record: ClickMethodRecord = ClickMethodRecord {
        name: #str_ptr("nativeOnClick\0"),
        signature: #str_ptr("(JLandroid/view/View;)V\0"),
        fn_ptr: cplus_av_native_on_click,
    };
    let _rc: i32 = unsafe {
        (*(*env.env)).RegisterNatives(env.env, cls_local, #addr_of(record) as *u8, 1)
    };

    // The class global ref also keeps its loader (and the dex) reachable.
    let cls_global: jni::jobject = env.new_global_ref(cls_local);
    unsafe { LISTENER_CLASS = cls_global as usize; }
    env.delete_local_ref(cls_local);
    env.delete_local_ref(class_name);
    env.delete_local_ref(loader);
    env.delete_local_ref(imdcl);
    env.delete_local_ref(app_loader);
    env.delete_local_ref(ctx);
    env.delete_local_ref(buffer);
    return cls_global;
}

// Wire a click handler with no host-side adapter class: the package's
// embedded one is instantiated with `token` and installed on `view`.
pub fn set_on_click(env: rt::Env, view: jni::jobject, token: i64) {
    let cls: jni::jobject = ensure_listener_class(env, view);
    let ctor: jni::jmethodID = env.get_method_id(cls, #str_ptr("<init>\0"), #str_ptr("(J)V\0"));
    var args: [jni::JValue; 1] = [jni::arg_long(token as i64)];
    let listener: jni::jobject = unsafe {
        (*(*env.env)).NewObjectA(env.env, cls, ctor, #addr_of(args[0]))
    };
    env.call_void_1(
        view,
        #str_ptr("android/view/View\0"),
        #str_ptr("setOnClickListener\0"),
        #str_ptr("(Landroid/view/View$OnClickListener;)V\0"),
        rt::arg_object(listener),
    );
    env.delete_local_ref(listener);
    return;
}
