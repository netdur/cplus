// Activity handoff helpers. The JVM still owns Activity creation/lifecycle;
// C+ can build a View tree and hand the root back through setContentView.

import "jni/jni" as jni;
import "./runtime" as rt;

struct Activity {
    env: rt::Env,
    opaque obj: jni::jobject,
}

impl Activity {
    fn from_borrowed(env: rt::Env, activity: jni::jobject) -> Activity {
        return Activity { env: env, obj: activity };
    }

    fn as_context(this) -> rt::Context {
        return this.obj;
    }

    fn set_content_view(this, view: jni::jobject) {
        this.env.call_void_1(
            this.obj,
            #str_ptr("android/app/Activity\0"),
            #str_ptr("setContentView\0"),
            #str_ptr("(Landroid/view/View;)V\0"),
            rt::arg_object(view),
        );
    }
}

