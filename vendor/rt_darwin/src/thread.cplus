// vendor/rt_darwin/src/thread.cplus — thread scheduling priority (Darwin QoS).
//
// On Darwin the idiomatic way to raise a worker's scheduling priority is the
// Quality-of-Service API rather than raw POSIX `sched_param`: it composes with
// the kernel's thread scheduler and needs no privileges for the interactive
// tiers. `pthread_set_qos_class_self_np` sets the calling thread's QoS class.
//
// Returns an explicit `Result` (never a trap): `Ok(0)` on success, `Err(rc)`
// with the libc return code otherwise.

import "stdlib/result" as result;

extern fn pthread_set_qos_class_self_np(qos_class: u32, relative_priority: i32) -> i32;

// Scheduling intent, mapped to Darwin `qos_class_t` values (`sys/qos.h`).
enum Priority {
    // QOS_CLASS_USER_INTERACTIVE (0x21) — main/audio-style work that must run
    // now. The closest QoS to a soft-real-time audio callback thread.
    RealtimeAudio,
    // QOS_CLASS_USER_INITIATED (0x19) — work the user is waiting on.
    Interactive,
    // QOS_CLASS_DEFAULT (0x15).
    Default,
    // QOS_CLASS_BACKGROUND (0x09) — maintenance work, may be throttled.
    Background,
}

fn qos_value(p: Priority) -> u32 {
    return match p {
        Priority::RealtimeAudio => 0x21 as u32,
        Priority::Interactive => 0x19 as u32,
        Priority::Default => 0x15 as u32,
        Priority::Background => 0x09 as u32,
    };
}

// Set the calling thread's QoS class. `Ok(0)` on success; `Err(rc)` carries
// the nonzero libc return code.
fn set_current_priority(p: Priority) -> result::Result[i32, i32] {
    let rc: i32 = unsafe { pthread_set_qos_class_self_np(qos_value(p), 0 as i32) };
    if rc == (0 as i32) {
        return result::Result[i32, i32]::Ok(0 as i32);
    }
    return result::Result[i32, i32]::Err(rc);
}

// ---------------- Unit tests ----------------

#[test]
fn test_set_priority_realtime_audio_ok() {
    // Interactive QoS tiers require no privileges — should succeed.
    match set_current_priority(Priority::RealtimeAudio) {
        result::Result[i32, i32]::Ok(_) => { assert true; }
        result::Result[i32, i32]::Err(_) => { assert false; }
    };
}

#[test]
fn test_set_priority_each_tier_returns() {
    // Every tier maps to a valid qos_class_t; exercise the full mapping.
    let _a: result::Result[i32, i32] = set_current_priority(Priority::Interactive);
    let _b: result::Result[i32, i32] = set_current_priority(Priority::Default);
    let _c: result::Result[i32, i32] = set_current_priority(Priority::Background);
    // Restore an interactive default so the test process isn't left throttled.
    match set_current_priority(Priority::Default) {
        result::Result[i32, i32]::Ok(_) => { assert true; }
        result::Result[i32, i32]::Err(_) => { assert true; }
    };
}

#[test]
fn test_qos_values_distinct() {
    assert qos_value(Priority::RealtimeAudio) != qos_value(Priority::Background);
    assert qos_value(Priority::RealtimeAudio) == (33 as u32);
}
