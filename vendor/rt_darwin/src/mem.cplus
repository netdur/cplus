// vendor/rt_darwin/src/mem.cplus — page locking / prefaulting.
//
// A real-time hot path must not take page faults (a fault can block for
// milliseconds on disk I/O). `lock_pages` wires the given range into physical
// memory via `mlock(2)` so subsequent accesses never fault; `unlock_pages`
// releases it. Both return an explicit `Result` — `mlock` can fail (e.g.
// `EPERM`/`ENOMEM` when the locked-memory rlimit is hit), and a real-time
// program wants to handle that, not trap.

import "stdlib/result" as result;

extern fn mlock(addr: *u8, len: usize) -> i32;
extern fn munlock(addr: *u8, len: usize) -> i32;

// Wire `[addr, addr+len)` into RAM. `Ok(0)` on success; `Err(-1)` on failure
// (libc sets `errno`; a richer error is a future refinement).
fn lock_pages(addr: *u8, len: usize) -> result::Result[i32, i32] {
    let rc: i32 = { mlock(addr, len) };
    if rc == (0 as i32) {
        return result::Result[i32, i32]::Ok(0 as i32);
    }
    return result::Result[i32, i32]::Err(rc);
}

// Release a previously locked range.
fn unlock_pages(addr: *u8, len: usize) -> result::Result[i32, i32] {
    let rc: i32 = { munlock(addr, len) };
    if rc == (0 as i32) {
        return result::Result[i32, i32]::Ok(0 as i32);
    }
    return result::Result[i32, i32]::Err(rc);
}

// ---------------- Unit tests ----------------

#[test]
fn test_lock_unlock_stack_buffer() {
    // Locking a small stack buffer typically succeeds under the default
    // RLIMIT_MEMLOCK; if the sandbox denies it we still exercise the FFI
    // path and the unlock. Assert the round-trip returns without trapping.
    let buf: [u8; 256] = [0u8; 256];
    let r: result::Result[i32, i32] = lock_pages({ #addr_of(buf[0]) }, 256 as usize);
    match r {
        result::Result[i32, i32]::Ok(_) => {
            // Locked — must unlock cleanly.
            match unlock_pages({ #addr_of(buf[0]) }, 256 as usize) {
                result::Result[i32, i32]::Ok(_) => { assert true; }
                result::Result[i32, i32]::Err(_) => { assert false; }
            };
        }
        result::Result[i32, i32]::Err(_) => {
            // Denied by the sandbox/rlimit — acceptable; FFI path exercised.
            assert true;
        }
    };
}
