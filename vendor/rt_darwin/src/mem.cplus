// vendor/rt_darwin/src/mem.cplus — page locking / prefaulting.
//
// A real-time hot path must not take page faults (a fault can block for
// milliseconds on disk I/O). `lock_pages` wires the given range into physical
// memory via `mlock(2)` so subsequent accesses never fault; `unlock_pages`
// releases it. Both return an explicit `Result` — `mlock` can fail (e.g.
// `EPERM`/`ENOMEM` when the locked-memory rlimit is hit), and a real-time
// program wants to handle that, not trap.

import "stdlib/result" as result;

extern fn mlock(addr: *u8, len: usize) -> i32;
extern fn munlock(addr: *u8, len: usize) -> i32;

// Wire `[at, at+len)` into RAM. The labeled parameters read as a phrase —
// `lock_pages(at: addr, len: 256)`. `Ok(0)` on success; `Err(rc)` carries the
// nonzero libc return code (libc also sets `errno`; a richer error is a future
// refinement). The address is a genuine memory location, so it stays a raw
// `*u8` — the `Text`/`str` rule is for string-shaped data, not addresses.
fn lock_pages(at: *u8, len: usize) -> result::Result[i32, i32] {
    let rc: i32 = { mlock(at, len) };
    if rc == (0 as i32) {
        return result::Result[i32, i32]::Ok(0 as i32);
    }
    return result::Result[i32, i32]::Err(rc);
}

// Release a previously locked range. `unlock_pages(at: addr, len: 256)`.
fn unlock_pages(at: *u8, len: usize) -> result::Result[i32, i32] {
    let rc: i32 = { munlock(at, len) };
    if rc == (0 as i32) {
        return result::Result[i32, i32]::Ok(0 as i32);
    }
    return result::Result[i32, i32]::Err(rc);
}

// ---------------- Unit tests ----------------

#[test]
fn test_lock_unlock_stack_buffer() {
    // Locking a small stack buffer typically succeeds under the default
    // RLIMIT_MEMLOCK; if the sandbox denies it we still exercise the FFI
    // path and the unlock. Assert the round-trip returns without trapping.
    let buf: [u8; 256] = [0u8; 256];
    let r: result::Result[i32, i32] = lock_pages(at: { #addr_of(buf[0]) }, len: 256 as usize);
    match r {
        result::Result[i32, i32]::Ok(_) => {
            // Locked — must unlock cleanly.
            match unlock_pages(at: { #addr_of(buf[0]) }, len: 256 as usize) {
                result::Result[i32, i32]::Ok(_) => { assert true; }
                result::Result[i32, i32]::Err(_) => { assert false; }
            };
        }
        result::Result[i32, i32]::Err(_) => {
            // Denied by the sandbox/rlimit — acceptable; FFI path exercised.
            assert true;
        }
    };
}

#[test]
fn test_unlock_unlocked_range_recovers() {
    // Negative case: unlocking a range that was never locked must return
    // (Ok or Err) without trapping. Exercises the failure path's recovery.
    let buf: [u8; 64] = [0u8; 64];
    match unlock_pages(at: { #addr_of(buf[0]) }, len: 64 as usize) {
        result::Result[i32, i32]::Ok(_) => { assert true; }
        result::Result[i32, i32]::Err(_) => { assert true; }
    };
}

#[test]
fn test_lock_zero_len_recovers() {
    // Negative case: a zero-length range is a degenerate request; mlock may
    // accept or reject it, but the binding must return without trapping.
    let buf: [u8; 16] = [0u8; 16];
    match lock_pages(at: { #addr_of(buf[0]) }, len: 0 as usize) {
        result::Result[i32, i32]::Ok(_) => {
            let _u: result::Result[i32, i32] = unlock_pages(at: { #addr_of(buf[0]) }, len: 0 as usize);
            assert true;
        }
        result::Result[i32, i32]::Err(_) => { assert true; }
    };
}
