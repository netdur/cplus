// vendor/rt_darwin — Darwin (macOS) real-time platform controls.
//
// `realtime.md` Phase 7 keeps OS-specific real-time knobs in packages rather
// than core syntax. This package exposes the Darwin subset:
//
//   * clock  — monotonic, high-resolution timestamps (latency measurement)
//   * thread — scheduling priority via the Darwin QoS API
//   * mem    — page locking / prefaulting (`mlock`/`munlock`)
//
// All fallible operations return an explicit `Result`; none trap. A sibling
// `rt_linux` would mirror this surface with Linux constants/syscalls.
//
// This file is the package entry: it imports the submodules so the build/test
// graph (and `#[test]` discovery) includes them.

import "./clock" as clock;
import "./thread" as thread;
import "./mem" as mem;
