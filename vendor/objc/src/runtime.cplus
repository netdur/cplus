// alloc + init — the common +1-owned constructor.
fn alloc_init(class_name: *u8) -> *u8 {
    let cls: *u8 = get_class(class_name);
    let alloced: *u8 = msg_id(cls, sel(#str_ptr("alloc\0")));
    return msg_id(alloced, sel(#str_ptr("init\0")));
}

// Geometry msgSend shapes. Each `Rect`/`Point`/`Size` argument passes as an
// HFA in the float registers — indistinguishable at the call-site from that
// many separate f64 arguments under the arm64 ABI.
#[link_name = "objc_msgSend"]
extern fn objc_msg_rect(recv: *u8, sel: *u8) -> Rect;
#[link_name = "objc_msgSend"]
extern fn objc_msg_void_rect(recv: *u8, sel: *u8, a: Rect);
