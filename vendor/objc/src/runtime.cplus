// Minimal, framework-agnostic Objective-C runtime: the `objc_msgSend` shims and
// class / selector / lifetime helpers that every generated ObjC binding builds
// on. Framework wrappers (NaturalLanguage, AppKit, ...) depend on this rather
// than each re-declaring the runtime. The richer per-arity message zoo lives
// here; add shapes as new selectors need them.

extern fn objc_getClass(name: *u8) -> *u8;
extern fn sel_registerName(name: *u8) -> *u8;

// Objective-C block support. A block passed to a synchronous NS_NOESCAPE method
// is a `#[repr(C)]` struct { isa, flags, reserved, invoke, descriptor, captures }
// built on the stack; generated bindings emit the per-signature struct and an
// `invoke` trampoline, and use these shared helpers for the isa + descriptor.
#[link_name = "dlsym"]
extern fn dlsym(handle: *u8, symbol: *u8) -> *u8;

#[repr(C)]
struct BlockDescriptor {
    reserved: u64,
    size: u64,
}

// The isa for a stack block (`_NSConcreteStackBlock`), resolved at runtime via
// dlsym(RTLD_DEFAULT, ...) so no extern global is needed.
fn stack_block_isa() -> *u8 {
    let rtld_default: *u8 = { ((0 as usize) -% (2 as usize)) as *u8 };
    return { dlsym(rtld_default, #str_ptr("_NSConcreteStackBlock\0")) };
}

// ARC primitives (libobjc) — the same reference-counting calls ARC emits,
// invoked by hand for the +1/`drop` ownership model.
#[link_name = "objc_retain"]
extern fn objc_retain(obj: *u8) -> *u8;

#[link_name = "objc_release"]
extern fn objc_release(obj: *u8);

#[link_name = "objc_autorelease"]
extern fn objc_autorelease(obj: *u8) -> *u8;

// NSRange — Foundation's `{ location, length }` value type (NSUInteger is `u64`
// on 64-bit Apple). Crosses the ObjC boundary by value via `#[repr(C)]`.
#[repr(C)]
struct Range {
    location: u64,
    length: u64,
}

// objc_msgSend shapes, one per (return, args) ABI signature in use.
#[link_name = "objc_msgSend"]
extern fn objc_msg_id(recv: *u8, sel: *u8) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_id(recv: *u8, sel: *u8, a: *u8) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_void(recv: *u8, sel: *u8);

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_id(recv: *u8, sel: *u8, a: *u8);

#[link_name = "objc_msgSend"]
extern fn objc_msg_u64(recv: *u8, sel: *u8) -> u64;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_u64(recv: *u8, sel: *u8, a: u64) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_i8(recv: *u8, sel: *u8) -> i8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_i8(recv: *u8, sel: *u8, a: i8);

#[link_name = "objc_msgSend"]
extern fn objc_msg_i64(recv: *u8, sel: *u8) -> i64;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_i64(recv: *u8, sel: *u8, a: i64) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_id_u64(recv: *u8, sel: *u8, a: *u8, b: u64) -> *u8;

// Floating-point sends. `double` (CGFloat / NSTimeInterval on 64-bit Apple)
// rides the xmm registers; plain `objc_msgSend` handles fp returns on both
// arm64 and x86_64 (no `_fpret` needed there for `double`).
#[link_name = "objc_msgSend"]
extern fn objc_msg_f64(recv: *u8, sel: *u8) -> f64;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_f64(recv: *u8, sel: *u8, a: f64) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_f64(recv: *u8, sel: *u8, a: f64);

// 32-bit scalar sends. `int`/`unsigned int` ride the GPR low halves and `float`
// the fp register class; each width needs its own typed prototype — a 32-bit
// value cannot be routed through the 64-bit (`i64`/`u64`/`f64`) shims.
#[link_name = "objc_msgSend"]
extern fn objc_msg_i32(recv: *u8, sel: *u8) -> i32;

#[link_name = "objc_msgSend"]
extern fn objc_msg_u32(recv: *u8, sel: *u8) -> u32;

#[link_name = "objc_msgSend"]
extern fn objc_msg_f32(recv: *u8, sel: *u8) -> f32;

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_i32(recv: *u8, sel: *u8, a: i32);

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_u32(recv: *u8, sel: *u8, a: u32);

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_f32(recv: *u8, sel: *u8, a: f32);

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_i32(recv: *u8, sel: *u8, a: i32) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_u32(recv: *u8, sel: *u8, a: u32) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_f32(recv: *u8, sel: *u8, a: f32) -> *u8;

// NSRange-valued / NSRange-taking sends (e.g. `-tokenRangeAtIndex:`,
// `-tokensForRange:`, `-[NSValue rangeValue]`). NSRange is two integer
// eightbytes, so it rides registers in and out under the SysV ABI.
#[link_name = "objc_msgSend"]
extern fn objc_msg_range(recv: *u8, sel: *u8) -> Range;

#[link_name = "objc_msgSend"]
extern fn objc_msg_range_u64(recv: *u8, sel: *u8, a: u64) -> Range;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_range(recv: *u8, sel: *u8, a: Range) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_range_range(recv: *u8, sel: *u8, a: Range) -> Range;

// `(recv, sel, NSRange, id)` — e.g. `-enumerateTokensInRange:usingBlock:`, where
// the trailing `id` is a block pointer.
#[link_name = "objc_msgSend"]
extern fn objc_msg_void_range_id(recv: *u8, sel: *u8, a: Range, b: *u8);

fn get_class(name: *u8) -> *u8 {
    return { objc_getClass(name) };
}

fn sel(name: *u8) -> *u8 {
    return { sel_registerName(name) };
}

fn retain(obj: *u8) -> *u8 {
    return { objc_retain(obj) };
}

fn release(obj: *u8) {
    { objc_release(obj); };
}

fn autorelease(obj: *u8) -> *u8 {
    return { objc_autorelease(obj) };
}

fn msg_id(recv: *u8, selector: *u8) -> *u8 {
    return { objc_msg_id(recv, selector) };
}

fn msg_id_id(recv: *u8, selector: *u8, a: *u8) -> *u8 {
    return { objc_msg_id_id(recv, selector, a) };
}

fn msg_void(recv: *u8, selector: *u8) {
    { objc_msg_void(recv, selector); };
}

fn msg_void_id(recv: *u8, selector: *u8, a: *u8) {
    { objc_msg_void_id(recv, selector, a); };
}

fn msg_u64(recv: *u8, selector: *u8) -> u64 {
    return { objc_msg_u64(recv, selector) };
}

fn msg_id_u64(recv: *u8, selector: *u8, a: u64) -> *u8 {
    return { objc_msg_id_u64(recv, selector, a) };
}

fn msg_i8(recv: *u8, selector: *u8) -> i8 {
    return { objc_msg_i8(recv, selector) };
}

fn msg_void_i8(recv: *u8, selector: *u8, a: i8) {
    { objc_msg_void_i8(recv, selector, a); };
}

fn msg_i64(recv: *u8, selector: *u8) -> i64 {
    return { objc_msg_i64(recv, selector) };
}

fn msg_id_i64(recv: *u8, selector: *u8, a: i64) -> *u8 {
    return { objc_msg_id_i64(recv, selector, a) };
}

fn msg_id_id_u64(recv: *u8, selector: *u8, a: *u8, b: u64) -> *u8 {
    return { objc_msg_id_id_u64(recv, selector, a, b) };
}

fn msg_f64(recv: *u8, selector: *u8) -> f64 {
    return { objc_msg_f64(recv, selector) };
}

fn msg_id_f64(recv: *u8, selector: *u8, a: f64) -> *u8 {
    return { objc_msg_id_f64(recv, selector, a) };
}

fn msg_void_f64(recv: *u8, selector: *u8, a: f64) {
    { objc_msg_void_f64(recv, selector, a); };
}

fn msg_i32(recv: *u8, selector: *u8) -> i32 {
    return { objc_msg_i32(recv, selector) };
}

fn msg_u32(recv: *u8, selector: *u8) -> u32 {
    return { objc_msg_u32(recv, selector) };
}

fn msg_f32(recv: *u8, selector: *u8) -> f32 {
    return { objc_msg_f32(recv, selector) };
}

fn msg_void_i32(recv: *u8, selector: *u8, a: i32) {
    { objc_msg_void_i32(recv, selector, a); };
}

fn msg_void_u32(recv: *u8, selector: *u8, a: u32) {
    { objc_msg_void_u32(recv, selector, a); };
}

fn msg_void_f32(recv: *u8, selector: *u8, a: f32) {
    { objc_msg_void_f32(recv, selector, a); };
}

fn msg_id_i32(recv: *u8, selector: *u8, a: i32) -> *u8 {
    return { objc_msg_id_i32(recv, selector, a) };
}

fn msg_id_u32(recv: *u8, selector: *u8, a: u32) -> *u8 {
    return { objc_msg_id_u32(recv, selector, a) };
}

fn msg_id_f32(recv: *u8, selector: *u8, a: f32) -> *u8 {
    return { objc_msg_id_f32(recv, selector, a) };
}

fn msg_range(recv: *u8, selector: *u8) -> Range {
    return { objc_msg_range(recv, selector) };
}

fn msg_range_u64(recv: *u8, selector: *u8, a: u64) -> Range {
    return { objc_msg_range_u64(recv, selector, a) };
}

fn msg_id_range(recv: *u8, selector: *u8, a: Range) -> *u8 {
    return { objc_msg_id_range(recv, selector, a) };
}

fn msg_range_range(recv: *u8, selector: *u8, a: Range) -> Range {
    return { objc_msg_range_range(recv, selector, a) };
}

fn msg_void_range_id(recv: *u8, selector: *u8, a: Range, b: *u8) {
    { objc_msg_void_range_id(recv, selector, a, b); };
}

// alloc + init — the common +1-owned constructor.
fn alloc_init(class_name: *u8) -> *u8 {
    let cls: *u8 = get_class(class_name);
    let alloced: *u8 = msg_id(cls, sel(#str_ptr("alloc\0")));
    return msg_id(alloced, sel(#str_ptr("init\0")));
}
