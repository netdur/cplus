// Minimal, framework-agnostic Objective-C runtime: the `objc_msgSend` shims and
// class / selector / lifetime helpers that every generated ObjC binding builds
// on. Framework wrappers (NaturalLanguage, AppKit, ...) depend on this rather
// than each re-declaring the runtime. The richer per-arity message zoo lives
// here; add shapes as new selectors need them.

extern fn objc_getClass(name: *u8) -> *u8;
extern fn sel_registerName(name: *u8) -> *u8;

// Objective-C block support. A block passed to a synchronous NS_NOESCAPE method
// is a `#[repr(C)]` struct { isa, flags, reserved, invoke, descriptor, captures }
// built on the stack; generated bindings emit the per-signature struct and an
// `invoke` trampoline, and use these shared helpers for the isa + descriptor.
#[link_name = "dlsym"]
extern fn dlsym(handle: *u8, symbol: *u8) -> *u8;

#[repr(C)]
struct BlockDescriptor {
    reserved: u64,
    size: u64,
}

// The isa for a stack block (`_NSConcreteStackBlock`), resolved at runtime via
// dlsym(RTLD_DEFAULT, ...) so no extern global is needed.
fn stack_block_isa() -> *u8 {
    let rtld_default: *u8 = { ((0 as usize) -% (2 as usize)) as *u8 };
    return { dlsym(rtld_default, #str_ptr("_NSConcreteStackBlock\0")) };
}

// ARC primitives (libobjc) — the same reference-counting calls ARC emits,
// invoked by hand for the +1/`drop` ownership model.
#[link_name = "objc_retain"]
extern fn objc_retain(obj: *u8) -> *u8;

#[link_name = "objc_release"]
extern fn objc_release(obj: *u8);

#[link_name = "objc_autorelease"]
extern fn objc_autorelease(obj: *u8) -> *u8;

// NSRange — Foundation's `{ location, length }` value type (NSUInteger is `u64`
// on 64-bit Apple). Crosses the ObjC boundary by value via `#[repr(C)]`.
#[repr(C)]
struct Range {
    location: u64,
    length: u64,
}

// Core Graphics geometry types. On arm64 each is an HFA (homogeneous float
// aggregate): Rect passes in v0-v3, Point and Size in v0-v1. Passing these
// structs by value is ABI-compatible with NSRect/NSPoint/NSSize — no pointer
// indirection, no padding. x86_64 macOS is out of support (macOS 26 Tahoe
// is arm64-only), so no sret/memory-class handling is needed.
#[repr(C)]
struct Rect {
    x: f64,
    y: f64,
    w: f64,
    h: f64,
}

#[repr(C)]
struct Point {
    x: f64,
    y: f64,
}

#[repr(C)]
struct Size {
    w: f64,
    h: f64,
}

// objc_msgSend shapes, one per (return, args) ABI signature in use.
#[link_name = "objc_msgSend"]
extern fn objc_msg_id(recv: *u8, sel: *u8) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_id(recv: *u8, sel: *u8, a: *u8) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_void(recv: *u8, sel: *u8);

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_id(recv: *u8, sel: *u8, a: *u8);

#[link_name = "objc_msgSend"]
