#[link_name = "objc_msgSend"]
extern fn objc_msg_void_rect_i8(recv: *u8, sel: *u8, a: Rect, b: i8);
#[link_name = "objc_msgSend"]
extern fn objc_msg_void_rect_i8_i8(recv: *u8, sel: *u8, a: Rect, b: i8, c: i8);
#[link_name = "objc_msgSend"]
extern fn objc_msg_id_rect_u64_i64_i8(recv: *u8, sel: *u8, a: Rect, b: u64, c: i64, d: i8) -> *u8;
#[link_name = "objc_msgSend"]
extern fn objc_msg_f64_rect(recv: *u8, sel: *u8, a: Rect) -> f64;
#[link_name = "objc_msgSend"]
extern fn objc_msg_size(recv: *u8, sel: *u8) -> Size;
#[link_name = "objc_msgSend"]
