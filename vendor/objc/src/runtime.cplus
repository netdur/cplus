#[link_name = "objc_msgSend"]
extern fn objc_msg_id_u64(recv: *u8, sel: *u8, a: u64) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_i8(recv: *u8, sel: *u8) -> i8;
#[link_name = "objc_msgSend"]
extern fn objc_msg_i8_id(recv: *u8, sel: *u8, a: *u8) -> i8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_i8(recv: *u8, sel: *u8, a: i8);

#[link_name = "objc_msgSend"]
extern fn objc_msg_i64(recv: *u8, sel: *u8) -> i64;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_i64(recv: *u8, sel: *u8, a: i64) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_i64(recv: *u8, sel: *u8, a: i64);

#[link_name = "objc_msgSend"]
extern fn objc_msg_i8_i64(recv: *u8, sel: *u8, a: i64) -> i8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_id_u64(recv: *u8, sel: *u8, a: *u8, b: u64) -> *u8;

// Floating-point sends. `double` (CGFloat / NSTimeInterval on 64-bit Apple)
// rides the xmm registers; plain `objc_msgSend` handles fp returns on both
// arm64 and x86_64 (no `_fpret` needed there for `double`).
#[link_name = "objc_msgSend"]
extern fn objc_msg_f64(recv: *u8, sel: *u8) -> f64;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_f64(recv: *u8, sel: *u8, a: f64) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_f64(recv: *u8, sel: *u8, a: f64);

// 32-bit scalar sends. `int`/`unsigned int` ride the GPR low halves and `float`
// the fp register class; each width needs its own typed prototype — a 32-bit
// value cannot be routed through the 64-bit (`i64`/`u64`/`f64`) shims.
#[link_name = "objc_msgSend"]
extern fn objc_msg_i32(recv: *u8, sel: *u8) -> i32;

#[link_name = "objc_msgSend"]
extern fn objc_msg_u32(recv: *u8, sel: *u8) -> u32;

#[link_name = "objc_msgSend"]
extern fn objc_msg_f32(recv: *u8, sel: *u8) -> f32;

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_i32(recv: *u8, sel: *u8, a: i32);

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_u32(recv: *u8, sel: *u8, a: u32);

#[link_name = "objc_msgSend"]
extern fn objc_msg_void_f32(recv: *u8, sel: *u8, a: f32);

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_i32(recv: *u8, sel: *u8, a: i32) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_u32(recv: *u8, sel: *u8, a: u32) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_f32(recv: *u8, sel: *u8, a: f32) -> *u8;

// NSRange-valued / NSRange-taking sends (e.g. `-tokenRangeAtIndex:`,
// `-tokensForRange:`, `-[NSValue rangeValue]`). NSRange is two integer
// eightbytes, so it rides registers in and out under the SysV ABI.
#[link_name = "objc_msgSend"]
extern fn objc_msg_range(recv: *u8, sel: *u8) -> Range;

#[link_name = "objc_msgSend"]
extern fn objc_msg_range_u64(recv: *u8, sel: *u8, a: u64) -> Range;

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_range(recv: *u8, sel: *u8, a: Range) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_range_range(recv: *u8, sel: *u8, a: Range) -> Range;

// `(recv, sel, NSRange, id)` — e.g. `-enumerateTokensInRange:usingBlock:`, where
// the trailing `id` is a block pointer.
#[link_name = "objc_msgSend"]
extern fn objc_msg_void_range_id(recv: *u8, sel: *u8, a: Range, b: *u8);

// Additional (return, arg) shapes covering the Metal setter / encoder / resource
// surface. Every element is an integer eightbyte (`id`/`i64`/`u64`/`i8`), an
// `NSRange` (two eightbytes), or an `f32` (fp register class) — same ABI classes
// as the shims above, so each combination lowers correctly by construction.
