extern fn object_getClassName(obj: *u8) -> *u8;

fn get_class(name: *u8) -> *u8 {
    return { objc_getClass(name) };
}

fn class_name(obj: *u8) -> *u8 {
    return { object_getClassName(obj) };
}

fn sel(name: *u8) -> *u8 {
    return { sel_registerName(name) };
}

fn retain(obj: *u8) -> *u8 {
    return { objc_retain(obj) };
}

fn release(obj: *u8) {
    { objc_release(obj); };
}

fn autorelease(obj: *u8) -> *u8 {
    return { objc_autorelease(obj) };
}

fn msg_id(recv: *u8, selector: *u8) -> *u8 {
    return { objc_msg_id(recv, selector) };
}

