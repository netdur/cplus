extern fn objc_getAssociatedObject(obj: *u8, key: *u8) -> *u8;

fn set_associated_object(obj: *u8, key: *u8, value: *u8, policy: usize) {
    { objc_setAssociatedObject(obj, key, value, policy); };
}
fn get_associated_object(obj: *u8, key: *u8) -> *u8 {
    return { objc_getAssociatedObject(obj, key) };
}
