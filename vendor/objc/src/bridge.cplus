// C+ <-> Objective-C string bridge. Richer C+ types (`Text`, `str`) have no
// direct ObjC counterpart, so they need explicit conversions; this is the
// shared one every generated binding reaches for. `str`/`Text` in, `Text` (or
// `Option[Text]` for nilable returns) out — the NSString stays hidden.

import "./runtime" as rt;
import "stdlib/text" as text;
import "stdlib/option" as option;
import "stdlib/vec" as vec;

// NSUTF8StringEncoding = 4. C+ has no top-level const; a fn folds the same.
fn ns_utf8() -> u64 { return 4 as u64; }

#[link_name = "objc_msgSend"]
extern fn objc_msg_id_ptr_len_enc(recv: *u8, sel: *u8, ptr: *u8, len: usize, enc: u64) -> *u8;

#[link_name = "objc_msgSend"]
extern fn objc_msg_u64_u64(recv: *u8, sel: *u8, arg: u64) -> u64;

// `str` -> NSString via `+[NSString stringWithBytes:length:encoding:]`, which
// copies the buffer internally, so the caller's borrow can drop freely after.
fn nsstring(s: str) -> *u8 {
    let cls: *u8 = rt::get_class(#str_ptr("NSString\0"));
    let selector: *u8 = rt::sel(#str_ptr("stringWithBytes:length:encoding:\0"));
    return { objc_msg_id_ptr_len_enc(cls, selector, #str_ptr(s), #str_len(s), ns_utf8()) };
}

// NSString -> owned `Text` (copies out of the autoreleased UTF8 buffer, so it
// is safe to outlive the source NSString and its pool).
fn to_text(ns: *u8) -> text::Text {
    let utf8_ptr: *u8 = rt::msg_id(ns, rt::sel(#str_ptr("UTF8String\0")));
    let len_sel: *u8 = rt::sel(#str_ptr("lengthOfBytesUsingEncoding:\0"));
    let len: u64 = { objc_msg_u64_u64(ns, len_sel, ns_utf8()) };
    let view: str = { #str_from_raw_parts(utf8_ptr, len as usize) };
    return view.to_text();
}

// Nilable NSString -> `Option[Text]`: a nil NSString (AppKit/Foundation's "no
// value" signal) maps to `None`, a real one to `Some(owned Text)`.
fn to_text_option(ns: *u8) -> option::Option[text::Text] {
    if ns == { 0 as *u8 } {
        return option::Option[text::Text]::None;
    }
    return option::some(to_text(ns));
}

// `Vec[Text]` -> `NSArray<NSString *> *` (the collection-param direction; the
// reverse of `to_text` over an array). Builds an autoreleased NSMutableArray and
// fills it with NSStrings; each `stringWithBytes:` copies, so the caller's `Vec`
// (and its `Text`s) may drop freely afterward. Elements are read in place via
// `at_ptr` since `Text` is not `Copy`.
fn nsarray_of_text(items: vec::Vec[text::Text]) -> *u8 {
    let cls: *u8 = rt::get_class(#str_ptr("NSMutableArray\0"));
    let arr: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("array\0")));
    let add: *u8 = rt::sel(#str_ptr("addObject:\0"));
    let n: usize = items.count();
    var i: usize = 0 as usize;
    while i < n {
        match items.at_ptr(i) {
            option::Option[*text::Text]::Some(tp) => {
                match (*tp).c_str() {
                    option::Option[text::CString]::Some(cs) => {
                        let view: str = { #str_from_raw_parts(cs.as_ptr(), cs.count()) };
                        rt::msg_void_id(arr, add, nsstring(view));
                    }
                    option::Option[text::CString]::None => {}
                }
            }
            option::Option[*text::Text]::None => {}
        }
        i = i +% (1 as usize);
    }
    return arr;
}

// Nilable object handle -> `Option[*u8]`: `nil` -> `None`, else `Some(handle)`.
// The path for nullable Objective-C object returns (a `nil` is absence, not a
// sentinel).
fn obj_option(p: *u8) -> option::Option[*u8] {
    if p == { 0 as *u8 } {
        return option::Option[*u8]::None;
    }
    return option::some(p);
}
