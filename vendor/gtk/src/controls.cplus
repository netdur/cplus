// ---- Switch ----

#[link_name = "gtk_switch_new"]
extern fn gtk_switch_new() -> *u8;

#[link_name = "gtk_switch_set_active"]
extern fn gtk_switch_set_active(sw: *u8, active: i32);

#[link_name = "gtk_switch_get_active"]
extern fn gtk_switch_get_active(sw: *u8) -> i32;

struct Switch {
    opaque obj: *u8,
}

impl Switch {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> Switch { return Switch { obj: obj }; }

    fn new() -> Switch {
        return Switch { obj: { gtk_switch_new() } };
    }

    fn set_active(this, active: i32) {
        { gtk_switch_set_active(this.obj, active); };
    }

    fn is_active(this) -> i32 {
        return { gtk_switch_get_active(this.obj) };
    }

    // The "state-set" signal: `fn(sw, state: i32, user_data) -> i32`. Return 1
    // to suppress GTK's default state update (you own the state), 0 to accept it.
    fn connect_state_set(this, handler: fn(*u8, i32, *u8) -> i32) {
        let _id: u64 = g::signal_connect_state(this.obj, #str_ptr("state-set\0"), handler, 0 as *u8);
    }
}

// ---- Scale (slider) ----
//
// A `GtkScale` is a `GtkRange`, so value access is via `gtk_range_*` and the
// change signal is "value-changed".

#[link_name = "gtk_scale_new_with_range"]
extern fn gtk_scale_new_with_range(orientation: i32, min: f64, max: f64, step: f64) -> *u8;

#[link_name = "gtk_range_get_value"]
extern fn gtk_range_get_value(range: *u8) -> f64;

#[link_name = "gtk_range_set_value"]
extern fn gtk_range_set_value(range: *u8, value: f64);

#[link_name = "gtk_scale_set_draw_value"]
extern fn gtk_scale_set_draw_value(scale: *u8, draw_value: i32);

struct Scale {
    opaque obj: *u8,
}

impl Scale {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> Scale { return Scale { obj: obj }; }

    // `orientation` is a `glib::orientation_*` value.
    fn new(orientation: i32, min: f64, max: f64, step: f64) -> Scale {
        return Scale { obj: { gtk_scale_new_with_range(orientation, min, max, step) } };
    }

    fn value(this) -> f64 {
        return { gtk_range_get_value(this.obj) };
    }

    fn set_value(this, value: f64) {
        { gtk_range_set_value(this.obj, value); };
    }

    // Whether the current value is drawn next to the slider.
    fn set_draw_value(this, draw_value: i32) {
        { gtk_scale_set_draw_value(this.obj, draw_value); };
    }

    fn connect_value_changed(this, handler: fn(*u8, *u8)) {
        let _id: u64 = g::signal_connect(this.obj, #str_ptr("value-changed\0"), handler, 0 as *u8);
    }
}

