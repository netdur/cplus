import "./glib" as g;

// Interactive controls — the GTK analog of appkit's `controls`: Button, Label,
// Entry, CheckButton, Switch, Scale (slider), SpinButton, ProgressBar,
// ToggleButton, DropDown. Each wraps a widget pointer (`opaque`, floating-ref
// model — a parent container sinks the ref on append), exposes `raw()` for
// packing into containers, and connects its primary signal through `glib`.

// ---- Button ----

#[link_name = "gtk_button_new_with_label"]
extern fn gtk_button_new_with_label(label: *u8) -> *u8;

#[link_name = "gtk_button_new_from_icon_name"]
extern fn gtk_button_new_from_icon_name(icon_name: *u8) -> *u8;

#[link_name = "gtk_button_set_label"]
extern fn gtk_button_set_label(button: *u8, label: *u8);

#[link_name = "gtk_button_get_label"]
extern fn gtk_button_get_label(button: *u8) -> *u8;

struct Button {
    opaque obj: *u8,
}

impl Button {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> Button { return Button { obj: obj }; }

    fn new(label: *u8) -> Button {
        return Button { obj: { gtk_button_new_with_label(label) } };
    }

    fn from_icon_name(icon_name: *u8) -> Button {
        return Button { obj: { gtk_button_new_from_icon_name(icon_name) } };
    }

    fn set_label(this, label: *u8) {
        { gtk_button_set_label(this.obj, label); };
    }

    fn label(this) -> *u8 {
        return { gtk_button_get_label(this.obj) };
    }

    // The "clicked" signal: `fn(button: *u8, user_data: *u8)`.
    fn connect_clicked(this, handler: fn(*u8, *u8)) {
        let _id: u64 = g::signal_connect(this.obj, #str_ptr("clicked\0"), handler, 0 as *u8);
    }
}

// ---- Label ----

#[link_name = "gtk_label_new"]
extern fn gtk_label_new(text: *u8) -> *u8;

#[link_name = "gtk_label_set_text"]
extern fn gtk_label_set_text(label: *u8, text: *u8);

#[link_name = "gtk_label_get_text"]
extern fn gtk_label_get_text(label: *u8) -> *u8;

#[link_name = "gtk_label_set_markup"]
extern fn gtk_label_set_markup(label: *u8, markup: *u8);

#[link_name = "gtk_label_set_xalign"]
extern fn gtk_label_set_xalign(label: *u8, xalign: f32);

#[link_name = "gtk_label_set_wrap"]
extern fn gtk_label_set_wrap(label: *u8, wrap: i32);

#[link_name = "gtk_label_set_selectable"]
extern fn gtk_label_set_selectable(label: *u8, selectable: i32);

struct Label {
    opaque obj: *u8,
}

impl Label {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> Label { return Label { obj: obj }; }

    fn new(text: *u8) -> Label {
        return Label { obj: { gtk_label_new(text) } };
    }

    fn set_text(this, text: *u8) {
        { gtk_label_set_text(this.obj, text); };
    }

    fn text(this) -> *u8 {
        return { gtk_label_get_text(this.obj) };
    }

    // Set Pango-markup text (`<b>`, `<i>`, `<span>`…).
    fn set_markup(this, markup: *u8) {
        { gtk_label_set_markup(this.obj, markup); };
    }

    // Horizontal alignment of the text within the label, 0.0 (left) … 1.0 (right).
    fn set_xalign(this, xalign: f32) {
        { gtk_label_set_xalign(this.obj, xalign); };
    }

    fn set_wrap(this, wrap: i32) {
        { gtk_label_set_wrap(this.obj, wrap); };
    }

    fn set_selectable(this, selectable: i32) {
        { gtk_label_set_selectable(this.obj, selectable); };
    }
}

// ---- Entry (single-line text input) ----
//
// `GtkEntry` implements `GtkEditable`, so its text getter/setter are the
// `gtk_editable_*` calls and its text-change signal is "changed".

#[link_name = "gtk_entry_new"]
extern fn gtk_entry_new() -> *u8;

#[link_name = "gtk_editable_set_text"]
extern fn gtk_editable_set_text(editable: *u8, text: *u8);

#[link_name = "gtk_editable_get_text"]
extern fn gtk_editable_get_text(editable: *u8) -> *u8;

#[link_name = "gtk_entry_set_placeholder_text"]
extern fn gtk_entry_set_placeholder_text(entry: *u8, text: *u8);

#[link_name = "gtk_entry_set_visibility"]
extern fn gtk_entry_set_visibility(entry: *u8, visible: i32);

#[link_name = "gtk_editable_set_editable"]
extern fn gtk_editable_set_editable(editable: *u8, editable: i32);

struct Entry {
    opaque obj: *u8,
}

impl Entry {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> Entry { return Entry { obj: obj }; }

    fn new() -> Entry {
        return Entry { obj: { gtk_entry_new() } };
    }

    fn set_text(this, text: *u8) {
        { gtk_editable_set_text(this.obj, text); };
    }

    // Borrow the current text as a `const char*` (owned by GTK — copy it before
    // the entry changes; do not free).
    fn text(this) -> *u8 {
        return { gtk_editable_get_text(this.obj) };
    }

    fn set_placeholder_text(this, text: *u8) {
        { gtk_entry_set_placeholder_text(this.obj, text); };
    }

    // Set 0 to mask input (a basic password field); 1 shows characters.
    fn set_visibility(this, visible: i32) {
        { gtk_entry_set_visibility(this.obj, visible); };
    }

    fn set_editable(this, editable: i32) {
        { gtk_editable_set_editable(this.obj, editable); };
    }

    // The "changed" signal: fired on every edit. `fn(entry: *u8, user_data: *u8)`.
    fn connect_changed(this, handler: fn(*u8, *u8)) {
        let _id: u64 = g::signal_connect(this.obj, #str_ptr("changed\0"), handler, 0 as *u8);
    }

    // The "activate" signal: fired when the user presses Enter.
    fn connect_activate(this, handler: fn(*u8, *u8)) {
        let _id: u64 = g::signal_connect(this.obj, #str_ptr("activate\0"), handler, 0 as *u8);
    }
}

