#[link_name = "gtk_spin_button_new_with_range"]
extern fn gtk_spin_button_new_with_range(min: f64, max: f64, step: f64) -> *u8;

#[link_name = "gtk_spin_button_get_value"]
extern fn gtk_spin_button_get_value(spin: *u8) -> f64;

#[link_name = "gtk_spin_button_set_value"]
