#[link_name = "gtk_spin_button_set_digits"]
extern fn gtk_spin_button_set_digits(spin: *u8, digits: u32);

struct SpinButton {
    opaque obj: *u8,
}

impl SpinButton {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> SpinButton { return SpinButton { obj: obj }; }

    fn new(min: f64, max: f64, step: f64) -> SpinButton {
        return SpinButton { obj: { gtk_spin_button_new_with_range(min, max, step) } };
    }

    fn value(this) -> f64 {
        return { gtk_spin_button_get_value(this.obj) };
    }

    fn set_value(this, value: f64) {
        { gtk_spin_button_set_value(this.obj, value); };
    }

    // Number of decimal places shown.
    fn set_digits(this, digits: u32) {
        { gtk_spin_button_set_digits(this.obj, digits); };
    }

    fn connect_value_changed(this, handler: fn(*u8, *u8)) {
        let _id: u64 = g::signal_connect(this.obj, #str_ptr("value-changed\0"), handler, 0 as *u8);
    }
}

// ---- ProgressBar ----

#[link_name = "gtk_progress_bar_new"]
extern fn gtk_progress_bar_new() -> *u8;

#[link_name = "gtk_progress_bar_set_fraction"]
extern fn gtk_progress_bar_set_fraction(bar: *u8, fraction: f64);

#[link_name = "gtk_progress_bar_get_fraction"]
extern fn gtk_progress_bar_get_fraction(bar: *u8) -> f64;

#[link_name = "gtk_progress_bar_pulse"]
extern fn gtk_progress_bar_pulse(bar: *u8);

#[link_name = "gtk_progress_bar_set_text"]
extern fn gtk_progress_bar_set_text(bar: *u8, text: *u8);

#[link_name = "gtk_progress_bar_set_show_text"]
extern fn gtk_progress_bar_set_show_text(bar: *u8, show_text: i32);

struct ProgressBar {
    opaque obj: *u8,
}

impl ProgressBar {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> ProgressBar { return ProgressBar { obj: obj }; }

    fn new() -> ProgressBar {
        return ProgressBar { obj: { gtk_progress_bar_new() } };
    }

    // Fill fraction, 0.0 … 1.0.
    fn set_fraction(this, fraction: f64) {
        { gtk_progress_bar_set_fraction(this.obj, fraction); };
    }

    fn fraction(this) -> f64 {
        return { gtk_progress_bar_get_fraction(this.obj) };
    }

    // Bump the "activity" block for indeterminate progress.
    fn pulse(this) {
        { gtk_progress_bar_pulse(this.obj); };
    }

    fn set_text(this, text: *u8) {
        { gtk_progress_bar_set_text(this.obj, text); };
    }

    fn set_show_text(this, show_text: i32) {
        { gtk_progress_bar_set_show_text(this.obj, show_text); };
    }
}

