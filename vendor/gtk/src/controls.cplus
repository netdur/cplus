#[link_name = "gtk_toggle_button_new_with_label"]
extern fn gtk_toggle_button_new_with_label(label: *u8) -> *u8;

#[link_name = "gtk_toggle_button_set_active"]
extern fn gtk_toggle_button_set_active(button: *u8, active: i32);

#[link_name = "gtk_toggle_button_get_active"]
extern fn gtk_toggle_button_get_active(button: *u8) -> i32;

struct ToggleButton {
    opaque obj: *u8,
}

impl ToggleButton {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> ToggleButton { return ToggleButton { obj: obj }; }

    fn new(label: *u8) -> ToggleButton {
        return ToggleButton { obj: { gtk_toggle_button_new_with_label(label) } };
    }

    fn set_active(this, active: i32) {
        { gtk_toggle_button_set_active(this.obj, active); };
    }

    fn is_active(this) -> i32 {
        return { gtk_toggle_button_get_active(this.obj) };
    }

    fn connect_toggled(this, handler: fn(*u8, *u8)) {
        let _id: u64 = g::signal_connect(this.obj, #str_ptr("toggled\0"), handler, 0 as *u8);
    }
}

// ---- DropDown ----

// `strings` is a `const char * const *` — a pointer to a NULL-terminated array
// of C string pointers. Build it as a local `[N+1 x *u8]` ending in `0 as *u8`
// and pass its address.
#[link_name = "gtk_drop_down_new_from_strings"]
extern fn gtk_drop_down_new_from_strings(strings: *u8) -> *u8;

#[link_name = "gtk_drop_down_get_selected"]
extern fn gtk_drop_down_get_selected(dropdown: *u8) -> u32;

#[link_name = "gtk_drop_down_set_selected"]
extern fn gtk_drop_down_set_selected(dropdown: *u8, position: u32);

struct DropDown {
    opaque obj: *u8,
}

impl DropDown {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> DropDown { return DropDown { obj: obj }; }

    fn from_strings(strings: *u8) -> DropDown {
        return DropDown { obj: { gtk_drop_down_new_from_strings(strings) } };
    }

    // Index of the selected item (GTK_INVALID_LIST_POSITION = 0xffffffff if none).
    fn selected(this) -> u32 {
        return { gtk_drop_down_get_selected(this.obj) };
    }

    fn set_selected(this, position: u32) {
        { gtk_drop_down_set_selected(this.obj, position); };
    }

    // Selection changes fire "notify::selected".
    fn connect_selected_changed(this, handler: fn(*u8, *u8)) {
        let _id: u64 = g::signal_connect(this.obj, #str_ptr("notify::selected\0"), handler, 0 as *u8);
    }
}
