import "./glib" as g;

// Dialogs — the GTK analog of appkit's `dialogs`/`panels`: AlertDialog (a
// message box) and FileDialog (open/save chooser). Both are the modern GTK
// 4.10+ objects (the deprecated `GtkMessageDialog`/`GtkFileChooserDialog` are
// avoided). They are owned by the caller until shown — hold the wrapper across
// the `show`/`open` call and `unref()` once done.

// ---- AlertDialog ----

// `gtk_alert_dialog_new` is variadic (printf-style message). Pass a plain
// message with no `%` specifiers, or pre-format it yourself.
#[link_name = "gtk_alert_dialog_new"]
extern fn gtk_alert_dialog_new(format: *u8, ...) -> *u8;

#[link_name = "gtk_alert_dialog_set_detail"]
extern fn gtk_alert_dialog_set_detail(dialog: *u8, detail: *u8);

#[link_name = "gtk_alert_dialog_set_modal"]
extern fn gtk_alert_dialog_set_modal(dialog: *u8, modal: i32);

#[link_name = "gtk_alert_dialog_set_buttons"]
extern fn gtk_alert_dialog_set_buttons(dialog: *u8, labels: *u8);

#[link_name = "gtk_alert_dialog_show"]
extern fn gtk_alert_dialog_show(dialog: *u8, parent: *u8);

struct AlertDialog {
    opaque obj: *u8,
}

impl AlertDialog {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> AlertDialog { return AlertDialog { obj: obj }; }

    fn new(message: *u8) -> AlertDialog {
        return AlertDialog { obj: { gtk_alert_dialog_new(message) } };
    }

    // Secondary explanatory text under the message.
    fn set_detail(this, detail: *u8) {
        { gtk_alert_dialog_set_detail(this.obj, detail); };
    }

    fn set_modal(this, modal: i32) {
        { gtk_alert_dialog_set_modal(this.obj, modal); };
    }

    // Button labels as a NULL-terminated `const char * const *` array. To read
    // back which was pressed, use the async `gtk_alert_dialog_choose` path
    // (left to the app); `show` just displays the alert.
    fn set_buttons(this, labels: *u8) {
        { gtk_alert_dialog_set_buttons(this.obj, labels); };
    }

    // Display the alert over `parent` (a window `raw()`, or `0 as *u8`).
    fn show(this, parent: *u8) {
        { gtk_alert_dialog_show(this.obj, parent); };
    }

    fn unref(this) {
        g::unref(this.obj);
    }
}

// ---- FileDialog ----

#[link_name = "gtk_file_dialog_new"]
extern fn gtk_file_dialog_new() -> *u8;

#[link_name = "gtk_file_dialog_set_title"]
extern fn gtk_file_dialog_set_title(dialog: *u8, title: *u8);

#[link_name = "gtk_file_dialog_set_modal"]
extern fn gtk_file_dialog_set_modal(dialog: *u8, modal: i32);

// Async: `callback` is a `GAsyncReadyCallback`
// `fn(source: *u8, result: *u8, user_data: *u8)`; inside it call
// `open_finish(result)` to get the chosen `GFile*`.
#[link_name = "gtk_file_dialog_open"]
extern fn gtk_file_dialog_open(dialog: *u8, parent: *u8, cancellable: *u8, callback: fn(*u8, *u8, *u8), data: *u8);

#[link_name = "gtk_file_dialog_save"]
extern fn gtk_file_dialog_save(dialog: *u8, parent: *u8, cancellable: *u8, callback: fn(*u8, *u8, *u8), data: *u8);

#[link_name = "gtk_file_dialog_open_finish"]
extern fn gtk_file_dialog_open_finish(dialog: *u8, result: *u8, error: *u8) -> *u8;

#[link_name = "gtk_file_dialog_save_finish"]
extern fn gtk_file_dialog_save_finish(dialog: *u8, result: *u8, error: *u8) -> *u8;

// `g_file_get_path` returns a newly-allocated filesystem path (`gchar*`) —
// free it with `glib::free` when done.
#[link_name = "g_file_get_path"]
extern fn g_file_get_path(file: *u8) -> *u8;

struct FileDialog {
    opaque obj: *u8,
}

impl FileDialog {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> FileDialog { return FileDialog { obj: obj }; }

    fn new() -> FileDialog {
        return FileDialog { obj: { gtk_file_dialog_new() } };
    }

    fn set_title(this, title: *u8) {
        { gtk_file_dialog_set_title(this.obj, title); };
    }

    fn set_modal(this, modal: i32) {
        { gtk_file_dialog_set_modal(this.obj, modal); };
    }

    // Present an open-file chooser. `parent` is a window `raw()` (or null);
    // pass `0 as *u8` for `cancellable`. The result arrives in `callback`.
    fn open(this, parent: *u8, callback: fn(*u8, *u8, *u8), data: *u8) {
        { gtk_file_dialog_open(this.obj, parent, 0 as *u8, callback, data); };
    }

    fn save(this, parent: *u8, callback: fn(*u8, *u8, *u8), data: *u8) {
        { gtk_file_dialog_save(this.obj, parent, 0 as *u8, callback, data); };
    }

    // Call from the open callback with its `result`. Returns the chosen
    // `GFile*` (or null on cancel/error). Pass `0 as *u8` for `error` to ignore
    // it. Resolve a path with `FileDialog::file_path`.
    fn open_finish(this, result: *u8, error: *u8) -> *u8 {
        return { gtk_file_dialog_open_finish(this.obj, result, error) };
    }

    fn save_finish(this, result: *u8, error: *u8) -> *u8 {
        return { gtk_file_dialog_save_finish(this.obj, result, error) };
    }

    // The filesystem path of a `GFile*` (newly-allocated; free with `glib::free`).
    fn file_path(file: *u8) -> *u8 {
        return { g_file_get_path(file) };
    }

    fn unref(this) {
        g::unref(this.obj);
    }
}
