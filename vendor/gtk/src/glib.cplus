// GObject / GLib runtime primitives shared by the GTK bindings — the GTK
// analog of appkit's `runtime` module. GTK is a C library built on GObject,
// so there is no `objc_msgSend` dispatch: every function is a direct C symbol
// (`gtk_*` / `g_*`) bound as an `extern fn` and called inside an FFI block.
//
// This module owns the cross-cutting pieces: reference counting
// (`g_object_ref` / `g_object_unref`), the `g_signal_connect` family (typed by
// callback shape, the way appkit types its `class_addMethod_*` IMPs), the main
// loop / idle / timeout helpers, and the small set of GLib/GTK enum constants
// (orientation, alignment, …) the widget modules reach for.

// ---- GObject reference counting ----

#[link_name = "g_object_ref"]
extern fn g_object_ref(obj: *u8) -> *u8;

#[link_name = "g_object_unref"]
extern fn g_object_unref(obj: *u8);

// `g_object_ref_sink` sinks a floating reference: the first call converts the
// widget's initial floating ref into a normal owned ref; later calls behave
// like `g_object_ref`. Containers do this for you on append — you rarely call
// it by hand.
#[link_name = "g_object_ref_sink"]
extern fn g_object_ref_sink(obj: *u8) -> *u8;

// Stash/fetch an arbitrary pointer on a GObject under a string key — the
// GObject analog of appkit's associated objects. Use it to thread app state
// to a signal handler (callbacks are closure-free; reach state through this,
// a `static mut`, or a global).
#[link_name = "g_object_set_data"]
extern fn g_object_set_data(obj: *u8, key: *u8, data: *u8);

#[link_name = "g_object_get_data"]
extern fn g_object_get_data(obj: *u8, key: *u8) -> *u8;

// `g_free` releases memory returned to us by GLib (e.g. a `gchar*` from a
// `*_dup`/`*_to_string` getter).
#[link_name = "g_free"]
extern fn g_free(mem: *u8);

fn ref_obj(obj: *u8) -> *u8 {
    return { g_object_ref(obj) };
}

fn unref(obj: *u8) {
    { g_object_unref(obj); };
}

fn ref_sink(obj: *u8) -> *u8 {
    return { g_object_ref_sink(obj) };
}

fn set_data(obj: *u8, key: *u8, data: *u8) {
    { g_object_set_data(obj, key, data); };
}

fn get_data(obj: *u8, key: *u8) -> *u8 {
    return { g_object_get_data(obj, key) };
}

fn free(mem: *u8) {
    { g_free(mem); };
}

// ---- signals (g_signal_connect family) ----
//
// `g_signal_connect(obj, "name", cb, data)` is a C macro for
// `g_signal_connect_data(obj, name, cb, data, NULL, 0)`. We bind the
// underlying function once per callback shape — the GObject equivalent of
// appkit declaring a typed `objc_msgSend`/`class_addMethod` per signature.
// The handler id (`gulong`) is returned so a caller can later disconnect.

// `void handler(GObject *emitter, gpointer user_data)` — the dominant shape
// (button "clicked", switch/check "toggled", range "value-changed", editable
// "changed", application "activate", …).
#[link_name = "g_signal_connect_data"]
extern fn g_signal_connect_2(
    instance: *u8,
    signal: *u8,
    handler: fn(*u8, *u8),
    data: *u8,
    destroy: *u8,
    flags: u32,
) -> u64;

// `void handler(GObject *emitter, GObject *arg1, gpointer user_data)` — e.g.
// list box "row-activated" (`GtkListBox*, GtkListBoxRow*, gpointer`) and
// `GSimpleAction` "activate" (`GSimpleAction*, GVariant*, gpointer`).
#[link_name = "g_signal_connect_data"]
extern fn g_signal_connect_3(
    instance: *u8,
    signal: *u8,
    handler: fn(*u8, *u8, *u8),
    data: *u8,
    destroy: *u8,
    flags: u32,
) -> u64;

// `gboolean handler(GtkSwitch *sw, gboolean state, gpointer user_data)` — the
// switch "state-set" signal (return 1 to stop the default handler / keep your
// state, 0 to let GTK apply it).
#[link_name = "g_signal_connect_data"]
extern fn g_signal_connect_state(
    instance: *u8,
    signal: *u8,
    handler: fn(*u8, i32, *u8) -> i32,
    data: *u8,
    destroy: *u8,
    flags: u32,
) -> u64;

// Connect the common `(emitter, user_data)` handler. Returns the handler id.
fn signal_connect(instance: *u8, signal: *u8, handler: fn(*u8, *u8), data: *u8) -> u64 {
    return { g_signal_connect_2(instance, signal, handler, data, 0 as *u8, 0 as u32) };
}

// Connect a `(emitter, arg1, user_data)` handler (row-activated, action
// activate, …).
fn signal_connect3(instance: *u8, signal: *u8, handler: fn(*u8, *u8, *u8), data: *u8) -> u64 {
    return { g_signal_connect_3(instance, signal, handler, data, 0 as *u8, 0 as u32) };
}

// Connect a `GtkSwitch` "state-set" handler.
fn signal_connect_state(instance: *u8, signal: *u8, handler: fn(*u8, i32, *u8) -> i32, data: *u8) -> u64 {
    return { g_signal_connect_state(instance, signal, handler, data, 0 as *u8, 0 as u32) };
}

// ---- main loop / idle / timeout ----

#[link_name = "g_idle_add"]
extern fn g_idle_add(func: fn(*u8) -> i32, data: *u8) -> u32;

#[link_name = "g_timeout_add"]
extern fn g_timeout_add(interval_ms: u32, func: fn(*u8) -> i32, data: *u8) -> u32;

#[link_name = "g_source_remove"]
extern fn g_source_remove(source_id: u32) -> i32;

// Schedule `func` to run when the main loop is idle. Return 1 (G_SOURCE_CONTINUE)
// from the callback to keep it scheduled, 0 (G_SOURCE_REMOVE) to drop it.
fn idle_add(func: fn(*u8) -> i32, data: *u8) -> u32 {
    return { g_idle_add(func, data) };
}

// Run `func` every `interval_ms` milliseconds (same return convention as `idle_add`).
fn timeout_add(interval_ms: u32, func: fn(*u8) -> i32, data: *u8) -> u32 {
    return { g_timeout_add(interval_ms, func, data) };
}

fn source_remove(source_id: u32) -> i32 {
    return { g_source_remove(source_id) };
}

// ---- GTK lifecycle / version ----

#[link_name = "gtk_init"]
extern fn gtk_init();

#[link_name = "gtk_get_major_version"]
extern fn gtk_get_major_version() -> u32;

#[link_name = "gtk_get_minor_version"]
extern fn gtk_get_minor_version() -> u32;

// Initialize GTK without a GtkApplication — for the rare non-`GApplication`
// entry point. The `Application` path (`g_application_run`) initializes GTK for
// you and is the recommended shape.
fn init() {
    { gtk_init(); };
}

fn major_version() -> u32 {
    return { gtk_get_major_version() };
}

fn minor_version() -> u32 {
    return { gtk_get_minor_version() };
}

// ---- enum constants ----

// GtkOrientation
fn orientation_horizontal() -> i32 { return 0; }
fn orientation_vertical() -> i32 { return 1; }

// GtkAlign — for `widget::set_halign` / `set_valign`.
fn align_fill() -> i32 { return 0; }
fn align_start() -> i32 { return 1; }
fn align_end() -> i32 { return 2; }
fn align_center() -> i32 { return 3; }
fn align_baseline() -> i32 { return 4; }

// GApplicationFlags — `G_APPLICATION_DEFAULT_FLAGS` (GLib ≥ 2.74).
fn application_default_flags() -> u32 { return 0; }

// GtkPolicyType — for `containers::ScrolledWindow::set_policy`.
fn policy_always() -> i32 { return 0; }
fn policy_automatic() -> i32 { return 1; }
fn policy_never() -> i32 { return 2; }
fn policy_external() -> i32 { return 3; }

// gboolean truth values — GTK setters take `gboolean` (a C `int`).
fn true_() -> i32 { return 1; }
fn false_() -> i32 { return 0; }
