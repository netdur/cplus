// Cairo drawing primitives — the 2D paint API used inside a
// `graphics::DrawingArea` draw function. GTK hands the callback a `cairo_t*`
// (`cr`); these are the move/line/rect/arc + source-color + fill/stroke calls
// you issue against it. This is the GTK analog of appkit's `BezierPath`.
//
// Usage (inside `fn(area, cr, width, height, data)`):
//   cairo::set_source_rgb(cr, 0.2, 0.4, 0.9);
//   cairo::rectangle(cr, 10.0, 10.0, 100.0, 60.0);
//   cairo::fill(cr);

#[link_name = "cairo_set_source_rgb"]
extern fn cairo_set_source_rgb(cr: *u8, r: f64, g: f64, b: f64);

#[link_name = "cairo_set_source_rgba"]
extern fn cairo_set_source_rgba(cr: *u8, r: f64, g: f64, b: f64, a: f64);

#[link_name = "cairo_set_line_width"]
extern fn cairo_set_line_width(cr: *u8, width: f64);

#[link_name = "cairo_move_to"]
extern fn cairo_move_to(cr: *u8, x: f64, y: f64);

#[link_name = "cairo_line_to"]
extern fn cairo_line_to(cr: *u8, x: f64, y: f64);

#[link_name = "cairo_rectangle"]
extern fn cairo_rectangle(cr: *u8, x: f64, y: f64, width: f64, height: f64);

#[link_name = "cairo_arc"]
extern fn cairo_arc(cr: *u8, xc: f64, yc: f64, radius: f64, angle1: f64, angle2: f64);

#[link_name = "cairo_close_path"]
extern fn cairo_close_path(cr: *u8);

#[link_name = "cairo_new_path"]
extern fn cairo_new_path(cr: *u8);

#[link_name = "cairo_fill"]
extern fn cairo_fill(cr: *u8);

#[link_name = "cairo_fill_preserve"]
extern fn cairo_fill_preserve(cr: *u8);

#[link_name = "cairo_stroke"]
extern fn cairo_stroke(cr: *u8);

#[link_name = "cairo_stroke_preserve"]
extern fn cairo_stroke_preserve(cr: *u8);

#[link_name = "cairo_paint"]
extern fn cairo_paint(cr: *u8);

// Solid RGB source color, components 0.0–1.0.
fn set_source_rgb(cr: *u8, r: f64, g: f64, b: f64) {
    { cairo_set_source_rgb(cr, r, g, b); };
}

// RGBA source color (with alpha).
fn set_source_rgba(cr: *u8, r: f64, g: f64, b: f64, a: f64) {
    { cairo_set_source_rgba(cr, r, g, b, a); };
}

fn set_line_width(cr: *u8, width: f64) {
    { cairo_set_line_width(cr, width); };
}

fn move_to(cr: *u8, x: f64, y: f64) {
    { cairo_move_to(cr, x, y); };
}

fn line_to(cr: *u8, x: f64, y: f64) {
    { cairo_line_to(cr, x, y); };
}

fn rectangle(cr: *u8, x: f64, y: f64, width: f64, height: f64) {
    { cairo_rectangle(cr, x, y, width, height); };
}

// Arc centered at (`xc`,`yc`), `radius`, from `angle1` to `angle2` (radians).
// A full circle is angle1 = 0, angle2 = 2π.
fn arc(cr: *u8, xc: f64, yc: f64, radius: f64, angle1: f64, angle2: f64) {
    { cairo_arc(cr, xc, yc, radius, angle1, angle2); };
}

fn close_path(cr: *u8) {
    { cairo_close_path(cr); };
}

fn new_path(cr: *u8) {
    { cairo_new_path(cr); };
}

// Fill the current path with the source color (clears the path).
fn fill(cr: *u8) {
    { cairo_fill(cr); };
}

fn fill_preserve(cr: *u8) {
    { cairo_fill_preserve(cr); };
}

// Stroke the current path's outline (clears the path).
fn stroke(cr: *u8) {
    { cairo_stroke(cr); };
}

fn stroke_preserve(cr: *u8) {
    { cairo_stroke_preserve(cr); };
}

// Paint the source everywhere (e.g. a background fill).
fn paint(cr: *u8) {
    { cairo_paint(cr); };
}
