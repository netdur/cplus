import "./glib" as g;

// Layout containers ŌĆö the GTK analog of appkit's `containers` + `view`'s
// stack/scroll widgets: Box, Grid, Stack (+ StackSwitcher), Notebook, Paned,
// ScrolledWindow, Frame, CenterBox, ListBox, HeaderBar. Children are added by
// `raw()` pointer; a container sinks each child's floating reference, so the
// wrappers stay `opaque` with no `drop`.

// ---- Box ----

#[link_name = "gtk_box_new"]
extern fn gtk_box_new(orientation: i32, spacing: i32) -> *u8;

#[link_name = "gtk_box_append"]
extern fn gtk_box_append(box: *u8, child: *u8);

#[link_name = "gtk_box_prepend"]
extern fn gtk_box_prepend(box: *u8, child: *u8);

#[link_name = "gtk_box_remove"]
extern fn gtk_box_remove(box: *u8, child: *u8);

#[link_name = "gtk_box_set_spacing"]
extern fn gtk_box_set_spacing(box: *u8, spacing: i32);

#[link_name = "gtk_box_set_homogeneous"]
extern fn gtk_box_set_homogeneous(box: *u8, homogeneous: i32);

struct Box {
    opaque obj: *u8,
}

impl Box {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> Box { return Box { obj: obj }; }

    // `orientation` is a `glib::orientation_*` value; `spacing` is the gap (px)
    // between children.
    fn new(orientation: i32, spacing: i32) -> Box {
        return Box { obj: { gtk_box_new(orientation, spacing) } };
    }

    fn append(this, child: *u8) {
        { gtk_box_append(this.obj, child); };
    }

    fn prepend(this, child: *u8) {
        { gtk_box_prepend(this.obj, child); };
    }

    fn remove(this, child: *u8) {
        { gtk_box_remove(this.obj, child); };
    }

    fn set_spacing(this, spacing: i32) {
        { gtk_box_set_spacing(this.obj, spacing); };
    }

    // When true, all children get the same size along the orientation axis.
    fn set_homogeneous(this, homogeneous: i32) {
        { gtk_box_set_homogeneous(this.obj, homogeneous); };
    }
}

// ---- Grid ----

#[link_name = "gtk_grid_new"]
extern fn gtk_grid_new() -> *u8;

#[link_name = "gtk_grid_attach"]
extern fn gtk_grid_attach(grid: *u8, child: *u8, column: i32, row: i32, width: i32, height: i32);

#[link_name = "gtk_grid_set_row_spacing"]
extern fn gtk_grid_set_row_spacing(grid: *u8, spacing: u32);

#[link_name = "gtk_grid_set_column_spacing"]
extern fn gtk_grid_set_column_spacing(grid: *u8, spacing: u32);

struct Grid {
    opaque obj: *u8,
}

impl Grid {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> Grid { return Grid { obj: obj }; }

    fn new() -> Grid {
        return Grid { obj: { gtk_grid_new() } };
    }

    // Place `child` spanning `width`├Ś`height` cells with its top-left at
    // (`column`, `row`).
    fn attach(this, child: *u8, column: i32, row: i32, width: i32, height: i32) {
        { gtk_grid_attach(this.obj, child, column, row, width, height); };
    }

    fn set_row_spacing(this, spacing: u32) {
        { gtk_grid_set_row_spacing(this.obj, spacing); };
    }

    fn set_column_spacing(this, spacing: u32) {
        { gtk_grid_set_column_spacing(this.obj, spacing); };
    }
}

// ---- Stack (+ StackSwitcher) ----

#[link_name = "gtk_stack_new"]
extern fn gtk_stack_new() -> *u8;

#[link_name = "gtk_stack_add_named"]
extern fn gtk_stack_add_named(stack: *u8, child: *u8, name: *u8) -> *u8;

#[link_name = "gtk_stack_add_titled"]
extern fn gtk_stack_add_titled(stack: *u8, child: *u8, name: *u8, title: *u8) -> *u8;

#[link_name = "gtk_stack_set_visible_child_name"]
extern fn gtk_stack_set_visible_child_name(stack: *u8, name: *u8);

#[link_name = "gtk_stack_get_visible_child_name"]
extern fn gtk_stack_get_visible_child_name(stack: *u8) -> *u8;

struct Stack {
    opaque obj: *u8,
}

impl Stack {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> Stack { return Stack { obj: obj }; }

    fn new() -> Stack {
        return Stack { obj: { gtk_stack_new() } };
    }

    fn add_named(this, child: *u8, name: *u8) {
        let _page: *u8 = { gtk_stack_add_named(this.obj, child, name) };
    }

    // Like `add_named` but with a human title used by a StackSwitcher.
    fn add_titled(this, child: *u8, name: *u8, title: *u8) {
        let _page: *u8 = { gtk_stack_add_titled(this.obj, child, name, title) };
    }

    fn set_visible_child_name(this, name: *u8) {
        { gtk_stack_set_visible_child_name(this.obj, name); };
    }

    fn visible_child_name(this) -> *u8 {
        return { gtk_stack_get_visible_child_name(this.obj) };
    }
}

#[link_name = "gtk_stack_switcher_new"]
extern fn gtk_stack_switcher_new() -> *u8;

#[link_name = "gtk_stack_switcher_set_stack"]
extern fn gtk_stack_switcher_set_stack(switcher: *u8, stack: *u8);

struct StackSwitcher {
    opaque obj: *u8,
}

impl StackSwitcher {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> StackSwitcher { return StackSwitcher { obj: obj }; }

    fn new() -> StackSwitcher {
        return StackSwitcher { obj: { gtk_stack_switcher_new() } };
    }

    fn set_stack(this, stack: *u8) {
        { gtk_stack_switcher_set_stack(this.obj, stack); };
    }
}

// ---- Notebook (tabs) ----

#[link_name = "gtk_notebook_new"]
extern fn gtk_notebook_new() -> *u8;

#[link_name = "gtk_notebook_append_page"]
extern fn gtk_notebook_append_page(notebook: *u8, child: *u8, tab_label: *u8) -> i32;

#[link_name = "gtk_notebook_set_current_page"]
extern fn gtk_notebook_set_current_page(notebook: *u8, page_num: i32);

#[link_name = "gtk_notebook_get_current_page"]
extern fn gtk_notebook_get_current_page(notebook: *u8) -> i32;

struct Notebook {
    opaque obj: *u8,
}

impl Notebook {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> Notebook { return Notebook { obj: obj }; }

    fn new() -> Notebook {
        return Notebook { obj: { gtk_notebook_new() } };
    }

    // Append a tab; `tab_label` is any widget (commonly a `Label`'s `raw()`).
    // Returns the new page index.
    fn append_page(this, child: *u8, tab_label: *u8) -> i32 {
        return { gtk_notebook_append_page(this.obj, child, tab_label) };
    }

    fn set_current_page(this, page_num: i32) {
        { gtk_notebook_set_current_page(this.obj, page_num); };
    }

    fn current_page(this) -> i32 {
        return { gtk_notebook_get_current_page(this.obj) };
    }
}

