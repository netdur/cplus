#[link_name = "gtk_header_bar_set_title_widget"]
extern fn gtk_header_bar_set_title_widget(bar: *u8, title_widget: *u8);

struct HeaderBar {
    opaque obj: *u8,
}

impl HeaderBar {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> HeaderBar { return HeaderBar { obj: obj }; }

    fn new() -> HeaderBar {
        return HeaderBar { obj: { gtk_header_bar_new() } };
    }

    fn pack_start(this, child: *u8) {
        { gtk_header_bar_pack_start(this.obj, child); };
    }

    fn pack_end(this, child: *u8) {
        { gtk_header_bar_pack_end(this.obj, child); };
    }

    fn set_title_widget(this, title_widget: *u8) {
        { gtk_header_bar_set_title_widget(this.obj, title_widget); };
    }
}
