extern fn gtk_paned_new(orientation: i32) -> *u8;

#[link_name = "gtk_paned_set_start_child"]
extern fn gtk_paned_set_start_child(paned: *u8, child: *u8);

#[link_name = "gtk_paned_set_end_child"]
extern fn gtk_paned_set_end_child(paned: *u8, child: *u8);

#[link_name = "gtk_paned_set_position"]
extern fn gtk_paned_set_position(paned: *u8, position: i32);

struct Paned {
    opaque obj: *u8,
}

impl Paned {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> Paned { return Paned { obj: obj }; }

    fn new(orientation: i32) -> Paned {
        return Paned { obj: { gtk_paned_new(orientation) } };
    }

    fn set_start_child(this, child: *u8) {
        { gtk_paned_set_start_child(this.obj, child); };
    }

    fn set_end_child(this, child: *u8) {
        { gtk_paned_set_end_child(this.obj, child); };
    }

    // Divider offset (px) from the start edge.
    fn set_position(this, position: i32) {
        { gtk_paned_set_position(this.obj, position); };
    }
}

// ---- ScrolledWindow ----

#[link_name = "gtk_scrolled_window_new"]
extern fn gtk_scrolled_window_new() -> *u8;

#[link_name = "gtk_scrolled_window_set_child"]
extern fn gtk_scrolled_window_set_child(sw: *u8, child: *u8);

#[link_name = "gtk_scrolled_window_set_policy"]
extern fn gtk_scrolled_window_set_policy(sw: *u8, hscrollbar_policy: i32, vscrollbar_policy: i32);

struct ScrolledWindow {
    opaque obj: *u8,
}

impl ScrolledWindow {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> ScrolledWindow { return ScrolledWindow { obj: obj }; }

    fn new() -> ScrolledWindow {
        return ScrolledWindow { obj: { gtk_scrolled_window_new() } };
    }

    fn set_child(this, child: *u8) {
        { gtk_scrolled_window_set_child(this.obj, child); };
    }

    // Scrollbar policies are `glib::policy_*` values.
    fn set_policy(this, hpolicy: i32, vpolicy: i32) {
        { gtk_scrolled_window_set_policy(this.obj, hpolicy, vpolicy); };
    }
}

// ---- Frame ----

#[link_name = "gtk_frame_new"]
extern fn gtk_frame_new(label: *u8) -> *u8;

#[link_name = "gtk_frame_set_child"]
extern fn gtk_frame_set_child(frame: *u8, child: *u8);

#[link_name = "gtk_frame_set_label"]
extern fn gtk_frame_set_label(frame: *u8, label: *u8);

struct Frame {
    opaque obj: *u8,
}

impl Frame {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> Frame { return Frame { obj: obj }; }

    // Pass `0 as *u8` for no caption.
    fn new(label: *u8) -> Frame {
        return Frame { obj: { gtk_frame_new(label) } };
    }

    fn set_child(this, child: *u8) {
        { gtk_frame_set_child(this.obj, child); };
    }

    fn set_label(this, label: *u8) {
        { gtk_frame_set_label(this.obj, label); };
    }
}

