// ---- ListBox ----

#[link_name = "gtk_list_box_new"]
extern fn gtk_list_box_new() -> *u8;

#[link_name = "gtk_list_box_append"]
extern fn gtk_list_box_append(list_box: *u8, child: *u8);

#[link_name = "gtk_list_box_remove"]
extern fn gtk_list_box_remove(list_box: *u8, child: *u8);

#[link_name = "gtk_list_box_get_selected_row"]
extern fn gtk_list_box_get_selected_row(list_box: *u8) -> *u8;

#[link_name = "gtk_list_box_row_get_index"]
extern fn gtk_list_box_row_get_index(row: *u8) -> i32;

struct ListBox {
    opaque obj: *u8,
}

impl ListBox {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> ListBox { return ListBox { obj: obj }; }

    fn new() -> ListBox {
        return ListBox { obj: { gtk_list_box_new() } };
    }

    fn append(this, child: *u8) {
        { gtk_list_box_append(this.obj, child); };
    }

    fn remove(this, child: *u8) {
        { gtk_list_box_remove(this.obj, child); };
    }

    // The currently selected row widget, or null. Use `row_index` to map it
    // back to a position.
    fn selected_row(this) -> *u8 {
        return { gtk_list_box_get_selected_row(this.obj) };
    }

    fn row_index(row: *u8) -> i32 {
        return { gtk_list_box_row_get_index(row) };
    }

    // The "row-activated" signal: `fn(list_box, row, user_data)`.
    fn connect_row_activated(this, handler: fn(*u8, *u8, *u8)) {
        let _id: u64 = g::signal_connect3(this.obj, #str_ptr("row-activated\0"), handler, 0 as *u8);
    }
}

