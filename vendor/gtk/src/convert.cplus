// C+ ‚Üî C string/data bridges ‚Äî the GTK analog of appkit's `convert`. GTK and
// GLib speak NUL-terminated UTF-8 `char*`; C+ speaks `str` (a `{ptr,len}` fat
// pointer, NOT NUL-terminated) and owned `text::Text`. These helpers cross the
// boundary explicitly. Import directly ‚Äî there is no umbrella re-export:
//
//   import "gtk/convert" as bridge;
//
// Requires `stdlib` (for `text::Text` / `vec::Vec`).

import "stdlib/text" as text;
import "stdlib/vec" as vec;

extern fn strlen(s: *u8) -> usize;

// `g_strndup(s, n)` copies `n` bytes and NUL-terminates ‚Äî exactly what we need
// to hand a non-terminated C+ `str` to a C API. Free the result with
// `glib::free` (or `g_free`).
#[link_name = "g_strndup"]
extern fn g_strndup(s: *u8, n: usize) -> *u8;

#[link_name = "g_free"]
extern fn g_free(mem: *u8);

// ---- C string ‚Üí C+ ----

// Length of a NUL-terminated C string (excludes the terminator).
fn cstr_len(s: *u8) -> usize {
    return { strlen(s) };
}

// Borrow a `const char*` as a C+ `str` WITHOUT copying. The view is valid only
// while the C string lives and is unchanged ‚Äî copy it (`cstr_to_text`) if GTK
// owns the buffer and may mutate/free it (e.g. an entry's live text).
fn cstr_to_str_unsafe(s: *u8) -> str {
    let n: usize = { strlen(s) };
    return { #str_from_raw_parts(s, n) };
}

// Copy a `const char*` into an owned `text::Text` ‚Äî safe to keep past the
// lifetime of the C buffer.
fn cstr_to_text(s: *u8) -> text::Text {
    let n: usize = { strlen(s) };
    let view: str = { #str_from_raw_parts(s, n) };
    return view.to_text();
}

// ---- C+ ‚Üí C string ----

// Copy a C+ `str` into a freshly-allocated NUL-terminated `char*` suitable for
// any GTK/GLib `const char*` parameter. Free it with `glib::free` once the call
// that consumed it returns (GTK setters copy the string, so you can free
// immediately after).
fn str_to_cstring(s: str) -> *u8 {
    return { g_strndup(#str_ptr(s), #str_len(s)) };
}

// Free a string returned by `str_to_cstring` (or any `g_*` allocator).
fn free_cstring(s: *u8) {
    { g_free(s); };
}

// ---- GTK string objects ----

#[link_name = "gtk_string_object_get_string"]
extern fn gtk_string_object_get_string(string_object: *u8) -> *u8;

// The text of a `GtkStringObject` (the element type of a `data::StringList`) as
// a borrowed `const char*`. Pair with `cstr_to_text` to own it.
fn string_object_text(string_object: *u8) -> *u8 {
    return { gtk_string_object_get_string(string_object) };
}

// ---- bytes ----

// `g_bytes_get_data(bytes, &size)` exposes the raw view of a `GBytes`. We bind
// the size out-param as a `*u8` (pointer to a `usize` slot).
#[link_name = "g_bytes_get_data"]
extern fn g_bytes_get_data(bytes: *u8, size_out: *u8) -> *u8;

#[link_name = "g_bytes_new"]
extern fn g_bytes_new(data: *u8, size: usize) -> *u8;

// Wrap a byte buffer as a `GBytes` (copies). Unref with `glib::unref` when done.
fn bytes_new(data: *u8, size: usize) -> *u8 {
    return { g_bytes_new(data, size) };
}

// Copy a `GBytes`' contents into an owned `vec::Vec[u8]`.
fn bytes_to_vec_u8(bytes: *u8) -> vec::Vec[u8] {
    var size: usize = 0 as usize;
    let data: *u8 = { g_bytes_get_data(bytes, #addr_of(size) as *u8) };
    var out: vec::Vec[u8] = vec::Vec[u8]::with_capacity(size);
    { out.extend_from_raw(data, size); }
    return out;
}
