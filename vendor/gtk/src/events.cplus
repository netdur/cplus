import "./glib" as g;

// Input event controllers — the GTK analog of appkit's `events`. GTK 4 routes
// input through *event controllers* you attach to any widget with
// `add_controller`: click/press gestures, key events, and pointer motion. Each
// controller exposes signals with its own callback shape, so the typed
// `g_signal_connect_data` declarations live here. Import directly:
//
//   import "gtk/events" as events;

#[link_name = "gtk_widget_add_controller"]
extern fn gtk_widget_add_controller(widget: *u8, controller: *u8);

// Attach a controller to a widget (the widget takes ownership).
fn add_controller(widget: *u8, controller: *u8) {
    { gtk_widget_add_controller(widget, controller); };
}

// ---- typed signal connectors for controller callbacks ----

// `void (emitter, gint n_press, gdouble x, gdouble y, gpointer)` — gesture
// "pressed" / "released".
#[link_name = "g_signal_connect_data"]
extern fn connect_press(instance: *u8, signal: *u8, handler: fn(*u8, i32, f64, f64, *u8), data: *u8, destroy: *u8, flags: u32) -> u64;

// `gboolean (emitter, guint keyval, guint keycode, GdkModifierType state, gpointer)`
// — key controller "key-pressed" (return 1 to stop propagation).
#[link_name = "g_signal_connect_data"]
extern fn connect_key(instance: *u8, signal: *u8, handler: fn(*u8, u32, u32, u32, *u8) -> i32, data: *u8, destroy: *u8, flags: u32) -> u64;

// `void (emitter, gdouble x, gdouble y, gpointer)` — motion "motion" / "enter".
#[link_name = "g_signal_connect_data"]
extern fn connect_motion(instance: *u8, signal: *u8, handler: fn(*u8, f64, f64, *u8), data: *u8, destroy: *u8, flags: u32) -> u64;

// ---- Click gesture ----

#[link_name = "gtk_gesture_click_new"]
extern fn gtk_gesture_click_new() -> *u8;

struct ClickGesture {
    opaque obj: *u8,
}

impl ClickGesture {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> ClickGesture { return ClickGesture { obj: obj }; }

    fn new() -> ClickGesture {
        return ClickGesture { obj: { gtk_gesture_click_new() } };
    }

    // "pressed": `fn(gesture, n_press: i32, x: f64, y: f64, user_data)`.
    fn connect_pressed(this, handler: fn(*u8, i32, f64, f64, *u8)) {
        let _id: u64 = { connect_press(this.obj, #str_ptr("pressed\0"), handler, 0 as *u8, 0 as *u8, 0 as u32) };
    }

    // "released": same shape as "pressed".
    fn connect_released(this, handler: fn(*u8, i32, f64, f64, *u8)) {
        let _id: u64 = { connect_press(this.obj, #str_ptr("released\0"), handler, 0 as *u8, 0 as *u8, 0 as u32) };
    }
}

// ---- Key controller ----

#[link_name = "gtk_event_controller_key_new"]
extern fn gtk_event_controller_key_new() -> *u8;

struct KeyController {
    opaque obj: *u8,
}

impl KeyController {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> KeyController { return KeyController { obj: obj }; }

    fn new() -> KeyController {
        return KeyController { obj: { gtk_event_controller_key_new() } };
    }

    // "key-pressed": `fn(controller, keyval: u32, keycode: u32, state: u32,
    // user_data) -> i32`. Return 1 to mark the event handled. `keyval` is a
    // GDK keysym (e.g. GDK_KEY_Escape = 0xff1b).
    fn connect_key_pressed(this, handler: fn(*u8, u32, u32, u32, *u8) -> i32) {
        let _id: u64 = { connect_key(this.obj, #str_ptr("key-pressed\0"), handler, 0 as *u8, 0 as *u8, 0 as u32) };
    }
}

// ---- Motion controller ----

#[link_name = "gtk_event_controller_motion_new"]
extern fn gtk_event_controller_motion_new() -> *u8;

struct MotionController {
    opaque obj: *u8,
}

impl MotionController {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> MotionController { return MotionController { obj: obj }; }

    fn new() -> MotionController {
        return MotionController { obj: { gtk_event_controller_motion_new() } };
    }

    // "motion": `fn(controller, x: f64, y: f64, user_data)` — pointer moved
    // over the widget.
    fn connect_motion(this, handler: fn(*u8, f64, f64, *u8)) {
        let _id: u64 = { connect_motion(this.obj, #str_ptr("motion\0"), handler, 0 as *u8, 0 as *u8, 0 as u32) };
    }

    // "enter": same shape — pointer entered the widget.
    fn connect_enter(this, handler: fn(*u8, f64, f64, *u8)) {
        let _id: u64 = { connect_motion(this.obj, #str_ptr("enter\0"), handler, 0 as *u8, 0 as *u8, 0 as u32) };
    }
}

// ---- a few common GDK keysyms ----

fn key_escape() -> u32 { return 65307 as u32; } // 0xff1b
fn key_return() -> u32 { return 65293 as u32; } // 0xff0d
fn key_tab() -> u32 { return 65289 as u32; }    // 0xff09
fn key_space() -> u32 { return 32 as u32; }
fn key_left() -> u32 { return 65361 as u32; }
fn key_right() -> u32 { return 65363 as u32; }
fn key_up() -> u32 { return 65362 as u32; }
fn key_down() -> u32 { return 65364 as u32; }
