import "./glib" as g;

// GAction / GSimpleAction — the named commands that menu items and keyboard
// shortcuts invoke. A menu item references an action by name ("app.quit"); you
// create the matching `GSimpleAction` here, connect its "activate" handler, and
// register it on the application's action map
// (`application::Application::add_action`). This is GTK's decoupled stand-in
// for appkit's target/action selectors.
//
//   fn on_quit(action: *u8, param: *u8, data: *u8) { /* … */ }
//   let quit = actions::Action::new(#str_ptr("quit\0"));
//   quit.connect_activate(on_quit);
//   app.add_action(quit.raw());          // now reachable as "app.quit"
//   menu.append(#str_ptr("Quit\0"), #str_ptr("app.quit\0"));

// `parameter_type` is a `GVariantType*` — pass `0 as *u8` for a parameterless
// action.
#[link_name = "g_simple_action_new"]
extern fn g_simple_action_new(name: *u8, parameter_type: *u8) -> *u8;

#[link_name = "g_simple_action_set_enabled"]
extern fn g_simple_action_set_enabled(action: *u8, enabled: i32);

struct Action {
    opaque obj: *u8,
}

impl Action {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> Action { return Action { obj: obj }; }

    // Create a parameterless action with the given bare name ("quit", "save").
    fn new(name: *u8) -> Action {
        return Action { obj: { g_simple_action_new(name, 0 as *u8) } };
    }

    // Create an action carrying a typed parameter (`parameter_type` is a
    // `GVariantType*`, e.g. from `g_variant_type_new`).
    fn with_parameter(name: *u8, parameter_type: *u8) -> Action {
        return Action { obj: { g_simple_action_new(name, parameter_type) } };
    }

    // The "activate" signal: `fn(action: *u8, parameter: *u8, user_data: *u8)`.
    fn connect_activate(this, handler: fn(*u8, *u8, *u8)) {
        let _id: u64 = g::signal_connect3(this.obj, #str_ptr("activate\0"), handler, 0 as *u8);
    }

    // Greyed-out actions are skipped by their menu items.
    fn set_enabled(this, enabled: i32) {
        { g_simple_action_set_enabled(this.obj, enabled); };
    }

    fn unref(this) {
        g::unref(this.obj);
    }
}
