import "./glib" as g;

// Menus — the GTK analog of appkit's `menu`. GTK 4 menus are data, not
// widgets: you build a `GMenu` model of labelled items that reference actions
// by name ("app.quit", "win.save"), then surface it through a `MenuButton`
// popover or the application menubar (`application::Application::set_menubar`).
// The actions themselves are created in `actions`.

// ---- GMenu (the model) ----

#[link_name = "g_menu_new"]
extern fn g_menu_new() -> *u8;

#[link_name = "g_menu_append"]
extern fn g_menu_append(menu: *u8, label: *u8, detailed_action: *u8);

#[link_name = "g_menu_append_submenu"]
extern fn g_menu_append_submenu(menu: *u8, label: *u8, submenu: *u8);

#[link_name = "g_menu_append_section"]
extern fn g_menu_append_section(menu: *u8, label: *u8, section: *u8);

struct Menu {
    opaque obj: *u8,
}

impl Menu {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> Menu { return Menu { obj: obj }; }

    fn new() -> Menu {
        return Menu { obj: { g_menu_new() } };
    }

    // Append a clickable item. `detailed_action` is an action name like
    // "app.quit" (optionally with a target, "app.set-mode::dark").
    fn append(this, label: *u8, detailed_action: *u8) {
        { g_menu_append(this.obj, label, detailed_action); };
    }

    // Nest another menu under `label`.
    fn append_submenu(this, label: *u8, submenu: *u8) {
        { g_menu_append_submenu(this.obj, label, submenu); };
    }

    // Append a visually-separated section (pass `0 as *u8` for no heading).
    fn append_section(this, label: *u8, section: *u8) {
        { g_menu_append_section(this.obj, label, section); };
    }

    fn unref(this) {
        g::unref(this.obj);
    }
}

// ---- MenuButton (surfaces a menu as a popover) ----

#[link_name = "gtk_menu_button_new"]
extern fn gtk_menu_button_new() -> *u8;

#[link_name = "gtk_menu_button_set_menu_model"]
extern fn gtk_menu_button_set_menu_model(button: *u8, menu_model: *u8);

#[link_name = "gtk_menu_button_set_label"]
extern fn gtk_menu_button_set_label(button: *u8, label: *u8);

#[link_name = "gtk_menu_button_set_icon_name"]
extern fn gtk_menu_button_set_icon_name(button: *u8, icon_name: *u8);

struct MenuButton {
    opaque obj: *u8,
}

impl MenuButton {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> MenuButton { return MenuButton { obj: obj }; }

    fn new() -> MenuButton {
        return MenuButton { obj: { gtk_menu_button_new() } };
    }

    // Attach a `Menu`'s model — clicking the button opens it as a popover.
    fn set_menu_model(this, menu_model: *u8) {
        { gtk_menu_button_set_menu_model(this.obj, menu_model); };
    }

    fn set_label(this, label: *u8) {
        { gtk_menu_button_set_label(this.obj, label); };
    }

    fn set_icon_name(this, icon_name: *u8) {
        { gtk_menu_button_set_icon_name(this.obj, icon_name); };
    }
}

// ---- PopoverMenu (a free-standing popover from a model) ----

#[link_name = "gtk_popover_menu_new_from_model"]
extern fn gtk_popover_menu_new_from_model(menu_model: *u8) -> *u8;

#[link_name = "gtk_popover_set_parent"]
extern fn gtk_popover_set_parent(popover: *u8, parent: *u8);

#[link_name = "gtk_popover_popup"]
extern fn gtk_popover_popup(popover: *u8);

struct PopoverMenu {
    opaque obj: *u8,
}

impl PopoverMenu {
    fn raw(this) -> *u8 { return this.obj; }
    fn from_raw(obj: *u8) -> PopoverMenu { return PopoverMenu { obj: obj }; }

    fn from_model(menu_model: *u8) -> PopoverMenu {
        return PopoverMenu { obj: { gtk_popover_menu_new_from_model(menu_model) } };
    }

    fn set_parent(this, parent: *u8) {
        { gtk_popover_set_parent(this.obj, parent); };
    }

    fn popup(this) {
        { gtk_popover_popup(this.obj); };
    }
}
