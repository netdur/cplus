// agent_mcp — the MCP bridge for the agent surface (Theme B, plan.agent-mcp.md).
//
// An external agent drives a live `agent_appkit::Surface` over JSON-RPC 2.0:
//
//   - describe_ui  -> the live node snapshot (read path)
//   - click / set_text / scroll_to -> authorized actions (write path)
//   - poll_event   -> the next queued semantic event
//
// Every request is first gated by the agent_core consent `AuthGate` on the
// `External` channel: an un-served (deny-all) gate rejects everything, so the
// surface is closed until the developer arms a policy. This module is the
// protocol + serialization core (pure, no sockets); `serve.cplus` layers the
// UDS-by-PID transport on top.

import "stdlib/vec" as vec;
import "stdlib/text" as text;
import "stdlib/option" as option;
import "stdlib/result" as result;
import "json/json" as json;
import "agent_core/backend" as backend;
import "agent_core/identity" as identity;
import "agent_core/surface" as surface;
import "agent_core/events" as events;
import "agent_core/auth" as auth;

// ---- JSON building helpers --------------------------------------------------

fn jstr(s: str) -> json::Value {
    return json::Value::Text(text::from_str(s));
}

// Extract a text::Text from a json::Value (falls back to empty on non-text).
fn val_as_text(v: json::Value) -> text::Text {
    return match v.as_text() {
        option::Option[text::Text]::Some(t) => t,
        option::Option[text::Text]::None => text::from_str(""),
    };
}

// Extract an f64 from a json::Value (falls back to 0.0 on non-number).
fn val_as_number(v: json::Value) -> f64 {
    return match v.as_number() {
        option::Option[f64]::Some(n) => n,
        option::Option[f64]::None => 0.0,
    };
}

// Get an object field by key, or Null if absent / not an object.
fn obj_get(v: json::Value, key: str) -> json::Value {
    return match v.value(key) {
        option::Option[json::Value]::Some(val) => val,
        option::Option[json::Value]::None => json::Value::Null,
    };
}

fn jnum(n: f64) -> json::Value {
    return json::Value::Number(n);
}

fn jbool(b: bool) -> json::Value {
    return json::Value::Bool(b);
}

fn member(k: str, take v: json::Value) -> json::Member {
    return json::Member { key: text::from_str(k), value: v };
}

// ---- enum -> wire string ----------------------------------------------------

fn role_to_str(role: identity::Role) -> str {
    if identity::role_eq(role, identity::Role::Button) { return "button"; }
    if identity::role_eq(role, identity::Role::Text) { return "text"; }
    if identity::role_eq(role, identity::Role::Input) { return "input"; }
    if identity::role_eq(role, identity::Role::List) { return "list"; }
    if identity::role_eq(role, identity::Role::Group) { return "group"; }
    if identity::role_eq(role, identity::Role::Window) { return "window"; }
    return "group";
}

fn outcome_to_str(o: surface::Outcome) -> str {
    if surface::outcome_eq(o, surface::Outcome::Allowed) { return "allowed"; }
    if surface::outcome_eq(o, surface::Outcome::NotFound) { return "not_found"; }
    if surface::outcome_eq(o, surface::Outcome::NotExposed) { return "not_exposed"; }
    if surface::outcome_eq(o, surface::Outcome::NotActionable) { return "not_actionable"; }
    return "version_conflict";
}

fn verb_to_str(v: events::Verb) -> str {
    if events::verb_eq(v, events::Verb::Clicked) { return "clicked"; }
    if events::verb_eq(v, events::Verb::Changed) { return "changed"; }
    if events::verb_eq(v, events::Verb::Submitted) { return "submitted"; }
    if events::verb_eq(v, events::Verb::Selected) { return "selected"; }
    if events::verb_eq(v, events::Verb::Toggled) { return "toggled"; }
    if events::verb_eq(v, events::Verb::Opened) { return "opened"; }
    if events::verb_eq(v, events::Verb::Closed) { return "closed"; }
    if events::verb_eq(v, events::Verb::Enabled) { return "enabled"; }
    if events::verb_eq(v, events::Verb::Disabled) { return "disabled"; }
    if events::verb_eq(v, events::Verb::Added) { return "added"; }
    if events::verb_eq(v, events::Verb::Removed) { return "removed"; }
    if events::verb_eq(v, events::Verb::Appeared) { return "appeared"; }
    if events::verb_eq(v, events::Verb::Disappeared) { return "disappeared"; }
    if events::verb_eq(v, events::Verb::WindowOpened) { return "window_opened"; }
    if events::verb_eq(v, events::Verb::WindowClosed) { return "window_closed"; }
    return "ui_changed";
}

// ---- surface -> JSON --------------------------------------------------------

// One describe_ui node as a JSON object. Takes a raw pointer INTO the node Vec
// and reads fields through it (Text fields coerce to `str` borrows, the rest
// are Copy) — never moving the non-Copy `UiNode` out of the Vec, which would
// double-free its owned `Text`s. `parent` is the index into the node array, or
// JSON null for the window root.
fn node_to_json(p: *backend::UiNode) -> json::Value {
    var frame: vec::Vec[json::Member] = vec::new::[json::Member]();
    frame.append(member("x", jnum({ (*p).frame.x })));
    frame.append(member("y", jnum({ (*p).frame.y })));
    frame.append(member("w", jnum({ (*p).frame.w })));
    frame.append(member("h", jnum({ (*p).frame.h })));

    let parent_val: json::Value = match { (*p).parent } {
        option::Option[usize]::Some(pi) => jnum(pi as f64),
        option::Option[usize]::None => json::Value::Null,
    };

    var m: vec::Vec[json::Member] = vec::new::[json::Member]();
    m.append(member("id", jstr({ (*p).id })));
    m.append(member("role", jstr(role_to_str({ (*p).role }))));
    m.append(member("class", jstr({ (*p).class_name })));
    m.append(member("frame", json::Value::Object(frame)));
    m.append(member("hidden", jbool({ (*p).is_hidden })));
    m.append(member("text", jstr({ (*p).text })));
    m.append(member("actionable", jbool({ (*p).actionable })));
    m.append(member("parent", parent_val));
    return json::Value::Object(m);
}

// The whole describe_ui snapshot as a JSON array of node objects.
fn describe_to_json(nodes: vec::Vec[backend::UiNode]) -> json::Value {
    var arr: vec::Vec[json::Value] = vec::new::[json::Value]();
    var i: usize = 0 as usize;
    while i < nodes.count() {
        match nodes.at_ptr(i) {
            option::Option[*backend::UiNode]::Some(p) => {
                arr.append(node_to_json(p));
            }
            option::Option[*backend::UiNode]::None => {}
        }
        i = i +% (1 as usize);
    }
    return json::Value::Array(arr);
}

fn outcome_result(o: surface::Outcome) -> json::Value {
    var m: vec::Vec[json::Member] = vec::new::[json::Member]();
    m.append(member("outcome", jstr(outcome_to_str(o))));
    return json::Value::Object(m);
}

// ---- JSON-RPC envelopes -----------------------------------------------------

fn ok_response(id: f64, take result: json::Value) -> json::Value {
    var m: vec::Vec[json::Member] = vec::new::[json::Member]();
    m.append(member("jsonrpc", jstr("2.0")));
    m.append(member("id", jnum(id)));
    m.append(member("result", result));
    return json::Value::Object(m);
}

fn err_response(id: f64, code: f64, msg: str) -> json::Value {
    var e: vec::Vec[json::Member] = vec::new::[json::Member]();
    e.append(member("code", jnum(code)));
    e.append(member("message", jstr(msg)));
    var m: vec::Vec[json::Member] = vec::new::[json::Member]();
    m.append(member("jsonrpc", jstr("2.0")));
    m.append(member("id", jnum(id)));
    m.append(member("error", json::Value::Object(e)));
    return json::Value::Object(m);
}

// ---- the dispatch -----------------------------------------------------------

// JSON-RPC error codes: -32601 method-not-found (standard); -32001 the
// surface-specific "consent denied" (server error range).

// Dispatch one parsed JSON-RPC request against the live surface. `params` is the
// request's `params` object; `id` is the request id (echoed back). Every call is
// gated on the External consent channel first — a rejected gate yields a
// consent-denied error and never touches the surface.
fn dispatch(
    surf: *u8,
    vt: backend::Backend,
    ref sub: events::Subscriber,
    gate: auth::AuthGate,
    method: str,
    params: json::Value,
    id: f64,
) -> json::Value {
    if auth::decision_eq(gate.check(auth::request(auth::Channel::External)), auth::Decision::Reject) {
        return err_response(id, - 32001 as f64, "consent denied");
    }

    if method == "describe_ui" {
        return ok_response(id, describe_to_json((vt.describe)(surf)));
    }
    if method == "click" {
        let target: text::Text = val_as_text(obj_get(params, "id"));
        let o: surface::Outcome = (vt.click)(surf, { target });
        return ok_response(id, outcome_result(o));
    }
    if method == "scroll_to" {
        let target: text::Text = val_as_text(obj_get(params, "id"));
        let o: surface::Outcome = (vt.navigate)(surf, { target });
        return ok_response(id, outcome_result(o));
    }
    if method == "set_text" {
        let target: text::Text = val_as_text(obj_get(params, "id"));
        let value: text::Text = val_as_text(obj_get(params, "value"));
        let base: u64 = val_as_number(obj_get(params, "base_version")) as u64;
        let o: surface::Outcome = (vt.set_text)(surf, { target }, { value }, base);
        return ok_response(id, outcome_result(o));
    }
    if method == "poll_event" {
        let ev: option::Option[events::Event] = sub.poll();
        let result: json::Value = match ev {
            option::Option[events::Event]::Some(e) => {
                var m: vec::Vec[json::Member] = vec::new::[json::Member]();
                m.append(member("source", jnum(e.source as f64)));
                m.append(member("verb", jstr(verb_to_str(e.verb))));
                json::Value::Object(m)
            }
            option::Option[events::Event]::None => json::Value::Null,
        };
        return ok_response(id, result);
    }
    return err_response(id, - 32601 as f64, "method not found");
}

// Convenience: dispatch a raw JSON-RPC request string and return the response
// string. Parses `{ "method": ..., "params": ..., "id": ... }`; a parse failure
// or missing method yields a JSON-RPC error envelope. This is the unit the
// transport reads/writes per line.
fn handle_request(
    surf: *u8,
    vt: backend::Backend,
    ref sub: events::Subscriber,
    gate: auth::AuthGate,
    line: str,
) -> text::Text {
    let out: text::Text = match json::Value::parse(line) {
        result::Result[json::Value, json::ParseError]::Ok(req) => {
            let method_t: text::Text = val_as_text(obj_get(req, "method"));
            let id: f64 = val_as_number(obj_get(req, "id"));
            let params: json::Value = obj_get(req, "params");
            let resp: json::Value = dispatch(surf, vt, sub, gate, method_t.view(), params, id);
            resp.to_text()
        }
        result::Result[json::Value, json::ParseError]::Err(_e) => {
            err_response(0 as f64, - 32700 as f64, "parse error").to_text()
        }
    };
    return out;
}

// ---- UDS transport ----------------------------------------------------------
//
// The wire is newline-delimited JSON-RPC over a Unix-domain stream socket. An
// agent connects (by a per-PID path), sends one request object per line, and
// reads one response object per line, until it closes the connection.
//
// AF_UNIX = 1, SOCK_STREAM = 1, SHUT_WR = 1 on Darwin. `sockaddr_un` is
// { uint8 sun_len; uint8 sun_family; char sun_path[104] } — we build it in a
// byte buffer: offset 1 = family, offset 2 = the NUL-terminated path.

extern fn socket(domain: i32, ty: i32, protocol: i32) -> i32;
extern fn bind(fd: i32, addr: *u8, addrlen: u32) -> i32;
extern fn listen(fd: i32, backlog: i32) -> i32;
extern fn accept(fd: i32, addr: *u8, addrlen: *u32) -> i32;
extern fn read(fd: i32, buf: *u8, count: usize) -> i64;
extern fn write(fd: i32, buf: *u8, count: usize) -> i64;
extern fn close(fd: i32) -> i32;
extern fn unlink(path: *u8) -> i32;
extern fn getpid() -> i32;

// The PID of this process — for an agent socket path like
// `/tmp/cplus-agent-<pid>.sock` (the path convention is the app's choice).
fn current_pid() -> i32 {
    return { getpid() };
}

// Read one newline-terminated line into `buf` (without the newline). Returns the
// byte length, or -1 on EOF before any byte was read. A line longer than `cap`
// is truncated at `cap`.
fn read_line(fd: i32, buf_ptr: *u8, cap: usize) -> i64 {
    var n: usize = 0 as usize;
    loop {
        if n >= cap {
            break;
        }
        var byte: u8 = 0 as u8;
        let r: i64 = { read(fd, #addr_of(byte), 1 as usize) };
        if r <= (0 as i64) {
            if n == (0 as usize) {
                return - 1 as i64;
            }
            break;
        }
        if byte == ('\n' as u8) {
            break;
        }
        { *(buf_ptr + n) = byte; }
        n = n +% (1 as usize);
    }
    return n as i64;
}

fn write_all(fd: i32, ptr: *u8, len: usize) {
    var off: usize = 0 as usize;
    while off < len {
        let w: i64 = { write(fd, ptr + off, len -% off) };
        if w <= (0 as i64) {
            return;
        }
        off = off +% (w as usize);
    }
    return;
}

// Serve one connected stream socket: read requests line by line, dispatch each
// (re-arming a fresh gate from `policy` per request), and write the response
// line, until the peer closes (EOF). The connection fd is the caller's to close.
fn serve_fd(
    surf: *u8,
    vt: backend::Backend,
    ref sub: events::Subscriber,
    policy: fn(auth::Request) -> auth::Decision,
    fd: i32,
) -> i32 {
    var buf: [u8; 8192] = [0 as u8; 8192];
    loop {
        let len: i64 = read_line(fd, { #addr_of(buf[0]) }, 8192 as usize);
        if len < (0 as i64) {
            break;
        }
        let line: str = { #str_from_raw_parts(#addr_of(buf[0]), len as usize) };
        let resp: text::Text = handle_request(surf, vt, sub, auth::serve(policy), line);
        let rs: str = { resp };
        write_all(fd, #str_ptr(rs), #str_len(rs));
        let nl: u8 = '\n' as u8;
        write_all(fd, { #addr_of(nl) }, 1 as usize);
    }
    return 0;
}

// Bind a Unix-domain socket at `path`, then accept connections and serve each
// (one at a time) via `serve_fd`. Blocks until `accept` fails. Returns a
// negative code on a setup error (socket/bind/listen). `path` must be ≤ 100
// bytes (sun_path limit). Removes the socket file on entry (stale) and exit.
fn serve_uds(
    surf: *u8,
    vt: backend::Backend,
    ref sub: events::Subscriber,
    policy: fn(auth::Request) -> auth::Decision,
    path: str,
) -> i32 {
    let plen: usize = #str_len(path);
    if plen > (100 as usize) {
        return - 4 as i32;
    }
    var addr: [u8; 110] = [0 as u8; 110];
    addr[1] = 1 as u8; // sun_family = AF_UNIX
    let pbytes: *u8 = #str_ptr(path);
    var i: usize = 0 as usize;
    while i < plen {
        addr[(2 as usize) +% i] = { *(pbytes + i) };
        i = i +% (1 as usize);
    }
    let path_c: *u8 = { #addr_of(addr[2]) }; // NUL-terminated path inside the struct
    let addrlen: u32 = ((2 as usize) +% plen +% (1 as usize)) as u32;

    let fd: i32 = { socket(1 as i32, 1 as i32, 0 as i32) };
    if fd < (0 as i32) {
        return - 1 as i32;
    }
    { unlink(path_c); }
    if { bind(fd, #addr_of(addr[0]), addrlen) } != (0 as i32) {
        { close(fd); }
        return - 2 as i32;
    }
    if { listen(fd, 4 as i32) } != (0 as i32) {
        { close(fd); }
        return - 3 as i32;
    }
    loop {
        let conn: i32 = { accept(fd, 0 as *u8, 0 as *u32) };
        if conn < (0 as i32) {
            break;
        }
        serve_fd(surf, vt, sub, policy, conn);
        { close(conn); }
    }
    { close(fd); }
    { unlink(path_c); }
    return 0;
}
