// vendor/coreai/src/coreai.cplus — C+ facade for Apple's Core AI runtime.
//
// CoreAI is currently Swift-first. This package deliberately exposes a small,
// stable C+ surface over a Swift bridge:
//
//   C+ code -> C ABI functions -> Swift bridge -> CoreAI.framework
//
// The MVP supports loading a model, loading a named function, creating f32
// NDArrays, running one named input to one named output, and copying f32
// outputs back to C+ memory. Add shape/descriptor/tokenizer helpers after the
// bridge is validated with an SDK that actually ships CoreAI.
//
// The public surface follows naming_guideline.md:
//   - The raw bridge handle is hidden behind `_raw`; callers never touch it.
//   - Construction takes its content: `Model::load(path)`,
//     `NDArray::f32(shape:, values:)`.
//   - Methods and their labels read as phrases: `model.function(named: "main")`,
//     `function.run(input, named: "x", to: "y")`, `array.copy_into(dest)`.
//   - Public APIs take/return `str` / `Text`, never raw `*u8`. The last bridge
//     error is read as `last_error() -> Option[Text]`, absence as a value.
//   - Fallible operations follow the error model: a value-plus-reason returns
//     `Result[T, CoreAIError]`.

import "stdlib/result" as result;
import "stdlib/option" as option;
import "stdlib/text" as text;

extern fn cplus_coreai_runtime_available() -> i32;
extern fn cplus_coreai_last_error(buf: *u8, len: usize) -> i32;
extern fn cplus_coreai_release(handle: *u8);

extern fn cplus_coreai_model_load(path: *u8, path_len: usize) -> *u8;
extern fn cplus_coreai_model_load_function(model: *u8, name: *u8, name_len: usize) -> *u8;

extern fn cplus_coreai_ndarray_create_f32(
    shape: *u64,
    rank: u64,
    data: *f32,
    count: u64,
) -> *u8;

extern fn cplus_coreai_function_run1_f32(
    function: *u8,
    input_name: *u8,
    input_name_len: usize,
    input: *u8,
    output_name: *u8,
    output_name_len: usize,
) -> *u8;

extern fn cplus_coreai_ndarray_copy_f32(array: *u8, dest: *f32, count: u64) -> i64;

enum CoreAIError {
    RuntimeUnavailable,
    BridgeFailure,
    NullHandle,
    CopyFailed,
    InvalidArgument,
}

struct Model {
    opaque _raw: *u8,
}

struct Function {
    opaque _raw: *u8,
}

struct NDArray {
    opaque _raw: *u8,
}

fn null() -> *u8 {
    return { 0 as *u8 };
}

fn is_null(p: *u8) -> bool {
    return p == null();
}

// True when CoreAI.framework is present and usable in the running process.
// On hosts without an SDK that ships CoreAI this is `false`, and every
// loader below short-circuits to `RuntimeUnavailable`.
fn runtime_available() -> bool {
    let ok: i32 = { cplus_coreai_runtime_available() };
    return ok != 0;
}

// The most recent bridge error message, or `None` if the bridge has not
// recorded one. Returns owned `Text` — the raw C buffer is filled inside
// this function and never exposed.
fn last_error() -> option::Option[text::Text] {
    var buf: [u8; 256] = [
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
    ];
    let wrote: i32 = { cplus_coreai_last_error(#addr_of(buf) as *u8, 256 as usize) };
    if wrote <= 0 {
        return option::Option[text::Text]::None;
    }
    let view: str = { #str_from_raw_parts(#addr_of(buf) as *u8, wrote as usize) };
    return option::Option[text::Text]::Some(view.to_text());
}

impl Model {
    // Load a model from a filesystem path. The constructor takes its
    // content — the path — directly. `RuntimeUnavailable` when CoreAI is
    // absent, `BridgeFailure` when the bridge could not open the asset.
    fn load(path: str) -> result::Result[Model, CoreAIError] {
        if !runtime_available() {
            return result::Result[Model, CoreAIError]::Err(CoreAIError::RuntimeUnavailable);
        }
        let raw: *u8 = {
            cplus_coreai_model_load(#str_ptr(path), #str_len(path))
        };
        if is_null(raw) {
            return result::Result[Model, CoreAIError]::Err(CoreAIError::BridgeFailure);
        }
        return result::Result[Model, CoreAIError]::Ok(Model { _raw: raw });
    }

    // Look up a named inference function in this model. Reads as
    // "the function named main".
    fn function(this, named: str) -> result::Result[Function, CoreAIError] {
        if is_null(this._raw) {
            return result::Result[Function, CoreAIError]::Err(CoreAIError::NullHandle);
        }
        let raw: *u8 = {
            cplus_coreai_model_load_function(this._raw, #str_ptr(named), #str_len(named))
        };
        if is_null(raw) {
            return result::Result[Function, CoreAIError]::Err(CoreAIError::BridgeFailure);
        }
        return result::Result[Function, CoreAIError]::Ok(Function { _raw: raw });
    }

    fn drop(ref this) {
        if !is_null(this._raw) {
            { cplus_coreai_release(this._raw); }
            this._raw = null();
        }
        return;
    }
}

impl Function {
    // Run this function on a single named input, reading a single named
    // output. Reads as "run input named x to y". The input array is
    // borrowed; the result is a freshly owned output `NDArray`.
    fn run(
        this,
        input: NDArray,
        named: str,
        to: str,
    ) -> result::Result[NDArray, CoreAIError] {
        if is_null(this._raw) || is_null(input._raw) {
            return result::Result[NDArray, CoreAIError]::Err(CoreAIError::NullHandle);
        }
        let raw: *u8 = {
            cplus_coreai_function_run1_f32(
                this._raw,
                #str_ptr(named),
                #str_len(named),
                input._raw,
                #str_ptr(to),
                #str_len(to),
            )
        };
        if is_null(raw) {
            return result::Result[NDArray, CoreAIError]::Err(CoreAIError::BridgeFailure);
        }
        return result::Result[NDArray, CoreAIError]::Ok(NDArray { _raw: raw });
    }

    fn drop(ref this) {
        if !is_null(this._raw) {
            { cplus_coreai_release(this._raw); }
            this._raw = null();
        }
        return;
    }
}

impl NDArray {
    // Build an f32 NDArray from a shape and its row-major values. The
    // constructor takes its content — `NDArray::f32(shape, values)`.
    // `InvalidArgument` for a rank-0 (empty) shape.
    fn f32(shape: usize[], values: f32[]) -> result::Result[NDArray, CoreAIError] {
        let rank: usize = #slice_len(shape);
        let count: usize = #slice_len(values);
        if rank == (0 as usize) {
            return result::Result[NDArray, CoreAIError]::Err(CoreAIError::InvalidArgument);
        }
        let raw: *u8 = {
            cplus_coreai_ndarray_create_f32(
                #slice_ptr(shape) as *u64,
                rank as u64,
                #slice_ptr(values),
                count as u64,
            )
        };
        if is_null(raw) {
            return result::Result[NDArray, CoreAIError]::Err(CoreAIError::BridgeFailure);
        }
        return result::Result[NDArray, CoreAIError]::Ok(NDArray { _raw: raw });
    }

    // Copy this array's f32 elements into `dest`, up to its length.
    // Returns the number of elements written.
    fn copy_into(this, dest: f32[]) -> result::Result[usize, CoreAIError] {
        if is_null(this._raw) {
            return result::Result[usize, CoreAIError]::Err(CoreAIError::NullHandle);
        }
        let n: usize = #slice_len(dest);
        let wrote: i64 = {
            cplus_coreai_ndarray_copy_f32(this._raw, #slice_ptr(dest), n as u64)
        };
        if wrote < (0 as i64) {
            return result::Result[usize, CoreAIError]::Err(CoreAIError::CopyFailed);
        }
        return result::Result[usize, CoreAIError]::Ok(wrote as usize);
    }

    fn drop(ref this) {
        if !is_null(this._raw) {
            { cplus_coreai_release(this._raw); }
            this._raw = null();
        }
        return;
    }
}

// ---------------- Unit tests (run via `cpc test`) ----------------
//
// CoreAI.framework is not present on pre-Xcode-27 hosts, so the bridge's
// `runtime_available()` returns false and every loader short-circuits to
// `RuntimeUnavailable` / `InvalidArgument` *without* touching the Swift
// bridge. These tests drive exactly those host-independent paths: the
// error model, argument validation, and null-handle guards. The happy
// path needs a real CoreAI SDK and is covered by the bridge integration
// build, not here.

#[test]
fn test_runtime_available_is_false_on_host() {
    // No CoreAI SDK here: the bridge must report the runtime as absent.
    assert runtime_available() == false;
}

#[test]
fn test_load_model_without_runtime_is_runtime_unavailable() {
    // With no runtime, loading must fail with RuntimeUnavailable and
    // must NOT have reached the bridge.
    let r: result::Result[Model, CoreAIError] = Model::load("/no/such/model.aimodel");
    match r {
        result::Result[Model, CoreAIError]::Ok(_) => { assert false; }
        result::Result[Model, CoreAIError]::Err(e) => {
            match e {
                CoreAIError::RuntimeUnavailable => { assert true; }
                _ => { assert false; }
            };
        }
    };
}

#[test]
fn test_load_model_empty_path_without_runtime() {
    // The runtime check fires before the path is even examined.
    let r: result::Result[Model, CoreAIError] = Model::load("");
    match r {
        result::Result[Model, CoreAIError]::Ok(_) => { assert false; }
        result::Result[Model, CoreAIError]::Err(e) => {
            match e {
                CoreAIError::RuntimeUnavailable => { assert true; }
                _ => { assert false; }
            };
        }
    };
}

#[test]
fn test_ndarray_f32_rejects_empty_shape() {
    // A rank-0 (zero-length) shape is invalid regardless of the runtime
    // — pure argument validation, host-independent. A zero-length slice
    // over a backing array gives rank 0.
    var shape_buf: [usize; 1] = [1 as usize];
    var values_buf: [f32; 1] = [1.0f32];
    let shape: usize[] = { #slice_from_raw_parts(#addr_of(shape_buf) as *usize, 0 as usize) };
    let values: f32[] = { #slice_from_raw_parts(#addr_of(values_buf) as *f32, 1 as usize) };
    let r: result::Result[NDArray, CoreAIError] = NDArray::f32(shape, values);
    match r {
        result::Result[NDArray, CoreAIError]::Ok(_) => { assert false; }
        result::Result[NDArray, CoreAIError]::Err(e) => {
            match e {
                CoreAIError::InvalidArgument => { assert true; }
                _ => { assert false; }
            };
        }
    };
}

#[test]
fn test_function_run_on_null_handle_is_null_handle() {
    // A null Function/NDArray must guard before calling the bridge:
    // NullHandle, never a segfault.
    let f: Function = Function { _raw: { 0 as *u8 } };
    let a: NDArray = NDArray { _raw: { 0 as *u8 } };
    let r: result::Result[NDArray, CoreAIError] = f.run(a, named: "input", to: "output");
    match r {
        result::Result[NDArray, CoreAIError]::Ok(_) => { assert false; }
        result::Result[NDArray, CoreAIError]::Err(e) => {
            match e {
                CoreAIError::NullHandle => { assert true; }
                _ => { assert false; }
            };
        }
    };
}

#[test]
fn test_function_run_free_label_order() {
    // Labeled parameters are order-independent: same null-handle guard
    // reached with the labels supplied in a different order.
    let f: Function = Function { _raw: { 0 as *u8 } };
    let a: NDArray = NDArray { _raw: { 0 as *u8 } };
    let r: result::Result[NDArray, CoreAIError] = f.run(a, to: "output", named: "input");
    match r {
        result::Result[NDArray, CoreAIError]::Ok(_) => { assert false; }
        result::Result[NDArray, CoreAIError]::Err(e) => {
            match e {
                CoreAIError::NullHandle => { assert true; }
                _ => { assert false; }
            };
        }
    };
}

#[test]
fn test_copy_into_null_handle_is_null_handle() {
    let a: NDArray = NDArray { _raw: { 0 as *u8 } };
    var dest_buf: [f32; 2] = [0.0f32, 0.0f32];
    let dest: f32[] = { #slice_from_raw_parts(#addr_of(dest_buf) as *f32, 2 as usize) };
    let r: result::Result[usize, CoreAIError] = a.copy_into(dest);
    match r {
        result::Result[usize, CoreAIError]::Ok(_) => { assert false; }
        result::Result[usize, CoreAIError]::Err(e) => {
            match e {
                CoreAIError::NullHandle => { assert true; }
                _ => { assert false; }
            };
        }
    };
}

#[test]
fn test_model_function_null_handle_is_null_handle() {
    // A model with a null handle cannot resolve a function.
    let m: Model = Model { _raw: { 0 as *u8 } };
    let r: result::Result[Function, CoreAIError] = m.function(named: "main");
    match r {
        result::Result[Function, CoreAIError]::Ok(_) => { assert false; }
        result::Result[Function, CoreAIError]::Err(e) => {
            match e {
                CoreAIError::NullHandle => { assert true; }
                _ => { assert false; }
            };
        }
    };
}

#[test]
fn test_last_error_returns_option() {
    // last_error() yields an Option: absence is a value, never an empty
    // string. Either arm is acceptable on a host with no bridge state.
    match last_error() {
        option::Option[text::Text]::Some(_) => { assert true; }
        option::Option[text::Text]::None => { assert true; }
    };
}
