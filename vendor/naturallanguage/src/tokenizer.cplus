import "objc/runtime" as rt;
import "objc/bridge" as bridge;
import "stdlib/text" as text;
import "stdlib/option" as option;
import "stdlib/vec" as vec;

// NLTokenUnit — the granularity at which `Tokenizer` segments text.
enum TokenUnit {
    Word,
    Sentence,
    Paragraph,
    Document,
}

// NLTokenUnit is an `NS_ENUM(NSInteger, ...)` with sequential values starting at
// 0; these mirror that wire encoding.
fn unit_raw(u: TokenUnit) -> i64 {
    return match u {
        TokenUnit::Word => { 0 as i64 },
        TokenUnit::Sentence => { 1 as i64 },
        TokenUnit::Paragraph => { 2 as i64 },
        TokenUnit::Document => { 3 as i64 },
    };
}

fn unit_from_raw(raw: i64) -> TokenUnit {
    if raw == (1 as i64) { return TokenUnit::Sentence; }
    if raw == (2 as i64) { return TokenUnit::Paragraph; }
    if raw == (3 as i64) { return TokenUnit::Document; }
    return TokenUnit::Word;
}

// Segments natural-language text into ranges at a chosen unit (word / sentence /
// paragraph / document), script- and language-aware. Owned (+1 via
// alloc/initWithUnit:); `drop` releases this wrapper's +1.
struct Tokenizer {
    _obj: *u8,
}

impl Tokenizer {
    fn raw(this) -> *u8 { return this._obj; }

    fn new(unit: TokenUnit) -> Tokenizer {
        let cls: *u8 = rt::get_class(#str_ptr("NLTokenizer\0"));
        let alloced: *u8 = rt::msg_id(cls, rt::sel(#str_ptr("alloc\0")));
        return Tokenizer { _obj: rt::msg_id_i64(alloced, rt::sel(#str_ptr("initWithUnit:\0")), unit_raw(unit)) };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    // The unit this tokenizer segments at.
    fn unit(this) -> TokenUnit {
        return unit_from_raw(rt::msg_i64(this._obj, rt::sel(#str_ptr("unit\0"))));
    }

    // The text to tokenize.
    fn set_text(this, text: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setString:\0")), bridge::nsstring(text));
    }

    fn text(this) -> option::Option[text::Text] {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("string\0")));
        return bridge::to_text_option(ns);
    }

    // Hint the text's language (an `NLLanguage` code like "en"); otherwise it is
    // inferred.
    fn set_language(this, language: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("setLanguage:\0")), bridge::nsstring(language));
    }

    // The token range containing the character at `at`. `at` must be within the
    // text or AppKit raises.
    fn token_range(this, at: usize) -> rt::Range {
        return rt::msg_range_u64(this._obj, rt::sel(#str_ptr("tokenRangeAtIndex:\0")), at as u64);
    }

    // The token ranges intersecting `range`, as owned `Range` values. `range`
    // must not extend past the end of the text.
    fn tokens(this, range: rt::Range) -> vec::Vec[rt::Range] {
        let arr: *u8 = rt::msg_id_range(this._obj, rt::sel(#str_ptr("tokensForRange:\0")), range);
        let n: u64 = rt::msg_u64(arr, rt::sel(#str_ptr("count\0")));
        var out: vec::Vec[rt::Range] = vec::Vec[rt::Range]::with_capacity(n as usize);
        let at_sel: *u8 = rt::sel(#str_ptr("objectAtIndex:\0"));
        let range_sel: *u8 = rt::sel(#str_ptr("rangeValue\0"));
        var i: u64 = 0 as u64;
        while i < n {
            let value: *u8 = rt::msg_id_u64(arr, at_sel, i);
            let r: rt::Range = rt::msg_range(value, range_sel);
            out.append(r);
            i = i +% (1 as u64);
        }
        return out;
    }
}

#[test]
fn tokenizer_segments_words() {
    let tok: Tokenizer = Tokenizer::new(TokenUnit::Word);
    tok.set_text("the quick brown fox");                       // 19 ASCII chars
    let full: rt::Range = rt::Range { location: 0 as u64, length: 19 as u64 };
    let toks: vec::Vec[rt::Range] = tok.tokens(full);
    assert toks.count() == (4 as usize);
    return;
}

#[test]
fn tokenizer_first_token_range() {
    let tok: Tokenizer = Tokenizer::new(TokenUnit::Word);
    tok.set_text("the quick brown fox");
    let r: rt::Range = tok.token_range(at: 0 as usize);
    assert r.location == (0 as u64);
    assert r.length == (3 as u64);                             // "the"
    return;
}
