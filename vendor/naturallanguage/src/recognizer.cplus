import "objc/runtime" as rt;
import "objc/bridge" as bridge;
import "stdlib/text" as text;
import "stdlib/option" as option;

// Identifies the dominant language of natural-language text, on-device. Owned
// (+1 via alloc/init); `drop` releases this wrapper's +1.
//
// A language is returned as its BCP-47-style code `Text` (e.g. "en", "fr"),
// AppKit's `NLLanguage`. Absence (no confident guess) is `None`, never a
// sentinel.
struct LanguageRecognizer {
    _obj: *u8,
}

impl LanguageRecognizer {
    fn raw(this) -> *u8 { return this._obj; }

    fn new() -> LanguageRecognizer {
        return LanguageRecognizer { _obj: rt::alloc_init(#str_ptr("NLLanguageRecognizer\0")) };
    }

    fn drop(ref this) {
        rt::release(this._obj);
    }

    // The single most likely language of `string`, or `None` if it cannot be
    // determined — `+[NLLanguageRecognizer dominantLanguageForString:]`, the
    // one-shot convenience that needs no instance.
    fn detect(string: str) -> option::Option[text::Text] {
        let cls: *u8 = rt::get_class(#str_ptr("NLLanguageRecognizer\0"));
        let ns: *u8 = rt::msg_id_id(cls, rt::sel(#str_ptr("dominantLanguageForString:\0")), bridge::nsstring(string));
        return bridge::to_text_option(ns);
    }

    // Feed text to the recognizer; identification accumulates across calls.
    fn process(this, string: str) {
        rt::msg_void_id(this._obj, rt::sel(#str_ptr("processString:\0")), bridge::nsstring(string));
    }

    // Restore the recognizer to its initial state so it can be reused.
    fn reset(this) {
        rt::msg_void(this._obj, rt::sel(#str_ptr("reset\0")));
    }

    // The single most likely language for the text processed so far, or `None`.
    fn dominant_language(this) -> option::Option[text::Text] {
        let ns: *u8 = rt::msg_id(this._obj, rt::sel(#str_ptr("dominantLanguage\0")));
        return bridge::to_text_option(ns);
    }
}

#[test]
fn recognizer_detect_french() {
    match LanguageRecognizer::detect("Bonjour le monde, comment allez-vous aujourd'hui?") {
        option::Option[text::Text]::Some(lang) => { assert lang.equals("fr"); }
        option::Option[text::Text]::None => { assert false; }
    }
    return;
}

#[test]
fn recognizer_detect_english_via_instance() {
    let rec: LanguageRecognizer = LanguageRecognizer::new();
    rec.process("The quick brown fox jumps over the lazy dog every single morning.");
    match rec.dominant_language() {
        option::Option[text::Text]::Some(lang) => { assert lang.equals("en"); }
        option::Option[text::Text]::None => { assert false; }
    }
    return;
}
