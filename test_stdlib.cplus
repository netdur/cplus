import "vendor/stdlib/src/io" as io;
import "vendor/stdlib/src/fs" as fs;
import "vendor/stdlib/src/hash_map" as hash_map;
import "vendor/stdlib/src/vec" as vec;
import "vendor/stdlib/src/result" as result;

fn main() -> i32 {
    io::println("Testing println!");

    let mut map: hash_map::StrIntMap = hash_map::new_str_int_map();
    map.insert("hello", 42 as i32);
    
    // Test that the grow_to memset works correctly by forcing a grow
    let mut i: i32 = 0 as i32;
    while i < (32 as i32) {
        if i == (0 as i32) { map.insert("k0", i); }
        if i == (1 as i32) { map.insert("k1", i); }
        if i == (2 as i32) { map.insert("k2", i); }
        if i == (3 as i32) { map.insert("k3", i); }
        if i == (4 as i32) { map.insert("k4", i); }
        if i == (5 as i32) { map.insert("k5", i); }
        if i == (6 as i32) { map.insert("k6", i); }
        if i == (7 as i32) { map.insert("k7", i); }
        if i == (8 as i32) { map.insert("k8", i); }
        if i == (9 as i32) { map.insert("k9", i); }
        if i == (10 as i32) { map.insert("k10", i); }
        if i == (11 as i32) { map.insert("k11", i); }
        if i == (12 as i32) { map.insert("k12", i); }
        if i == (13 as i32) { map.insert("k13", i); }
        if i == (14 as i32) { map.insert("k14", i); }
        if i == (15 as i32) { map.insert("k15", i); }
        if i == (16 as i32) { map.insert("k16", i); }
        if i == (17 as i32) { map.insert("k17", i); }
        if i == (18 as i32) { map.insert("k18", i); }
        if i == (19 as i32) { map.insert("k19", i); }
        i = i +% (1 as i32);
    }
    
    io::println("HashMap test passed.");

    let mut v: vec::Vec[i32] = vec::new::[i32]();
    v.push(100 as i32);
    io::println("Vec test passed.");

    return 0;
}
