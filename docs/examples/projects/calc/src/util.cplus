// `util.cplus` — convenience constructors so callers don't have to
// reach into `expr`'s namespace twice. Demonstrates a file that
// re-exposes another file's variants behind a friendlier API surface.

import "expr.cplus" as expr;

pub fn add_lit(a: i32, b: i32) -> expr::Expr {
    return expr::Expr::Add(a, b);
}

pub fn mul_lit(a: i32, b: i32) -> expr::Expr {
    return expr::Expr::Mul(a, b);
}

pub fn neg_lit(v: i32) -> expr::Expr {
    return expr::Expr::Neg(v);
}
