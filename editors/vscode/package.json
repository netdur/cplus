{
  "name": "cplus-vscode",
  "displayName": "C+",
  "description": "C+ language support for VS Code (diagnostics, formatting, quick fixes via cpc-lsp).",
  "version": "0.0.1",
  "publisher": "cplus",
  "private": true,
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages"],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cplus",
        "aliases": ["C+", "cplus"],
        "extensions": [".cplus"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cplus",
        "scopeName": "source.cplus",
        "path": "./syntaxes/cplus.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "C+",
      "properties": {
        "cplus.cpcPath": {
          "type": "string",
          "default": "cpc",
          "description": "Path to the `cpc` binary. Defaults to `cpc` on PATH. The extension launches `<cpcPath> lsp` for diagnostics."
        },
        "cplus.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace LSP JSON-RPC traffic. Useful when reporting bugs."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0"
  }
}
